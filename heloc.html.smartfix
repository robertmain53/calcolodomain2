  <!-- Logic -->
  <script>
    (function(){
      'use strict';
      const $ = (sel, ctx=document) => ctx.querySelector(sel);

      // Inputs
      const homeValue = $('#homeValue');
      const mortgageBalance = $('#mortgageBalance');
      const cltvLimit = $('#cltvLimit');
      const drawAmount = $('#drawAmount');
      const drawYears = $('#drawYears');
      const repayYears = $('#repayYears');
      const drawApr = $('#drawApr');
      const repayApr = $('#repayApr');
      const sameRate = $('#sameRate');

      // Buttons
      const calcBtn = $('#calcBtn');
      const resetBtn = $('#resetBtn');
      const renderChartBtn = $('#renderChartBtn');
      const downloadCsvBtn = $('#downloadCsvBtn');

      // Results
      const maxLineValue = $('#maxLineValue');
      const cltvAfterValue = $('#cltvAfterValue');
      const drawPaymentValue = $('#drawPaymentValue');
      const repayPaymentValue = $('#repayPaymentValue');
      const totalInterestValue = $('#totalInterestValue');
      const feasibilityValue = $('#feasibilityValue');

      // Helpers
      const parseNum = (el)=>{ const v=parseFloat(el.value); return Number.isFinite(v)?v:NaN; };
      const money = (v)=> Number.isFinite(v) ? v.toLocaleString(undefined,{style:'currency',currency:'USD'}) : '$0.00';

      // Errors
      const errs = {
        homeValue: $('#err-homeValue'),
        mortgage: $('#err-mortgage'),
        cltv: $('#err-cltv'),
        draw: $('#err-draw'),
        drawYears: $('#err-drawYears'),
        repayYears: $('#err-repayYears'),
        drawApr: $('#err-drawApr'),
        repayApr: $('#err-repayApr'),
      };
      function setError(el, key, msg){ el?.setAttribute('aria-invalid','true'); if(errs[key]) errs[key].textContent=msg||''; }
      function clearError(el, key){ el?.setAttribute('aria-invalid','false'); if(errs[key]) errs[key].textContent=''; }

      function validate(){
        let ok = true;
        const hv=parseNum(homeValue); if(!(hv>0)){ setError(homeValue,'homeValue','Enter a positive home value.'); ok=false; } else clearError(homeValue,'homeValue');
        const mb=parseNum(mortgageBalance); if(!(mb>=0)){ setError(mortgageBalance,'mortgage','Enter a non-negative mortgage balance.'); ok=false; } else if (hv && mb>hv){ setError(mortgageBalance,'mortgage','Balance cannot exceed home value.'); ok=false; } else clearError(mortgageBalance,'mortgage');
        const cl=parseNum(cltvLimit); if(!(cl>=50&&cl<=100)){ setError(cltvLimit,'cltv','CLTV must be between 50% and 100%.'); ok=false; } else clearError(cltvLimit,'cltv');
        const d=parseNum(drawAmount); if(!(d>=0)){ setError(drawAmount,'draw','Enter a non-negative draw amount.'); ok=false; } else clearError(drawAmount,'draw');
        const yd=parseNum(drawYears); if(!(Number.isFinite(yd)&&yd>=0&&yd<=20)){ setError(drawYears,'drawYears','Draw years must be 0–20.'); ok=false; } else clearError(drawYears,'drawYears');
        const yr=parseNum(repayYears); if(!(Number.isFinite(yr)&&yr>=1&&yr<=30)){ setError(repayYears,'repayYears','Repayment years must be 1–30.'); ok=false; } else clearError(repayYears,'repayYears');
        const rd=parseNum(drawApr); if(!(rd>=0&&rd<100)){ setError(drawApr,'drawApr','Draw APR must be 0–100%.'); ok=false; } else clearError(drawApr,'drawApr');
        const rr = sameRate.checked ? rd : parseNum(repayApr);
        if(!sameRate.checked && !(rr>=0&&rr<100)){ setError(repayApr,'repayApr','Repayment APR must be 0–100%.'); ok=false; } else clearError(repayApr,'repayApr');
        return ok;
      }

      // Schedule state
      let schedule=[]; let chart=null;

      function compute(){
        if(!validate()){ schedule=[]; return; }

        const V=parseNum(homeValue), M=parseNum(mortgageBalance), CL=parseNum(cltvLimit)/100,
              D=parseNum(drawAmount), Yd=parseNum(drawYears), Yr=parseNum(repayYears),
              Rd=parseNum(drawApr), Rr=sameRate.checked?parseNum(drawApr):parseNum(repayApr);

        const Lmax = Math.max(0, CL*V - M);
        const cltvAfter = (M + D)/V;

        const rd_m = (Rd/100)/12, nDraw = Math.round(Yd*12);
        const drawPay = D * rd_m;
        const totalDrawInterest = drawPay * nDraw;

        const rr_m = (Rr/100)/12, nRepay = Math.round(Yr*12);
        const repayPay = rr_m>0 ? (rr_m*D)/(1 - Math.pow(1+rr_m, -nRepay)) : (nRepay>0 ? D/nRepay : 0);
        const totalRepayInterest = nRepay>0 ? (repayPay*nRepay - D) : 0;

        // KPIs
        maxLineValue.textContent = money(Lmax);
        cltvAfterValue.textContent = (cltvAfter*100).toFixed(2)+'%';
        drawPaymentValue.textContent = money(drawPay);
        repayPaymentValue.textContent = money(repayPay);
        totalInterestValue.textContent = money(totalDrawInterest + totalRepayInterest);

        // Feasibility badge
        if (D <= Lmax && cltvAfter <= CL) {
          feasibilityValue.innerHTML = '<span class="inline-flex items-center px-2 py-1 rounded-full border text-sm bg-emerald-50 border-emerald-200 text-emerald-800">Feasible within CLTV limit</span>';
          if (errs.draw.textContent.startsWith('Requested')) clearError(drawAmount,'draw');
        } else if (D <= Lmax) {
          feasibilityValue.innerHTML = '<span class="inline-flex items-center px-2 py-1 rounded-full border text-sm bg-amber-50 border-amber-200 text-amber-800">Within line, but CLTV exceeds limit</span>';
        } else {
          feasibilityValue.innerHTML = '<span class="inline-flex items-center px-2 py-1 rounded-full border text-sm bg-rose-50 border-rose-200 text-rose-800">Requested draw exceeds estimated maximum line</span>';
          errs.draw.textContent = 'Requested draw exceeds the estimated maximum line ('+money(Lmax)+').';
        }

        // Build schedule
        schedule = [];
        for(let k=1;k<=nDraw;k++){
          schedule.push({period:k,phase:'Draw',payment:drawPay,interest:drawPay,principal:0,balance:D});
        }
        let bal=D;
        for(let k=1;k<=nRepay && bal>1e-8;k++){
          const interest = rr_m>0 ? bal*rr_m : 0;
          let principal = repayPay - interest;
          if (principal > bal) principal = bal;
          bal = Math.max(0, bal - principal);
          schedule.push({period:nDraw+k,phase:'Repayment',payment:principal+interest,interest,principal,balance:bal});
        }
      }

      function downloadCSV(){
        if(schedule.length===0){ alert('Please calculate first.'); return; }
        const header=['Period','Phase','Payment','Interest','Principal','Balance'];
        const rows=schedule.map(r=>[r.period,r.phase,r.payment.toFixed(2),r.interest.toFixed(2),r.principal.toFixed(2),r.balance.toFixed(2)]);
        const csv=[header.join(','),...rows.map(r=>r.join(','))].join('\\n');
        const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
        const a=document.createElement('a');
        a.href=URL.createObjectURL(blob);
        a.download='heloc-schedule.csv';
        document.body.appendChild(a); a.click(); URL.revokeObjectURL(a.href); a.remove();
      }

      function renderChart(){
        if(schedule.length===0){ alert('Please calculate first.'); return; }
        const ctx = document.getElementById('balanceChart').getContext('2d');
        const labels = schedule.map(r=>r.period);
        const balances = schedule.map(r=>r.balance);
        if(chart) chart.destroy();
        chart = new Chart(ctx,{
          type:'line',
          data:{ labels, datasets:[{ label:'Balance', data:balances, tension:.15, pointRadius:0 }]},
          options:{
            responsive:true, maintainAspectRatio:false, aspectRatio:2.4,
            scales:{ x:{ title:{display:true,text:'Month'} }, y:{ title:{display:true,text:'Balance (USD)'}, beginAtZero:true } },
            plugins:{ legend:{display:true} }
          }
        });
      }

      function syncRates(){
        if(sameRate.checked){
          repayApr.value = drawApr.value;
          repayApr.setAttribute('disabled','true');
          clearError(repayApr,'repayApr');
        }else{
          repayApr.removeAttribute('disabled');
        }
      }

      // Wire up
      ['input','blur'].forEach(ev=>{
        [homeValue,mortgageBalance,cltvLimit,drawAmount,drawYears,repayYears,drawApr,repayApr].forEach(el=>{
          el.addEventListener(ev, ()=>{ if(el===drawApr && sameRate.checked){ repayApr.value=drawApr.value; } compute(); });
        });
      });
      sameRate.addEventListener('change', ()=>{ syncRates(); compute(); });
      calcBtn.addEventListener('click', compute);
      resetBtn.addEventListener('click', ()=>{
        homeValue.value=''; mortgageBalance.value=''; cltvLimit.value='85';
        drawAmount.value=''; drawYears.value='10'; repayYears.value='20';
        drawApr.value='8.25'; sameRate.checked=true; repayApr.value='8.25'; repayApr.setAttribute('disabled','true');
        Object.values(errs).forEach(e=>e.textContent='');
        schedule=[]; if(chart){ chart.destroy(); chart=null; }
        maxLineValue.textContent='$0.00'; cltvAfterValue.textContent='0.00%'; drawPaymentValue.textContent='$0.00'; repayPaymentValue.textContent='$0.00'; totalInterestValue.textContent='$0.00';
        feasibilityValue.innerHTML='<span class="inline-flex items-center px-2 py-1 rounded-full border text-sm bg-yellow-50 border-yellow-200 text-yellow-800">Awaiting inputs</span>';
      });
      renderChartBtn.addEventListener('click', renderChart);
      downloadCsvBtn.addEventListener('click', downloadCSV);

      // Defaults
      syncRates(); compute();
    })();
  </script>

    <script>
        // Mobile menu toggle
        (function() {
            const mobileToggle = document.getElementById('mobile-menu-toggle');
            const mobileMenu = document.getElementById('mobile-menu');
            if (mobileToggle && mobileMenu) {
                mobileToggle.addEventListener('click', () => {
                    mobileMenu.classList.toggle('hidden');
                });
            }
        })();
    </script>
</body>
</html>
