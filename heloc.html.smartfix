<head>
  <meta charset="utf-8"/>
  <title>HELOC Calculator | Maximum Line, CLTV, Draw & Repayment Payments</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="description" content="Estimate HELOC maximum line (by CLTV), interest-only draw payment, amortized repayment, CLTV after draw, and total interest. Includes balance chart and CSV export. Mobile-first, accessible."/>
  <meta name="author" content="Ugo Candido"/>
  <link rel="canonical" href="https://calcdomain.com/heloc.html"/>
  <meta name="theme-color" content="#ffffff"/>
  <meta name="robots" content="index,follow"/>

  <!-- Fonts + Tailwind (from blueprint) -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Chart.js (for the balance chart) -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

  <!-- MathJax for formulas (used in SEO prose below) -->
  <script>
    window.MathJax = {
      tex: { inlineMath: [['\\(','\\)'], ['$', '$']], displayMath: [['\\[','\\]']] },
      svg: { fontCache: 'global' }
    };
  </script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>

  <!-- Site scripts (from blueprint) -->
  <script src="search.js" defer></script>
  <link rel="preload" href="/assets/js/mobile-menu.js" as="script">
  <link rel="preload" href="/assets/js/page-enhancements.js" as="script">

  <!-- Page-scoped, non-invasive styles -->
  <style>
    body{font-family:'Inter',system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif}
    .prose{max-width:72ch}
    .prose h2{font-size:1.5rem;font-weight:700;margin-top:2rem;margin-bottom:.75rem}
    .prose h3{font-weight:700;margin-top:1.25rem}
    .formula-box{background:#F1F5F9;border:1px solid #E2E8F0;border-radius:10px;padding:14px;overflow:auto;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace}

    /* Cards & inputs */
    .card{background:#fff;border:1px solid #E5E7EB;border-radius:12px;box-shadow:0 4px 10px rgba(0,0,0,.06)}
    .form-control{width:100%;padding:.75rem .9rem;border:1px solid #E5E7EB;border-radius:.5rem}
    .form-control:focus{outline:3px solid rgba(59,130,246,.25);border-color:#3B82F6}
    .input-unit{position:absolute;right:.6rem;top:50%;transform:translateY(-50%);color:#6B7280}
    .error{color:#DC2626;font-size:.875rem;margin-top:.25rem}

    /* Results tiles */
    .result-grid{display:grid;grid-template-columns:1fr;gap:.75rem}
    @media (min-width:768px){.result-grid{grid-template-columns:1fr 1fr}}
    .result-item{display:flex;justify-content:space-between;align-items:center;padding:.85rem 1rem;background:#F8FAFC;border:1px solid #E2E8F0;border-radius:10px}
    .result-label{color:#475569}
    .result-value{font-weight:800;color:#14532D}

    /* Chart container */
    #balanceChart{max-height:280px}

    @media print{
      header, .no-print, .actions{display:none!important}
      body{background:#fff}
      .card{box-shadow:none;border-color:#ddd}
    }
  </style>

  <!-- JSON-LD (concise) -->
  <script type="application/ld+json">
