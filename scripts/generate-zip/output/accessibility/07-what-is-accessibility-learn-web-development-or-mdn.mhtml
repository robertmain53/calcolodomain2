.footer__socials a { color: var(--color-text-secondary); }

:is(.footer__socials a):hover { color: var(--color-text-primary); }

:is(.footer__socials a)::before { background-color: currentcolor; content: =
""; display: block; height: 1.5rem; mask-size: cover; width: 1.5rem; }

