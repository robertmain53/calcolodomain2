@charset "utf-8";

article, aside, details, figcaption, figure, footer, header, hgroup, menu, =
nav, section { display: block; }

audio, canvas, video { display: inline-block; }

audio:not([controls]) { display: none; }

html { font-size: 100%; text-size-adjust: 100%; }

:hover, :focus, :active { outline: none; }

html, button, input, select, textarea { font-family: "Open sans", "Helvetic=
a Neue", HelveticaNeue, Helvetica, Arial, sans-serif; font-weight: 400; col=
or: rgb(85, 85, 85); -webkit-font-smoothing: antialiased; text-shadow: rgba=
(0, 0, 0, 0.004) 1px 1px 1px; }

body { margin: 0px; font-size: 13px; line-height: 1.6; }

a { color: rgb(0, 120, 207); font-weight: normal; cursor: pointer; text-dec=
oration: none; transition: color 0.2s; }

a:hover { color: rgb(0, 0, 0); text-decoration: underline; background: rgba=
(0, 0, 0, 0.024); }

::selection { background: rgb(0, 120, 207); color: rgb(255, 255, 255); text=
-shadow: none; }

p { margin: 0px 0px 1em; }

p:last-child { margin-bottom: 0px; }

a:visited { opacity: 0.9; }

a:active, a:focus { position: relative; top: 1px; }

abbr[title] { border-bottom: 1px dotted; }

dfn { font-style: italic; }

hr { display: block; height: 1px; border-width: 1px 0px 0px; border-right-s=
tyle: initial; border-bottom-style: initial; border-left-style: initial; bo=
rder-right-color: initial; border-bottom-color: initial; border-left-color:=
 initial; border-image: initial; border-top-style: solid; border-top-color:=
 rgb(221, 221, 221); margin: 1em 0px; padding: 0px; }

pre, code, kbd, samp { font-family: monospace, monospace; font-size: 1em; }

q { quotes: none; }

q::before, q::after { content: none; }

blockquote { margin: 1em 1em 1em 0px; padding: 1em; border-left: 1px solid =
rgb(221, 221, 221); font-style: italic; color: rgb(153, 153, 153); }

blockquote p { font-size: 1.1em; line-height: 2em; margin-bottom: 0px; }

blockquote small { display: block; font-size: 1em; line-height: 1.6em; colo=
r: rgb(191, 191, 191); text-align: right; }

blockquote small::before { content: "=E2=80=94=C2=A0"; }

b, strong { font-weight: 700; }

small { font-size: 85%; color: rgb(153, 153, 153); }

sub, sup { font-size: 75%; line-height: 0; position: relative; vertical-ali=
gn: baseline; }

sup { top: -0.5em; }

sub { bottom: -0.25em; }

dd { margin: 0px 0px 0px 40px; }

dt { font-weight: 700; }

ul, ol { list-style: none none; margin: 0px; padding: 0px; }

img { border: 0px; vertical-align: middle; }

svg:not(:root) { overflow: hidden; }

figure { margin: 0px; }

form { margin: 0px; }

fieldset { border: 0px; margin: 0px; padding: 0px; }

label { cursor: pointer; }

legend { border: 0px; padding: 0px; white-space: normal; }

button, input, select, textarea { font-size: 100%; margin: 0px; vertical-al=
ign: baseline; }

button, input { line-height: normal; }

table button, table input { }

button, input[type=3D"button"], input[type=3D"reset"], input[type=3D"submit=
"] { cursor: pointer; appearance: button; }

input[type=3D"checkbox"], input[type=3D"radio"] { box-sizing: border-box; }

input[type=3D"search"] { appearance: textfield; box-sizing: content-box; }

input[type=3D"search"]::-webkit-search-decoration { appearance: none; }

textarea { overflow: auto; vertical-align: top; resize: vertical; }

table { border-collapse: collapse; border-spacing: 0px; }

td { vertical-align: top; }

