				<label for=3D"units_Dipole_out" class=3D"visually-hidden">Magnetic dipo=
le moment output units:</label>
				<select id=3D"units_Dipole_out" name=3D"units_Dipole_out">
					<option value=3D"Am2">amperes meter-squared (A m=C2=B2)</option>
