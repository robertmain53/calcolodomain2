			=09
				<option value=3D"Am2" selected=3D"selected">amperes meter-squared (A m=
=C2=B2)</option>
				<option value=3D"Nm/T">newton meter/tesla (Nm/T)</option>
				<option value=3D"J/T">joules/tesla (J/T)</option>
				<option value=3D"erg/G">ergs/gauss (erg/G)</option>
				<option value=3D"inlb/G">inch pounds/gauss (in lb/G)</option>
			=09
			</select>

		</div>
