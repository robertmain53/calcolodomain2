portant; }

.stat__svgIcon--roofTitle { height: 8px; margin-bottom: 1px; width: 6px; }

.stat__svgIcon--container { align-items: center; display: flex; height: 100=
%; margin-right: 10px; }

.xmoPromotedMarketsAndRegions .hl-module { color: rgb(69, 95, 124); }

@media only screen and (min-width: 768px) {
  .xmoPromotedMarketsAndRegions .xmoPromotedMarketsAndRegions__panel { heig=
ht: 400px; }
}

.xmoPromotedMarketsAndRegions__backgroundGradient::before { background: lin=
ear-gradient(rgb(255, 255, 255) 30%, rgb(244, 247, 249)); bottom: 22px; con=
tent: ""; height: 100%; position: absolute; width: 100%; }

.xmoPromotedMarketsAndRegions__backgroundBlue::before { background-color: r=
gb(245, 248, 251); bottom: 22px; content: ""; height: 115%; position: absol=
ute; width: 100%; }

.xmoPromotedMarketsAndRegions__searchWrapper { max-width: 650px; }

.xmoPromotedMarketsAndRegions__searchWrapper .responsiveSection__grid { pad=
ding: 0px; }

.xmoPromotedMarketsAndRegions__searchWrapper .marketingHubPage__autoComplet=
eList { width: 100%; }

.xmoMarketTree .list--tree::before, .xmoMarketTree .list__itemTree::before =
{ border-color: rgb(69, 95, 124); }

@media only screen and (min-width: 768px) {
