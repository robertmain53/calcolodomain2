:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;=
0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&qu=
ot;}" data-image-title=3D"gauge-pattern" data-image-description=3D"" data-i=
mage-caption=3D"" data-medium-file=3D"https://i0.wp.com/blog.tincanknits.co=
m/wp-content/uploads/2013/10/gauge-pattern.jpg?fit=3D300%2C119&amp;ssl=3D1"=
 data-large-file=3D"https://i0.wp.com/blog.tincanknits.com/wp-content/uploa=
ds/2013/10/gauge-pattern.jpg?fit=3D600%2C237&amp;ssl=3D1" src=3D"https://i0=
