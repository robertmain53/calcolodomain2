@charset "utf-8";

body { margin: 0px; font-size: 1em; font-family: "Source Sans Pro Web", "He=
lvetica Neue", Helvetica, Roboto, Arial, sans-serif; }

.inner { padding: 0px 5%; }

.left { float: left; }

.gap { margin-right: 10px; }

#top-grey { padding-bottom: 0.25rem; padding-top: 0.25rem; min-height: 0px;=
 background-color: rgb(240, 240, 240); }

#arrow { background-repeat: no-repeat; background-size: cover; width: 10px;=
 height: 10px; display: inline-block; }

#arrow[aria-expanded=3D"false"] { background-image: url("../img/arrow-down.=
svg"); }

#arrow[aria-expanded=3D"true"] { background-image: url("../img/arrow-up.svg=
"); }

#top-grey-exp { background-color: rgb(240, 240, 240); height: auto; }

.col-50 { width: 50%; float: left; line-height: 1.5em; }

.no-marg { margin: 0px; }

.pad-4 { padding: 4%; }

.pad-2 { padding: 2%; }

#col-main .pad-2 { padding: 2% 2% 0px; }

.clear { clear: both; }

.img10 { width: 10%; height: auto; }

#title-area { background-color: rgb(0, 0, 0); color: rgb(255, 255, 255); pa=
dding: 10px 0px; vertical-align: middle; }

.title { font-size: 3em; }

#logo { width: 290px; height: auto; margin-right: 30px; vertical-align: mid=
dle; }

#logo2 { width: 211px; height: auto; margin-left: 30px; vertical-align: mid=
dle; }

#clock-utc { border: 1px solid rgb(0, 0, 0); text-align: center; margin-bot=
tom: 5px; }

.ital { font-style: italic; text-align: center; margin-bottom: 15px !import=
ant; }

#myDate { margin-top: 15px; }

#myTime { font-size: 1.4em; font-weight: bold; }

.imgSmText { font-size: 0.7em; line-height: 1.5em; text-transform: uppercas=
e; }

#rightColBot a { display: block; margin-bottom: 10px; color: rgb(0, 0, 0); =
}

#rightColBot { display: block; margin-top: 15px; padding-top: 15px; border-=
top: 1px solid rgb(0, 0, 0); }

.text-xs { font-size: 0.8em; margin: 5px 10px 0px; }

.text-lg { font-size: 1.8em; font-weight: bold; margin: 0px 10px; }

#callout-bar { color: rgb(255, 255, 255); background-color: rgb(153, 153, 1=
53); padding: 0.25rem 0px; text-align: center; font-weight: bold; }

#callout-bar p { margin: 0px; }

#content { display: table; width: 100%; }

#col-left { width: 15%; background-color: rgb(217, 232, 246); display: tabl=
e-cell; }

#col-main { width: 70%; display: table-cell; position: relative; }

#col-right { width: 15%; background-color: rgb(226, 226, 226); display: tab=
le-cell; position: relative; }

.col-25 { width: 25%; float: left; }

#noncontTitle, #contTitle { display: none; }

#pr-lt { display: none; }

.clock-box { margin-bottom: 15px; }

#col-main .clock-box { margin-bottom: 0px; }

.clock-box .title { text-transform: uppercase; font-size: 0.9em; font-weigh=
t: bold; }

.sub-title { text-transform: uppercase; font-size: 0.7em; margin-bottom: 5p=
x; }

.time-display { display: table; width: 90%; }

.color-area { width: 5%; display: table-cell; }

.time-text { background-color: rgb(0, 0, 0); font-weight: bold; color: rgb(=
255, 255, 255); font-size: 1.4em; padding: 5px; display: table-cell; }

.side-img { max-width: 90%; display: block; margin: 0px auto 15px; }

.margTop15 { margin-top: 15px; }

#twenty-hour { float: left; }

#main-time-area { background-color: rgb(0, 0, 0); width: 100%; text-align: =
center; color: rgb(255, 255, 255); padding: 15px 0px; }

.full-img { width: 94.5%; display: block; margin: 0px 2.3%; }

#mainland { position: relative; }

#az-clock { position: absolute; z-index: 100; bottom: 0px; left: 5%; }

.hours-wrapper { padding: 5px; background: rgb(238, 238, 238); margin-botto=
m: 15px; }

.striped-box { max-height: 0.75rem; max-width: 0.75rem; }

#analog-clock { max-width: 90%; }

#responseTime { display: none; }

input[type=3D"checkbox"].css-checkbox { position: absolute; z-index: -1000;=
 left: -1000px; overflow: hidden; clip: rect(0px, 0px, 0px, 0px); height: 1=
px; width: 1px; margin: -1px; padding: 0px; border: 0px; }

input[type=3D"checkbox"].css-checkbox + label.css-label { padding-left: 20p=
x; height: 15px; display: inline-block; line-height: 15px; background-repea=
t: no-repeat; background-position: 0px 0px; vertical-align: middle; cursor:=
 pointer; font-size: 0.7em; }

input[type=3D"checkbox"].css-checkbox:checked + label.css-label { backgroun=
d-position: 0px -15px; }

label.css-label { background-image: url("../img/csscheckbox.png"); user-sel=
ect: none; }

.no-saving { background-image: url("../img/diagonal-white.png"); }

