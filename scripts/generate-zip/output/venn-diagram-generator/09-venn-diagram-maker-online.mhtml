.form-wrap { width: 340px; margin: 20px auto; padding: 40px 50px; border-ra=
dius: 4px; background-image: linear-gradient(rgb(255, 255, 255) 0px, rgb(23=
8, 238, 238) 100%); }

.form-wrap .img-logo { display: block; margin: 0px auto 20px; width: 130px;=
 height: 130px; }

