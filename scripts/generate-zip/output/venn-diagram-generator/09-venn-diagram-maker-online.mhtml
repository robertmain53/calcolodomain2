.form-wrap .status_msg { color: rgb(0, 0, 255); }

.btn-facebook, .btn-google { color: rgb(255, 255, 255); text-decoration: no=
ne !important; }

.btn-facebook .fa, .btn-google .fa { margin-right: 10px; }

.btn-facebook { background-color: rgb(62, 89, 165); }

.btn-facebook:hover { background-color: rgb(65, 107, 186); }

.btn-google { background-color: rgb(204, 51, 51); }

.btn-google:hover { background-color: rgb(222, 51, 51); }

.divider-wrap { display: flex; justify-content: space-between; align-items:=
 center; margin: 20px 0px; }

.divider-wrap .divider { flex: 1 1 45%; border-bottom: 1px solid rgb(0, 0, =
0); height: 0px; }

