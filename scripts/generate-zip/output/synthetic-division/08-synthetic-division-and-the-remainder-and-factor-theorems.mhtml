eight=3D"81">
      </center></td>
    </tr>
  </tbody></table>
</center>
<p><a name=3D"step3"></a> <br>
  &nbsp;
</p><center>
  <table border=3D"0" cellspacing=3D"0" cellpadding=3D"0" cols=3D"1" width=
=3D"90%">
    <tbody><tr>
      <td><div align=3D"left"><b><font size=3D"+1"><font color=3D"#CC0000">=
Step 3:</font>&nbsp; Multiply <i>c</i> by the value just written on the bot=
tom row.</font></b></div></td>
    </tr>
  </tbody></table>
</center>
<br>
&nbsp;
<center>
  <table border=3D"0" cellspacing=3D"0" cellpadding=3D"0" cols=3D"1" width=
=3D"80%">
    <tbody><tr>
      <td><div align=3D"left">Place this value right beneath the next coeff=
icient in the dividend:
      </div>
        <center>
            <p><img src=3D"https://www.wtamu.edu/academic/anns/mps/math/mat=
hlab/col_algebra/col_alg_tut37div6.gif" alt=3D"synthetic division" width=3D=
"366" height=3D"81">
            </p></center></td>
    </tr>
  </tbody></table>
</center>
<p><a name=3D"step4"></a> <br>
  &nbsp;
</p><center>
  <table border=3D"0" cellspacing=3D"0" cellpadding=3D"0" cols=3D"1" width=
