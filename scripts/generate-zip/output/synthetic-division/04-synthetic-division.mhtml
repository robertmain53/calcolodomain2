-align: -0.505ex; width:6.047ex; height:2.176ex;" alt=3D"{\displaystyle x-a=
.}"></span>
</p><p>The advantage of calculating the value this way is that it requires =
just over half as many multiplication steps as naive evaluation. An alterna=
tive evaluation strategy is <a href=3D"https://en.wikipedia.org/wiki/Horner=
%27s_method" title=3D"Horner's method">Horner's method</a>.
</p>
<div class=3D"mw-heading mw-heading2"><h2 id=3D"Expanded_synthetic_division=
">Expanded synthetic division</h2><span class=3D"mw-editsection"><span clas=
s=3D"mw-editsection-bracket">[</span><a href=3D"https://en.wikipedia.org/w/=
index.php?title=3DSynthetic_division&amp;action=3Dedit&amp;section=3D3" tit=
le=3D"Edit section: Expanded synthetic division"><span>edit</span></a><span=
 class=3D"mw-editsection-bracket">]</span></span></div>
<p>This method generalizes to division by any <a href=3D"https://en.wikiped=
ia.org/wiki/Monic_polynomial" title=3D"Monic polynomial">monic polynomial</=
a> with only a slight modification with <b>changes in bold</b>. Note that w=
hile it may not be displayed in the following example, the divisor must als=
o be written with verbose coefficients. (Such as with <span class=3D"mwe-ma=
th-element mwe-math-element-inline"><span class=3D"mwe-math-mathml-inline m=
we-math-mathml-a11y" style=3D"display: none;"><math xmlns=3D"http://www.w3.=
org/1998/Math/MathML" alttext=3D"{\displaystyle 2x^{3}+0x^{2}-4x+8}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mn>2</mn>
        <msup>
          <mi>x</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>3</mn>
          </mrow>
        </msup>
        <mo>+</mo>
        <mn>0</mn>
        <msup>
          <mi>x</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>2</mn>
          </mrow>
        </msup>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mn>4</mn>
        <mi>x</mi>
        <mo>+</mo>
        <mn>8</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle 2x^{3}+0x^{2}=
-4x+8}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/47854bfdde6c18a307301b3e7d2aa771dddb8da9" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.505ex; width:19.269ex; height:2.843ex;" alt=3D"{\displaystyle 2x=
^{3}+0x^{2}-4x+8}"></span>) Using the same steps as before, perform the fol=
lowing division:
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e {\frac {x^{3}-12x^{2}-42}{x^{2}+x-3}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>3</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>12</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>42</mn>
            </mrow>
            <mrow>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>3</mn>
            </mrow>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\frac {x^{3}=
-12x^{2}-42}{x^{2}+x-3}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/bc765ce618bb98db8376c9a7a558ecb542f1a0bc" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -2.338ex; width:15.935ex; height:6.176ex;" alt=3D"{\displaystyle {\=
frac {x^{3}-12x^{2}-42}{x^{2}+x-3}}}"></span></dd></dl>
<p>We concern ourselves only with the coefficients.
Write the coefficients of the polynomial to be divided at the top.
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
