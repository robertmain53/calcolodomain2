        <mi>x</mi>
        <mo stretchy=3D"false">)</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle p(x)}</annota=
tion>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/8cb7afced134ef75572e5314a5d278c2d644f438" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.838ex; margin-left: -0.089ex; width:4.398ex; height:2.843ex;" al=
t=3D"{\displaystyle p(x)}"></span> at <span class=3D"mwe-math-element mwe-m=
ath-element-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a=
11y" style=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/Ma=
thML" alttext=3D"{\displaystyle a}">
  <semantics>
