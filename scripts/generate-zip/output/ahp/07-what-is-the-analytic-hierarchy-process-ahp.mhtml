                                <td>0.193</td>
                            </tr>
                            <tr>
                                <th>Storage</th>
                                <td>252.671</td>
                                <td>76.564</td>
                                <td>594.407</td>
                                <td>866.206</td>
                                <td>1789.848</td>
                                <td>0.667</td>
                            </tr>
                            <tr>
                                <th>Looks</th>
                                <td>30.692</td>
                                <td>9.235</td>
                                <td>72.402</td>
