@charset "utf-8";

.morado { background-color: rgb(153, 51, 102); }

.events { color: white; font-size: 24px; text-decoration: underline 5px yel=
low; font-weight: bold; }

.headings { color: rgb(3, 58, 73); font-size: 24px; text-decoration: underl=
ine 5px rgb(153, 51, 102); font-weight: bold; }

.comheading { color: white; font-size: 38px; }

.evento { color: white; font-size: 26px; font-weight: bold; text-decoration=
: none; }

.evento:hover { color: yellow; }

.fecha { color: white; font-size: 18px; }

.card { background: rgb(255, 255, 255); border-radius: 0px; padding: 40px; =
max-width: 400px; position: relative; box-shadow: rgba(0, 0, 0, 0.1) 0px 10=
px 25px; }

.card h1 { font-size: 2.5rem; margin: 0px 0px 10px; }

.card h2 { font-size: 1.4rem; margin: 10px 0px; font-weight: 700; }

.card p { font-size: 1rem; line-height: 1.5; margin: 10px 0px; color: rgb(8=
5, 85, 85); padding-right: 100px; }

.card strong { font-weight: 700; color: rgb(51, 51, 51); }

.btn { display: inline-block; margin-top: 20px; padding: 12px 24px; backgro=
und: rgb(0, 153, 255); color: rgb(255, 255, 255); border: none; border-radi=
us: 8px; text-decoration: none; font-size: 1rem; }

.image-box { position: absolute; top: 50%; right: -170px; transform: transl=
ateY(-50%); width: 300px; height: 250px; border-radius: 8px; overflow: hidd=
en; box-shadow: rgba(0, 0, 0, 0.15) 0px 5px 15px; }

.image-box img { width: 100%; height: 100%; object-fit: cover; display: blo=
ck; }

@media (max-width: 700px) {
  .card { padding: 30px; }
  .image-box { position: static; transform: none; margin-top: 20px; width: =
100%; height: auto; border-radius: 8px; }
}

.event-heroOverlay { background: url("https://www.ahp.org/Sitefinity/Websit=
eTemplates/ahc/App_Themes/ahc/global/images/home-hero-overangle.png") right=
 bottom no-repeat; }

.event-heroTextLiner .ht2 h1 { line-height: normal; margin-right: 200px; }

.event-heroTextLiner { top: 30px; }

.event-heroTextLiner .ht4 a { margin-top: 50px; }

.event-heroTextLiner .ht1 { font-size: 20px; color: rgb(255, 255, 255); lin=
e-height: 24px; top: 220px; position: relative; }

@media screen and (max-width: 480px) {
  .event-heroTextLiner .ht2 h1 { margin-right: 0px; font-size: 40px; }
  .event-heroTextLiner { top: 100px; }
  .event-heroText { padding-bottom: 150px; }
  .event-heroTextLiner .ht1 { top: 270px; }
  .fecha { padding-left: 25px; }
  .evento { padding-left: 25px; }
}
