sition: absolute; animation: 0.5s ease 0s 1 normal none running error-check=
mark; }

.device-check__error::before { transform: scaleX(-1) rotate(-45deg); }

.device-check__error::after { transform: scaleX(-1) rotate(225deg); }

@keyframes error-checkmark {=20
