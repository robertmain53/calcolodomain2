om: 3.5em; position: relative; display: inline-block; vertical-align: top; =
border-radius: 50%; width: 4em; height: 4em; }

.device-check__green-circle { border-color: var(--device-check-ok-color); }

.device-check__red-circle { border-color: var(--device-check-ko-color); }

.device-check__success::after { opacity: 1; height: 2em; width: 1em; left: =
0.8em; top: 2em; transform-origin: left top; border-right: 3px solid var(--=
