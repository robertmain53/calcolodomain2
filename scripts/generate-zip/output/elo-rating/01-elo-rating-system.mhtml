sup id=3D"cite_ref-21" class=3D"reference"><a href=3D"https://en.wikipedia.=
org/wiki/Elo_rating_system#cite_note-21"><span class=3D"cite-bracket">[</sp=
an>20<span class=3D"cite-bracket">]</span></a></sup></li></ul></li>
