@charset "utf-8";

#sitemap { font-family: Roboto, sans-serif; display: flex; padding: 15px; c=
olor: rgb(221, 221, 221); background: rgb(34, 34, 34); }

#sitemap .site-logo { height: 50px; margin: 5px 20px 5px 10px; cursor: poin=
ter; }

#sitemap .site-logo img { height: 50px; }

#sitemap .siteLinks { display: flex; flex-direction: column; font-size: 10p=
t; color: rgb(221, 221, 221); padding: 10px 0px; margin: 0px 15px; }

#sitemap .siteLinks h3 { font-size: 16px; color: white; }

#sitemap a { display: flex; align-items: center; text-decoration: none; col=
or: rgb(153, 153, 153); height: 40px; padding: 5px 0px; }

#sitemap a:hover, #sitemap a:active { color: white; text-decoration: underl=
ine; }

#sitemap .siteLinks .social-icon { height: 30px; width: 30px; margin: 0px 5=
px 0px 0px; }

#downloadLinks .badge { padding: 10px 0px; height: auto; width: fit-content=
; }

#sitemap .app-badge { height: 50px; width: 170px; }

#sitemap .app-badge:hover { box-shadow: gray 0px 0px 10px 1px; background-c=
olor: rgba(128, 128, 128, 0.5); }

@media (hover: none) {
  #sitemap a:hover { color: rgb(221, 221, 221); }
  #sitemap .app-badge { box-shadow: none; background-color: transparent; }
}

@media only screen and (min-width: 150px) {
  #sitemap { flex-wrap: wrap; }
  #sitemap .site-logo { width: 100%; }
  #sitemap .siteLinks { width: 100%; }
}

@media only screen and (min-width: 400px) {
  #sitemap { flex-wrap: wrap; }
  #sitemap .site-logo { width: 100%; }
  #sitemap .siteLinks { width: 45%; }
}

@media only screen and (min-width: 800px) {
  #sitemap { flex-wrap: nowrap; }
  #sitemap .site-logo { width: 33.33%; }
  #sitemap .siteLinks { width: 33.33%; }
}

@media only screen and (min-width: 1000px) {
  #sitemap { flex-wrap: nowrap; }
  #sitemap .site-logo { width: 25%; }
  #sitemap .siteLinks { width: 25%; }
}
