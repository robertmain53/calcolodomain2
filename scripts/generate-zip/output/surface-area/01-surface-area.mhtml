        <mrow class=3D"MJX-TeXAtom-ORD">
          <mtable columnalign=3D"right left left left" rowspacing=3D"4pt" c=
olumnspacing=3D"1em">
            <mtr>
              <mtd>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mtext>Sphere surface area</mtext>
                </mrow>
              </mtd>
              <mtd>
                <mo>=3D</mo>
                <mn>4</mn>
                <mi>=CF=80<!-- =CF=80 --></mi>
                <msup>
                  <mi>r</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msup>
              </mtd>
              <mtd></mtd>
              <mtd>
                <mo>=3D</mo>
                <mo stretchy=3D"false">(</mo>
                <mn>2</mn>
                <mi>=CF=80<!-- =CF=80 --></mi>
                <msup>
                  <mi>r</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msup>
                <mo stretchy=3D"false">)</mo>
                <mo>=C3=97<!-- =C3=97 --></mo>
                <mn>2</mn>
              </mtd>
            </mtr>
            <mtr>
              <mtd>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mtext>Cylinder surface area</mtext>
                </mrow>
              </mtd>
              <mtd>
                <mo>=3D</mo>
                <mn>2</mn>
                <mi>=CF=80<!-- =CF=80 --></mi>
                <mi>r</mi>
                <mo stretchy=3D"false">(</mo>
                <mi>h</mi>
                <mo>+</mo>
                <mi>r</mi>
                <mo stretchy=3D"false">)</mo>
              </mtd>
              <mtd>
                <mo>=3D</mo>
                <mn>2</mn>
                <mi>=CF=80<!-- =CF=80 --></mi>
                <mi>r</mi>
                <mo stretchy=3D"false">(</mo>
                <mn>2</mn>
                <mi>r</mi>
                <mo>+</mo>
                <mi>r</mi>
                <mo stretchy=3D"false">)</mo>
              </mtd>
              <mtd>
                <mo>=3D</mo>
                <mo stretchy=3D"false">(</mo>
                <mn>2</mn>
                <mi>=CF=80<!-- =CF=80 --></mi>
                <msup>
                  <mi>r</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msup>
                <mo stretchy=3D"false">)</mo>
                <mo>=C3=97<!-- =C3=97 --></mo>
                <mn>3</mn>
              </mtd>
