.si-field-label { color: rgb(84, 84, 84); display: block; font-size: 15px; =
line-height: 18px; }

.si-helper-text { font-size: 11px; line-height: 13px; }

.si-input-container .si-text-field { border: 1px solid rgb(211, 211, 211); =
border-radius: 6px; box-shadow: rgba(0, 0, 0, 0.15) 0px 1px 4px inset; box-=
sizing: border-box; padding: 8px 12px; width: 100%; }

.si-input-container .si-text-field:active, .si-input-container .si-text-fie=
ld:focus { border-color: rgb(0, 174, 239); outline: none; }

.si-input-container .si-text-field.error { border-color: rgb(245, 63, 70); =
}

.si-input-container .helper-top { margin-top: 3px; }

.si-input-container .helper-bottom { margin-bottom: 3px; }

.forgot-info-button { background-color: inherit; border: 0px; color: rgb(14=
8, 148, 148); font-size: 11px; line-height: 13px; margin-bottom: 5px; outli=
ne: none; padding: 0px; text-decoration: none; }

.forgot-info-button:focus-visible, .forgot-info-button:hover { text-decorat=
ion: underline; }

.signin-form .form-header { color: rgb(0, 174, 239); font: 30px/35px var(--=
font-roboto-slab); margin-bottom: 20px; padding: 0px; text-align: center; }

.signin-form .signin-dialog-message { color: rgb(84, 84, 84); font-size: 14=
px; line-height: 18px; margin-bottom: 20px; text-align: left; }

.signin-form .si-input-container { margin: 0px 0px 20px; }

.signin-form .label-forgot-info { align-items: flex-end; display: flex; jus=
tify-content: space-between; }

.signin-form .signin-field-label { flex-shrink: 0; margin-right: 10px; }

.signin-form .forgot-info-button { flex-shrink: 1; text-align: right; }

.signin-form .form-bottom { align-items: center; display: flex; justify-con=
tent: space-between; margin-top: 25px; }

.signin-form .form-bottom .remember-me-container { align-items: baseline; d=
isplay: flex; }

.signin-form .form-bottom .checkbox { border: 1px solid rgb(211, 211, 211);=
 border-radius: 1px; flex-shrink: 0; height: 12px; width: 12px; }

.signin-form .form-bottom .si-field-label { display: inline-block; margin-l=
eft: 5px; }

.signin-form .form-bottom .submit-btn { border: 0px; font-size: 16px; heigh=
t: 40px; min-width: 120px; }

.signin-form .error-message { background: rgb(255, 232, 232); border-radius=
: 4px; box-sizing: border-box; color: rgb(254, 61, 1); font: 11px/13px var(=
--font-verdana); margin: -10px 0px 10px; padding: 3px 10px 4px; text-align:=
 left; }

.signin-form .si-input-container .si-text-field { font-size: 15px; }

@media screen and (min-width: 481px) {
  .signin-form .form-header { text-align: left; }
}

.signin-avatar { display: inline-block; position: relative; }

.signin-avatar .icon-container { align-items: center; background-color: rgb=
(240, 240, 240); border-radius: 50%; box-sizing: border-box; display: flex;=
 justify-content: center; }

.signin-avatar .avatar-name { color: rgb(102, 102, 102); display: block; ma=
