0px; margin-left: 0px; }

.nist-footer__menu-item::after { content: "|"; margin-right: 1.6px; display=
: inherit; position: static; font: inherit; color: inherit; }

.nist-footer__menu-item:last-child::after { content: none; }

.nist-footer__menu-item a { font-weight: normal; margin-right: 6px; white-s=
pace: nowrap; padding: 0.5em 0px; display: inline-block; }

