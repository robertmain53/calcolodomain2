<h3>Reference table of weight conversions</h3>
<table class=3D"tblContent tblAlt">
<tbody>
<tr>
<th colspan=3D"3">1 Troy Ounce equals</th>
</tr>
<tr>
<td>Grams</td>
<td>31.103</td>
<td>g</td>
</tr>
<tr>
<td>Kilograms</td>
<td>0.0311</td>
<td>kg</td>
</tr>
