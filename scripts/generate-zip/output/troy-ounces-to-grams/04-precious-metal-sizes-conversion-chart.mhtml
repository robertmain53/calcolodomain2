ight: 1em; width: 1em; }

.elementor-popup-modal .dialog-widget-content { background-color: rgb(255, =
255, 255); border-radius: 0px; box-shadow: none; max-height: 100%; max-widt=
h: 100%; overflow: visible; pointer-events: all; width: auto; }

.elementor-popup-modal .dialog-message { display: flex; max-height: 100vh; =
max-width: 100vw; overflow: auto; padding: 0px; width: 640px; }

.elementor-popup-modal .elementor { width: 100%; }
