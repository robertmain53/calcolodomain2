area) { display: none; }

.elementor-popup-modal.dialog-type-lightbox { background-color: transparent=
; display: flex; pointer-events: none; user-select: auto; }

.elementor-popup-modal .dialog-buttons-wrapper, .elementor-popup-modal .dia=
