        <mo stretchy=3D"false">)</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mrow class=3D"MJX-TeXAtom-CLOSE">
            <mo maxsize=3D"1.2em" minsize=3D"1.2em">)</mo>
          </mrow>
        </mrow>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle f(x)=3D{\ln }=
{\bigl (}1+(\cos x-1){\bigr )},}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/1b555cfe366f3dce664b2632e76ad49860d5e7eb" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -1.005ex; width:26.875ex; height:3.176ex;" alt=3D"{\displaystyle f=
(x)=3D{\ln }{\bigl (}1+(\cos x-1){\bigr )},}"></span>
the composition of two functions <span class=3D"mwe-math-element mwe-math-e=
lement-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" =
style=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML"=
 alttext=3D"{\displaystyle x\mapsto \ln(1+x)}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
