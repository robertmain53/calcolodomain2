            <msup>
              <mi>x</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>4</mn>
              </mrow>
            </msup>
            <mn>24</mn>
          </mfrac>
        </mrow>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <msup>
              <mi>x</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>6</mn>
              </mrow>
            </msup>
            <mn>720</mn>
          </mfrac>
        </mrow>
        <mo>+</mo>
        <mi>O</mi>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mrow>
            <mo>(</mo>
            <msup>
              <mi>x</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>8</mn>
              </mrow>
            </msup>
            <mo>)</mo>
          </mrow>
        </mrow>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \cos x-1=3D-{=
\frac {x^{2}}{2}}+{\frac {x^{4}}{24}}-{\frac {x^{6}}{720}}+O{\left(x^{8}\ri=
ght)}.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/4ba3942535c77d8caa7aef25f2bcad9e54cda9f3" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -2.005ex; width:39.956ex; height:5.843ex;" alt=3D"{\displaystyle \=
cos x-1=3D-{\frac {x^{2}}{2}}+{\frac {x^{4}}{24}}-{\frac {x^{6}}{720}}+O{\l=
eft(x^{8}\right)}.}"></span>
</p><p>The first several terms from the second series can be substituted in=
to each term of the first series. Because the first term in the second seri=
es has degree 2, three terms of the first series suffice to give a 7th-degr=
ee polynomial:
<span class=3D"mwe-math-element mwe-math-element-block"><span class=3D"mwe-=
math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;"><math di=
splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle {\begin{aligned}f(x)&amp;=3D\ln {\bigl (}1+(\cos x-1){\bigr )}\=
\&amp;=3D(\cos x-1)-{\tfrac {1}{2}}(\cos x-1)^{2}+{\tfrac {1}{3}}(\cos x-1)=
^{3}+O{\left((\cos x-1)^{4}\right)}\\&amp;=3D-{\frac {x^{2}}{2}}-{\frac {x^=
{4}}{12}}-{\frac {x^{6}}{45}}+O{\left(x^{8}\right)}.\end{aligned}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mtable columnalign=3D"right left right left right left right lef=
t right left right left" rowspacing=3D"3pt" columnspacing=3D"0em 2em 0em 2e=
m 0em 2em 0em 2em 0em 2em 0em" displaystyle=3D"true">
            <mtr>
              <mtd>
                <mi>f</mi>
                <mo stretchy=3D"false">(</mo>
                <mi>x</mi>
                <mo stretchy=3D"false">)</mo>
              </mtd>
              <mtd>
                <mi></mi>
                <mo>=3D</mo>
                <mi>ln</mi>
                <mo>=E2=81=A1<!-- =E2=81=A1 --></mo>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mrow class=3D"MJX-TeXAtom-OPEN">
                    <mo maxsize=3D"1.2em" minsize=3D"1.2em">(</mo>
