    <annotation encoding=3D"application/x-tex">{\displaystyle f(x)=3D\ln(\c=
os x),\quad x\in {\bigl (}{-{\tfrac {\pi }{2}}},{\tfrac {\pi }{2}}{\bigr )}=
,}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/00c33c80d4c59178c6b43e60e4c8b84511657136" class=3D"mwe-math-fallback=
