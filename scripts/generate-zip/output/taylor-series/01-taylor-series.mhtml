        <mo>=E2=81=A1<!-- =E2=81=A1 --></mo>
        <mo stretchy=3D"false">(</mo>
        <mn>1</mn>
        <mo>+</mo>
        <mi>x</mi>
        <mo stretchy=3D"false">)</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle x\mapsto \ln(=
1+x)}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/5caae16484b3cd819e452483f9ff91a0a795f107" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.838ex; width:14.025ex; height:2.843ex;" alt=3D"{\displaystyle x\=
mapsto \ln(1+x)}"></span> and <span class=3D"mwe-math-element mwe-math-elem=
ent-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" sty=
le=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" al=
ttext=3D"{\displaystyle x\mapsto \cos x-1.}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>x</mi>
        <mo stretchy=3D"false">=E2=86=A6<!-- =E2=86=A6 --></mo>
        <mi>cos</mi>
        <mo>=E2=81=A1<!-- =E2=81=A1 --></mo>
        <mi>x</mi>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mn>1.</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle x\mapsto \cos=
 x-1.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/2a3129cfb65535734789f1f1fcb32e363b9f4967" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.505ex; width:14.421ex; height:2.343ex;" alt=3D"{\displaystyle x\=
mapsto \cos x-1.}"></span> The Taylor series for the natural logarithm is (=
using <a href=3D"https://en.wikipedia.org/wiki/Big_O_notation" title=3D"Big=
 O notation">big O notation</a>)
<span class=3D"mwe-math-element mwe-math-element-block"><span class=3D"mwe-=
math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;"><math di=
splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle \ln(1+x)=3Dx-{\frac {x^{2}}{2}}+{\frac {x^{3}}{3}}+O{\left(x^{4=
}\right)}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>ln</mi>
        <mo>=E2=81=A1<!-- =E2=81=A1 --></mo>
        <mo stretchy=3D"false">(</mo>
        <mn>1</mn>
        <mo>+</mo>
        <mi>x</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=3D</mo>
        <mi>x</mi>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <msup>
              <mi>x</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
