</ul>
<h3>
<a name=3D"Length"></a><b><font size=3D"+1">Length</font></b></h3>
<ul>
  <li>
1 (statute) mile (mi) =3D 1.6093 kilometer (km)</li>
  <li>
1 (nautical) mile (mi) =3D 1.8520 kilometer (km)</li>
  <li>
1 foot (ft) =3D 0.3048 meter (m)</li>
  <li>
1 yard =3D 0.9144 meter (m)</li>
  <li>
1 inch (in) =3D 2.54 centimeter (cm)</li>
  <li>
1 angstrom (A) =3D 10<sup>-8</sup> centimeter (cm) =3D 10<sup>-10</sup>
meter
(m)</li>
</ul>
<h3>
<a name=3D"Area"></a><b><font size=3D"+1">Area</font></b></h3>
<ul>
  <li>
1 square kilometer (km<sup>2</sup>) =3D 10<sup>6</sup> square meters (m<sup=
>2</sup>)
=3D 100 hectares (ha)</li>
  <li>
1 hectare (ha) =3D 10,000 square meters (m<sup>2</sup>)</li>
  <li>
1 acre (ac) =3D 4047 square meters (m<sup>2</sup>) =3D 0.4047 hectare (ha)<=
/li>
</ul>
<h3>
<a name=3D"Volume"></a><b><font size=3D"+1">Volume</font></b></h3>
<ul>
  <li>
1 milliliter (ml) =3D 1 cubic centimeter (cm<sup>3</sup>)</li>
  <li>
1 cubic meter (m<sup>3</sup>) =3D 1000 liters (L)</li>
  <li>
1 (US) quart (qt) =3D 0.9461 liter (L)</li>
  <li>
1 (US) gallon (gal) =3D 3.7854 liter (L)</li>
  <li>
1 (US) pint =3D 0.4723 liter (L)</li>
  <li>
1 (US) fluid ounce =3D 29.6 milliliter (ml)</li>
</ul>
<h3>
<a name=3D"Mass"></a><b><font size=3D"+1">Mass</font></b></h3>
<ul>
  <li>
1 metric ton (m.t.) =3D 1000 kilograms (kg)</li>
  <li>
1&nbsp; pound (lb) =3D 0.4535924 kilogram (kg)</li>
  <li>
1 ounce (oz) =3D 28.3495 grams (g)</li>
</ul>
<h3>
<a name=3D"Pressure"></a><b><font size=3D"+1">Pressure</font></b></h3>
<ul>
  <li>
1 pascal (Pa) =3D 1 newton/square meter (N/m<sup>2</sup>) =3D 1 Kg m<sup>-1=
</sup>
s<sup>-2</sup></li>
  <li>
1 bar =3D 0.98692 atmosphere (atm) =3D 10<sup>5</sup> pascals (Pa)</li>
  <li>
1 pound per square inch (psi) =3D 68.97 millibars (mb) =3D 6897 pascals (Pa=
)</li>
</ul>
<h3>
<a name=3D"Energy"></a><b><font size=3D"+1">Energy</font></b></h3>
<ul>
  <li>
1 joule (J) =3D 1 newton meter (Nm)</li>
  <li>
1 calorie (cal) =3D 4.184 joule (J)</li>
  <li>
1 kilowatt hour (kWh) =3D 3.6 x 10<sup>6</sup> joules (J) =3D 8.60 x 10<sup=
>5</sup>
calories</li>
</ul>
<h3>
<a name=3D"Power"></a><b><font size=3D"+1">Power (energy per unit time)</fo=
nt></b></h3>
<ul>
  <li>
1 watt (W) =3D 1 joule per second (J/s) =3D 14.34 calories per minute
(cal/min)</li>
</ul>
<h3>
<a name=3D"Temperature"></a><b><font size=3D"+1">Temperature</font></b></h3=
>
<ul>
  <li>
from Fahrenheit to Celsius: C =3D (F - 32) x 5/9</li>
  <li>
from Celsius to Fahrenheit: F =3D (C x 9/5) + 32</li>
  <li>
from Celsius to Kelvin: K =3D C + 273.15</li>
</ul>
<h3>
<a name=3D"Radioactivity"></a>Radioactivity</h3>
<ul>
  <li>
1 Curie (Ci) =3D 3.7x10<sup>10</sup> Becquerel (Bq)</li>
  <li>
1 Gray (Gy) =3D 1 J/kg tissue =3D 100 rad</li>
</ul>
