@charset "utf-8";

body, html { font-family: Arial, sans-serif; }

.hidden, .skip a { height: 1px; position: absolute; width: 1px; overflow: h=
idden; }

.clearBoth, .hidden, td { padding: 0px; }

menu, ol, p, ul { margin-left: 2em; margin-right: 1em; }

body, dl { background-color: rgb(240, 240, 240); }

div#wrapper, dl { border: 1px solid rgb(179, 179, 179); }

dl, menu, ol, p, ul { margin-right: 1em; }

#headerCenter, #headerLeft { vertical-align: middle; display: table-cell; }

div#cite p, p#title { font-size: unset; }

#Bottom, #LeftSidebar, #RightSidebar, .hidden, .skip a, div.TextTextFit, dl=
 { overflow: hidden; }

#asc-ad-wrapper.sticky.show-adtext::before, .pages3::before, .pages::before=
 { content: "Advertisement"; font-size: 10px; top: 5px; text-transform: upp=
ercase; }

