@charset "utf-8";

#vittoria-tcp { touch-action: pan-y; overflow-x: hidden; }

#vittoria-tcp ol { list-style: decimal; overflow-wrap: break-word; font-siz=
e: 12px; padding: 0px 1.125rem; }

.vt-tcp-container { margin: 0px auto; display: flex; }

.vt-tcp-section { width: 50%; }

.vt-tcp-center { text-align: center; }

.vt-tcp-review { text-align: center; padding-left: 30px; }

.vt-tcp-info { text-align: left; max-width: 70%; margin-bottom: 30px; }

.vt-tcp-heading-tag { color: rgb(204, 51, 51); font-weight: 700; font-size:=
 1.2em; margin-bottom: 5px; text-transform: uppercase; }

.vt-tcp-heading { font-size: 2em; font-weight: 700; margin-bottom: 15px; li=
ne-height: 1.2em; }

.vt-tcp-subheading { font-size: 0.9em; }

.vt-tcp-select-button { background-color: rgb(204, 51, 51); color: rgb(255,=
 255, 255); padding: 15px 20px; border: none; font-size: 1.1em; font-weight=
: 700; cursor: pointer; margin: 10px 0px 20px; }

.vt-tcp-select-button:hover { background-color: rgb(204, 51, 51); }

.vt-tcp-select-button.disabled { opacity: 0.5; }

.vt-tcp-chart { text-align: center; position: relative; max-width: 600px; }

.vt-tcp-disclaimer { margin-bottom: 40px; margin-top: 20px; text-align: lef=
t; }

.vt-tcp-selection-review { padding: 20px; margin-bottom: 30px; background-c=
olor: rgb(var(--text-color) / .05); text-align: left; }

.vt-tcp-selection-item { display: flex; justify-content: space-between; ali=
gn-items: center; padding: 16px 0px; font-size: 0.9em; border-bottom: 1px s=
olid rgb(var(--text-color) / .1); line-height: 1.2; }

.vt-tcp-review-value { margin-top: 5px; display: block; }

.vt-tcp-selection-item.cliccable { cursor: pointer; }

.vt-tcp-selection-section { margin: 20px 0px 12px; }

.vt-tcp-selection-section:last-child .vt-tcp-selection-item:last-of-type { =
border-bottom: none; }

.vt-tcp-section-heading { font-weight: 700; margin-bottom: 10px; font-size:=
 1.1em; }

.vt-tcp-edit-button { font-size: 20px; }

.vt-tcp-bold { font-weight: 700; }

.vt-tcp-back-button { align-items: center; gap: var(--spacing-4); border-ra=
dius: var(--rounded-button); opacity: 0.7; transition: 0.2s ease-in-out; di=
