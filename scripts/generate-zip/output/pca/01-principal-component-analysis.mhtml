<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e \mathbf {w} _{(1)}=3D\arg \max _{\Vert \mathbf {w} \Vert =3D1}\,\left\{\s=
um _{i}(t_{1})_{(i)}^{2}\right\}=3D\arg \max _{\Vert \mathbf {w} \Vert =3D1=
}\,\left\{\sum _{i}\left(\mathbf {x} _{(i)}\cdot \mathbf {w} \right)^{2}\ri=
ght\}}">
