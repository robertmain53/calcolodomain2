        <mo>=E2=81=A1<!-- =E2=81=A1 --></mo>
        <munder>
          <mo movablelimits=3D"true" form=3D"prefix">max</mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mo fence=3D"false" stretchy=3D"false">=E2=80=96<!-- =E2=80=96 =
--></mo>
            <mrow class=3D"MJX-TeXAtom-ORD">
              <mi mathvariant=3D"bold">w</mi>
            </mrow>
            <mo fence=3D"false" stretchy=3D"false">=E2=80=96<!-- =E2=80=96 =
--></mo>
            <mo>=3D</mo>
            <mn>1</mn>
