tion-padding-bottom); }

.mobile-dock.section--divider { border-block-start: 1px solid rgb(var(--col=
or-foreground)/ .06); }

.mobile-dock.section--divider::after { content: none; }

.dock__item { height: var(--sp-11); width: 100%; max-width: 100%; text-deco=
ration: none; color: rgb(var(--color-foreground)); }

