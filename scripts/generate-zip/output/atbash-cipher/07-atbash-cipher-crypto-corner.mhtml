</div></div>

<div><div id=3D"966223646713465805" align=3D"left" style=3D"width: 100%; ov=
erflow-y: hidden;" class=3D"wcustomhtml"><a name=3D"encrypt"></a></div>



</div>

<div><div id=3D"748908732767774067" align=3D"left" style=3D"width: 100%; ov=
erflow-y: hidden;" class=3D"wcustomhtml">
<!-- Horizontal -->
<ins class=3D"adsbygoogle" style=3D"display: block; height: 280px;" data-ad=
-client=3D"ca-pub-6012495557192475" data-ad-slot=3D"7512497312" data-ad-for=
