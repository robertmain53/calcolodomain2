inomialDistribution/Inline180.svg" class=3D"inlineformula" style=3D"max-hei=
ght:100%;max-width:100%" border=3D"0" width=3D"30" height=3D"21" alt=3D"n,p=
">
 and <img src=3D"https://mathworld.wolfram.com/images/equations/BinomialDis=
tribution/Inline181.svg" class=3D"inlineformula" style=3D"max-height:100%;m=
ax-width:100%" border=3D"0" width=3D"34" height=3D"21" alt=3D"m,p">.
 The <a href=3D"https://mathworld.wolfram.com/ConditionalProbability.html">=
conditional probability</a> of <img src=3D"https://mathworld.wolfram.com/im=
ages/equations/BinomialDistribution/Inline182.svg" class=3D"inlineformula" =
style=3D"max-height:100%;max-width:100%" border=3D"0" width=3D"9" height=3D=
"21" alt=3D"x"> given that <img src=3D"https://mathworld.wolfram.com/images=
/equations/BinomialDistribution/Inline183.svg" class=3D"inlineformula" styl=
e=3D"max-height:100%;max-width:100%" border=3D"0" width=3D"67" height=3D"21=
" alt=3D"x+y=3Dk"> is
</p>
<div>
<table summary=3D"" width=3D"100%" align=3D"center" cellspacing=3D"0" cellp=
