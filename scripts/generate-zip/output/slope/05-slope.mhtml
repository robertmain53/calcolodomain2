      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle (x_{2},y_{2})=
}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/d52d44e16a796acee486af49af05f678566d181a" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.838ex; width:7.421ex; height:2.843ex;" alt=3D"{\displaystyle (x_=
{2},y_{2})}"></span>, the change in <span class=3D"mwe-math-element mwe-mat=
h-element-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11=
y" style=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/Math=
ML" alttext=3D"{\displaystyle x}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>x</mi>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle x}</annotatio=
n>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/87f9e315fd7e2ba406057a97300593c4802b53e4" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.338ex; width:1.33ex; height:1.676ex;" alt=3D"{\displaystyle x}">=
</span> from one to the other is <span class=3D"mwe-math-element mwe-math-e=
lement-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" =
style=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML"=
 alttext=3D"{\displaystyle x_{2}-x_{1}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
