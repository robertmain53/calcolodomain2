    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle (x_{1},y_{1})=
}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/7fc74086e56542bd28b46a84faaee3cebdd4a899" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.838ex; width:7.421ex; height:2.843ex;" alt=3D"{\displaystyle (x_=
{1},y_{1})}"></span> and <span class=3D"mwe-math-element mwe-math-element-i=
nline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D=
"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=
=3D"{\displaystyle (x_{2},y_{2})}">
