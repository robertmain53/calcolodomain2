env.workspace =3D <span class=3D"hljs-string">"C:/sapyexamples/data"</span>

<span class=3D"hljs-comment"># Set local variables</span>
inRaster =3D <span class=3D"hljs-string">"elevation"</span>
outMeasurement =3D <span class=3D"hljs-string">"DEGREE"</span>
zFactor =3D <span class=3D"hljs-string">""</span>
