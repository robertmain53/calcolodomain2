<span class=3D"hljs-comment"># Execute Slope</span>
outSlope =3D Slope(inRaster, outMeasurement, zFactor, method, zUnit)

<span class=3D"hljs-comment"># Save the output </span>
outSlope.save(<span class=3D"hljs-string">"C:/sapyexamples/output/outslope0=
