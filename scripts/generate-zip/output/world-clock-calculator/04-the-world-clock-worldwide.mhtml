.bn-header--worldclock { background: url("//c.tadst.com/gfx/n/citybg-map.pn=
g") 50% 5% no-repeat fixed rgb(23, 109, 179); }

#ad-wrap { background: rgb(23, 109, 179); }

.my-city__header::before { content: ""; }

.tb-theme label { color: rgb(255, 255, 255); }

.tb-theme select { color: rgb(69, 69, 69); font-weight: normal; }

button.tb-conf { background-color: rgb(179, 23, 96); }

.tb-quick-change { margin-bottom: 6px; color: rgb(119, 119, 119); line-heig=
ht: 1.4; }

.tb-header { float: left; }

.tb-show { float: right; margin-left: 12px; }

.tb-scroll { padding-top: 0px; }

@media only screen and (max-width: 64em) {
  .tb-header { float: none; }
  .tb-show { float: left; }
  button.tb-conf { margin-right: 0px; }
  .tb-scroll { clear: both; }
}

@media only screen and (max-width: 37.438em) {
  .tb-header { float: none; }
  .tb-show { float: none; margin: 0px 0px 6px; }
  button.tb-conf { margin-right: 12px; }
}

.my-city__more { z-index: 100; top: 0px; }

@media only screen and (max-width: 50em) {
  .my-city__more { display: none; }
}
