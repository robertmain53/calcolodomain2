.analog-clock { --color-clockface: #f5f5f5; --color-stroke: #292a2d; --colo=
r-stroke-lighter: #777; --color-seconds: #fb4d56; filter: drop-shadow(rgba(=
0, 0, 0, 0.1) 0px 0px 16px); height: 100%; width: 100%; }

.analog-clock__marker { stroke-width: 1; stroke-linecap: round; stroke: var=
(--color-stroke-lighter); display: none; }

.analog-clock__marker--hour { stroke: var(--color-stroke); stroke-width: 2;=
 }

.analog-clock__face, .analog-clock__pin-inner { fill: var(--color-clockface=
); }

.analog-clock__pin { fill: var(--color-stroke); }

.analog-clock__numbers { fill: var(--color-stroke-lighter); }

.analog-clock__hand { stroke: var(--color-stroke); stroke-width: 2; transfo=
rm-origin: center center; }

.analog-clock__hand--seconds { stroke: var(--color-seconds); stroke-width: =
1; }

.analog-clock.isNight { --color-clockface: #292a2d; --color-stroke: #ccc; -=
-color-stroke-lighter: #fff; --color-seconds: #ffa000; }

.analog-clock--light { --color-clockface: #fff; }
