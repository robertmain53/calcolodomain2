@media only screen and (min-width: 90.063em) {
  .pdflexi-t--small { padding-top: 24px; }
}

.tb-theme label { color: rgb(255, 255, 255); }

.tb-theme select { color: rgb(69, 69, 69); font-weight: 400; }

.tb-header { float: left; }

.tb-show { float: right; margin-left: 12px; }

.tb-scroll { padding-top: 0px; }

button.tb-conf { background-color: rgb(179, 23, 96); }

.tb-quick-change { color: rgb(119, 119, 119); line-height: 1.4; margin-bott=
om: 6px; }

.tb-quick-change .active { color: rgb(119, 119, 119); }

@media only screen and (max-width: 870px) {
  .tb-header { float: none; }
  .tb-show { float: left; }
  button.tb-conf { margin-right: 0px; }
  button.tb-conf::before { color: rgb(179, 23, 96); content: ""; font-size:=
 12px; position: absolute; right: 44px; }
  .tb-scroll { clear: both; }
}

@media only screen and (max-width: 37.438em) {
  .tb-header, .tb-show { float: none; }
  .tb-show { margin: 0px 0px 6px; }
  button.tb-conf { margin-right: 12px; }
}

.my-city__clocks, .my-city__weather { margin-bottom: 20px; overflow: auto; =
}

.my-city__clocks::after, .my-city__weather::after { clear: both; content: "=
"; display: table; }

@media only screen and (min-width: 37.5em) {
  .my-city__clocks, .my-city__weather { float: left; width: calc(100% - 310=
px); }
}

@media only screen and (max-width: 37.438em) {
  .my-city__clocks, .my-city__weather { margin-right: -10px; }
}

.my-city__more:hover { opacity: 1; text-decoration: none; }

.my-city__more { color: rgb(69, 69, 69); font-size: 44px; opacity: 0.4; pos=
ition: absolute; right: 310px; top: 80px; }

@media only screen and (max-width: 37.438em) {
  .my-city__more { display: none; }
}

.my-city__items { position: relative; }

.my-city__empty { font-style: italic; margin-top: 24px; }

.tb-theme td { vertical-align: middle; }

#clc-results h2 { word-break: break-word; }

.picker-city { font-size: 16px; }
