              <mn>4</mn>
            </mfrac>
          </mstyle>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\tfrac {3}{4=
}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/8ec6051ef87eb0dafdaeaacd61f340052fcbf2bf" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.171ex; width:1.658ex; height:3.509ex;" alt=3D"{\displaystyle {\t=
frac {3}{4}}}"></span> and <span class=3D"mwe-math-element mwe-math-element=
-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=
=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" altt=
ext=3D"{\displaystyle {\tfrac {5}{6}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mstyle displaystyle=3D"false" scriptlevel=3D"0">
