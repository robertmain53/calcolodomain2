            </mtr>
            <mtr>
              <mtd></mtd>
              <mtd>
                <mi></mi>
                <mo>=3D</mo>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mfrac>
                    <mrow>
                      <mn>3</mn>
                      <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
                      <mn>3</mn>
                    </mrow>
                    <mrow>
                      <mn>4</mn>
                      <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
