        </mrow>
        <mo>=3D</mo>
        <mn>1</mn>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mn>4</mn>
            <mn>15</mn>
          </mfrac>
        </mrow>
        <mo>.</mo>
      </mstyle>
    </mrow>
