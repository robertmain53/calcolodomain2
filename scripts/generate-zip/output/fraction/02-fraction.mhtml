        </mrow>
        <mo>=C3=B7<!-- =C3=B7 --></mo>
        <mn>5</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\tfrac {10}{=
3}}\div 5}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
