              <mn>5</mn>
              <mspace width=3D"1em"></mspace>
              <mn>3</mn>
            </mrow>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\frac {3\qua=
d 1}{5\quad 3}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/b078d004ad0c501c44d3ff1d2360ade80bb2fad3" class=3D"mwe-math-fallback=
