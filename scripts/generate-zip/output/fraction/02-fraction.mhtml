              <mn>7</mn>
            </msqrt>
          </mfrac>
        </mrow>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mn>3</mn>
            <msqrt>
              <mn>7</mn>
            </msqrt>
          </mfrac>
        </mrow>
        <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <msqrt>
              <mn>7</mn>
            </msqrt>
            <msqrt>
              <mn>7</mn>
            </msqrt>
          </mfrac>
        </mrow>
        <mo>=3D</mo>
