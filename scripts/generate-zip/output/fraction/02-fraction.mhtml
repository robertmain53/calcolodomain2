2{\sqrt {5}}}{3+2{\sqrt {5}}}}=3D{\frac {3(3+2{\sqrt {5}})}{{3}^{2}-(2{\sqr=
t {5}})^{2}}}=3D{\frac {3(3+2{\sqrt {5}})}{9-20}}=3D-{\frac {9+6{\sqrt {5}}=
}{11}},}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
