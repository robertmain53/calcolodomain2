">[</span><span class=3D"n">y0</span><span class=3D"p">]</span>

<span class=3D"n">y</span> <span class=3D"o">=3D</span> <span class=3D"n">y=
0</span>
<span class=3D"n">x</span> <span class=3D"o">=3D</span> <span class=3D"n">x=
0</span>

<span class=3D"k">while</span> <span class=3D"n">x</span> <span class=3D"o"=
>&lt;=3D</span> <span class=3D"n">x_end</span><span class=3D"p">:</span>
   =20
    <span class=3D"n">x</span><span class=3D"p">,</span> <span class=3D"n">=
