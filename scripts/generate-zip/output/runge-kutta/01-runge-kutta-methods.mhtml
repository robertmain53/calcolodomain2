        <mi>=CE=BB<!-- =CE=BB --></mi>
        <mi>y</mi>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle y'=3D\lambda =
y}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/de1e4490620ccdb32e4bcb6f2edd017eb158d0a0" class=3D"mwe-math-fallback=
