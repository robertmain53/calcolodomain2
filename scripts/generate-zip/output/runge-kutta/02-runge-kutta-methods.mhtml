<td align=3D"LEFT" nowrap=3D""><i>k</i><sub>4</sub> =3D <i>h</i>(<i>y</i><s=
ub><i>n</i></sub>+<i>k</i><sub>3</sub>, <i>t</i><sub><i>n</i></sub> + <i>h<=
/i>)</td>
<td width=3D"10" align=3D"RIGHT">
&nbsp;</td></tr>
