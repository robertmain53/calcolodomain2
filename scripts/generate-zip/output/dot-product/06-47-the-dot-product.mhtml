@charset "utf-8";

@import url("https://fonts.googleapis.com/css2?family=3DMaterial+Symbols+Ou=
tlined:opsz,wght,FILL,GRAD@48,400,0,0");

.readerView #attachments, .readerView #custom_open, .readerView .LTBranding=
, .readerView .elm-meta-icons, .readerView .sbHeader, .readerView div.annot=
ator-frame { display: none; }

.darkMode { background-color: rgb(37, 37, 37); }

@font-face { font-family: OpenDyslexic; src: url("https://dl.dropboxusercon=
tent.com/s/qfpakpjedhsrdb9/OpenDyslexicAlta-Regular.ttf"); }

.dyslexic-toggle { align-items: center; color: rgb(0, 0, 0); display: flex;=
 font-family: OpenDyslexic; font-size: medium; gap: 10px; margin-left: 10px=
; }

.switch { display: inline-block; height: 34px; position: relative; width: 6=
0px; }

.switch input { height: 0px; opacity: 0; width: 0px; }

.slider.round { border-radius: 34px; }

.slider.round::before { border-radius: 50%; }

.slider { background-color: rgb(204, 204, 204); inset: 0px; cursor: pointer=
; }

.slider, .slider::before { position: absolute; transition: 0.4s; }

.slider::before { background-color: rgb(255, 255, 255); bottom: 4px; conten=
t: ""; height: 26px; left: 4px; width: 26px; }

input:checked + .slider { background-color: rgb(17, 96, 175); }

input:focus + .slider { box-shadow: rgb(33, 150, 243) 0px 0px 1px; }

input:checked + .slider::before { transform: translateX(26px); }

#chevron-icon:hover { color: rgb(29, 81, 140); cursor: pointer; }

.readerView header.elm-header { margin-bottom: 1em; position: sticky; top: =
0px; z-index: 1003; }

.readerView header.elm-header .mt-container-highlight, .readerView header.e=
lm-header > * { display: none; }

.readerView .elm-header > .elm-header-custom { display: block; }

.readerView #mt-summary { display: none !important; }

.readerView .elm-meta-top, .readerView article.elm-content-container .mt-co=
ntent-header { display: none; }

.buttonContainer { white-space: nowrap; }

.fontSize_label { color: rgb(17, 17, 17); display: inline-block; font-size:=
 medium; font-weight: 700; padding: 10px; }

.fontSize_in { margin-top: -15px; }

.readerView .elm-article-feedback { display: none; }

.readerView a:disabled, .readerView button:disabled { cursor: not-allowed !=
important; opacity: 0.7; }

.readerView .hidden { display: none; }

.readerView #backButton, .readerView #nextButton { display: block !importan=
t; }

.readerView #backButton, .readerView #nextButton, .readerView .libreNavTitl=
e { border-radius: 0px; bottom: 10px; position: fixed; top: unset; }

.readerView #nextTitle { right: calc(3em + 40px); }

.readerView #prevTitle { left: calc(3em + 40px); }

.readerView #nextButton { right: 3em; }

.readerView #backButton { left: 3em; }

@media (max-width: 1366px) {
  .readerView #nextButton { right: 2px; }
  .readerView #backButton { left: 2px; }
}

@media (max-width: 768px) {
  .readerView header.elm-header { position: static; }
}

#readerview { display: none; }

.readerView #readerview { background-color: rgb(255, 255, 255); border-bott=
om: 1px solid rgb(211, 211, 211); display: grid; gap: 10px; grid-template-c=
olumns: 1fr 6fr 4fr; }

#readerview .header-left-control { border-right: 1px solid rgb(211, 211, 21=
1); column-gap: 10px; display: flex; width: 15rem; }

#readerview .header-menu { align-self: center; margin-left: 0.5em; }

#readerview .header-menu > button { background: unset; border: unset; borde=
r-radius: unset; color: rgb(0, 0, 0); display: inline-block; line-height: u=
nset; padding: 0.5em; }

#readerview .header-menu > button:focus, #readerview .header-menu > button:=
