s=3D"hljs-number">0</span>:
            a_n =3D a_n
            b_n =3D m_n
        <span class=3D"hljs-keyword">elif</span> f(b_n)*f_m_n &lt; <span cl=
ass=3D"hljs-number">0</span>:
