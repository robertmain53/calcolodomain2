    &gt;&gt;&gt; bisection(f,1,2,25)
    1.618033990263939
    &gt;&gt;&gt; f =3D lambda x: (2*x - 1)*(x - 3)
    &gt;&gt;&gt; bisection(f,0,1,10)
    0.5
