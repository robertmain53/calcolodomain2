        <span class=3D"hljs-keyword">return</span> <span class=3D"hljs-lite=
ral">None</span>
    a_n =3D a
    b_n =3D b
    <span class=3D"hljs-keyword">for</span> n <span class=3D"hljs-keyword">=
in</span> range(<span class=3D"hljs-number">1</span>,N+<span class=3D"hljs-=
number">1</span>):
        m_n =3D (a_n + b_n)/<span class=3D"hljs-number">2</span>
        f_m_n =3D f(m_n)
