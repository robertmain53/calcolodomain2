        <span class=3D"hljs-keyword">else</span>:
            print(<span class=3D"hljs-string">"Bisection method fails."</sp=
an>)
            <span class=3D"hljs-keyword">return</span> <span class=3D"hljs-=
literal">None</span>
    <span class=3D"hljs-keyword">return</span> (a_n + b_n)/<span class=3D"h=
ljs-number">2</span>
