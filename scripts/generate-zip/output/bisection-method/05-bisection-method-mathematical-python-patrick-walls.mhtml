@charset "utf-8";

.hljs { display: block; overflow-x: auto; padding: 0.5em; background: white=
; color: black; }

.hljs-comment, .hljs-quote { color: rgb(136, 0, 0); }

.hljs-keyword, .hljs-selector-tag, .hljs-section, .hljs-title, .hljs-name {=
 color: rgb(0, 0, 136); }

.hljs-variable, .hljs-template-variable { color: rgb(102, 102, 0); }

.hljs-string, .hljs-selector-attr, .hljs-selector-pseudo, .hljs-regexp { co=
lor: rgb(0, 136, 0); }

.hljs-literal, .hljs-symbol, .hljs-bullet, .hljs-meta, .hljs-number, .hljs-=
link { color: rgb(0, 102, 102); }

.hljs-title, .hljs-doctag, .hljs-type, .hljs-attr, .hljs-built_in, .hljs-bu=
iltin-name, .hljs-params { color: rgb(102, 0, 102); }

.hljs-attribute, .hljs-subst { color: rgb(0, 0, 0); }

.hljs-formula { background-color: rgb(238, 238, 238); font-style: italic; }

.hljs-selector-id, .hljs-selector-class { color: rgb(155, 112, 63); }

.hljs-addition { background-color: rgb(186, 238, 186); }

.hljs-deletion { background-color: rgb(255, 200, 189); }

.hljs-doctag, .hljs-strong { font-weight: bold; }

.hljs-emphasis { font-style: italic; }
