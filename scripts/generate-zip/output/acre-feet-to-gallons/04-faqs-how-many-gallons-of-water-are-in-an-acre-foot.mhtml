@charset "utf-8";

.cp-Splash { background-color: rgb(255, 255, 255); box-shadow: rgba(0, 0, 0=
, 0.5) 0px 5px 10px; transition: opacity 240ms cubic-bezier(0.45, 0.45, 0.4=
5, 1); width: 20rem; display: none; }

.cp-Splash-body { padding: 0px 2rem; }

.cp-Splash-footer { padding: 1rem 2rem; }

.cp-Splash-header { color: rgb(51, 51, 51); padding: 1.25rem 4rem 1.25rem 2=
rem; }

.cp-Splash-title { font-size: 1.2rem; font-weight: 700; margin: 0px; overfl=
ow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.cp-Splash-close.cp-Splash-close.cp-Splash-close { background: none; border=
: 0px; height: 4rem; padding: 1rem; position: absolute; right: 0px; top: 0p=
x; color: rgb(51, 51, 51); }

.cp-Splash-close.cp-Splash-close.cp-Splash-close > svg { width: 2rem; heigh=
t: 2rem; }

.is-vHidden { border: 0px !important; clip: rect(0px, 0px, 0px, 0px) !impor=
tant; height: 1px !important; margin: -1px !important; overflow: hidden !im=
portant; padding: 0px !important; position: absolute !important; width: 1px=
 !important; }

.cp-Splash--modal .cp-Splash-body { max-height: calc(-141px + 70vh); overfl=
ow: auto; }

.cp-Splash--modal .cp-Splash-footer { text-align: right; }

.cp-Splash-Btn { border-width: 1px 1px 2px; border-style: solid; border-ima=
ge: initial; border-color: transparent; cursor: pointer; display: inline-bl=
ock; font-size: 13px; font-weight: 400; letter-spacing: 1px; line-height: 4=
1px; margin: 0px; padding: 0px 1.5rem; position: relative; text-align: cent=
er; text-transform: uppercase; transition: background 240ms cubic-bezier(0.=
45, 0.45, 0.45, 1), border-color 240ms cubic-bezier(0.45, 0.45, 0.45, 1), c=
olor 240ms cubic-bezier(0.45, 0.45, 0.45, 1), opacity 240ms cubic-bezier(0.=
45, 0.45, 0.45, 1); vertical-align: middle; white-space: nowrap; user-selec=
t: none; }

.cp-Splash-Btn { background-color: rgb(227, 227, 227); border-bottom-color:=
 rgb(194, 194, 194); }

.cp-Splash-Btn:focus, .cp-Splash-Btn:hover { background-color: rgb(232, 232=
, 232); border-bottom-color: rgb(204, 204, 204); }

.cp-Splash-Btn:active { background-color: rgb(194, 194, 194); border-bottom=
-color: rgb(194, 194, 194); }

.cp-Splash--modal:focus { outline: 0px; }

.cp-Splash-wrapper { justify-content: center; align-items: center; position=
: fixed; inset: 0px; z-index: 1000000; display: none; background-color: rgb=
a(0, 0, 0, 0.5); }

@media (min-width: 32em) {
  .cp-Splash--modal { min-width: 32rem; max-width: 60rem; width: 75%; displ=
ay: none; position: relative; }
}

@media (max-width: 31.999em) {
  .cp-Splash { box-shadow: rgba(0, 0, 0, 0.5) 0px 5px 10px; max-height: 90v=
h; width: 94%; position: relative; }
  .cp-Splash-body { overflow: auto; max-height: 50vh !important; }
  .cp-Splash--modal .cp-Splash-footer { text-align: center; }
  .cp-Splash-Btn--NoShow, .cp-Splash-Btn--Close { display: block; margin: 8=
px 0px; width: 100%; }
}

.newCP .splashProps label.check { line-height: 1.5; }

#splashModalChoices { margin-bottom: 1rem; }

.splashDisplayEndDate { margin-top: 1rem; }
