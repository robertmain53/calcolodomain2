#loader-box::after, .loader { opacity: 0.7; position: absolute; }

.loader circle { animation: 2s ease-in-out 0s infinite normal none running =
draw; transform: rotate(-90deg); transform-origin: 75px 75px; }

.loader-2 circle, .loader-6 circle { animation-delay: 0.5s; }

.loader-7 circle { animation-delay: 1s; }

.loader-4 circle, .loader-8 circle { animation-delay: 1.5s; }

.loader-3 { left: -150px; transform: rotateY(180deg); }

.loader-6, .loader-7, .loader-8 { left: -150px; transform: rotateX(180deg) =
rotateY(180deg); }

.loader-5 circle { opacity: 0.2; }

@keyframes draw {=20
  50% { stroke-dashoffset: 0; transform: scale(0.5); }
}
