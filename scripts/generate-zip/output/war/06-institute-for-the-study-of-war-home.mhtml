.tooltipster-slide.tooltipster-initial { left: -40px !important; }

.tooltipster-slide.tooltipster-dying { transition-property: all; opacity: 0=
; left: 0px !important; }

@keyframes tooltipster-fading {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.tooltipster-update-fade { animation: 0.4s ease 0s 1 normal none running to=
oltipster-fading; }

@keyframes tooltipster-rotating {=20
