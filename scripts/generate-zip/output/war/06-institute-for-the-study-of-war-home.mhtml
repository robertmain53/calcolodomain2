  75% { transform: rotate(2deg); }
  100% { transform: rotate(0deg); }
}

.tooltipster-update-rotate { animation: 0.6s ease 0s 1 normal none running =
tooltipster-rotating; }

@keyframes tooltipster-scaling {=20
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.tooltipster-update-scale { animation: 0.6s ease 0s 1 normal none running t=
ooltipster-scaling; }

