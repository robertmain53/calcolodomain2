        <mo>=E2=81=A1<!-- =E2=81=A1 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mtext>likelihood of the fitted model</mtext>
            <mtext>likelihood of the saturated model</mtext>
