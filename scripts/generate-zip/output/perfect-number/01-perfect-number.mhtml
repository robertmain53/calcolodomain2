        <mo>=3D</mo>
        <mn>2</mn>
        <mi>n</mi>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \sigma _{1}(n=
)=3D2n}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/8bce2fc4e5094e627bb338b6ab9479702a8de3e4" class=3D"mwe-math-fallback=
