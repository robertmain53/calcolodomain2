-align: -0.338ex; width:8.72ex; height:2.176ex;" alt=3D"{\displaystyle \alp=
ha =3D0.05}"></span> means one only rejects the null hypothesis if the <i>p=
</i>-value is less than or equal to <span class=3D"mwe-math-element mwe-mat=
h-element-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11=
y" style=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/Math=
ML" alttext=3D"{\displaystyle 0.05}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mn>0.05</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle 0.05}</annota=
tion>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/54a85a0defd4a4dd078acd9e7362dd04d3772d5a" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.338ex; width:4.134ex; height:2.176ex;" alt=3D"{\displaystyle 0.0=
5}"></span>, and the hypothesis test will indeed have a <i>maximum</i> type=
-1 error rate of <span class=3D"mwe-math-element mwe-math-element-inline"><=
span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display=
: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\di=
splaystyle 0.05}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mn>0.05</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle 0.05}</annota=
tion>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/54a85a0defd4a4dd078acd9e7362dd04d3772d5a" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.338ex; width:4.134ex; height:2.176ex;" alt=3D"{\displaystyle 0.0=
