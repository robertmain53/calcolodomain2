                    </mrow>
                    <mrow>
                      <mn>1</mn>
                      <mspace width=3D"thinmathspace"></mspace>
                      <mn>048</mn>
                      <mspace width=3D"thinmathspace"></mspace>
                      <mn>576</mn>
                    </mrow>
                  </mfrac>
                </mrow>
                <mo>=E2=89=88<!-- =E2=89=88 --></mo>
