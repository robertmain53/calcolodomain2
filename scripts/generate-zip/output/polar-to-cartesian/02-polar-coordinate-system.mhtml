splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle \left[r(\varphi _{i})\right]^{2}\pi \cdot {\frac {\Delta \varph=
i }{2\pi }}=3D{\frac {1}{2}}\left[r(\varphi _{i})\right]^{2}\Delta \varphi =
.}">
