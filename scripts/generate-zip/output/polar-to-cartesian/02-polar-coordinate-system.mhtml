                  <mo stretchy=3D"false">(</mo>
                  <mi>=CF=86<!-- =CF=86 --></mi>
                  <mo stretchy=3D"false">)</mo>
                </mrow>
                <mo>]</mo>
              </mrow>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>2</mn>
              </mrow>
            </msup>
            <mo>+</mo>
            <msup>
              <mrow>
