            </msup>
            <mo>]</mo>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>i</mi>
            <mi>j</mi>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <msub>
          <mrow>
            <mo>[</mo>
            <mrow class=3D"MJX-TeXAtom-ORD">
              <mi mathvariant=3D"bold">A</mi>
            </mrow>
            <mo>]</mo>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>j</mi>
            <mi>i</mi>
          </mrow>
        </msub>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \left[\mathbf=
 {A} ^{\text{T}}\right]_{ij}=3D\left[\mathbf {A} \right]_{ji}.}</annotation=
>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
