        <td class=3D"detl">4</td>
        <td class=3D"detr">3</td>
        </tr>
      <tr>
        <td class=3D"detl">2</td>
        <td class=3D"detr">2</td>
        </tr>
    </tbody></table>
      <br>      =3D 8 - 6 =3D 2</td>
    <td class=3D"lhs"><table border=3D"0" cellspacing=3D"0" cellpadding=3D"=
1">
      <tbody><tr>
        <td class=3D"detl">4</td>
