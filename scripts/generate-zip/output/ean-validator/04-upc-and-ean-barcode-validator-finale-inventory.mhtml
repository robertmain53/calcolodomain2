 flex; flex-direction: column; flex: 1 1 0%; justify-content: center; align=
-items: center; }

.bpErrorIcon { color: var(--error-content-icon); stroke-width: 1.25; width:=
 5rem; height: 5rem; }

.bpErrorTitle { color: var(--error-content-title); padding: var(--bpSpacing=
-2); font-weight: 600; font-size: 1.25rem; }

.bpErrorMessage { line-height: 1.5; color: var(--error-content-message); ma=
rgin-bottom: var(--bpSpacing-2); white-space: pre-line; }

.bpErrorId { color: var(--bpGray-200); font-size: 0.75rem; }

@keyframes fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes fadeOut {=20
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes fadeInScaleUp {=20
  0% { opacity: 0; transform: scale(0.8); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes slideUp {=20
  0% { transform: translateY(100%); }
  100% { transform: translateY(0px); }
}

@keyframes slideDown {=20
  0% { transform: translateY(0px); }
  100% { transform: translateY(100%); }
}

@keyframes fadeInSlideUp {=20
  0% { transform: translateY(20%); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes fadeInFromRight {=20
  0% { opacity: 0; transform: translate(10px); }
  100% { opacity: 1; transform: translate(0px); }
}

@keyframes pulsate-background {=20
  0%, 100% { background-color: var(--bpPrimary-100); color: var(--bpGray-60=
0); }
  50% { background-color: var(--bpPrimary-400); color: var(--bpGray-800); }
}
