@charset "utf-8";

.password-wrap { }

#password_input { width: 430px; }

.password-field { display: flex; }

.password_progress { display: flex; flex-flow: row; gap: 10px; margin-top: =
40px; }

#password_eye { width: 44px; height: 44px; padding: 10px; position: relativ=
e; left: -47px; top: 2px; }

.score { height: 8px; width: 100px; border-radius: 10px; position: relative=
; }

.score-text { font-size: 13px; padding: 0px 5px; position: absolute; top: -=
20px; right: 0px; left: 0px; }

.password_progress { margin-bottom: 20px; }

.password_statuses { font-size: 15px; display: flex; flex-flow: wrap; gap: =
8px 20px; }

.display-none { display: none; }

.score-off { background-color: gray; }

#score1.score-on { background-color: red; }

#score2.score-on { background-color: orange; }

#score3.score-on { background-color: darkseagreen; }

#score4.score-on { background-color: green; }

.inside-article .google-auto-placed { margin-bottom: 20px; }

.status-on { color: green; }

.status-off { color: red; }

.inside-footer-widgets h2 { color: rgb(216, 216, 216); font-size: 20px; fon=
t-weight: 400; }

.entry-content { margin-top: 10px !important; }

.site-header { position: absolute; right: 0px; }

.code-section textarea { resize: vertical; min-height: 100px; max-height: 1=
00vh; }

.code-section table { width: 100%; border-collapse: collapse; border: none;=
 }

.code-section table td { border: none; width: 50%; text-align: left; }

:root { --code-color-main: rgba(0,63,159,1); --code-color-light: rgba(66,13=
4,244,0.1); --code-color-warn: rgba(255, 121, 0, 0.25); }

.inside-article .code-section, .inside-article .instructions-section, .insi=
de-article .warning-section { padding: 20px; }

.inside-article .code-section, .inside-article .instructions-section { back=
ground-color: var(--code-color-light); }

.inside-article .warning-section { background-color: var(--code-color-warn)=
; }

.inside-article .adsbygoogle { margin-bottom: 16px; }

.inside-article .code-section textarea { height: 200px; font-family: courie=
r, consolas, monospace; line-height: 1.1; margin-bottom: 10px; }

.code-section p { font-size: 14px; margin-bottom: 4px; }

.code-section h2 { margin-bottom: 10px; }

.code-section .wp-element-button { border-radius: 4px; border: 1px solid rg=
b(204, 204, 204); font-size: 14px; color: rgb(85, 85, 85) !important; }

.code-section .wp-element-button:active { border-color: red; }

.wp-block-group__inner-container { margin: 0px; padding: 0px !important; }

.wp-block-group__inner-container > :last-child { margin-bottom: 0px !import=
ant; }

.inside-footer-widgets a { position: relative; left: 24px; }

.inside-footer-widgets a .fa { position: absolute; left: -24px; }

.content-area .site-main { margin-top: 0px; }

.content-area .site-main .inside-article { padding-top: 20px; }

#mobile-header { border-bottom: 1px solid rgb(237, 237, 237); }

@media (min-width: 769px) {
  #site-navigation.has-branding.main-navigation { border-bottom: 1px solid =
rgb(237, 237, 237); }
  #site-navigation.has-branding.main-navigation .main-nav .menu-item a, .ma=
in-navigation.sticky-navigation-transition .main-nav > ul > li > a { font-s=
ize: 18px; }
}

@media (max-width: 768px) {
  .content-area .site-main { margin-top: 0px; }
  .content-area .site-main .inside-article { padding-top: 10px; }
  .inside-article .code-section, .inside-article .warning-section, .inside-=
article .instructions-section { margin-left: -30px; margin-right: -30px; }
  .inside-article ul { margin-left: 20px; }
}
