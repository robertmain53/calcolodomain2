.popup .content { margin: 20px 0px; }

.popup .icons { margin: 15px 0px 20px; }

.content p { font-size: 16px; }

.content .icons a { height: 50px; width: 50px; font-size: 20px; text-decora=
tion: none; border: 1px solid transparent; }

.icons a i { transition: transform 0.3s ease-in-out; }

.icons a:nth-child(1) { color: rgb(255, 69, 0); border-color: rgb(255, 216,=
 178); }

.icons a:nth-child(1):hover { background: rgb(255, 69, 0); }

.icons a:nth-child(2) { color: rgb(28, 114, 232); border-color: rgb(164, 20=
0, 248); }

.icons a:nth-child(2):hover { background: rgb(28, 114, 232); }

.icons a:nth-child(3) { color: rgb(37, 211, 102); border-color: rgb(165, 24=
3, 176); }

.icons a:nth-child(3):hover { background: rgb(37, 211, 102); }

.icons a:nth-child(4) { color: rgb(228, 64, 95); border-color: rgb(248, 192=
, 201); }

.icons a:nth-child(4):hover { background: rgb(228, 64, 95); }

#bluesky:hover { transform: scale(1.2); }

.icons a:hover { color: rgb(255, 255, 255); border-color: transparent; }

.icons a:hover svg { transform: scale(1.2); }

.content .field { margin: 12px 0px -5px; height: 45px; border-radius: 4px; =
padding: 0px 5px; border: 1px solid rgb(117, 113, 113); }

.field.active { border-color: rgb(51, 78, 172); }

.field i, .field svg { width: 50px; font-size: 18px; text-align: center; }

.field.active i, .field.active svg { color: rgb(51, 78, 172); }

.field input { width: 100%; height: 100%; border: none; outline: none; font=
-size: 15px; margin: 0px; padding: 0px; background-color: rgb(255, 254, 255=
); }

.field button { color: rgb(255, 255, 255); padding: 10px; margin: 10px; bac=
kground: rgb(253, 85, 35); border: none; }

.field button:hover { background: rgb(253, 85, 35); }

#navToggle { display: flex; align-items: center; gap: 10px; }

#navToggle a { text-decoration: none; font-weight: bold; transition: color =
0.3s ease-in-out; }

#navToggle h1 { font-size: 1.5rem; margin: 0px; text-decoration: none; }

.toggle-divider { font-size: 0.5rem; color: rgb(31, 28, 28); }

#notionFAQ { border-bottom: 2px solid rgb(31, 28, 28); padding: 20px; }
