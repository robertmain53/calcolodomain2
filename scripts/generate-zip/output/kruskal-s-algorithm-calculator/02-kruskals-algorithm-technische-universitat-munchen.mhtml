WHILE queue =E2=89=A0 =E2=88=85 AND trees-count &gt; 1 DO</p></div>
                            <div><p class=3D"pseudocode" id=3D"tf1_p_l7">  =
  {u, v} =E2=86=90 queue.extractMin()</p></div>
                            <div><p class=3D"pseudocode" id=3D"tf1_p_l8">  =
  IF !(T =E2=88=AA {{u, v}} has cycle)</p>
                            <p class=3D"pseudocode" id=3D"tf1_p_l9">      T=
.add({u, v})</p>
                            <p class=3D"pseudocode" id=3D"tf1_p_l10">      =
merge(tree-of(u), tree-of(v))</p></div>
                            <div><p class=3D"pseudocode" id=3D"tf1_l11">END=
</p></div>
                        </div>
                    </div>
                </div>
            </div>
