ut[type=3D"email"], input[type=3D"search"], textarea { cursor: var(--f-curs=
or-text); }
  a, a *, button:not(.tooltip-btn), button:not(.tooltip-btn) *, select, inp=
ut[type=3D"checkbox"] { cursor: var(--f-cursor-pointer); }
  button[aria-disabled=3D"true"] { pointer-events: none; }
}

:target { scroll-margin-block-start: 20px; }

img, svg, video { display: block; max-width: 100%; }

h1, h2, h3, h4, h5, h6 { margin: 0px; }

iframe { border: 0px; }

a { text-decoration-thickness: 1px; color: inherit; text-underline-offset: =
0.25em; }

a:focus-visible, button:focus-visible { outline: var(--f-text-color, #00000=
0) dashed 2px; outline-offset: 4px; }

