ckground: rgb(255, 255, 255); border: 1px solid rgb(204, 204, 204); box-sha=
dow: rgba(0, 0, 0, 0.1) 0px 0px 2px 0px, rgba(0, 0, 0, 0.1) 1px 1px 1px 0px=
; padding: 0.5em 1em 0.5em 2em; position: relative; border-radius: 2px; cur=
sor: pointer; transition: 0.2s; }

