"></span><span class=3D"mord">1</span></span></span></span></code>).
</p>
<p>The quantile is defined as the smallest value <code class=3D"reqn"><span=
 class=3D"katex"><span class=3D"katex-mathml"><math xmlns=3D"http://www.w3.=
org/1998/Math/MathML"><semantics><mrow><mi>x</mi></mrow><annotation encodin=
g=3D"application/x-tex">x</annotation></semantics></math></span><span class=
=3D"katex-html" aria-hidden=3D"true"><span class=3D"base"><span class=3D"st=
rut" style=3D"height: 0.4306em;"></span><span class=3D"mord mathnormal">x</=
span></span></span></span></code> such that
<code class=3D"reqn"><span class=3D"katex"><span class=3D"katex-mathml"><ma=
th xmlns=3D"http://www.w3.org/1998/Math/MathML"><semantics><mrow><mi>F</mi>=
<mo stretchy=3D"false">(</mo><mi>x</mi><mo stretchy=3D"false">)</mo><mo>=E2=
=89=A5</mo><mi>p</mi></mrow><annotation encoding=3D"application/x-tex">F(x)=
 \ge p</annotation></semantics></math></span><span class=3D"katex-html" ari=
a-hidden=3D"true"><span class=3D"base"><span class=3D"strut" style=3D"heigh=
t: 1em; vertical-align: -0.25em;"></span><span class=3D"mord mathnormal" st=
yle=3D"margin-right: 0.1389em;">F</span><span class=3D"mopen">(</span><span=
 class=3D"mord mathnormal">x</span><span class=3D"mclose">)</span><span cla=
ss=3D"mspace" style=3D"margin-right: 0.2778em;"></span><span class=3D"mrel"=
>=E2=89=A5</span><span class=3D"mspace" style=3D"margin-right: 0.2778em;"><=
/span></span><span class=3D"base"><span class=3D"strut" style=3D"height: 0.=
625em; vertical-align: -0.1944em;"></span><span class=3D"mord mathnormal">p=
</span></span></span></span></code>, where <code class=3D"reqn"><span class=
=3D"katex"><span class=3D"katex-mathml"><math xmlns=3D"http://www.w3.org/19=
98/Math/MathML"><semantics><mrow><mi>F</mi></mrow><annotation encoding=3D"a=
pplication/x-tex">F</annotation></semantics></math></span><span class=3D"ka=
