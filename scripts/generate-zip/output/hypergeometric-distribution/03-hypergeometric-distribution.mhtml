2.047em" maxsize=3D"2.047em">)</mo></mrow></mrow></math></mjx-assistive-mml=
></mjx-container>
                    </div>
                    <div style=3D"margin:auto 2rem;">or</div>
                    <div style=3D"display:flex; flex-direction:column; just=
ify-content:center;">
                        <span><sub>n</sub>C<sub>r</sub></span>
                    </div>
                </div>
                <p>
                    This is read as "n choose r." And the formula for a com=
bination is:
                </p>
                <div style=3D"display:flex;justify-content:center; margin:-=
1rem; auto;">
                    <div style=3D"font-size:.9rem; color:#555555;">
