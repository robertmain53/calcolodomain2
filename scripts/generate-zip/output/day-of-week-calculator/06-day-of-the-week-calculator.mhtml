footer { clear: both; width: 100%; font-size: 11px; }

#topadsensenottools { display: none; }

#columnadsense { display: none; }

#topad { display: block; margin: 0px 0px 30px; }

#main_nav { position: relative; margin: 10px 0px; }

#main_nav ul { margin: 0px; padding: 0px; }

#main_nav ul li { display: inline-block; list-style-type: none; margin: 0px=
 15px 10px; padding: 0px; }

#main_nav ul li a:hover { color: rgb(51, 51, 51); }

#main_nav ul li.current a { color: rgb(51, 51, 51); border-radius: 5px; }

@media screen and (max-width: 650px) {
  #header { height: auto; }
  #page_content { width: auto; float: none; margin: 20px 0px; }
  #sidebar { width: 100%; float: none; margin: 0px; }
  #main_nav { position: relative; min-height: 10px; }
  #main_nav ul { background: rgb(255, 255, 255); border: 1px solid rgb(221,=
 221, 221); padding: 5px 0px; position: absolute; width: 60%; }
  #main_nav ul li { display: none; margin: 0px; }
  #main_nav ul li.current { display: block; color: rgb(51, 51, 51); }
  #main_nav ul li a, #main_nav ul li.current a { background: 0px center; di=
splay: block; padding: 2px; }
  #main_nav ul li.current a { color: rgb(51, 51, 51); }
  #main_nav ul:hover li { display: block; }
  img { width: 90%; }
  #topad { display: none; margin: 0px; }
  #topadname { display: none; margin: 0px; }
  #topadusasearch { display: none; margin: 0px; }
  #topadsensenottools { display: block; margin: 0px auto; width: 90%; }
  #columnad { display: none; margin: 0px; }
  #columnadsense { display: block; margin: 0px auto; width: 90%; }
}
