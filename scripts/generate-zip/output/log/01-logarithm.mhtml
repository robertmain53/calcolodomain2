    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle 2^{3}=3D8.}</=
annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/2c3f620a5eabedc8d4791da4f800c50e570212a4" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
