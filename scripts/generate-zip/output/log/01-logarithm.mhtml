        <mo stretchy=3D"false">)</mo>
        <mo>+</mo>
        <mi>f</mi>
        <mo stretchy=3D"false">(</mo>
        <mi>y</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle f(xy)=3Df(x)+=
f(y).}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
