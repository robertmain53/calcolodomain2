@charset "utf-8";

.footer-links { font-family: "Source Sans Pro", sans-serif; text-align: cen=
ter; position: relative; margin: 4rem 3% 3.5rem; }

.footer-links .inner { padding: 0px; }

.footer-links .box { padding: 0px 0px 1.2rem; background: rgb(249, 249, 249=
); border: 1px solid rgb(222, 222, 222); color: rgb(153, 153, 153); margin:=
 0px auto; }

.footer-links a { font-size: 0.876rem; margin: 0px 0.7rem; opacity: 0.8; co=
lor: rgb(68, 68, 68); }

.footer-links a:hover { opacity: 1; }

.footer-links .footer-main-links { padding: 1rem 0px; }

.footer-links .footer-main-links a { font-size: 1rem; margin: 1rem 0.5rem; =
}

.footer-links a::before { opacity: 0.8; }

.footer-links a:hover::before { opacity: 1; }

.footer-links .divider { color: rgb(119, 119, 119); font-weight: 300; opaci=
ty: 0.8; }

.nowrap { white-space: nowrap; display: inline-block; }

a.toplink.above-footer { opacity: 0; transition: 0.3s ease-out; }

a.toplink { display: none; color: rgb(204, 204, 204); position: fixed; text=
-align: center; width: 25px; right: 3%; bottom: 3%; font-size: 1.07rem; lin=
e-height: 1; z-index: 10; }

a.toplink::before { position: relative; top: -5px; z-index: 10; }

a.toplink::after { content: ""; display: block; width: 25px; height: 25px; =
background: rgb(203, 203, 203); border-radius: 3px; top: -10px; position: a=
bsolute; }

a.toplink:hover::after { background: rgb(247, 119, 0); }

a.toplink .top { white-space: nowrap; display: inline-block; }

section.modified-wrapper { margin: 0px; }

.modified-wrapper .inner { padding: 0px; border-top: 1px solid rgb(202, 202=
, 202); margin: 0px auto; }

.modified { color: rgb(51, 51, 51); font-style: italic; font-size: 12px; po=
sition: absolute; margin: 0.5rem 13rem 0px 0px; }

.modified .inner { padding: 0px; }

.history-version { display: inline; color: rgb(139, 139, 139); margin: 0px =
0px 0px 1px; }

.history-delimiter { color: rgb(164, 164, 164); display: inline-block; marg=
in: 0px 4.3px; }

.history-delimiter ~ .history-version::after { content: ""; width: 4px; hei=
ght: 4px; border-radius: 4px; display: inline-block; background: rgb(164, 1=
64, 164); vertical-align: middle; margin: 0px 5.1px 1px; }

.history-delimiter ~ .history-version:last-of-type::after { display: none; =
}

.feedback-content { border-top: 1px solid rgb(202, 202, 202); margin: 0px a=
uto; }

.modified-wrapper + .feedback-wrapper .feedback-content { border: 0px; marg=
in: 0px; }

section.feedback-wrapper { margin: 0px; }

.feedback-wrapper .inner { margin: 0px auto; }

.feedback { background: transparent; border: 0px; float: right; font-size: =
1rem; color: rgb(139, 139, 139); margin: 0.5rem 4rem 0px; position: relativ=
e; z-index: 10; }

.feedback:hover { color: rgb(247, 119, 0); }

#feedback { display: none; top: 1rem; position: relative; }

.feedback-form.opened { display: block; }

.feedback-form .text { margin: 0px 0px 0.3rem; display: block; }

