.zp-button:focus, form .zp-button:hover { background-color: rgb(51, 153, 51=
); }

#zp-submit-wrap { margin-top: 32px; }

#zp-fetch-birthreport { margin: 3px 0px 36px; width: 100%; cursor: pointer;=
 }

