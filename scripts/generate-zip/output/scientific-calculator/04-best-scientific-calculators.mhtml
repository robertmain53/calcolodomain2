inline-block; }

.rufus-panel-container[data-state=3D"minimized"] .rufus-overflow-menu-conta=
iner { bottom: calc(var(--overflow-menu-top)); top: auto; }

.rufus-FAQs-ingress-button { font-size: 14px; font-weight: 400; line-height=
: 20px; display: flex; position: relative; width: 100%; border: none; text-=
align: left; padding: 6px 12px; cursor: pointer; background-color: rgb(255,=
 255, 255); }

.rufus-FAQs-ingress-button:hover { background-color: rgb(213, 217, 217); }

.rufus-FAQs-ingress-button:active { background-color: rgb(237, 253, 255); }

a.rufus-FAQs-ingress-button { color: rgb(0, 0, 0); text-decoration: none; }

.rufus-panel-closed-to-expanded { animation: 0.5s ease-in-out 0s 1 normal n=
one running expandPanel; }

.rufus-panel-expanded-to-closed { animation: 0.5s ease-in-out 0s 1 normal n=
one running closePanel; }

.rufus-panel-expanded-to-closed-movable { animation: 0.5s ease-in-out 0s 1 =
normal none running closePanelMovable; }

.rufus-panel-closed-to-expanded-movable { animation: 0.5s ease-in-out 0s 1 =
normal none running openPanelMovable; }

.rufus-panel-expanded-to-closed-movable-right-ingress { animation: 0.5s eas=
e-in-out 0s 1 normal none running closePanelMovableRightIngress; }

.rufus-panel-closed-to-expanded-movable-right-ingress { animation: 0.5s eas=
e-in-out 0s 1 normal none running openPanelMovableRightIngress; }

.rufus-panel-minimized-to-expanded { animation: 0.8s ease-in-out 0s 1 norma=
l none running bounceUp; transform-origin: left bottom; }

.rufus-panel-expanded-to-minimized { animation: 0.8s ease-in-out 0s 1 norma=
l none running bounceDown; transform-origin: left bottom; }

.rufus-panel-minimized-to-expanded-movable { animation: 0.5s ease-in-out 0s=
 1 normal none running bounceUpMovable; transform-origin: left bottom; }

.rufus-panel-expanded-to-minimized-movable { animation: 0.5s ease-in-out 0s=
 1 normal none running bounceDownMovable; transform-origin: left bottom; }

@keyframes bounceUp {=20
  0%, 100% { transform: scale(1); }
  30% { transform: scale(1.02); }
}

@keyframes bounceDown {=20
  0%, 100% { transform: scale(1); }
  30% { transform: scale(0.98); }
}

@keyframes bounceDownMovable {=20
  0% { transform: scale(1); bottom: var(--expanded-container-bottom); left:=
 var(--expanded-container-left); }
  30% { transform: scale(0.98); }
  100% { transform: scale(1); bottom: 0px; left: 0px; }
}

@keyframes bounceUpMovable {=20
  0% { transform: scale(1); bottom: 0px; left: 0px; }
  30% { transform: scale(1.02); }
  100% { transform: scale(1); bottom: var(--expanded-container-bottom); lef=
t: var(--expanded-container-left); }
}

@keyframes closePanel {=20
  0% { transform: translateY(0px); opacity: 1; }
  100% { transform: translateY(-200vh); opacity: 0; }
}

@keyframes expandPanel {=20
  0% { transform: translateY(-100%); opacity: 0; }
  70% { transform: translateY(1%); opacity: 0.8; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes closePanelMovable {=20
  0% { bottom: var(--expanded-container-bottom); left: var(--expanded-conta=
iner-left); opacity: 1; }
  100% { bottom: 100vh; left: 0px; opacity: 0; }
}

@keyframes openPanelMovable {=20
  0% { bottom: 100vh; left: 0px; opacity: 0; }
  100% { bottom: var(--expanded-container-bottom); left: var(--expanded-con=
tainer-left); opacity: 1; }
}

