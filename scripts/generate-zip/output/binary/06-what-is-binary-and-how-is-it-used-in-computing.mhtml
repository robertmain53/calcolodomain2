   </tr>=20
   <tr>=20
    <td style=3D"width: .75in;"> <p><b>Binary-to-decimal calculation (expon=
ent)</b></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>0</sup></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>1</sup></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>2</sup></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>3</sup></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>4</sup></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>5</sup></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>6</sup></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>2<sup>7</sup></p> </td>=20
   </tr>=20
   <tr>=20
    <td style=3D"width: .75in;"> <p><b>Decimal value (x2)</b></p> </td>=20
    <td style=3D"width: 48.0pt;"> <p>1</p> </td>=20
