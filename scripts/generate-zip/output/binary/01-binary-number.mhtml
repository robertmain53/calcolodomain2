<tr>
<td><b>0</b> =C3=97 2<sup>=E2=88=921</sup></td>
<td>(0 =C3=97 <span class=3D"frac"><span class=3D"num">1</span>=E2=81=84<sp=
an class=3D"den">2</span></span> =3D <b>0</b>)</td>
<td>plus
</td></tr>
<tr>
<td><b>1</b> =C3=97 2<sup>=E2=88=922</sup></td>
<td>(1 =C3=97 <link rel=3D"mw-deduplicated-inline-style" href=3D"mw-data:Te=
