<td>=C3=97 2 +</td>
<td><b>1</b></td>
<td>=3D 9
</td></tr>
<tr>
<td align=3D"right">9</td>
<td>=C3=97 2 +</td>
<td><b>0</b></td>
<td>=3D 18
</td></tr>
<tr>
<td align=3D"right">18</td>
<td>=C3=97 2 +</td>
<td><b>1</b></td>
<td>=3D 37
</td></tr>
<tr>
<td align=3D"right">37</td>
<td>=C3=97 2 +</td>
<td><b>0</b></td>
<td>=3D 74
</td></tr>
<tr>
<td align=3D"right">74</td>
<td>=C3=97 2 +</td>
<td><b>1</b></td>
<td>=3D 149
</td></tr>
<tr>
