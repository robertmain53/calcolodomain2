          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>x</mi>
          </mrow>
        </msub>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \partial _{x}=
}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/57563dabdda89ee216b5a897bf9f78f5c7030eb6" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.671ex; width:2.407ex; height:2.509ex;" alt=3D"{\displaystyle \pa=
