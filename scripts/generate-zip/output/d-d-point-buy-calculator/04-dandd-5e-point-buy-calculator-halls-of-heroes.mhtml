        <title>D&amp;D 5e Point-Buy Calculator</title>
        <meta name=3D"description" content=3D"A point-buy calculator for Du=
ngeons and Dragons 5th Edition">
        <meta name=3D"viewport" content=3D"width=3Ddevice-width, initial-sc=
ale=3D1">
        <link rel=3D"stylesheet" href=3D"https://hallsofheroes.com/pointbuy=
/pointbuy.css">
   =20
    </head>
    <body>
	<div id=3D"contentwrapper">
	<div id=3D"content">
        <h2>Attribute Point-Buy Calculator</h2>
        <form id=3D"form-point-buy-calc">
			<div id=3D"race">
				<label>Ancestry Type:</label>
				<select id=3D"race_dropdown">
					<option value=3D"flex">Flex (+1,+2 or +1x3)</option>
                    <option value=3D"dwarfMountain">Dwarf, Mountain (+2,+2)=
</option>
                    <option value=3D"halfElf">Half-Elf (+1,+1,+2)</option>
                    <option value=3D"human">Human (+1 all)</option>
					<option value=3D"humanVariant">Human, Variant (+1,+1)</option>
					<option value=3D"triton">Triton (+1,+1,+1)</option>
					<option value=3D"other">Other (+1,+2)</option>
				</select>
			</div>

			<table id=3D"pointbuy">
				<tbody><tr class=3D"attribute-headers">
					<th></th>
					<th>Base</th>
					<th></th>
					<th class=3D"operator"></th>
					<th>Final<br>Score</th>
					<th></th>
					<th>Mod</th>
					<th></th>
					<th>Cost</th>
				</tr>
				<tr id=3D"str" class=3D"attribute-row">
					<th>STR</th>
					<td class=3D"stat_base">
					<span id=3D"base_str" class=3D"base">8</span>
					<button id=3D"up_str" class=3D"upper changer"></button>
					<button id=3D"down_str" class=3D"downer changer"></button>
					</td>
					<td class=3D"bonuses">
					<button id=3D"one_str" class=3D"bonus one"></button>
					<button id=3D"two_str" class=3D"bonus two"></button>
					</td>
					<td class=3D"operator">=3D</td>
					<td class=3D"stat_total"><span id=3D"total_str">8</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"modifier_str">-1</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"cost_str" class=3D"cost_span"></span></td>
				</tr>
				<tr id=3D"dex" class=3D"attribute-row">
					<th>DEX</th>
					<td class=3D"stat_base">
					<span id=3D"base_dex" class=3D"base">8</span>
					<button id=3D"up_dex" class=3D"upper changer"></button>
					<button id=3D"down_dex" class=3D"downer changer"></button>
					</td>
					<td class=3D"bonuses">
					<button id=3D"one_dex" class=3D"bonus one"></button>
					<button id=3D"two_dex" class=3D"bonus two"></button>
					</td>
					<td class=3D"operator">=3D</td>
					<td class=3D"stat_total"><span id=3D"total_dex">8</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"modifier_dex">-1</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"cost_dex" class=3D"cost_span"></span></td>
				</tr>
				<tr id=3D"con" class=3D"attribute-row">
					<th>CON</th>
					<td class=3D"stat_base">
					<span id=3D"base_con" class=3D"base">8</span>
					<button id=3D"up_con" class=3D"upper changer"></button>
					<button id=3D"down_con" class=3D"downer changer"></button>
					</td>
					<td class=3D"bonuses">
					<button id=3D"one_con" class=3D"bonus one"></button>
					<button id=3D"two_con" class=3D"bonus two"></button>
					</td>
					<td class=3D"operator">=3D</td>
					<td class=3D"stat_total"><span id=3D"total_con">8</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"modifier_con">-1</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"cost_con" class=3D"cost_span"></span></td>
				</tr>
				<tr id=3D"int" class=3D"attribute-row">
					<th>INT</th>
					<td class=3D"stat_base">
					<span id=3D"base_int" class=3D"base">8</span>
					<button id=3D"up_int" class=3D"upper changer"></button>
					<button id=3D"down_int" class=3D"downer changer"></button>
					</td>
					<td class=3D"bonuses">
					<button id=3D"one_int" class=3D"bonus one"></button>
					<button id=3D"two_int" class=3D"bonus two"></button>
					</td>
					<td class=3D"operator">=3D</td>
					<td class=3D"stat_total"><span id=3D"total_int">8</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"modifier_int">-1</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"cost_int" class=3D"cost_span"></span></td>
				</tr>
				<tr id=3D"wis" class=3D"attribute-row">
					<th>WIS</th>
					<td class=3D"stat_base">
					<span id=3D"base_wis" class=3D"base">8</span>
					<button id=3D"up_wis" class=3D"upper changer"></button>
					<button id=3D"down_wis" class=3D"downer changer"></button>
					</td>
					<td class=3D"bonuses">
					<button id=3D"one_wis" class=3D"bonus one"></button>
					<button id=3D"two_wis" class=3D"bonus two"></button>
					</td>
					<td class=3D"operator">=3D</td>
					<td class=3D"stat_total"><span id=3D"total_wis">8</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"modifier_wis">-1</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"cost_wis" class=3D"cost_span"></span></td>
				</tr>
				<tr id=3D"cha" class=3D"attribute-row">
					<th>CHA</th>
					<td class=3D"stat_base">
					<span id=3D"base_cha" class=3D"base">8</span>
					<button id=3D"up_cha" class=3D"upper changer"></button>
					<button id=3D"down_cha" class=3D"downer changer"></button>
					</td>
					<td class=3D"bonuses">
					<button id=3D"one_cha" class=3D"bonus one"></button>
					<button id=3D"two_cha" class=3D"bonus two"></button>
					</td>
					<td class=3D"operator">=3D</td>
					<td class=3D"stat_total"><span id=3D"total_cha">8</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"modifier_cha">-1</span></td>
					<td>&nbsp;</td>
					<td><span id=3D"cost_cha" class=3D"cost_span"></span></td>
				</tr>
				<tr>
				    <td colspan=3D"10">
				        <br>
                		<div id=3D"pointtotals">
                			<label>Total Points: </label><span id=3D"points-total">2=
7</span><br>
                			<label>Available Points: </label><span id=3D"points-avai=
lable">27</span><br>
                			<label>Used Points: </label><span id=3D"points-used">0</=
span>
                		</div>
			        </td>
				</tr>
			</tbody></table>
        </form>
        <br>
        <p>
            </p><ul style=3D"text-align: left;">
                <li>
                    Choose your ancestry type. Then push +1/+2 buttons to g=
ive yourself your desired bonuses.
                </li>
                <li>
                    Push the up and down arrows to spend points on improvin=
g stats.
                </li>
                <li>
                    New ancestries tend to be 'Flex' where you can have "+1=
 to 3 stats" or "+1 to 1 and +2 to another."
                </li>
                <li>
                    Traditional ancestries tend to be 'Other' where you hav=
e +1 to one and +2 to another.
                </li>
                <li>
                    Half-elves, tritons, mountain dwarves, humans and varia=
nt humans are the exceptions.
                </li>
            </ul>
           =20
        <p></p>
        You can still use <a href=3D"https://hallsofheroes.com/pointbuyance=
stral/index.html">the old version</a>.
        <br>
        <br>
        Hosted by <a href=3D"http://hallsofheroes.com/">Halls of Heroes</a>
	</div>
	</div>
=09
=09

</body></html>
