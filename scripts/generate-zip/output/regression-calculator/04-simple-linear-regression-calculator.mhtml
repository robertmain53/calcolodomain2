  .navigation { font-size: 1em; }
  .title { font-size: 2em; }
  .snl_container { margin: auto; }
}

@media (min-width: 700px) and (max-width: 800px) {
  .navigation { font-size: 1em; }
  .title { font-size: 2.5em; }
  .snl_container { margin: auto; }
}
