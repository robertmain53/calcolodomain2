@keyframes eg-slide-in {=20
  0% { opacity: 0; }
  100% { width: 240px; opacity: 1; }
}

@keyframes eg-slide-out {=20
  0% { width: 240px; opacity: 1; }
  100% { width: 0px; opacity: 0; }
}

@keyframes eg-slide-down {=20
  0% { transform: translateY(-40px); opacity: 0; height: 0px; }
  100% { transform: translateY(0px); opacity: 1; height: 40px; }
}

@keyframes eg-slide-up {=20
  0% { transform: translateY(0px); opacity: 1; height: 40px; }
  100% { transform: translateY(-40px); opacity: 0; height: 0px; }
}

@keyframes eg-menu-show {=20
  0% { opacity: 0; }
  25% { opacity: 0; }
  75% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes blink {=20
  0% { opacity: 0.2; }
  20% { opacity: 1; }
  100% { opacity: 0.2; }
}

@keyframes spin {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(1turn); }
}

