@charset "utf-8";

#content-slider { width: 997px; height: 400px; margin: 0px 0px 20px; paddin=
g: 0px; }

#slider { background: rgb(0, 0, 0); box-shadow: rgba(0, 0, 0, 0.7) 1px 1px =
5px; height: 400px; width: 100%; margin: 0px; overflow: visible; position: =
relative; }

#mask { overflow: hidden; height: 400px; }

#slider ul { margin: 0px; padding: 0px; position: relative; }

#slider li { width: 100%; height: 400px; position: absolute; top: -325px; l=
ist-style: none; }

#slider li.firstanimation { animation: 25s linear 0s infinite normal none r=
unning cycle; }

#slider li.secondanimation { animation: 25s linear 0s infinite normal none =
running cycletwo; }

#slider li.thirdanimation { animation: 25s linear 0s infinite normal none r=
unning cyclethree; }

#slider li.fourthanimation { animation: 25s linear 0s infinite normal none =
running cyclefour; }

#slider li.fifthanimation { animation: 25s linear 0s infinite normal none r=
unning cyclefive; }

#slider .tooltip { background: rgba(0, 0, 0, 0.7); width: 500px; height: 60=
px; position: relative; bottom: 75px; left: -520px; transition: 0.3s ease-i=
n-out; }

#slider .tooltip h1 { color: rgb(255, 255, 255); font-size: 24px; font-weig=
ht: 300; line-height: 60px; padding: 0px 0px 0px 20px; }

#slider li#first:hover .tooltip, #slider li#second:hover .tooltip, #slider =
li#third:hover .tooltip, #slider li#fourth:hover .tooltip, #slider li#fifth=
:hover .tooltip { left: 0px; }

#slider:hover li, #slider:hover .progress-bar { animation-play-state: pause=
d; }

.progress-bar { position: relative; top: -5px; width: 100%; height: 5px; ba=
ckground: rgb(0, 0, 0); animation: 25s ease-out 0s infinite normal none run=
ning fullexpand; }

@-webkit-keyframes cycle {=20
  0% { top: 0px; }
  4% { top: 0px; }
  16% { top: 0px; opacity: 1; z-index: 0; }
  20% { top: 325px; opacity: 0; z-index: 0; }
  21% { top: -325px; opacity: 0; z-index: -1; }
  50% { top: -325px; opacity: 0; z-index: -1; }
  92% { top: -325px; opacity: 0; z-index: 0; }
  96% { top: -325px; opacity: 0; }
  100% { top: 0px; opacity: 1; }
}

@-webkit-keyframes cycletwo {=20
  0% { top: -325px; opacity: 0; }
  16% { top: -325px; opacity: 0; }
  20% { top: 0px; opacity: 1; }
  24% { top: 0px; opacity: 1; }
  36% { top: 0px; opacity: 1; z-index: 0; }
  40% { top: 325px; opacity: 0; z-index: 0; }
  41% { top: -325px; opacity: 0; z-index: -1; }
  100% { top: -325px; opacity: 0; z-index: -1; }
}

@-webkit-keyframes cyclethree {=20
  0% { top: -325px; opacity: 0; }
  36% { top: -325px; opacity: 0; }
  40% { top: 0px; opacity: 1; }
  44% { top: 0px; opacity: 1; }
  56% { top: 0px; opacity: 1; z-index: 0; }
  60% { top: 325px; opacity: 0; z-index: 0; }
  61% { top: -325px; opacity: 0; z-index: -1; }
  100% { top: -325px; opacity: 0; z-index: -1; }
}

@-webkit-keyframes cyclefour {=20
  0% { top: -325px; opacity: 0; }
  56% { top: -325px; opacity: 0; }
  60% { top: 0px; opacity: 1; }
  64% { top: 0px; opacity: 1; }
  76% { top: 0px; opacity: 1; z-index: 0; }
  80% { top: 325px; opacity: 0; z-index: 0; }
  81% { top: -325px; opacity: 0; z-index: -1; }
  100% { top: -325px; opacity: 0; z-index: -1; }
}

@-webkit-keyframes cyclefive {=20
  0% { top: -325px; opacity: 0; }
  76% { top: -325px; opacity: 0; }
  80% { top: 0px; opacity: 1; }
  84% { top: 0px; opacity: 1; }
  96% { top: 0px; opacity: 1; z-index: 0; }
  100% { top: 325px; opacity: 0; z-index: 0; }
}

@-webkit-keyframes fullexpand {=20
  0%, 20%, 40%, 60%, 80%, 100% { width: 0%; opacity: 0; }
  4%, 24%, 44%, 64%, 84% { width: 0%; opacity: 0.3; }
  16%, 36%, 56%, 76%, 96% { width: 100%; opacity: 0.7; }
  17%, 37%, 57%, 77%, 97% { width: 100%; opacity: 0.3; }
  18%, 38%, 58%, 78%, 98% { width: 100%; opacity: 0; }
}
