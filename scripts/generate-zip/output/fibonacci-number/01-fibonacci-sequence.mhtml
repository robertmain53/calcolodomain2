        <mo stretchy=3D"false">(</mo>
        <mi>F</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=3D</mo>
        <mrow>
          <mo>=E2=8C=8A</mo>
          <mrow>
            <msub>
              <mi>log</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mi>=CF=86<!-- =CF=86 --></mi>
