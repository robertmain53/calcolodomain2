          <mo>=E2=88=91<!-- =E2=88=91 --></mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>i</mi>
            <mo>=3D</mo>
            <mn>1</mn>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>n</mi>
          </mrow>
        </munderover>
        <msub>
          <mi>F</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>i</mi>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <msub>
          <mi>F</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>n</mi>
            <mo>+</mo>
            <mn>2</mn>
          </mrow>
        </msub>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mn>1.</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \sum _{i=3D1}=
^{n}F_{i}=3DF_{n+2}-1.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/7d35c36bbee08b20fe2cbd2708ccf16dcc5b04f6" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
