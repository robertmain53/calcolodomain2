    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \sum _{k=3D1}=
^{\infty }{\frac {1}{{F_{k}}^{2}}}=3D{\frac {5}{24}}\!\left(\vartheta _{2}\=
!\left(0,{\frac {3-{\sqrt {5}}}{2}}\right)^{4}-\vartheta _{4}\!\left(0,{\fr=
ac {3-{\sqrt {5}}}{2}}\right)^{4}+1\right).}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
