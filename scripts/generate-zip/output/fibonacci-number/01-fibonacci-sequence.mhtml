              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>4</mn>
              </mrow>
            </msup>
            <mo>=E2=88=92<!-- =E2=88=92 --></mo>
            <msub>
              <mi>=CF=91<!-- =CF=91 --></mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>4</mn>
              </mrow>
            </msub>
            <mspace width=3D"negativethinmathspace"></mspace>
            <msup>
              <mrow>
                <mo>(</mo>
                <mrow>
                  <mn>0</mn>
                  <mo>,</mo>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mfrac>
                      <mrow>
                        <mn>3</mn>
                        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                        <mrow class=3D"MJX-TeXAtom-ORD">
                          <msqrt>
                            <mn>5</mn>
                          </msqrt>
                        </mrow>
                      </mrow>
                      <mn>2</mn>
                    </mfrac>
                  </mrow>
                </mrow>
                <mo>)</mo>
