    <annotation encoding=3D"application/x-tex">{\displaystyle F_{n}=3D\left=
\lfloor {\frac {\varphi ^{n}}{\sqrt {5}}}\right\rceil ,\ n\geq 0.}</annotat=
ion>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/e1472b2568affd51a4ff35dbc6b0e0b27094d093" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
