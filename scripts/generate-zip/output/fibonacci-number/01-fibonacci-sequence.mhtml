            </msub>
            <mo>=E2=81=A1<!-- =E2=81=A1 --></mo>
            <mrow class=3D"MJX-TeXAtom-ORD">
              <msqrt>
                <mn>5</mn>
              </msqrt>
            </mrow>
            <mi>F</mi>
          </mrow>
          <mo>=E2=8C=89</mo>
        </mrow>
        <mo>,</mo>
        <mtext>&nbsp;</mtext>
        <mi>F</mi>
        <mo>=E2=89=A5<!-- =E2=89=A5 --></mo>
        <mn>1.</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle n(F)=3D\left\=
lfloor \log _{\varphi }{\sqrt {5}}F\right\rceil ,\ F\geq 1.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/4b3f644578160a16c71f8fa46c1e5fc4f841e0ec" class=3D"mwe-math-fallback=
