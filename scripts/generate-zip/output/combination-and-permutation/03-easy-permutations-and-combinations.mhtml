" role=3D"img" focusable=3D"false" viewBox=3D"0 -677 6277.8 699" xmlns:xlin=
k=3D"http://www.w3.org/1999/xlink" aria-hidden=3D"true" style=3D"vertical-a=
lign: -0.05ex;"><g stroke=3D"currentColor" fill=3D"currentColor" stroke-wid=
th=3D"0" transform=3D"scale(1,-1)"><g data-mml-node=3D"math"><g data-mml-no=
de=3D"mn"><use data-c=3D"35" xlink:href=3D"#MJX-TEX-N-35"></use></g><g data=
-mml-node=3D"mo" transform=3D"translate(722.2,0)"><use data-c=3D"2217" xlin=
k:href=3D"#MJX-TEX-N-2217"></use></g><g data-mml-node=3D"mn" transform=3D"t=
ranslate(1444.4,0)"><use data-c=3D"34" xlink:href=3D"#MJX-TEX-N-34"></use><=
/g><g data-mml-node=3D"mo" transform=3D"translate(2166.7,0)"><use data-c=3D=
"2217" xlink:href=3D"#MJX-TEX-N-2217"></use></g><g data-mml-node=3D"mn" tra=
