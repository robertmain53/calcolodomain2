ot;Unitless&quot;]/QuantityVariable[&quot;ATT&quot;, &quot;Unitless&quot;])=
]], QuantityVariable[&quot;YPAC&quot;, &quot;Unitless&quot;] =3D=3D Max[0, =
Min[2.375, 0.25*(-3 + QuantityVariable[&quot;YARDS&quot;, &quot;Unitless&qu=
ot;]/QuantityVariable[&quot;ATT&quot;, &quot;Unitless&quot;])]], QuantityVa=
riable[&quot;TDC&quot;, &quot;Unitless&quot;] =3D=3D Max[0, Min[2.375, (20*=
QuantityVariable[&quot;TD&quot;, &quot;Unitless&quot;])/QuantityVariable[&q=
