  .many.cols2, .many.cols3, .many.cols4, .many.cols5 { grid-template-column=
s: 1fr; gap: 0.1rem; justify-items: center; }
  .many.cols2 > :nth-child(2n), .many.cols3 > :nth-child(3n), .many.cols4 >=
 :nth-child(4n), .many.cols5 > :nth-child(5n) { margin-bottom: 2rem; }
  .many > :last-child { margin-bottom: 0px; }
  .two .lt:empty, .many .lt:empty { padding: 0px; margin: 0px; }
  .two.no-stack { grid-template-columns: minmax(auto, max-content) minmax(a=
uto, max-content); }
  .two .lt { text-align: left; margin-top: 8px; }
  .two .rt { text-align: center; }
  .two .rtlt { text-align: center; }
  .two .rtct { text-align: center; }
  .two .rtrt { text-align: right; }
  .two p { grid-column: 1 / -1; }
  .two .span2 { grid-column: 1 / -1; }
  .wideOnly { display: none !important; }
}

