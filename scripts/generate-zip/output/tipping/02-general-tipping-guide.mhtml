<section class=3D"richtext">
    <div class=3D"container">
        <h2 data-children-count=3D"0">Travel:</h2>
<table style=3D"width:100%; border: 1px solid black;">
        <tbody>
            <tr>
                <th>Service</th>
                <th>Tip</th>
            </tr>
            <tr>
                <td>Skycap</td>
                <td>$2 first bag, $1 per additional bag</td>
            </tr>
            <tr>
                <td>Doorman</td>
                <td>A smile and a "thanks" when he opens the door, plus $1-=
$4 for carrying luggage; $1-$2 for hailing cab (add an extra $1 if it's rai=
ning); $1-$4 beyond the call of duty.</td>
            </tr>
            <tr>
                <td>Bellhop</td>
                <td>$2 first bag; $1 per additional bag; $2-3 for each addi=
tional service, such as room delivery.</td>
            </tr>
            <tr>
                <td>Housekeeper</td>
                <td>$2-$5 per day, left daily with a note marked "Housekeep=
ing - Thank you"</td>
            </tr>
            <tr>
                <td>Concierge</td>
                <td>No obligation for answering questions. $5-10 for ticket=
s or restaurant reservations; $15 for hard-to-get tickets or reservations (=
or 10-20% of the ticket price)</td>
            </tr>
            <tr>
                <td>Taxi Driver</td>
                <td>15-20% of the fare, but minimally $1; $2 for the first =
bag carried, $1 per additional bag.</td>
            </tr>
        </tbody>
    </table>
    </div>
</section>

