oxon</span><span class=3D"w"> </span><span class=3D"n">rank</span><span cla=
ss=3D"w"> </span><span class=3D"n">sum</span><span class=3D"w"> </span><spa=
n class=3D"n">test</span>

<span class=3D"n">data</span><span class=3D"o">:</span><span class=3D"w">  =
</span><span class=3D"n">airquality</span><span class=3D"o">$</span><span c=
lass=3D"n">Ozone</span><span class=3D"w"> </span><span class=3D"n">and</spa=
n><span class=3D"w"> </span><span class=3D"n">airquality</span><span class=
=3D"o">$</span><span class=3D"n">Month</span>

<span class=3D"w">  </span><span class=3D"m">5</span><span class=3D"w">    =
  </span><span class=3D"m">6</span><span class=3D"w">      </span><span cla=
ss=3D"m">7</span><span class=3D"w">      </span><span class=3D"m">8</span><=
