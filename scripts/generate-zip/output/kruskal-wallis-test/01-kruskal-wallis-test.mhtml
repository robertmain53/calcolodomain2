<span class=3D"m">6</span><span class=3D"w"> </span><span class=3D"m">1.000=
0</span><span class=3D"w"> </span><span class=3D"o">-</span><span class=3D"=
w">      </span><span class=3D"o">-</span><span class=3D"w">      </span><s=
pan class=3D"o">-</span><span class=3D"w">     </span>
<span class=3D"m">7</span><span class=3D"w"> </span><span class=3D"m">0.000=
3</span><span class=3D"w"> </span><span class=3D"m">0.1414</span><span clas=
s=3D"w"> </span><span class=3D"o">-</span><span class=3D"w">      </span><s=
pan class=3D"o">-</span><span class=3D"w">     </span>
<span class=3D"m">8</span><span class=3D"w"> </span><span class=3D"m">0.001=
2</span><span class=3D"w"> </span><span class=3D"m">0.2591</span><span clas=
s=3D"w"> </span><span class=3D"m">1.0000</span><span class=3D"w"> </span><s=
