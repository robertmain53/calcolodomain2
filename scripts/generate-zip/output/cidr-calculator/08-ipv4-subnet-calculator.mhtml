.col-md-30 { max-width: 16%; padding-right: 1px; padding-left: 1px; }

.footer__brand .brand__logo { width: 190px; padding-bottom: 40px; }

.footer__brand { justify-content: space-between; padding-right: 42px; }

.subscription-counter { color: rgb(82, 186, 255); font-weight: 300; font-si=
