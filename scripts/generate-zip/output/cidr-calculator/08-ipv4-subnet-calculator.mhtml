.footer__site-map { padding: 50px 10px 20px; }

.footer__btn { font-weight: 300; padding: 30px; font-size: 20px; text-align=
: center; color: white; border: 1px solid var(--brand-primary) !important; =
justify-content: center !important; }

.footer__btn:hover { font-weight: 500; color: white; }

.footer__bottom-nav .nav__link, .footer__nav .nav__link, .footer__brand .br=
and__desc { color: white; }

.footer__bottom-nav .nav__link:hover, .footer__nav .nav__link:hover { color=
: rgb(0, 123, 252) !important; }

.footer__socials img { opacity: 1; }

@media (max-width: 513px) {
  .footer__site-map { padding: 20px 50px; }
}

@media (max-width: 1011px) {
  .footer__btn { min-width: fit-content; padding: 5px; font-size: 16px; }
}

@media (max-width: 751px) {
  .footer__socials { display: flex; }
}
