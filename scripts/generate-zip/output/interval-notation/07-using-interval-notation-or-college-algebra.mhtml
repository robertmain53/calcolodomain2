x-n" space=3D"4"><mjx-c class=3D"mjx-c3D"></mjx-c></mjx-mo><mjx-mn class=3D=
"mjx-n" space=3D"4"><mjx-c class=3D"mjx-c34"></mjx-c></mjx-mn></mjx-math><m=
jx-assistive-mml unselectable=3D"on" display=3D"inline"><math xmlns=3D"http=
://www.w3.org/1998/Math/MathML"><mi>x</mi><mo>=3D</mo><mn>4</mn></math></mj=
x-assistive-mml></mjx-container> and, as indicated by the arrowhead, contin=
ues to infinity, which illustrates that the solution set includes all real =
numbers greater than or equal to 4.</p>
<div style=3D"width: 497px" class=3D"wp-caption aligncenter"><img decoding=
