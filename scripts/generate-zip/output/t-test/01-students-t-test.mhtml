-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -3.171ex; width:28.147ex; height:6.676ex;" alt=3D"{\displaystyle t_=
{\text{score,intercept}}=3D{\frac {\alpha }{\beta }}{\frac {t_{\text{score,=
slope}}}{\sqrt {s_{\text{x}}^{2}+{\bar {x}}^{2}}}},}"></span></dd></dl>
<p>where <span class=3D"texhtml"><i>s</i><sub>x</sub><sup>2</sup></span> is=
 the sample variance.
</p>
<div class=3D"mw-heading mw-heading3"><h3 id=3D"Independent_two-sample_t-te=
st">Independent two-sample <i>t</i>-test</h3><span class=3D"mw-editsection"=
><span class=3D"mw-editsection-bracket">[</span><a href=3D"https://en.wikip=
edia.org/w/index.php?title=3DStudent%27s_t-test&amp;action=3Dedit&amp;secti=
on=3D10" title=3D"Edit section: Independent two-sample t-test"><span>edit</=
span></a><span class=3D"mw-editsection-bracket">]</span></span></div>
<div class=3D"mw-heading mw-heading4"><h4 id=3D"Equal_sample_sizes_and_vari=
ance">Equal sample sizes and variance</h4><span class=3D"mw-editsection"><s=
pan class=3D"mw-editsection-bracket">[</span><a href=3D"https://en.wikipedi=
a.org/w/index.php?title=3DStudent%27s_t-test&amp;action=3Dedit&amp;section=
=3D11" title=3D"Edit section: Equal sample sizes and variance"><span>edit</=
span></a><span class=3D"mw-editsection-bracket">]</span></span></div>
<p>Given two groups (1, 2), this test is only applicable when:
</p>
<ul><li>the two sample sizes are equal,</li>
<li>it can be assumed that the two distributions have the same variance.</l=
i></ul>
<p>Violations of these assumptions are discussed below.
</p><p>The <span class=3D"texhtml"><i>t</i></span> statistic to test whethe=
r the means are different can be calculated as follows:
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e t=3D{\frac {{\bar {X}}_{1}-{\bar {X}}_{2}}{s_{p}{\sqrt {\frac {2}{n}}}}},=
}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>t</mi>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <msub>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mover>
                      <mi>X</mi>
                      <mo stretchy=3D"false">=C2=AF<!-- =C2=AF --></mo>
                    </mover>
                  </mrow>
                </mrow>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>1</mn>
                </mrow>
              </msub>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <msub>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mover>
                      <mi>X</mi>
                      <mo stretchy=3D"false">=C2=AF<!-- =C2=AF --></mo>
                    </mover>
                  </mrow>
                </mrow>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msub>
            </mrow>
            <mrow>
              <msub>
                <mi>s</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mi>p</mi>
                </mrow>
              </msub>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <msqrt>
                  <mfrac>
                    <mn>2</mn>
                    <mi>n</mi>
                  </mfrac>
                </msqrt>
              </mrow>
            </mrow>
          </mfrac>
        </mrow>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle t=3D{\frac {{=
\bar {X}}_{1}-{\bar {X}}_{2}}{s_{p}{\sqrt {\frac {2}{n}}}}},}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/09aab90a09d5dba053cb4e398f9999738c8ca5e3" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -4.671ex; width:14.33ex; height:8.509ex;" alt=3D"{\displaystyle t=
=3D{\frac {{\bar {X}}_{1}-{\bar {X}}_{2}}{s_{p}{\sqrt {\frac {2}{n}}}}},}">=
</span></dd></dl>
<p>where
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e s_{p}=3D{\sqrt {\frac {s_{X_{1}}^{2}+s_{X_{2}}^{2}}{2}}}.}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <msub>
          <mi>s</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>p</mi>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <msqrt>
            <mfrac>
              <mrow>
                <msubsup>
                  <mi>s</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <msub>
                      <mi>X</mi>
                      <mrow class=3D"MJX-TeXAtom-ORD">
                        <mn>1</mn>
                      </mrow>
                    </msub>
                  </mrow>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msubsup>
                <mo>+</mo>
                <msubsup>
                  <mi>s</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <msub>
                      <mi>X</mi>
                      <mrow class=3D"MJX-TeXAtom-ORD">
                        <mn>2</mn>
                      </mrow>
                    </msub>
                  </mrow>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msubsup>
              </mrow>
              <mn>2</mn>
            </mfrac>
          </msqrt>
        </mrow>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle s_{p}=3D{\sqr=
t {\frac {s_{X_{1}}^{2}+s_{X_{2}}^{2}}{2}}}.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/2adbe1794944e2924c113eacd348126a39746e59" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -2.505ex; width:18.925ex; height:7.676ex;" alt=3D"{\displaystyle s_=
{p}=3D{\sqrt {\frac {s_{X_{1}}^{2}+s_{X_{2}}^{2}}{2}}}.}"></span></dd></dl>
<p>Here <span class=3D"texhtml"><i>s<sub>p</sub></i></span> is the <a href=
=3D"https://en.wikipedia.org/wiki/Pooled_standard_deviation" class=3D"mw-re=
direct" title=3D"Pooled standard deviation">pooled standard deviation</a> f=
or <span class=3D"texhtml"><i>n</i> =3D <i>n</i><sub>1</sub> =3D <i>n</i><s=
ub>2</sub></span>, and <span class=3D"texhtml"><i>s</i><span class=3D"nowra=
p"><span style=3D"display:inline-block;margin-bottom:-0.3em;vertical-align:=
-0.4em;line-height:1.2em;font-size:80%;text-align:left"><sup style=3D"font-=
size:inherit;line-height:inherit;vertical-align:baseline">&nbsp;2</sup><br>=
<sub style=3D"font-size:inherit;line-height:inherit;vertical-align:baseline=
"><i>X</i><sub>1</sub></sub></span></span></span> and <span class=3D"texhtm=
l"><i>s</i><span class=3D"nowrap"><span style=3D"display:inline-block;margi=
n-bottom:-0.3em;vertical-align:-0.4em;line-height:1.2em;font-size:80%;text-=
align:left"><sup style=3D"font-size:inherit;line-height:inherit;vertical-al=
ign:baseline">&nbsp;2</sup><br><sub style=3D"font-size:inherit;line-height:=
inherit;vertical-align:baseline"><i>X</i><sub>2</sub></sub></span></span></=
span> are the <a href=3D"https://en.wikipedia.org/wiki/Unbiased_estimator" =
class=3D"mw-redirect" title=3D"Unbiased estimator">unbiased estimators</a> =
of the population variance. The denominator of <span class=3D"texhtml"><i>t=
</i></span> is the <a href=3D"https://en.wikipedia.org/wiki/Standard_error_=
(statistics)" class=3D"mw-redirect" title=3D"Standard error (statistics)">s=
tandard error</a> of the difference between two means.
</p><p>For significance testing, the <a href=3D"https://en.wikipedia.org/wi=
ki/Degrees_of_freedom_(statistics)" title=3D"Degrees of freedom (statistics=
)">degrees of freedom</a> for this test is <span class=3D"texhtml">2<i>n</i=
> =E2=88=92 2</span>, where <span class=3D"texhtml"><i>n</i></span> is samp=
le size.
</p>
<div class=3D"mw-heading mw-heading4"><h4 id=3D"Equal_or_unequal_sample_siz=
es,_similar_variances_(=E2=81=A01/2=E2=81=A0_&lt;_=E2=81=A0sX1/sX2=E2=81=A0=
_&lt;_2)"><span id=3D"Equal_or_unequal_sample_sizes.2C_similar_variances_.2=
8.E2.81.A01.2F2.E2.81.A0_.3C_.E2.81.A0sX1.2FsX2.E2.81.A0_.3C_2.29"></span>E=
qual or unequal sample sizes, similar variances (<link rel=3D"mw-deduplicat=
ed-inline-style" href=3D"mw-data:TemplateStyles:r1214402035"><span class=3D=
"sfrac">=E2=81=A0<span class=3D"tion"><span class=3D"num">1</span><span cla=
ss=3D"sr-only">/</span><span class=3D"den">2</span></span>=E2=81=A0</span> =
&lt; <link rel=3D"mw-deduplicated-inline-style" href=3D"mw-data:TemplateSty=
les:r1214402035"><span class=3D"sfrac">=E2=81=A0<span class=3D"tion"><span =
class=3D"num"><i>s</i><sub><i>X</i><sub>1</sub></sub></span><span class=3D"=
sr-only">/</span><span class=3D"den"><i>s</i><sub><i>X</i><sub>2</sub></sub=
></span></span>=E2=81=A0</span> &lt; 2)</h4><span class=3D"mw-editsection">=
<span class=3D"mw-editsection-bracket">[</span><a href=3D"https://en.wikipe=
dia.org/w/index.php?title=3DStudent%27s_t-test&amp;action=3Dedit&amp;sectio=
n=3D12" title=3D"Edit section: Equal or unequal sample sizes, similar varia=
nces (=E2=81=A01/2=E2=81=A0 &lt; =E2=81=A0sX1/sX2=E2=81=A0 &lt; 2)"><span>e=
dit</span></a><span class=3D"mw-editsection-bracket">]</span></span></div>
<p>This test is used only when it can be assumed that the two distributions=
 have the same variance (when this assumption is violated, see below).=20
The previous formulae are a special case of the formulae below, one recover=
s them when both samples are equal in size: <span class=3D"texhtml"><i>n</i=
> =3D <i>n</i><sub>1</sub> =3D <i>n</i><sub>2</sub></span>.
</p><p>The <span class=3D"texhtml"><i>t</i></span> statistic to test whethe=
r the means are different can be calculated as follows:
</p>
