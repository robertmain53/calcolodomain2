      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle t_{\text{scor=
e,intercept}}=3D{\frac {\alpha }{\beta }}{\frac {t_{\text{score,slope}}}{\s=
qrt {s_{\text{x}}^{2}+{\bar {x}}^{2}}}},}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
