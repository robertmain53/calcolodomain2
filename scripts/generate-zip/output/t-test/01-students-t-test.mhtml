                      </mover>
                    </mrow>
                  </mrow>
                  <msup>
                    <mo stretchy=3D"false">)</mo>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mn>2</mn>
                    </mrow>
                  </msup>
                </mrow>
              </mfrac>
            </msqrt>
          </mfrac>
        </mrow>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle t_{\text{scor=
e}}=3D{\frac {({\hat {\beta }}-\beta _{0}){\sqrt {n-2}}}{\sqrt {\frac {SSR}=
{\sum _{i=3D1}^{n}(x_{i}-{\bar {x}})^{2}}}}}.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/5cb5f3a4e467a67d1dfc346ca722edbbb2a41145" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -6.005ex; width:25.032ex; height:10.343ex;" alt=3D"{\displaystyle t=
_{\text{score}}=3D{\frac {({\hat {\beta }}-\beta _{0}){\sqrt {n-2}}}{\sqrt =
{\frac {SSR}{\sum _{i=3D1}^{n}(x_{i}-{\bar {x}})^{2}}}}}.}"></span></dd></d=
l>
<p>Another way to determine the <span class=3D"texhtml"><i>t</i></span><sub=
>score</sub> is
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e t_{\text{score}}=3D{\frac {r{\sqrt {n-2}}}{\sqrt {1-r^{2}}}},}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
