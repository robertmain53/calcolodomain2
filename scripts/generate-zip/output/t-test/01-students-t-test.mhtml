            <mtext>score</mtext>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mo stretchy=3D"false">(</mo>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mover>
                    <mi>=CE=B2<!-- =CE=B2 --></mi>
                    <mo stretchy=3D"false">^<!-- ^ --></mo>
                  </mover>
                </mrow>
              </mrow>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <msub>
                <mi>=CE=B2<!-- =CE=B2 --></mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>0</mn>
                </mrow>
              </msub>
              <mo stretchy=3D"false">)</mo>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <msqrt>
                  <mi>n</mi>
                  <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                  <mn>2</mn>
                </msqrt>
