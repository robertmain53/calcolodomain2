.easter header #logo::before { background: url("/assets/site/img/easter-ear=
s.png") center top; height: 26px; width: 43px; top: -25px; left: -1.5px; }

.easter header #logo::after { background: url("/assets/site/img/easter-eggs=
.png") center top; height: 28px; width: 28px; top: 25px; left: 0px; }

