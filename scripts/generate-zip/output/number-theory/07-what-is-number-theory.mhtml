	<figcaption class=3D"media-body-wrap bg-accent-3 p-4 w-max-full text-sm te=
xt-left">
											How do you relate to numbers?
										<div class=3D"media-sub uppercase text-brown">
				Andrea Pistolesi/The Image Bank/Getty Images
			</div>
			</figcaption>

	</figure>
