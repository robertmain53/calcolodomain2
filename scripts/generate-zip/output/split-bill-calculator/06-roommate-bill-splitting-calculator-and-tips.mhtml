: pointer; margin-top: 10px; margin-bottom: 10px; width: 100%; transition: =
background-color 0.3s; font-weight: 600; }

button:hover { background-color: rgb(209, 82, 45); }

.results-container { margin-top: 30px; padding: 20px; border-radius: 10px; =
background-color: rgb(249, 249, 249); display: none; }

.results-container h2 { color: rgb(39, 89, 197); margin-bottom: 15px; text-=
align: center; }

.summary { margin-bottom: 20px; padding: 15px; background-color: rgb(238, 2=
45, 255); border-radius: 8px; }

table { width: 100%; border-collapse: collapse; margin-top: 15px; }

th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid rgb=
