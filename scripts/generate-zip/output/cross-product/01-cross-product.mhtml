        </mrow>
        <mo>=3D</mo>
        <msub>
          <mi>q</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>e</mi>
          </mrow>
        </msub>
        <mrow>
          <mo>(</mo>
          <mrow>
            <mrow class=3D"MJX-TeXAtom-ORD">
              <mi mathvariant=3D"bold">E</mi>
            </mrow>
            <mo>+</mo>
            <mrow class=3D"MJX-TeXAtom-ORD">
              <mi mathvariant=3D"bold">v</mi>
            </mrow>
            <mo>=C3=97<!-- =C3=97 --></mo>
            <mrow class=3D"MJX-TeXAtom-ORD">
