        </mrow>
        <mo>=C3=97<!-- =C3=97 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mi mathvariant=3D"bold">c</mi>
        </mrow>
      </mstyle>
    </mrow>
