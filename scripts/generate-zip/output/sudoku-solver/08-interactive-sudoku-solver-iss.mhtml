      <label for=3D"debug-cell-index">Show cell index</label>
      <button id=3D"close-debug-button" class=3D"danger-button" title=3D"Cl=
ose debug">Close debug</button>
    </div>
    <div id=3D"debug-counters"></div>
    <div id=3D"debug-logs"></div>
  </div>

