  & .click-interceptor-svg { z-index: 100; position: absolute; top: 0px; le=
ft: 0px; }
}

.cell-single-value { font-size: 30px; font-family: var(--font-family-mono);=
 text-anchor: middle; dominant-baseline: middle; }

.cell-multi-value {
  font-size: 15px; font-family: var(--font-family-mono); text-anchor: middl=
e; dominant-baseline: hanging; white-space: pre;
  .grid-size-large & { font-size: 9px; }
}

.solution-group { fill: rgb(0, 128, 255); filter: drop-shadow(white 0px 0px=
