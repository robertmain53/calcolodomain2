<body>
  <h1>Interactive Sudoku Solver (ISS)</h1>

  <div id=3D"instruction-panel">
    <div>
      <div class=3D"description">
        <p>
          To set a value, select a cell and type a number.
        </p>
        <p>
          To add a line or region constraint, select and drag; or shift-cli=
ck.
        </p>
        <p>
          To add other outside clue constraints, select a row or column arr=
ow outside the grid.
        </p>
        <p>
          For more information, see the <a href=3D"https://sigh.github.io/I=
nteractive-Sudoku-Solver/help">help page</a>.
        </p>
      </div>
    </div>


    <div>
      <span class=3D"description">OR</span>

      <span id=3D"example-select-container">
        <select disabled=3D"">
          <option>-- Load an example --</option>
        </select>
        <a style=3D"display:none">(Source)</a>
      </span>
    </div>

    <div>
      <span class=3D"description">OR</span>

      <form id=3D"freeform-constraint-input">
        <span>
          <textarea name=3D"freeform-input" rows=3D"3"></textarea>
          <button type=3D"submit" title=3D"Load from text">Load from text</=
button>
        </span>
      </form>
    </div>

  </div>

  <hr>

  <div id=3D"debug-container" class=3D"hidden">
    <div id=3D"debug-panel">
      <label>
        Log level
        <select id=3D"debug-log-level" class=3D"thin-select">
          <option value=3D"0">None</option>
          <option value=3D"1">1</option>
          <option value=3D"2">2</option>
        </select>
      </label>
      <label>
        <input type=3D"checkbox" id=3D"conflict-heatmap-checkbox">
        Conflict heatmap
