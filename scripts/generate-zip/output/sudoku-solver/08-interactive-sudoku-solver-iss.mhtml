      <div>
        <input list=3D"debug-puzzles" id=3D"debug-puzzle-input" placeholder=
=3D"Load a puzzle">
        <datalist id=3D"debug-puzzles"></datalist>
      </div>
      <div id=3D"debug-puzzle-src"></div>
      <input type=3D"checkbox" id=3D"debug-cell-id" class=3D"debug-checkbox=
">
      <label for=3D"debug-cell-id">Show cell id</label>
