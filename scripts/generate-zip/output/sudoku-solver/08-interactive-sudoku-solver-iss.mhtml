.diff-group { fill: rgb(200, 120, 120); filter: drop-shadow(white 0px 0px 1=
px); }

.givens-group {
  & .cell-multi-value { fill: lightgrey; stroke: rgb(255, 255, 255); transf=
orm: translate(0px, -1.5px); }
  & .cell-single-value { font-family: sans-serif; }
}

.debug-candidate-group { fill: rgb(230, 50, 50); font-weight: bold; }

