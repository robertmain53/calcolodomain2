          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>0</mn>
          </mrow>
        </msub>
        <mo stretchy=3D"false">(</mo>
        <mi>n</mi>
        <mo stretchy=3D"false">)</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle f_{0}(n)}</an=
notation>
