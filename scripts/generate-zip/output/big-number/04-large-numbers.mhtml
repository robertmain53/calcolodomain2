                <mi>a</mi>
              </mrow>
            </msup>
          </mrow>
        </msup>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle 10^{10^{a}}}<=
/annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/5b591358b2a0245045937a5db691b6f5adeb86fb" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.338ex; width:5.071ex; height:2.676ex;" alt=3D"{\displaystyle 10^=
{10^{a}}}"></span> and <span class=3D"mwe-math-element mwe-math-element-inl=
ine"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"d=
isplay: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=
=3D"{\displaystyle 10^{10^{b}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
