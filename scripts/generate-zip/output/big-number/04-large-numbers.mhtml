        <mi>n</mi>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle n}</annotatio=
n>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/a601995d55609f2d9f5e233e36fbe9ea26011b3b" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.338ex; width:1.395ex; height:1.676ex;" alt=3D"{\displaystyle n}"=
></span> there is <span class=3D"mwe-math-element mwe-math-element-inline">=
<span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"displa=
y: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle n^{n}\approx 10^{n}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <msup>
          <mi>n</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>n</mi>
          </mrow>
        </msup>
        <mo>=E2=89=88<!-- =E2=89=88 --></mo>
        <msup>
