@charset "utf-8";

* { --primary-color: #0572ec; --text-color: #051627; }

.column-content { min-height: 79px; margin: 0px auto; display: flex; flex-d=
irection: column; justify-content: space-evenly; align-items: center; anima=
tion: 150ms ease 0s 1 normal none running fadeIn; }

.column-content .button { margin-top: 0.25em; margin-bottom: 0.25em; max-wi=
dth: 97%; }

.accept-or-reject-all-button-row { display: flex; flex-direction: column; j=
ustify-content: center; margin-top: 1em; width: 100%; }

.button { min-height: 42px; border-radius: 500px; width: 100%; background-c=
olor: rgba(255, 255, 255, 0.7); opacity: 0.9; border: 1px solid var(--prima=
ry-color); box-sizing: border-box; cursor: pointer; filter: brightness(100%=
); flex-shrink: 0; font-family: inherit; text-align: center; padding: 6px; =
transition: filter 150ms, background-color 150ms; }

.button:not(:last-of-type) { margin-bottom: 8px; }

.button:hover { background-color: var(--primary-color); }

.button:hover span { color: rgb(255, 255, 255); }

.button-base-text { color: var(--primary-color); display: block; font-style=
: normal; text-align: center; transition: color 150ms; }

.button-primary-text { font-size: 12px; font-weight: 700; }

.button-secondary-text { font-size: 9px; font-weight: 400; }

button:focus { outline: rgba(51, 157, 255, 0.7) solid 2px; }

a:focus { outline: rgba(51, 157, 255, 0.7) solid 2px; }

