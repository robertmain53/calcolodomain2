@keyframes rotate1 {=20
  0% { transform: rotate(-49deg) scale(0.3); opacity: 0; }
  2% { opacity: 1; }
  100% { transform: rotate(0deg) scale(1); opacity: 1; }
}

@keyframes rotate2 {=20
  0% { transform: rotate(90deg) scale(0.3); opacity: 0; }
  2% { opacity: 1; }
  100% { transform: rotate(0deg) scale(1); opacity: 1; }
}

@keyframes rotate3 {=20
  0% { transform: rotate(33deg) scale(0.3); opacity: 0; }
  2% { opacity: 1; }
  100% { transform: rotate(0deg) scale(1); opacity: 1; }
}

@keyframes rotate4 {=20
  0% { transform: rotate(15deg) scale(0.3); opacity: 0; }
  2% { opacity: 1; }
  100% { transform: rotate(0deg) scale(1); opacity: 1; }
}

@keyframes rotate5 {=20
  0% { transform: rotate(-15deg) scale(0.3); opacity: 0; }
  2% { opacity: 1; }
  100% { transform: rotate(0deg) scale(1); opacity: 1; }
}

@keyframes fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes slideDown {=20
  0% { transform: translateY(-20px); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes slideUp {=20
  0% { transform: translateY(20px); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

@keyframes fadeInAndSlideFromLeft {=20
  0% { transform: translate(-20px); opacity: 0; }
  100% { transform: translate(0px); opacity: 1; }
}

@keyframes popIn {=20
  0% { transform: scale(0); opacity: 0; }
  75% { transform: scale(1.3); opacity: 0.5; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes revealUp {=20
  0% { transform: translateY(100%); opacity: 0; }
  75% { transform: translate(0px); opacity: 0; }
  100% { transform: translate(0px); opacity: 1; }
}

@keyframes revealDown {=20
  0% { transform: translateY(-100%) scale(0.3); opacity: 0; }
  90% { transform: translate(0px) scale(1); opacity: 1; }
  100% { transform: translate(0px) scale(1); opacity: 1; }
}

@keyframes verticalFloating {=20
  0% { transform: translate(0px); }
  25% { transform: translateY(5%); }
  50% { transform: translateY(-5%); }
  75% { transform: translateY(5%); }
  100% { transform: translate(0px); }
}

@keyframes blurScaleIn {=20
  0% { transform: scale(0); opacity: 0; filter: blur(100px); }
  70% { transform: scale(0.8); opacity: 0.7; filter: blur(4px); }
  100% { transform: scale(1); opacity: 1; filter: none; }
}

@keyframes swipeReveal {=20
  0% { clip-path: polygon(0% 0px, 0px 0px, 0px 100%, 0% 100%); opacity: 0; =
}
  2% { opacity: 1; }
  100% { clip-path: polygon(0px 0px, 100% 0px, 100% 100%, 0% 100%); opacity=
: 1; }
}

@keyframes puffInCenter {=20
  0% { transform: scale(2); opacity: 0; filter: blur(2px); }
  100% { transform: scale(1); opacity: 1; filter: blur(0px); }
}

@keyframes growIn {=20
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes slideInBackCenter {=20
  0% { transform: perspective(20px) translateZ(-30px); opacity: 0; }
  100% { transform: perspective(20px) translateZ(0px); opacity: 1; }
}

@keyframes flipInFromBottom {=20
  0% { transform: rotateX(80deg); opacity: 0; }
  100% { transform: rotateX(0deg); opacity: 1; }
}

@keyframes flipInFromTop {=20
  0% { transform: rotateX(-80deg); opacity: 0; }
  100% { transform: rotateX(0deg); opacity: 1; }
}

@keyframes blurIn {=20
  0% { filter: blur(12px); opacity: 0; }
  95% { }
  100% { filter: blur(0px); opacity: 1; }
}

@keyframes wipeInAndOutFromLeft {=20
  0% { transform: scaleX(0); transform-origin: left center; }
  50% { transform: scaleX(1); transform-origin: left center; }
  100% { transform: scaleX(0); transform-origin: left center; }
}

@keyframes growWidth {=20
  0% { transform: scaleX(0); }
  100% { transform: scaleX(1); }
}

