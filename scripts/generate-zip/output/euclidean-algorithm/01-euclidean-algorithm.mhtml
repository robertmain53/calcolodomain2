            <mn>1</mn>
            <mi>a</mi>
          </mfrac>
        </mrow>
        <munder>
          <mo>=E2=88=91<!-- =E2=88=91 --></mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>0</mn>
            <mo>=E2=89=A4<!-- =E2=89=A4 --></mo>
            <mi>b</mi>
            <mo>&lt;</mo>
            <mi>a</mi>
          </mrow>
        </munder>
        <mi>T</mi>
        <mo stretchy=3D"false">(</mo>
        <mi>a</mi>
        <mo>,</mo>
