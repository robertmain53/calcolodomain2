                    <mn>3</mn>
                  </mrow>
                </msup>
                <mo>+</mo>
                <mn>4</mn>
                <msup>
                  <mi>x</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msup>
                <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                <mn>3</mn>
                <mi>x</mi>
                <mo>+</mo>
                <mn>14</mn>
                <mo>=3D</mo>
                <mo stretchy=3D"false">(</mo>
                <msup>
                  <mi>x</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msup>
                <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                <mn>5</mn>
                <mi>x</mi>
                <mo>+</mo>
                <mn>7</mn>
                <mo stretchy=3D"false">)</mo>
                <mo stretchy=3D"false">(</mo>
                <msup>
                  <mi>x</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msup>
                <mo>+</mo>
                <mi>x</mi>
                <mo>+</mo>
                <mn>2</mn>
                <mo stretchy=3D"false">)</mo>
                <mspace width=3D"2em"></mspace>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mtext>and</mtext>
                </mrow>
              </mtd>
            </mtr>
            <mtr>
              <mtd>
                <mi>b</mi>
                <mo stretchy=3D"false">(</mo>
                <mi>x</mi>
                <mo stretchy=3D"false">)</mo>
              </mtd>
              <mtd>
                <mi></mi>
                <mo>=3D</mo>
                <msup>
                  <mi>x</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>4</mn>
                  </mrow>
                </msup>
                <mo>+</mo>
