<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e {\begin{pmatrix}g\\0\end{pmatrix}}=3D\mathbf {M} ^{-1}{\begin{pmatrix}a\\=
b\end{pmatrix}}=3D(-1)^{N+1}{\begin{pmatrix}m_{22}&amp;-m_{12}\\-m_{21}&amp=
;m_{11}\end{pmatrix}}{\begin{pmatrix}a\\b\end{pmatrix}}\,.}">
