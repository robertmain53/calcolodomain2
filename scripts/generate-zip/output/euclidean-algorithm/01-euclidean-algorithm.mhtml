          </mrow>
        </msub>
        <msub>
          <mi>h</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>2</mn>
          </mrow>
        </msub>
        <mo>+</mo>
        <mo>=E2=8B=AF<!-- =E2=8B=AF --></mo>
        <mo>+</mo>
        <msub>
          <mi>x</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
