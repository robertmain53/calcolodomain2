    <td class=3D"top" colspan=3D"2">1</td>
    <td rowspan=3D"2" class=3D"vmid">&nbsp;=3D&nbsp;2 + </td>
    <td class=3D"top" colspan=3D"3">1</td></tr>
<tr><td class=3D"vtop">4 + x</td>
    <td class=3D"vtop">4 + </td>
    <td class=3D"top">1</td>
    <td>4 + </td>
    <td colspan=3D"3" class=3D"top">1</td></tr>
<tr><td colspan=3D"4"></td>
    <td>4 + x</td>
    <td colspan=3D"2"></td>
    <td>4 + </td>
    <td class=3D"top">1</td></tr>
<tr><td colspan=3D"8"></td>
    <td>4 + x</td></tr>
