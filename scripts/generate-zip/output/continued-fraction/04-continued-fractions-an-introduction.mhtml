    <td rowspan=3D"2"> =3D </td><td class=3D"top" colspan=3D"2">1</td></tr>
<tr><td>4 + x</td><td>4 + </td><td class=3D"top">2</td>
    <td>2 + </td><td class=3D"top">1</td></tr>
