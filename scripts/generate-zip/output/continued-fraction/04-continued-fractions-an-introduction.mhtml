2</td><td colspan=3D"7"></td><td>1/1</td></tr>
<tr><th>Level 3</th><td>0/1</td><td colspan=3D"3"></td><td class=3D"red">1/=
3</td><td colspan=3D"3"></td><td>1/2</td><td colspan=3D"3"></td><td class=
=3D"red">2/3</td><td colspan=3D"3"></td><td>1/1</td></tr>
<tr><th>Level 4</th><td>0/1</td><td></td><td class=3D"red">1/4</td><td></td=
><td>1/3</td><td></td><td class=3D"red">2/5</td><td></td><td>1/2</td><td></=
td><td class=3D"red">3/5</td><td></td><td>2/3</td><td></td><td class=3D"red=
">3/4</td><td></td><td>1/1</td></tr>
<tr><th>Level 5</th><td>0/1</td><td class=3D"red">1/5</td><td>1/4</td><td c=
lass=3D"red">2/7</td><td>1/3</td><td class=3D"red">3/8</td><td>2/5</td><td =
class=3D"red">3/7</td><td>1/2</td><td class=3D"red">4/7</td><td>3/5</td><td=
 class=3D"red">5/8</td><td>2/3</td><td class=3D"red">5/7</td><td>3/4</td><t=
d class=3D"red">4/5</td><td>1/1</td></tr>
</tbody></table>
