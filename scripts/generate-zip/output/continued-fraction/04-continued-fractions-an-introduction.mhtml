 0; a<sub>1</sub>, a<sub>2</sub>, ..., a<sub>n</sub>, <span class=3D"overli=
ne"> 1 </span> ] =3D </td>
<td class=3D"top">p + P Phi</td><td rowspan=3D"2"> =3D </td><td class=3D"to=
