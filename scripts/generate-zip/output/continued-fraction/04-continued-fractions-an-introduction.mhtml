  <tbody><tr><td valign=3D"middle">=E2=88=9A14 =3D<span class=3D"red">3</sp=
an> +</td><td>
     <table class=3D"noborder m"><tbody><tr><td align=3D"center">1</td></tr=
>
     <tr><td><img src=3D"https://r-knott.surrey.ac.uk/fibonacci/black.gif" =
width=3D"100%" height=3D"1" alt=3D"--"></td></tr>
     <tr><td align=3D"center">x<sub>1</sub></td></tr>
     </tbody></table></td></tr>
  </tbody></table></td>
 <td><table class=3D"fracTBL noborder m">
         <tbody><tr><td rowspan=3D"2">x<sub>1</sub> =3D</td><td class=3D"to=
p">1</td></tr>
            <tr><td>=E2=88=9A14 =E2=88=92 3</td></tr>
         </tbody></table></td>
     <td><table class=3D"noborder m">
         <tbody><tr><td valign=3D"middle"> =3D</td><td>
            <table class=3D"noborder m">
            <tbody><tr><td align=3D"center">1</td><td>(=E2=88=9A14 + 3)</td=
></tr>
            <tr><td colspan=3D"2"><img src=3D"https://r-knott.surrey.ac.uk/=
fibonacci/black.gif" width=3D"100%" height=3D"1" alt=3D"--"></td></tr>
            <tr><td>(=E2=88=9A14 =E2=88=92 3)</td><td>(=E2=88=9A14 + 3)</td=
></tr>
            </tbody></table></td>
          <td valign=3D"middle"> =3D</td>
