@charset "utf-8";

@keyframes animate-to-2 {=20
  25%, 75% { transform: translateX(-1.5rem) scale(0.75); }
  95% { transform: translateX(0rem) scale(1); }
}

@keyframes animate-to-3 {=20
  25%, 75% { transform: translateX(1.5rem) scale(0.75); }
  95% { transform: translateX(0rem) scale(1); }
}

@keyframes animate-to-1 {=20
  25% { transform: translateX(-1.5rem) scale(0.75); }
  50%, 75% { transform: translateX(-4.5rem) scale(0.6); }
  95% { transform: translateX(0rem) scale(1); }
}

@keyframes animate-to-4 {=20
  25% { transform: translateX(1.5rem) scale(0.75); }
  50%, 75% { transform: translateX(4.5rem) scale(0.6); }
  95% { transform: translateX(0rem) scale(1); }
}

@keyframes animate-to-0 {=20
  25% { transform: translateX(-1.5rem) scale(0.75); }
  50% { transform: translateX(-4.5rem) scale(0.6); }
  75% { transform: translateX(-7.5rem) scale(0.5); }
  95% { transform: translateX(0rem) scale(1); }
}

@keyframes animate-to-5 {=20
  25% { transform: translateX(1.5rem) scale(0.75); }
  50% { transform: translateX(4.5rem) scale(0.6); }
  75% { transform: translateX(7.5rem) scale(0.5); }
  95% { transform: translateX(0rem) scale(1); }
}

.blob { width: 2rem; height: 2rem; background: rgba(230, 230, 230, 0.85); b=
order-radius: 50%; position: absolute; left: calc(50% - 1rem); top: calc(50=
% - 1rem); box-shadow: rgba(255, 255, 255, 0.25) 0px 0px 1rem; }

.blob-2 { animation: 1.5s ease 0s infinite normal none running animate-to-2=
; }

.blob-3 { animation: 1.5s ease 0s infinite normal none running animate-to-3=
; }

.blob-1 { animation: 1.5s ease 0s infinite normal none running animate-to-1=
; }

.blob-4 { animation: 1.5s ease 0s infinite normal none running animate-to-4=
; }

.blob-0 { animation: 1.5s ease 0s infinite normal none running animate-to-0=
; }

.blob-5 { animation: 1.5s ease 0s infinite normal none running animate-to-5=
; }
