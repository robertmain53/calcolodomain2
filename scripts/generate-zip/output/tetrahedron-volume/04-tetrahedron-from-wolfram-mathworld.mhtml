<!-- Begin Title -->
<h1>Tetrahedron</h1>
<!-- End Title -->
<hr class=3D"margin-t-1-8 margin-b-3-4">
<!-- Begin Total Content -->
<div class=3D"attachments text-align-r">
<a href=3D"https://mathworld.wolfram.com/notebooks/Polyhedra/Tetrahedron.nb=
