data:image/gif;base64,R0lGODlhAQABAIAAANvf7wAAACH5BAEAAAAALAAAAAABAAEAAAICR=
AEAOw=3D=3D" alt=3D"[eq19]" style=3D"background-position:0px -4041px;vertic=
al-align:-5px"></span>
