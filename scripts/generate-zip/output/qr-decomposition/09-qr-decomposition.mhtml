=3D"data:image/gif;base64,R0lGODlhAQABAIAAANvf7wAAACH5BAEAAAAALAAAAAABAAEAA=
AICRAEAOw=3D=3D" alt=3D"$K	imes L$" style=3D"background-position:0px -3872p=
