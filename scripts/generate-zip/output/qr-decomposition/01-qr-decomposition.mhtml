n class=3D"mw-editsection"><span class=3D"mw-editsection-bracket">[</span><=
a href=3D"https://en.wikipedia.org/w/index.php?title=3DQR_decomposition&amp=
;action=3Dedit&amp;section=3D15" title=3D"Edit section: Example"><span>edit=
</span></a><span class=3D"mw-editsection-bracket">]</span></span></div>
