s=3D"n">np</span><span class=3D"o">.</span><span class=3D"n">reshape</span>=
<span class=3D"p">(</span><span class=3D"n">np</span><span class=3D"o">.</s=
pan><span class=3D"n">arange</span><span class=3D"p">(</span><span class=3D=
"mi">4</span><span class=3D"p">)</span> <span class=3D"o">+</span> <span cl=
ass=3D"mi">1</span><span class=3D"n">j</span> <span class=3D"o">*</span> <s=
pan class=3D"n">np</span><span class=3D"o">.</span><span class=3D"n">arange=
</span><span class=3D"p">(</span><span class=3D"mi">4</span><span class=3D"=
p">),</span> <span class=3D"p">(</span><span class=3D"mi">2</span><span cla=
ss=3D"p">,</span> <span class=3D"mi">2</span><span class=3D"p">))</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"nb">print</span><span=
 class=3D"p">(</span><span class=3D"n">A</span><span class=3D"p">)</span>
<span class=3D"go">[[0.+0.j 1.+1.j]</span>
<span class=3D"go"> [2.+2.j 3.+3.j]]</span>

<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"nb">print</span><span=
 class=3D"p">(</span><span class=3D"n">A</span><span class=3D"o">.</span><s=
pan class=3D"n">T</span><span class=3D"p">)</span>                      <sp=
an class=3D"c1"># Regular transpose.</span>
<span class=3D"go">[[0.+0.j 2.+2.j]</span>
<span class=3D"go"> [1.+1.j 3.+3.j]]</span>

<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"nb">print</span><span=
 class=3D"p">(</span><span class=3D"n">A</span><span class=3D"o">.</span><s=
pan class=3D"n">conj</span><span class=3D"p">()</span><span class=3D"o">.</=
span><span class=3D"n">T</span><span class=3D"p">)</span>               <sp=
an class=3D"c1"># Hermitian conjugate.</span>
<span class=3D"go">[[0.-0.j 2.-2.j]</span>
<span class=3D"go"> [1.-1.j 3.-3.j]]</span>
