.comment-form label, .comment-form input { transition: 0.2s; }

.comment-form input:placeholder-shown + label, .comment-form textarea:place=
holder-shown + label { white-space: nowrap; overflow: hidden; max-width: 90=
%; text-overflow: ellipsis; cursor: text; transform: translate(0.5em, 2.35e=
