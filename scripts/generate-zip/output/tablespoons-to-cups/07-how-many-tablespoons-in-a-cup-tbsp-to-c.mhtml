 85%; color: var(--global-palette5); line-height: 1; text-decoration: none;=
 background: rgba(0, 0, 0, 0); border: 1px solid var(--global-palette7); bo=
rder-radius: 0px; }

.comment-reply-link:hover, .comment-reply-link:focus { border-color: var(--=
global-palette4); color: var(--global-palette4); cursor: pointer; }

