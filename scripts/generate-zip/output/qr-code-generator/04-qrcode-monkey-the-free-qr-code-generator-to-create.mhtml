er-wrapper.color-picker-disabled .color-picker-hue, .color-picker-wrapper.c=
olor-picker-disabled .color-picker-input, .color-picker-wrapper.color-picke=
r-disabled .color-picker-opacity, .color-picker-wrapper.color-picker-disabl=
