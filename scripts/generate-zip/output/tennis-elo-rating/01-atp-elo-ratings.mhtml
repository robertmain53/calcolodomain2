e: none; color: black; background-color: inherit; font-family: inherit; mar=
gin: 0px; }

.navbar .dropdown-content { display: none; position: absolute; background-c=
olor: rgb(245, 248, 248); min-width: 160px; box-shadow: rgba(0, 0, 0, 0.2) =
0px 8px 16px 0px; z-index: 1; }

.navbar .dropdown-content a { float: none; color: black; padding: 12px 16px=
; text-decoration: none; display: block; text-align: left; }

