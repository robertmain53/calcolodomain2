tion: left center; cursor: pointer; text-align: left; }

table.menus tbody tr.closed { background-image: url("desc.gif"); }

table.menus tbody tr.open { background-image: url("asc.gif"); }

tr.inmenu { display: none; cursor: pointer; }

tr.moresplits { display: none; }

tr.yearsplits { display: none; }

tr.selected { color: red; }

th.selected { color: blue; }

.navbar { overflow: hidden; background-color: rgb(215, 228, 228); }

