<pre class=3D"wp-block-code"><code data-highlighted=3D"yes" class=3D"hljs l=
anguage-python"><span class=3D"hljs-comment">#Imporitng libraries</span>
<span class=3D"hljs-keyword">from</span> sklearn.metrics <span class=3D"hlj=
s-keyword">import</span> mean_squared_error
<span class=3D"hljs-keyword">from</span> sklearn.metrics <span class=3D"hlj=
s-keyword">import</span> r2_score</code><button class=3D"copy-button btn bt=
n-dark rounded-3 fs-12">Copy Code</button></pre>



<pre class=3D"wp-block-code"><code data-highlighted=3D"yes" class=3D"hljs l=
anguage-less"><span class=3D"hljs-selector-id">#RMSE</span> <span class=3D"=
