<pre class=3D"wp-block-code"><code data-highlighted=3D"yes" class=3D"hljs l=
anguage-python"><span class=3D"hljs-keyword">from</span> sklearn.linear_mod=
el <span class=3D"hljs-keyword">import</span> LinearRegression
<span class=3D"hljs-comment">#Representing LinearRegression as lr (creating=
 LinearRegression object)</span>
lr =3D LinearRegression()
<span class=3D"hljs-comment">#Fit the model using lr.fit()</span>
lr.fit( X_train_lm , y_train_lm )</code><button class=3D"copy-button btn bt=
n-dark rounded-3 fs-12">Copy Code</button></pre>



