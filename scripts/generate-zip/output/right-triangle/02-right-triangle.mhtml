            <mn>2</mn>
          </mrow>
        </msubsup>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mn>5</mn>
            <mn>4</mn>
          </mfrac>
        </mrow>
        <msup>
          <mi>c</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>2</mn>
          </mrow>
        </msup>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle m_{a}^{2}+m_{=
