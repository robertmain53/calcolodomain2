            <mn>2</mn>
          </mrow>
        </msubsup>
        <mo>+</mo>
        <msubsup>
          <mi>m</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>b</mi>
          </mrow>
