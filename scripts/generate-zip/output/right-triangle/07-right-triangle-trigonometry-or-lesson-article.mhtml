@charset "utf-8";

html { overflow: hidden; }

body { font: 12px Roboto, Arial, sans-serif; background-color: rgb(0, 0, 0)=
; color: rgb(255, 255, 255); height: 100%; width: 100%; overflow: hidden; p=
osition: absolute; margin: 0px; padding: 0px; }

#player { width: 100%; height: 100%; }

h1 { text-align: center; color: rgb(255, 255, 255); }

h3 { margin-top: 6px; margin-bottom: 3px; }

.player-unavailable { position: absolute; inset: 0px; padding: 25px; font-s=
ize: 13px; background: url("/img/meh7.png") 50% 65% no-repeat; }

.player-unavailable .message { text-align: left; margin: 0px -5px 15px; pad=
ding: 0px 5px 14px; border-bottom: 1px solid rgb(136, 136, 136); font-size:=
 19px; font-weight: normal; }

.player-unavailable a { color: rgb(22, 122, 198); text-decoration: none; }
