@keyframes fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes fadeInScaleUp {=20
  0% { opacity: 0; transform: scaleX(0.5) scaleY(0.5) translateY(60px); }
  100% { opacity: 1; transform: scaleX(1) scaleY(1) translateY(0px); }
}

@keyframes fadeInUp {=20
  0% { opacity: 0; transform: translateY(60px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes popOut {=20
  0% { opacity: 0; transform: scale(.74) translateY(var(--pop-translate-sta=
rt)); }
  100% { opacity: 1; transform: scale(1) translateY(0px); }
}

@keyframes up1 {=20
  0% { transform: translateY(40px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes up2 {=20
  0% { transform: translateY(100px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes up3 {=20
  0% { transform: translateY(120px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes fadeInLeft {=20
  0% { transform: translateX(-200px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes fadeInRight {=20
  0% { transform: translateX(200px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.draw-arrow { animation: unset; opacity: 1 !important; }

.draw-arrow path { stroke: var(--main-dark); stroke-width: 2; fill: none; s=
troke-dasharray: 300; stroke-dashoffset: 300; animation: 1.5s ease 0.6s 1 n=
ormal forwards running drawArrow; }

@keyframes drawArrow {=20
  0% { stroke-dashoffset: 300; }
  100% { stroke-dashoffset: 0; fill: var(--main-dark); }
}

@keyframes cardFadeInUp {=20
  0% { opacity: 0; transform: translateY(60px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes confettiBounce {=20
  0% { opacity: 0; transform: scale(0.2); }
  60% { opacity: 1; transform: scale(1.2); }
  80% { transform: scale(0.95); }
  100% { opacity: 1; transform: scale(1); }
}

