=3D"application/x-tex">\sin(x)</annotation></semantics></math></span><span =
class=3D"katex-html" aria-hidden=3D"true"><span class=3D"base"><span class=
=3D"strut" style=3D"height: 1em; vertical-align: -0.25em;"></span><span cla=
ss=3D"mop">sin</span><span class=3D"mopen">(</span><span class=3D"mord math=
normal">x</span><span class=3D"mclose">)</span></span></span></span></span>=
 and all of its derivatives when <span><span class=3D"katex"><span class=3D=
"katex-mathml"><math xmlns=3D"http://www.w3.org/1998/Math/MathML"><semantic=
s><mrow><mi>x</mi><mo>=3D</mo><mn>0</mn></mrow><annotation encoding=3D"appl=
ication/x-tex">x=3D0</annotation></semantics></math></span><span class=3D"k=
