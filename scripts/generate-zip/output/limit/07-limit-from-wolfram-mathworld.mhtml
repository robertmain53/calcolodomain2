<h1>Limit</h1>
<!-- End Title -->
<hr class=3D"margin-t-1-8 margin-b-3-4">
<!-- Begin Total Content -->
<div class=3D"attachments text-align-r">
<a href=3D"https://mathworld.wolfram.com/notebooks/Calculus/Limit.nb" downl=
oad=3D"Limit.nb"><img src=3D"https://mathworld.wolfram.com/images/entries/d=
