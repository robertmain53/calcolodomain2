l-align: -2.005ex; width:15.923ex; height:5.843ex;" alt=3D"{\displaystyle \=
lim _{x\to 1}{\frac {x^{2}-1}{x-1}}=3D2.}"></span>
</p><p>This can also be calculated algebraically, as <span class=3D"mwe-mat=
h-element mwe-math-element-inline"><span class=3D"mwe-math-mathml-inline mw=
e-math-mathml-a11y" style=3D"display: none;"><math xmlns=3D"http://www.w3.o=
rg/1998/Math/MathML" alttext=3D"{\textstyle {\frac {x^{2}-1}{x-1}}=3D{\frac=
 {(x+1)(x-1)}{x-1}}=3Dx+1}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"false" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
            <mrow>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
          </mfrac>
        </mrow>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mo stretchy=3D"false">(</mo>
              <mi>x</mi>
              <mo>+</mo>
              <mn>1</mn>
              <mo stretchy=3D"false">)</mo>
              <mo stretchy=3D"false">(</mo>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
              <mo stretchy=3D"false">)</mo>
            </mrow>
            <mrow>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
          </mfrac>
        </mrow>
        <mo>=3D</mo>
        <mi>x</mi>
        <mo>+</mo>
        <mn>1</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\textstyle {\frac {x^{2}-1}=
{x-1}}=3D{\frac {(x+1)(x-1)}{x-1}}=3Dx+1}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/756568d549e00d66356f7dd5d26f770ae61b38a3" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.338ex; width:25.714ex; height:4.343ex;" alt=3D"{\textstyle {\fra=
c {x^{2}-1}{x-1}}=3D{\frac {(x+1)(x-1)}{x-1}}=3Dx+1}"></span> for all real =
numbers <span class=3D"texhtml"><i>x</i> =E2=89=A0 1</span>.
</p><p>Now, since <span class=3D"texhtml"><i>x</i> + 1</span> is continuous=
 in <span class=3D"texhtml mvar" style=3D"font-style:italic;">x</span> at 1=
, we can now plug in 1 for <span class=3D"texhtml mvar" style=3D"font-style=
:italic;">x</span>, leading to the equation
<span class=3D"mwe-math-element mwe-math-element-block"><span class=3D"mwe-=
math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;"><math di=
splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle \lim _{x\to 1}{\frac {x^{2}-1}{x-1}}=3D1+1=3D2.}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <munder>
          <mo movablelimits=3D"true" form=3D"prefix">lim</mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>x</mi>
            <mo stretchy=3D"false">=E2=86=92<!-- =E2=86=92 --></mo>
            <mn>1</mn>
          </mrow>
        </munder>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
            <mrow>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
          </mfrac>
        </mrow>
        <mo>=3D</mo>
        <mn>1</mn>
        <mo>+</mo>
        <mn>1</mn>
        <mo>=3D</mo>
        <mn>2.</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \lim _{x\to 1=
}{\frac {x^{2}-1}{x-1}}=3D1+1=3D2.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/9c16112b53eb1f6c63555c7f678fd3b55d468b0c" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -2.005ex; width:24.187ex; height:5.843ex;" alt=3D"{\displaystyle \=
lim _{x\to 1}{\frac {x^{2}-1}{x-1}}=3D1+1=3D2.}"></span>
</p><p>In addition to limits at finite values, functions can also have limi=
ts at infinity. For example, consider the function
<span class=3D"mwe-math-element mwe-math-element-block"><span class=3D"mwe-=
math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;"><math di=
splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle f(x)=3D{\frac {2x-1}{x}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>f</mi>
        <mo stretchy=3D"false">(</mo>
        <mi>x</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mn>2</mn>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
            <mi>x</mi>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle f(x)=3D{\frac=
 {2x-1}{x}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/fe98ae2a5d981af203c092705320d924a5f10068" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -1.838ex; width:14.847ex; height:5.176ex;" alt=3D"{\displaystyle f=
(x)=3D{\frac {2x-1}{x}}}"></span>
where:
</p>
<ul><li><span class=3D"texhtml"><i>f</i>(100) =3D 1.9900</span></li>
<li><span class=3D"texhtml"><i>f</i>(1000) =3D 1.9990</span></li>
<li><span class=3D"texhtml"><i>f</i>(10000) =3D 1.9999</span></li></ul>
<p>As <span class=3D"texhtml mvar" style=3D"font-style:italic;">x</span> be=
comes extremely large, the value of <span class=3D"texhtml"><i>f</i>(<i>x</=
i>)</span> approaches <span class=3D"texhtml">2</span>, and the value of <s=
pan class=3D"texhtml"><i>f</i>(<i>x</i>)</span> can be made as close to <sp=
an class=3D"texhtml">2</span> as one could wish=E2=80=94by making <span cla=
ss=3D"texhtml mvar" style=3D"font-style:italic;">x</span> sufficiently larg=
e. So in this case, the limit of <span class=3D"texhtml"><i>f</i>(<i>x</i>)=
</span> as <span class=3D"texhtml mvar" style=3D"font-style:italic;">x</spa=
n> approaches infinity is <span class=3D"texhtml">2</span>, or in mathemati=
cal notation,<span class=3D"mwe-math-element mwe-math-element-block"><span =
class=3D"mwe-math-mathml-display mwe-math-mathml-a11y" style=3D"display: no=
ne;"><math display=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" a=
lttext=3D"{\displaystyle \lim _{x\to \infty }{\frac {2x-1}{x}}=3D2.}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
