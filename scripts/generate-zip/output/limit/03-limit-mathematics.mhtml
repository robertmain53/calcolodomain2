        <mi>L</mi>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \lim _{x\to c=
}f(x)=3DL,}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/f5c4adc667e687e332a498508b01cda56fbfc208" class=3D"mwe-math-fallback=
