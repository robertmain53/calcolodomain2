          <mo movablelimits=3D"true" form=3D"prefix">lim</mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>x</mi>
            <mo stretchy=3D"false">=E2=86=92<!-- =E2=86=92 --></mo>
            <mi mathvariant=3D"normal">=E2=88=9E<!-- =E2=88=9E --></mi>
          </mrow>
        </munder>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mn>2</mn>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
            <mi>x</mi>
          </mfrac>
        </mrow>
        <mo>=3D</mo>
        <mn>2.</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \lim _{x\to \=
infty }{\frac {2x-1}{x}}=3D2.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/9fd3ae906a64d6a49a74d2d4d10c19002da495a7" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -1.838ex; width:16.852ex; height:5.176ex;" alt=3D"{\displaystyle \=
