</mo><mi>n</mi></mrow><annotation encoding=3D"application/x-tex">P =3D a \t=
imes n</annotation></semantics></math></span><span class=3D"katex-html" ari=
a-hidden=3D"true"><span class=3D"base"><span class=3D"strut" style=3D"heigh=
