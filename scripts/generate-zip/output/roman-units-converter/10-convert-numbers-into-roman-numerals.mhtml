 margin: -1px; padding: 0px; border: 0px; overflow-wrap: normal !important;=
 }

.wpcf7 form .wpcf7-response-output { margin: 2em 0.5em 1em; padding: 0.2em =
1em; border: 2px solid rgb(0, 160, 210); }

