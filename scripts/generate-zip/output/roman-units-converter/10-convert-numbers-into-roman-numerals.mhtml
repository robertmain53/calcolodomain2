r: rgb(35, 40, 45); opacity: 0.75; width: 24px; height: 24px; border: none;=
 border-radius: 100%; padding: 0px; margin: 0px 24px; position: relative; }

form.submitting .wpcf7-spinner { visibility: visible; }

