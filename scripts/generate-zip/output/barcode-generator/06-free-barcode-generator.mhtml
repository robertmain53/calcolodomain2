footer .download-links a:hover { transform: scale(1.1); opacity: 1; }

footer .footer-header { font-weight: var(--font-weight-medium); font-size: =
var(--font-size-large); color: var(--footer-header-color); margin: 10px 0px=
 12px; position: relative; display: block; text-align: right; }

footer .social-legal-section { display: grid; grid-template-columns: auto a=
uto; row-gap: 30px; }

footer hr { border-width: 1px 0px 0px; border-right-style: initial; border-=
bottom-style: initial; border-left-style: initial; border-right-color: init=
ial; border-bottom-color: initial; border-left-color: initial; border-image=
: initial; border-top-style: solid; border-top-color: rgb(55, 59, 63); marg=
in: 36px 0px; }

.social-app-links { display: grid; grid-template-columns: auto auto; }

@media (max-width: 900px) {
  footer .footer-links ul { text-align: left; }
}

@media (max-width: 655px) {
  footer .copyright { line-height: normal; }
}

@media (max-width: 597px) {
  footer .download-links { display: grid; grid-template-columns: 1fr 1fr; }
  footer .product-hunt-badge { grid-area: 2 / 1 / auto / span 2; justify-se=
lf: center; }
  footer .product-hunt-badge a { margin: 10px 0px 20px; padding: 0px !impor=
tant; }
  footer .product-hunt-badge img { height: auto !important; }
}

@media (max-width: 480px) {
  footer .footer-links ul { text-align: center; }
  footer hr { display: none; }
  .social-legal-section { text-align-last: center; row-gap: 20px; grid-temp=
