ontent: center; left: 0px; opacity: 0; position: fixed; top: 0px; width: 10=
0vw; z-index: 9999; }

body:not(.cq-wcm-edit) .deprecated-browser--active { animation: 0.3s ease-i=
n 0s 1 normal forwards running fadeIn; display: flex; }

