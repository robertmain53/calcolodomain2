.cq-wcm-edit .deprecated-browser__popup { display: block; position: relativ=
e; }

.cq-wcm-edit .deprecated-browser__close { display: none; }

.deprecated-browser__container { background-color: rgb(255, 255, 255); bord=
er: 1px solid rgb(216, 216, 220); border-radius: 4px; position: relative; }

.deprecated-browser__close { cursor: pointer; padding: 20px; position: abso=
