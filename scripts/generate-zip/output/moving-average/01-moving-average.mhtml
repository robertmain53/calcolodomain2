margin: 0px 2em; }

.mw-gallery-slideshow .mw-gallery-slideshow-buttons .oo-ui-buttonElement:fi=
rst-child { margin-left: 0px; }

.mw-gallery-slideshow .mw-gallery-slideshow-buttons .oo-ui-buttonElement:la=
st-child { margin-right: 0px; }

.mw-gallery-slideshow .gallerybox.slideshow-current { background: var(--bac=
kground-color-interactive,#eaecf0); }

.mw-gallery-slideshow .gallerybox > div { max-width: 120px; }

.mw-gallery-slideshow .gallerybox div.thumb { border: 0px; background: tran=
