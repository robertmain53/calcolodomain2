                <mo maxsize=3D"1.2em" minsize=3D"1.2em">(</mo>
              </mrow>
              <mfrac linethickness=3D"0">
                <mi>m</mi>
                <mn>2</mn>
              </mfrac>
              <mrow class=3D"MJX-TeXAtom-CLOSE">
                <mo maxsize=3D"1.2em" minsize=3D"1.2em">)</mo>
              </mrow>
            </mrow>
