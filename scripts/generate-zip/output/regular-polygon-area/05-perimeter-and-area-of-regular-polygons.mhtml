ps://mathbitsnotebook.com/Geometry/Polygons/apothemformulag.gif" alt=3D"apo=
themformula" width=3D"127" height=3D"100"><br>
              </div></td>
            </tr>
            <tr>
              <td colspan=3D"2" class=3D"TimesBlack24"><div align=3D"center=
" class=3D"TimesBlack10">(where <em>a</em> =3D apothem and <em>p</em> =3D p=
erimeter) </div></td>
              </tr>
          </tbody></table></td>
        </tr>
</tbody></table>
      <p>&nbsp;</p>
      <table width=3D"750" border=3D"1" align=3D"center" cellpadding=3D"6" =
