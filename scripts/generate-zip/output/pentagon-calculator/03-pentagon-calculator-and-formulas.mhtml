</td><td><p><code>a=C2=B2/4 =C3=97 =E2=88=9A(25 + 10=E2=88=9A5)</code></p>
</td></tr><tr><td><p>Perimeter</p>
</td><td><p><code>5a</code></p>
</td></tr><tr><td><p>Diagonal (d)</p>
</td><td><p><code>a/2 =C3=97 (1 + =E2=88=9A5)</code></p>
</td></tr><tr><td><p>Height (h)</p>
</td><td><p><code>a/2 =C3=97 =E2=88=9A(5 + 2=E2=88=9A5)</code></p>
</td></tr><tr><td><p>Circumcircle radius (R)</p>
</td><td><p><code>a/10 =C3=97 =E2=88=9A(50 + 10=E2=88=9A5)</code></p>
</td></tr><tr><td><p>Incircle radius (apothem) (r)</p>
</td><td><p><code>a/10 =C3=97 =E2=88=9A(25 + 10=E2=88=9A5)</code></p>
