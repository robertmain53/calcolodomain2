@charset "utf-8";

.ibis-bookmark { display: inline-block; }

.ibis-bookmark__button { margin: 0px; border: none; border-radius: 0px; bac=
kground: none; font: inherit; display: inline-flex; align-items: center; pa=
dding: 0px; color: rgb(10, 70, 68); white-space: nowrap; transition: color =
0.666s; }

.ibis-bookmark__button:not([disabled]) { cursor: pointer; }

.ibis-bookmark__button:focus { outline: rgb(0, 181, 230) solid 2px; outline=
-offset: 2px; }

html[data-whatintent=3D"mouse"] .ibis-bookmark__button:focus { outline: non=
e; }

.ibis-bookmark__button[disabled] { color: rgb(199, 198, 204); pointer-event=
s: none; }

.ibis-bookmark__label { text-decoration: underline 0.125em rgb(190, 87, 74)=
; text-underline-offset: 0.35rem; font-weight: 600; }

.ibis-bookmark__label:hover { text-decoration-color: rgb(10, 70, 68); }

.ibis-bookmark__icon { width: 1.25rem; height: 1.25rem; margin-right: 0.5re=
m; }
