          <mi mathvariant=3D"normal">e</mi>
          <mi mathvariant=3D"normal">s</mi>
        </mrow>
        <mo stretchy=3D"false">)</mo>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \sigma =3D{\s=
qrt {\mathrm {average} \left((v-\mu )^{2}{\text{ for }}v\in \mathrm {values=
} \right)}}{\text{ where }}\mu =3D\mathrm {average} (\mathrm {values} ).}</=
annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/1ca8469f2609e7fd8a2ff15f972dd56c128952f7" class=3D"mwe-math-fallback=
