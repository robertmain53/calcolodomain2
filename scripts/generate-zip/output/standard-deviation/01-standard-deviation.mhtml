                  <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                  <mn>1</mn>
                </mrow>
              </mfrac>
            </mrow>
            <munderover>
              <mo>=E2=88=91<!-- =E2=88=91 --></mo>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mi>i</mi>
                <mo>=3D</mo>
                <mn>1</mn>
              </mrow>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mi>N</mi>
              </mrow>
            </munderover>
            <msup>
              <mrow>
                <mo>(</mo>
                <mrow>
