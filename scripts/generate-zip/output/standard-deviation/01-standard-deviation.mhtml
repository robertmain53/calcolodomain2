                    <msup>
                      <mi>=CF=83<!-- =CF=83 --></mi>
                      <mrow class=3D"MJX-TeXAtom-ORD">
                        <mn>2</mn>
                      </mrow>
                    </msup>
                  </mrow>
                </msup>
                <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                <mn>1</mn>
              </mrow>
              <mo>)</mo>
            </mrow>
            <mtext>&nbsp;</mtext>
            <msup>
              <mi>e</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>2</mn>
                <mi>=CE=BC<!-- =CE=BC --></mi>
                <mo>+</mo>
                <msup>
                  <mi>=CF=83<!-- =CF=83 --></mi>
