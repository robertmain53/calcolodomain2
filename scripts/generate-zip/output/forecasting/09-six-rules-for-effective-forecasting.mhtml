@font-face { font-family: "Tiempos Headline"; src: url("https://i.piano.io/=
managedservices/HBR/fonts/TiemposHeadline-Black.woff") format("woff"); font=
-weight: 900; }

* { box-sizing: border-box; }

body, p, h1, h2, h3, button, ul { margin: 0px; padding: 0px; }

button { background-color: rgba(0, 0, 0, 0); border: 0px; outline: 0px; cur=
sor: pointer; }

img, svg { display: block; max-height: 100%; height: auto; }

ul { list-style: none; }

a { text-decoration: none; }

strong { display: block; font-family: inherit; }

b { font-family: inherit; }

#ng-app, #checkout-container, body { background: rgba(0, 0, 0, 0); }

.pn-article { display: flex; justify-content: center; padding: 30px 16px; b=
order-radius: 5px 5px 0px 0px; background-color: rgb(40, 40, 40); }

.pn-article__inner { display: flex; max-width: 650px; width: 100%; }

@media (max-width: 414px) {
  .pn-article__inner { flex-direction: column; }
}

.pn-article__title { max-width: 316px; width: 100%; padding-right: 24px; ma=
rgin-right: 24px; font-family: "Tiempos Headline", Georgia, serif; color: r=
gb(255, 255, 255); font-size: 21px; font-style: normal; font-weight: 900; l=
ine-height: 26px; letter-spacing: -0.01px; border-right: 1px solid rgb(136,=
 136, 136); }

@media (max-width: 414px) {
  .pn-article__title { padding: 0px 0px 12px; margin: 0px 0px 12px; max-wid=
th: none; border-right: 0px; border-bottom: 1px solid rgb(136, 136, 136); }
}

.pn-article__title span { color: rgb(160, 198, 244); }

.pn-article__copy { align-self: center; color: rgb(255, 255, 255); font-fam=
ily: "GT America", Helvetica, sans-serif; font-size: 16px; font-style: norm=
al; font-weight: 400; line-height: 22px; letter-spacing: 0.021px; }

@media (max-width: 414px) {
  .pn-article__copy { align-self: flex-start; }
}

.pn-article__copy a { color: rgb(255, 255, 255); font-weight: 700; border-b=
ottom: 3px solid rgb(160, 198, 244); }

.pn-article__close { position: absolute; top: 16px; right: 16px; }

@media (max-width: 414px) {
  .pn-article__close { top: 10px; right: 10px; }
}
