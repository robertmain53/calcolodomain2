            <mrow class=3D"MJX-TeXAtom-ORD">
              <mfrac>
                <mrow>
                  <mi>Z</mi>
                  <mi>=CF=83<!-- =CF=83 --></mi>
                </mrow>
                <msqrt>
                  <mi>n</mi>
                </msqrt>
              </mfrac>
