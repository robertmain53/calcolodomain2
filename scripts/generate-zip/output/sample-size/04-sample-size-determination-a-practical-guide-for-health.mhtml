@keyframes iziT-revealIn {=20
  0% { opacity: 0; transform: scale3d(0.3, 0.3, 1); }
  100% { opacity: 1; }
}

@keyframes iziT-slideIn {=20
  0% { opacity: 0; transform: translate(50px); }
  100% { opacity: 1; transform: translate(0px); }
}

@keyframes iziT-bounceInLeft {=20
  0% { opacity: 0; transform: translate(280px); }
  50% { opacity: 1; transform: translate(-20px); }
  70% { transform: translate(10px); }
  100% { transform: translate(0px); }
}

@keyframes iziT-bounceInRight {=20
  0% { opacity: 0; transform: translate(-280px); }
  50% { opacity: 1; transform: translate(20px); }
  70% { transform: translate(-10px); }
  100% { transform: translate(0px); }
}

@keyframes iziT-bounceInDown {=20
  0% { opacity: 0; transform: translateY(-200px); }
  50% { opacity: 1; transform: translateY(10px); }
  70% { transform: translateY(-5px); }
  100% { transform: translateY(0px); }
}

@keyframes iziT-bounceInUp {=20
  0% { opacity: 0; transform: translateY(200px); }
  50% { opacity: 1; transform: translateY(-10px); }
  70% { transform: translateY(5px); }
  100% { transform: translateY(0px); }
}

@keyframes iziT-fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes iziT-fadeInUp {=20
  0% { opacity: 0; transform: translate3d(0px, 100%, 0px); }
  100% { opacity: 1; transform: none; }
}

@keyframes iziT-fadeInDown {=20
  0% { opacity: 0; transform: translate3d(0px, -100%, 0px); }
  100% { opacity: 1; transform: none; }
}

@keyframes iziT-fadeInLeft {=20
  0% { opacity: 0; transform: translate3d(300px, 0px, 0px); }
  100% { opacity: 1; transform: none; }
}

@keyframes iziT-fadeInRight {=20
  0% { opacity: 0; transform: translate3d(-300px, 0px, 0px); }
  100% { opacity: 1; transform: none; }
}

@keyframes iziT-flipInX {=20
  0% { transform: perspective(400px) rotateX(90deg); opacity: 0; }
  40% { transform: perspective(400px) rotateX(-20deg); }
  60% { transform: perspective(400px) rotateX(10deg); opacity: 1; }
  80% { transform: perspective(400px) rotateX(-5deg); }
  100% { transform: perspective(400px); }
}

@keyframes iziT-fadeOut {=20
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes iziT-fadeOutDown {=20
  0% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(0px, 100%, 0px); }
}

@keyframes iziT-fadeOutUp {=20
