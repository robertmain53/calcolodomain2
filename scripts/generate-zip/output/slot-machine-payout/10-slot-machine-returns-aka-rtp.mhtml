h2 + h3 { border-top: none; }

#practice td { text-align: center; min-width: 165px; height: 157px; }

#practice img { border-radius: 12px; border: 6px solid transparent; }

#practice img:hover { width: 160px; height: 126px; border: 2px solid blue; =
}

#practice h2 { background: none; margin: 0px; }

#practice a:link { text-decoration: none; }

#practice a:hover { background: none; }

#page { padding: 5px; background-color: white; }

#lefty, #righty { display: none; }

article p { margin-left: 0px; }

.il { border-radius: 9px; padding-left: 0px; display: block; margin: auto; =
}

h2 { font-size: 19px; }

img { max-width: 100%; }

#thirdPracticeIcon { display: none; }

#fourthPracticeIcon { display: none; }

.floatOrNot { border-radius: 12px; display: block; margin: auto auto 8px; }

.floatOrNot img { border-radius: 12px; }

li .floatOrNot { margin-left: -10px; }

@media screen and (min-width: 481px) {
  #page { margin-top: 10px; padding: 15px; border: 1px solid silver; border=
-radius: 9px; overflow: auto; }
  #mbj { margin: 0px; font: italic 14px Arial; }
  article p { margin-left: 30px; }
  .il { float: right; margin: 0px 0px 10px 10px; }
  .floatOrNot, li .floatOrNot { float: right; margin-left: 10px; }
  #ban { border: 1px solid silver; border-radius: 9px; padding: 3px; font: =
