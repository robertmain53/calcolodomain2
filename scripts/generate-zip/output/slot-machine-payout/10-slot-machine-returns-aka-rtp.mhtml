 0px; border: none; }

.dataTable tr:nth-child(2) td { background: gainsboro; font-weight: bold; f=
ont-size: 12px; padding: 4px; }

.dataTable td { border: 1px solid silver; padding: 3px 4px; text-align: cen=
ter; font: 14px Arial; }

.dataTable td:first-child { text-align: left; }

#bottomAd { font: 12.5px Arial; text-align: center; padding: 3px; width: 10=
0%; position: fixed; bottom: 0px; background: lightskyblue; }

@media screen and (min-width: 415px) {
  #bottomAd { display: none; }
}

@font-face { font-family: RobotoSlab; font-style: normal; font-weight: norm=
al; src: url("/parts/RobotoSlab-Regular.woff2"); }

@font-face { font-family: RobotoSlab; font-style: normal; font-weight: bold=
; src: url("/parts/RobotoSlab-Bold.woff2"); }

article { font: 17px / 200% RobotoSlab; }

h1, h2, h3 { line-height: 130%; }

h1 { margin-bottom: 0px; font: 36px Georgia; color: saddlebrown; text-align=
: center; }

h2 { padding: 3px 0px 3px 10px; font: bold 22px / 120% Tahoma, AvenirNextCo=
ndensed-Regular, "Roboto Condensed"; color: darkslategray; background: pale=
goldenrod; border-radius: 8px; letter-spacing: 0.02em; }

h3 { margin: 0px 0px -5px -5px; padding: 5px 0px 0px 10px; font: bold 20px =
