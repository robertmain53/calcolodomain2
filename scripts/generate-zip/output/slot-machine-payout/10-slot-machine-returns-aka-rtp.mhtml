der-radius: 6px; }

div.linebreak { display: block; }

article .playSlots img { width: 260px; height: 195px; margin: 20px; }

article .playSlots .linebreak { display: inline; }

article .playSlots .thumbshotProblem { display: none; }

a:hover { background: lightskyblue; }

.nohover a:hover { background: none; }

table { font: 12px / 170% Verdana; }

small, .sm { font-size: 80%; }

.ctr { text-align: center; }

.dataTable { margin: auto; border-collapse: collapse; }

.dataTable tr:nth-child(1) td { background: black; color: orange; text-alig=
