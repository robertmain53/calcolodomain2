@charset "utf-8";

.sf-menu, .sf-menu * { margin: 0px; padding: 0px; list-style: none; }

.sf-menu { line-height: 29px; }

.sf-menu ul { position: absolute; top: -999em; width: 200px; }

.sf-menu ul li { width: 95%; line-height: 29px; }

.sf-menu li:hover { visibility: inherit; }

.sf-menu li { float: left; position: relative; border-right: 1px solid rgb(=
255, 255, 255); padding: 0px 0.1em; }

