.sf-menu li:hover ul, .sf-menu li.sfHover ul { left: 0px; top: 29px; z-inde=
x: 99; background: rgb(204, 204, 204); opacity: 0.98; padding-bottom: 5px; =
}

ul.sf-menu li:hover li ul, ul.sf-menu li.sfHover li ul { top: -999em; }

ul.sf-menu li li:hover ul, ul.sf-menu li li.sfHover ul { left: 200px; top: =
0px; }

ul.sf-menu li li:hover li ul, ul.sf-menu li li.sfHover li ul { top: -999em;=
 }

ul.sf-menu li li li:hover ul, ul.sf-menu li li li.sfHover ul { left: 200px;=
 top: 0px; }

.sf-menu { float: left; }

.sf-menu a { text-decoration: none; }

.sf-menu a, .sf-menu a:visited { color: rgb(255, 255, 255); text-decoration=
: none; }

.sf-menu li li a, .sf-menu li li a:visited { color: rgb(0, 0, 0); text-deco=
ration: none; }

.sf-menu li { padding: 0px 10px; }

