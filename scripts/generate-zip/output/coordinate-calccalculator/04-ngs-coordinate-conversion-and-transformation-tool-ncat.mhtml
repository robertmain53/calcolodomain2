.sf-menu li li li { background: rgb(154, 174, 219); }

.sf-menu li li:hover, .sf-menu li li:focus { display: block; background-col=
or: rgb(245, 245, 245); }

.sf-menu li li a:hover, .sf-menu li li a:focus { color: rgb(0, 0, 0); }

.sf-menu li:hover, .sf-menu a:visited:hover, .sf-menu li.sfHover, .sf-menu =
a:focus, .sf-menu a:hover, .sf-menu a:active { outline: 0px; text-decoratio=
n: none; }

.sf-menu a.sf-with-ul { padding-right: 2.25em; min-width: 1px; }

.sf-sub-indicator { position: absolute; display: block; right: 0.75em; top:=
 1.05em; width: 10px; height: 10px; text-indent: -999em; overflow: hidden; =
