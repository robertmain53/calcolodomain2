isplaystyle A=3D{\begin{bmatrix}2&amp;0&amp;0&amp;0\\1&amp;2&amp;0&amp;0\\0=
&amp;1&amp;3&amp;0\\0&amp;0&amp;1&amp;3\end{bmatrix}},}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
