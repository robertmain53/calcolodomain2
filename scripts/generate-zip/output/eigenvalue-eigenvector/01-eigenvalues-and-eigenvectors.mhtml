=3D\lambda \mathbf {v} .}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/bab09470c0a743ad21485fe638ce04b8fdf3e68c" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -0.338ex; width:9.666ex; height:2.176ex;" alt=3D"{\displaystyle A\=
mathbf {v} =3D\lambda \mathbf {v} .}"></span>
</p><p>The eigenvalue and eigenvector problem can also be defined for <em>r=
ow</em> vectors that <em>left</em> multiply matrix <span class=3D"texhtml m=
var" style=3D"font-style:italic;">A</span>. In this formulation, the defini=
ng equation is
<span class=3D"mwe-math-element mwe-math-element-block"><span class=3D"mwe-=
math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;"><math di=
splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle \mathbf {u} A=3D\kappa \mathbf {u} ,}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mi mathvariant=3D"bold">u</mi>
        </mrow>
        <mi>A</mi>
        <mo>=3D</mo>
        <mi>=CE=BA<!-- =CE=BA --></mi>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mi mathvariant=3D"bold">u</mi>
        </mrow>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \mathbf {u} A=
=3D\kappa \mathbf {u} ,}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/bc646b147f57577a121c299aaa300c1dd928bff6" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
