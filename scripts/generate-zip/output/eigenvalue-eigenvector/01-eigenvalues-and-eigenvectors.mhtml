          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi mathvariant=3D"bold">v</mi>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>=CE=BB<!-- =CE=BB --></mi>
            <mo>=3D</mo>
            <mn>3</mn>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mrow>
            <mo>[</mo>
