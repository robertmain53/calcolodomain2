    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>A</mi>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mrow>
            <mo>[</mo>
            <mtable rowspacing=3D"4pt" columnspacing=3D"1em">
              <mtr>
                <mtd>
                  <mn>1</mn>
                </mtd>
