ps://en.wikipedia.org/wiki/Area#cite_note-30"><span class=3D"cite-bracket">=
[</span>30<span class=3D"cite-bracket">]</span></a></sup><sup id=3D"cite_re=
f-31" class=3D"reference"><a href=3D"https://en.wikipedia.org/wiki/Area#cit=
e_note-31"><span class=3D"cite-bracket">[</span>31<span class=3D"cite-brack=
et">]</span></a></sup>
<span class=3D"mwe-math-element mwe-math-element-block"><span class=3D"mwe-=
math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;"><math di=
splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle A=3D{\frac {(b^{2}-4ac)^{3/2}}{6a^{2}}}=3D{\frac {a}{6}}(\beta =
-\alpha )^{3},\qquad a\neq 0.}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
