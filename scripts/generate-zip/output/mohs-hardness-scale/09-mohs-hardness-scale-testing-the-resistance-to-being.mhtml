<tr bgcolor=3D"#FFE" align=3D"center"><td>Gypsum</td><td>2</td><td>61</td><=
/tr>
<tr bgcolor=3D"#FFE" align=3D"center"><td>Calcite</td><td>3</td><td>157</td=
