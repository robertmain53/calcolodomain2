<td colspan=3D"2" bgcolor=3D"#ddd"><center><b>Mohs Hardness of Common Objec=
ts</b></center></td></tr>
  <tr bgcolor=3D"#FFE"><td> &nbsp; Fingernail</td><td align=3D"center">2 to=
 2.5</td></tr>
  <tr bgcolor=3D"#FFE"><td> &nbsp; Copper sheet</td><td align=3D"center">3<=
/td></tr>
  <tr bgcolor=3D"#FFE"><td> &nbsp; Nail</td><td align=3D"center">4 to 7</td=
></tr>
  <tr bgcolor=3D"#FFE"><td> &nbsp; Glass</td><td align=3D"center">4 to 7</t=
d></tr>
  <tr bgcolor=3D"#FFE"><td> &nbsp; Knife blade</td><td align=3D"center">5 t=
o 6.5</td></tr>
  <tr bgcolor=3D"#FFE"><td> &nbsp; Steel file</td><td align=3D"center">5 to=
 6.5</td></tr>
  <tr bgcolor=3D"#FFE"><td> &nbsp; Streak plate</td><td align=3D"center">5 =
