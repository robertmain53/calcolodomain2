}
  .blogContainer h2, .blogContainer h2 a { font-size: var(--font-size-h4); =
}
  .blogContainer h3, .blogContainer h3 a { font-size: var(--font-size-h5); =
}
  .blogContainer h4, .blogContainer h4 a { font-size: var(--font-size-h6); =
}
  .blogContainer h5, .blogContainer h5 a { font-size: var(--font-size-h7); =
}
  .blogContainer p { margin-bottom: 16px; }
  .blogPostDate::before { display: none; }
}
