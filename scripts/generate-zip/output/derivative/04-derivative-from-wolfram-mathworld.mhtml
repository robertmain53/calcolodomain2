=3D"39" alt=3D" f^('')(x)=3Dlim_(h-&gt;0)(f^'(x+h)-f^'(x))/h "></td><td ali=
gn=3D"right" width=3D"3">
<div id=3D"eqn9" class=3D"eqnum">
(9)
</div>
</td></tr>
</tbody></table>
</div>
