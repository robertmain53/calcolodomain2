x}\\
\amp =3D \lim_{\Delta x\to0}{ {x\over x(x+\Delta x)} - {x+\Delta x\over x(x=
+\Delta x)}\over \Delta x}\\
\amp =3D \lim_{\Delta x\to0}{ {x-(x+\Delta x)\over x(x+\Delta x)}\over \Del=
ta x}\\
\amp =3D \lim_{\Delta x\to0} {x-x-\Delta x\over x(x+\Delta x)\Delta x}\\
\amp =3D\ \lim_{\Delta x\to0} {-\Delta x\over x(x+\Delta x)\Delta x}\\
\amp =3D \lim_{\Delta x\to0} {-1\over x(x+\Delta x)}=3D{-1\over x^2}
\end{split}
\end{equation*}
