@charset "utf-8";

.login form { border: 3px solid rgb(241, 241, 241); }

.login input[type=3D"text"], input[type=3D"password"] { width: 100%; paddin=
g: 12px 20px; margin: 8px 0px; display: inline-block; border: 1px solid rgb=
(204, 204, 204); box-sizing: border-box; }

.login button { background-color: rgb(76, 175, 80); color: white; padding: =
14px 20px; margin: 8px 0px; border: none; cursor: pointer; width: 100%; }

.login .instructions { padding-left: 1em; }

.login button:hover { opacity: 0.8; }

.login .container { padding: 16px 16px 32px; }

.login span.psw { float: right; }

.login.modal { position: fixed; z-index: 1; left: 0px; top: 0px; width: 100=
%; height: 100%; overflow: auto; background-color: rgba(0, 0, 0, 0.4); padd=
ing-top: 60px; }

.login .modal-content { background-color: rgb(254, 254, 254); margin: 5px a=
uto; border: 1px solid rgb(136, 136, 136); width: 50%; }

.login .close { position: absolute; right: 25px; top: 0px; color: rgb(0, 0,=
 0); font-size: 35px; font-weight: bold; }

.login .close:hover, .login .close:focus { color: red; cursor: pointer; }

.login .animate { animation: 0.6s ease 0s 1 normal none running animatezoom=
; }

.login-link { position: absolute; right: 10px; top: 10px; cursor: pointer; =
}

.login-link > * { visibility: hidden; }

.login-link:hover > * { visibility: visible; background-color: rgb(255, 204=
, 204); }

.login-link .logout { visibility: visible; background-color: rgb(255, 204, =
204); }

#dontlogout { float: right; font-size: 80%; cursor: pointer; }

#dontlogout:hover { background-color: rgb(255, 221, 221); }

.rq_answer .given_answer { background: rgb(255, 255, 221); }

#rq_submit { padding: 3px 5px; border-radius: 0.5em; }

#rq_submit.submitted { background: rgb(238, 255, 238); color: rgb(187, 187,=
 187); }

.addcontent, .action, .submit { cursor: pointer; }

.addcontent:hover, .action:hover { background: rgb(238, 255, 255); }

.action + .action { margin-left: 0.25em; display: block; }

.action + .amhelp { margin-left: 0.25em; display: block; }

.input_controls { font-family: sans-serif; font-weight: lighter; font-size:=
 90%; background: rgb(255, 255, 255); padding-left: 0.5em; padding-bottom: =
0px; margin-top: 0px; margin-bottom: -1.6em; display: inline; position: abs=
olute; }

.rq_answer_text { display: inline; }

textarea + .input_controls { margin-top: 0px; }

textarea { border-width: 0.1em; margin-bottom: -0.77em; }

.input_controls .action { border: 1px solid rgb(170, 170, 170); padding: 1p=
x 2px; }

.input_controls .action + .action { margin-top: 4px; }

.clear_item:hover { background: rgb(255, 221, 221); }

.save_item:hover, .edit_item:hover { background: rgb(221, 255, 221); }

.hidecontrols { display: none; }

.given_answer { font-family: "Lucida Console", Monaco, monospace; white-spa=
ce: pre-wrap; margin-top: 0.5em; margin-bottom: -0.5em; min-height: 2.72em;=
 }

textarea.rq_answer_text { font-family: "Lucida Console", Monaco, monospace;=
 resize: vertical; font-size: inherit; }

.compiled_answers { border-width: 0.35em 0.7em 0.7em; border-right-style: s=
olid; border-bottom-style: solid; border-left-style: solid; border-right-co=
lor: rgb(221, 255, 221); border-bottom-color: rgb(221, 255, 221); border-le=
ft-color: rgb(221, 255, 221); border-image: initial; border-top-style: init=
ial; border-top-color: initial; margin-top: 1em; }

.s_id { font-size: 80%; padding-top: 0.4em; padding-left: 0.5em; display: i=
nline; }

.rq_sub_time { font-size: 70%; padding-top: 0.5em; padding-right: 0.5em; fl=
oat: right; display: inline; }

.s_ans { font-family: "Lucida Console", Monaco, monospace; white-space: pre=
-wrap; width: 480px; margin-left: 3em; padding-bottom: 0.5em; }

.noanswer .s_ans { font-style: italic; font-size: 80%; margin-left: 4em; }

.one_answer:nth-of-type(2n+1) { background: rgb(221, 255, 221); }

#hlmenu { z-index: 1000; }

#hlmenu :hover { cursor: pointer; }

span.hl { background: yellow; }

#hlmenu { position: absolute; top: 300px; left: 200px; }

#hlmenu { padding: 8px; background: rgb(255, 255, 255); }

#hlmenu { box-shadow: rgb(136, 136, 136) 8px 10px 5px; border: 1px solid rg=
b(170, 170, 170); }

#hlmenu .hldelete { background: rgb(255, 221, 221); }

#hlmenu .hldelete:hover { background: rgb(255, 187, 187); }

#hlmenu .hlcopy { background: rgb(221, 221, 255); }

#hlmenu .hlcopy:hover { background: rgb(187, 187, 255); }

#hlmenu .dismiss:hover { background: rgb(255, 255, 153); }

#hlmenu > div { padding: 4px; font-size: 90%; }
