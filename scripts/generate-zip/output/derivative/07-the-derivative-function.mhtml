\begin{split} f'(t) \amp =3D  \ds\lim_{h\to0}\ds\frac{f(t+h)-f(t)}{h}  \\  =
\amp =3D\ds\lim_{h\to0}\ds\frac{(t+h)^2-t^2}{h} \\  \amp =3D \ds\lim_{h\to0=
}\ds\frac{t^2+2th+h^2-t^2}{h} \\  \amp =3D \ds\lim_{h\to0}\ds\frac{2th+h^2}=
{h} \\  \amp =3D \ds\lim_{h\to0} \left(2t+h\right) =3D 2t. \end{split}
\end{equation*}
