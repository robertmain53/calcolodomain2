            <mo symmetric=3D"true">=E2=80=96</mo>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>q</mi>
          </mrow>
        </msub>
        <mo>,</mo>
        <mspace width=3D"1em"></mspace>
        <mi>f</mi>
        <mo>=E2=88=88<!-- =E2=88=88 --></mo>
