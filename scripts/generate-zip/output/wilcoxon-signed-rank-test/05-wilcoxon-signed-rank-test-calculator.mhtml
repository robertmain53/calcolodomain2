.cc-animate.cc-revoke.cc-active.cc-bottom, .cc-animate.cc-revoke.cc-active.=
cc-top, .cc-revoke:hover { transform: translateY(0px); }

.cc-grower { max-height: 0px; overflow: hidden; transition: max-height 1s; =
}

.cc-link, .cc-revoke:hover { text-decoration: underline; }

