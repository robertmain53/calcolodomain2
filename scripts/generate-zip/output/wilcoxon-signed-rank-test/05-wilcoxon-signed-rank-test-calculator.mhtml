.cc-banner.cc-theme-edgeless .cc-btn { margin: 0px; padding: 0.8em 1.8em; h=
eight: 100%; }

.cc-banner.cc-theme-edgeless .cc-message { margin-left: 1em; }

.cc-floating.cc-theme-edgeless .cc-btn + .cc-btn { margin-left: 0px; }
