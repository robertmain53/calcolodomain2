.cc-banner.cc-bottom { left: 0px; right: 0px; bottom: 0px; }

.cc-banner .cc-message { display: block; flex: 1 1 auto; max-width: 100%; m=
argin-right: 1em; }

.cc-compliance { display: flex; align-items: center; align-content: space-b=
etween; }

.cc-floating .cc-compliance > .cc-btn { flex: 1 1 0%; }

