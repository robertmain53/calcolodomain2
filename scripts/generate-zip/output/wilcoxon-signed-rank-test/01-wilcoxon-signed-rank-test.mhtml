            <mn>12</mn>
          </mrow>
        </msup>
        <mo>=E2=89=88<!-- =E2=89=88 --></mo>
        <mn>0.0134</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \alpha &lt;55=
/2^{12}\approx 0.0134}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/9731cb73309bedd7fef7cd3282db805bf1d71ef5" class=3D"mwe-math-fallback=
