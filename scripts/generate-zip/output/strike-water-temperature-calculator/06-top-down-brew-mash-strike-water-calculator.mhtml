 (quarts/lb or liter/kg)</label>
<br>
<input type=3D"number" size=3D"3" maxlength=3D"3" value=3D"75" step=3D"1" n=
ame=3D"data2" id=3D"graintemp"><label for=3D"graintemp"> Grain temperature<=
/label>=20
<br>
<input type=3D"number" size=3D"3" maxlength=3D"3" value=3D"152" step=3D"1" =
name=3D"data3" id=3D"targettemp"><label for=3D"targettemp"> Target temperat=
ure</label>
<br>
<input type=3D"button" value=3D"Calculate">
<p></p>
<p>
</p></form>
<form id=3D"unit">
<input type=3D"radio" value=3D"0" name=3D"unit" checked=3D"" id=3D"US"><lab=
