@charset "utf-8";

#email-checker .main-container { background: rgb(245, 247, 249); overflow: =
hidden; }

.input-group.input-group-responsive { align-items: flex-start; }

.input-group-append button { height: calc(1.5em + 2px + 0.75rem); }

@media (max-width: 576px) {
  .input-group-append button { height: calc(1.5em + 0.75rem); }
}

@media (min-width: 577px) {
  .input-group .flex-grow-1 { position: relative; }
  .invalid-feedback { position: absolute; top: 100%; left: 0px; right: 0px;=
 z-index: 10; margin-top: 0.25rem; }
}

.tooltip-inner { max-width: min(450px, -2rem + 100vw); }

button[disabled]:hover { cursor: not-allowed; }

.main-container { border: 1px solid rgb(230, 231, 235); border-radius: 0.5r=
em; }

.break-word { word-break: break-word; }

textarea { flex-grow: 1; width: 100%; resize: none; padding: 0.5rem; }

.prompt-textarea { color: inherit; height: auto; resize: none; max-height: =
5.25rem; }

.result-textarea-container { display: flex; width: 100%; flex-direction: co=
lumn; }

.result-container { display: flex; flex-direction: column; width: 100%; bac=
kground-color: rgb(245, 247, 249); border-bottom-left-radius: 0.5rem; borde=
r-bottom-right-radius: 0.5rem; }

.result-header { display: flex; align-items: center; margin: 1.5rem; }

.result-header h3 { margin: 0px; }

.result-header p { margin: 0px; }

.result-details-container { display: grid; grid-template-columns: 1fr 1fr; =
gap: 2rem; margin-left: calc(62px + 3rem); margin-right: calc(62px + 3rem);=
 padding-bottom: 2rem; }

@media screen and (max-width: 768px) {
  .result-details-container { grid-template-columns: 1fr; margin-left: 1rem=
; margin-right: 1rem; }
}

.result-detail-item-explanation { color: rgb(108, 117, 125); }

.result-sub-container { display: flex; flex-direction: column; position: re=
lative; background: rgb(255, 255, 255); margin: 0rem 1.5rem 1.5rem; }

.examples-container { margin-left: 1.5rem; margin-top: 1rem; font-size: 0.8=
rem; }

@keyframes blinkdot {=20
  0% { opacity: 0.2; }
  20% { opacity: 1; }
  100% { opacity: 0.2; }
}

.loading span { animation-name: blinkdot; animation-duration: 1.4s; animati=
on-iteration-count: infinite; animation-fill-mode: both; }

.loading span:nth-child(2) { animation-delay: 0.2s; }

.loading span:nth-child(3) { animation-delay: 0.4s; }
