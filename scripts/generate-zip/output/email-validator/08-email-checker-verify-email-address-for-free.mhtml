.tool .tool-tabs { display: grid; grid-template-columns: repeat(3, 1fr); ba=
ckground: rgb(255, 255, 255); border-top-left-radius: 0.5rem; border-top-ri=
ght-radius: 0.5rem; }

.tool .tool-tab { display: flex; align-items: center; justify-content: cent=
er; padding: 0.9rem 1rem; font-weight: 700; text-transform: uppercase; colo=
r: rgb(154, 161, 175); text-decoration: none; border-right: 1px solid rgb(2=
30, 231, 234); text-align: center; line-height: 1; min-height: 48px; transi=
tion: 0.3s; }

