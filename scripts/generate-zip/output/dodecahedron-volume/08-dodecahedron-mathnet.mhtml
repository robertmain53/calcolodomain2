#hometwrapper { display: grid; row-gap: 30px; padding: 15px 3px; margin-lef=
t: 65px; grid-template-columns: 320px 320px 320px; }

.homet { margin: 10px 20px 0px; padding: 2px; text-align: center; }

#hometwrapper p, #hometwrapper div, #hometwrapper span { color: rgb(255, 25=
5, 255); }

#hometwrapper a { color: rgb(255, 255, 255); text-decoration: none; display=
: block; padding: 3px; }

