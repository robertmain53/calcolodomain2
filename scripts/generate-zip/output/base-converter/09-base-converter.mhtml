        </option>
        <option value=3D"9">9
        </option>
        <option value=3D"10" selected=3D"selected">10
            (decimal)
        </option>
        <option value=3D"11">11
        </option>
        <option value=3D"12">12
        </option>
        <option value=3D"13">13
        </option>
        <option value=3D"14">14
        </option>
        <option value=3D"15">15
        </option>
        <option value=3D"16">16
            (hexadecimal)
        </option>
    </select>
  </div>
  <div class=3D"field box">
    <label for=3D"obase">to write this number under base</label>
    <select name=3D"obase" id=3D"obase">
        <option value=3D"2">2
