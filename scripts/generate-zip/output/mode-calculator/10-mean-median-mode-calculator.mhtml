main::before { background-color: var(--main-dark); content: ""; display: bl=
ock; height: 0px; transition: all var(--duration) ease-in-out; width: 100%;=
 }

footer.v2 { background-color: var(--main-light-shade-1); background-image: =
url("https://staging.itbpcloud.space/resources/assets/images/home-v3-bg.web=
p"); }

footer.v2 .container .left-side .logo-wrap { flex: 0 1 386px; }

footer.v2 .container .left-side .logo-wrap > svg { margin-left: -34px; }

footer.v2 .container .left-side .site-socials { color: var(--main-dark); di=
splay: block; font-size: 18px; line-height: 110%; margin-bottom: 4px; }

footer.v2 .container .left-side .site-socials .highlight-2 { color: var(--a=
ccent-shade-1); }

footer.v2 .container .left-side .icons-social { justify-content: flex-end; =
}

footer.v2 .bottom .col-12 { text-align: center; }

.w-banner > .header, .w-banner > .header.on-checkout { background-color: va=
r(--main-dark); }

.w-banner > .header.background .logo svg.dark.svg-logo path { fill: rgb(255=
, 255, 255); }

.w-banner > main::before { height: 171px; }

.w-banner > main .course-holder { padding-top: 0px; }

.w-banner > main .course-holder .right-side { top: 0px; }

.w-banner > main .course-holder .right-side .sidebar-arrow { top: 171px; }

.course-lecture #tidio-chat { display: none; }

@media (max-width: 1023px) {
  .w-banner > main::before { height: 411px; }
  .container-wide { padding: 0 var(--spacing-24); width: 100%; }
  footer.v2 .container .left-side .logo-wrap { flex-basis: auto; flex-grow:=
 0; max-width: 100%; width: 386px; }
  footer.v2 .container .left-side .socials-wrap { margin-left: unset; }
  footer.v2 .container .left-side .icons-social { justify-content: flex-sta=
rt; }
  footer.v2 .bottom .container .row .col { margin-top: 0px; }
  .checkout-tidio #tidio-chat { display: none; }
}

