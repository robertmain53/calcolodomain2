@charset "utf-8";

#kite-modal-wrap { z-index: 9999999; background: rgba(255, 255, 255, 0.8); =
position: fixed; inset: 0px; }

#kite-modal { background: rgb(255, 255, 255); border: 1px solid rgb(221, 22=
1, 221); width: 800px; height: 450px; margin-left: -392px; position: fixed;=
 top: 90px; bottom: 90px; left: 50%; box-shadow: rgb(204, 204, 204) 0px 0px=
 3px; }

#kite-frame { border: 0px; width: 100%; height: 100%; overflow: hidden; }

#kite-close { color: rgb(204, 204, 204); margin: 0px; padding: 10px; font-f=
amily: Arial, sans; font-size: 20px; font-weight: 700; line-height: 15px; t=
ext-decoration: none; display: inline-block; position: absolute; top: -40px=
; right: -12px; }

button.kite-trade-button, kite-button { cursor: pointer; text-indent: -800p=
x; background: url("../../images/connect/trade-button.png") no-repeat; widt=
h: 68px; height: 22px; padding: 0px; display: inline-block; overflow: hidde=
n; border: 0px !important; }

.kite-trade-button.kite-buy, kite-button.kite-buy { background: url("../../=
images/connect/buy-button.png") no-repeat; }

.kite-trade-button.kite-sell, kite-button.kite-sell { background: url("../.=
./images/connect/sell-button.png") no-repeat; }

button.kite-trade-button:hover, kite-button:hover { opacity: 0.6; }

.shake { backface-visibility: hidden; perspective: 1000px; animation: 0.4s =
cubic-bezier(0.36, 0.07, 0.19, 0.97) 0s 1 normal both running shake; transf=
orm: translate(0px, 0px); }

@keyframes shake {=20
  10%, 90% { transform: translate(-1px); }
  20%, 80% { transform: translate(2px); }
  30%, 50%, 70% { transform: translate(-4px); }
  40%, 60% { transform: translate(4px); }
}

@media screen and (max-width: 865px) {
