.text-button-component:active p { color: rgb(41, 118, 111); text-decoration=
: underline; }

.text-button-component:active span { border-color: rgb(41, 118, 111); }

.text-button-component span { border-style: solid; border-color: rgb(0, 98,=
 107); border-image: initial; border-width: 0px 1px 1px 0px; display: inlin=
e-block; margin-left: 10px; margin-right: 2px; padding: 2px; transform: rot=
ate(-45deg); }

@media (max-width: 1023px) {
  .text-button-component { width: 6in; }
}

@media (max-width: 767px) {
