            <mi>t</mi>
          </mrow>
        </msub>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle W_{t}}</annot=
ation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/50680c5535c83badfa630dba63b583d2eeaa2977" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.671ex; width:3.02ex; height:2.509ex;" alt=3D"{\displaystyle W_{t=
}}"></span>, where <span class=3D"mwe-math-element mwe-math-element-inline"=
><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"displ=
ay: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\=
displaystyle t}">
