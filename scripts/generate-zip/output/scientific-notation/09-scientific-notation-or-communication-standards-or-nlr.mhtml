<div class=3D"">
	<h1>scientific notation</h1>

	<div class=3D"field field-name-field-content field-type-text-long field-la=
bel-hidden">
		<div class=3D"field-items">
			<div class=3D"field-item even">
			=09
                                          <p>Standard scientific notation r=
epresents a number as a factor multiplied by a power
                                             of 10; 3,560,000 is expressed =
as 3.56 =C3=97 10<sup>6</sup>. This is useful for very large and very small=
 numbers, especially in non-SI units.
                                             You can also use certain stand=
ard prefixes, many of which are listed here with their
                                             abbreviations.
                                          </p>
                                         =20
                                          <div class=3D"table table-respons=
ive">
                                             <table class=3D"table table-st=
riped">
                                                <tbody>
                                                   <tr>
                                                      <th scope=3D"col">
                                                        =20
                                                         <p>10<sup>24</sup>=
</p>
                                                        =20
                                                      </th>
                                                      <th scope=3D"col">
                                                        =20
                                                         <p>yotta</p>
                                                        =20
                                                      </th>
                                                      <th scope=3D"col">
                                                        =20
                                                         <p>Y</p>
                                                        =20
                                                      </th>
                                                   </tr>
                                                   <tr>
                                                      <td>
                                                        =20
                                                         <p>10<sup>21</sup>=
</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>zetta</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>Z</p>
                                                        =20
                                                      </td>
                                                   </tr>
                                                   <tr>
                                                      <td>
                                                        =20
                                                         <p>10<sup>18</sup>=
</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>exa</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>E</p>
                                                        =20
                                                      </td>
                                                   </tr>
                                                   <tr>
                                                      <td>
                                                        =20
                                                         <p>10<sup>15</sup>=
</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>peta</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>P</p>
                                                        =20
                                                      </td>
                                                   </tr>
                                                   <tr>
                                                      <td>
                                                        =20
                                                         <p>10<sup>12</sup>=
</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>tera</p>
                                                        =20
                                                      </td>
                                                      <td>
                                                        =20
                                                         <p>T</p>
                                                        =20
                                                      </td>
