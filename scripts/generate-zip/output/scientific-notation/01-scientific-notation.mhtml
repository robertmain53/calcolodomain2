            <mn>1</mn>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <mo stretchy=3D"false">(</mo>
        <msub>
          <mi>m</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>0</mn>
          </mrow>
        </msub>
        <mo>=C2=B1<!-- =C2=B1 --></mo>
