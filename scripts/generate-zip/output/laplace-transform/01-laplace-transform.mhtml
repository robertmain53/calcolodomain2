            <mi>T</mi>
            <mo stretchy=3D"false">=E2=86=92<!-- =E2=86=92 --></mo>
            <mi mathvariant=3D"normal">=E2=88=9E<!-- =E2=88=9E --></mi>
          </mrow>
        </munder>
        <msubsup>
          <mo>=E2=88=AB<!-- =E2=88=AB --></mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
