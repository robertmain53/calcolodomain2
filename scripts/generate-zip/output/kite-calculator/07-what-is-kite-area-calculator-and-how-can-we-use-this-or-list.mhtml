.device-check__main { padding: 0.25em 0px; }

.device-check__footer { font-size: 0.8em; padding: 1em 0px; }

.device-check__checkmark-wrapper { width: 100px; height: 100px; margin: 0px=
 auto; }

.device-check__circle { border-width: 2px; border-style: solid; margin-bott=
om: 3.5em; position: relative; display: inline-block; vertical-align: top; =
border-radius: 50%; width: 4em; height: 4em; }

.device-check__green-circle { border-color: var(--device-check-ok-color); }

.device-check__red-circle { border-color: var(--device-check-ko-color); }

.device-check__success::after { opacity: 1; height: 2em; width: 1em; left: =
0.8em; top: 2em; transform-origin: left top; border-right: 3px solid var(--=
device-check-ok-color); border-top: 3px solid var(--device-check-ok-color);=
 content: ""; position: absolute; animation: 0.5s ease 0s 1 normal none run=
ning success-checkmark; transform: scaleX(-1) rotate(135deg); }

@keyframes success-checkmark {=20
  0% { height: 0px; width: 0px; opacity: 1; }
  40% { height: 0px; width: 1em; opacity: 1; }
  100% { height: 2em; width: 1em; opacity: 1; }
}

.device-check__error::before, .device-check__error::after { opacity: 1; hei=
ght: 0px; width: 2.5em; left: 0.75em; top: 1.9em; transform-origin: center =
center; border-top: 3px solid var(--device-check-ko-color); content: ""; po=
sition: absolute; animation: 0.5s ease 0s 1 normal none running error-check=
mark; }

.device-check__error::before { transform: scaleX(-1) rotate(-45deg); }

.device-check__error::after { transform: scaleX(-1) rotate(225deg); }

@keyframes error-checkmark {=20
  0% { left: 2em; height: 0px; width: 0px; opacity: 1; }
  100% { left: 0.75em; height: 0px; width: 2.5em; opacity: 1; }
}

.device-check__hidden { display: none; }

