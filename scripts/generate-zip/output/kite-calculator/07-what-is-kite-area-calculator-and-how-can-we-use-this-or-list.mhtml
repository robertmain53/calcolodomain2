nner-wrapper .device-check__spinner-2 { animation: 2.2s ease-in-out 0s infi=
nite normal none running bounce; }

.device-check__spinner-wrapper .device-check__spinner-2 { animation-delay: =
-1s; }

@keyframes loading {=20
  100% { transform: rotate(360deg); }
}

@keyframes bounce {=20
  0%, 100% { transform: scale(0); }
  50% { transform: scale(1); }
}

.device-check__spinner-1, .device-check__spinner-2 { width: 30px; height: 3=
0px; border-radius: 100%; background-color: var(--device-check-spinner-colo=
r-1); margin: 5px; }

.device-check__spinner-2 { top: auto; bottom: 0px; background-color: var(--=
