      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mo stretchy=3D"false">(</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mstyle displaystyle=3D"false" scriptlevel=3D"0">
            <mtext>par</mtext>
          </mstyle>
        </mrow>
        <mo>+</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mstyle displaystyle=3D"false" scriptlevel=3D"0">
            <mtext>5</mtext>
          </mstyle>
        </mrow>
        <mo stretchy=3D"false">)</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle ({\mbox{par}}=
+{\mbox{5}})}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
