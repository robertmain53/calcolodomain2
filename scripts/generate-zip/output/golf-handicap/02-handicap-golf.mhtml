                <mstyle displaystyle=3D"false" scriptlevel=3D"0">
                  <mtext>slope rating</mtext>
                </mstyle>
              </mrow>
              <mo stretchy=3D"false">)</mo>
            </mrow>
            <mstyle displaystyle=3D"false" scriptlevel=3D"0">
              <mtext>113</mtext>
            </mstyle>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\mbox{Course=
 handicap}}=3D{\frac {({\mbox{handicap index}}\times {\mbox{slope rating}})=
}{\mbox{113}}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/7a723115a17f170540f201da232567b410e76ecb" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.838ex; width:52.291ex; height:5.676ex;" alt=3D"{\displaystyle {\=
mbox{Course handicap}}=3D{\frac {({\mbox{handicap index}}\times {\mbox{slop=
e rating}})}{\mbox{113}}}}"></span></dd></dl>
<p>or
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e {\mbox{Course handicap}}=3D{\frac {({\mbox{handicap index}}\times {\mbox{=
slope rating}})}{\mbox{113}}}+({\mbox{course rating}}-{\mbox{par}})}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mstyle displaystyle=3D"false" scriptlevel=3D"0">
            <mtext>Course handicap</mtext>
          </mstyle>
        </mrow>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mo stretchy=3D"false">(</mo>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mstyle displaystyle=3D"false" scriptlevel=3D"0">
                  <mtext>handicap index</mtext>
                </mstyle>
              </mrow>
              <mo>=C3=97<!-- =C3=97 --></mo>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mstyle displaystyle=3D"false" scriptlevel=3D"0">
                  <mtext>slope rating</mtext>
                </mstyle>
              </mrow>
              <mo stretchy=3D"false">)</mo>
            </mrow>
            <mstyle displaystyle=3D"false" scriptlevel=3D"0">
              <mtext>113</mtext>
            </mstyle>
          </mfrac>
        </mrow>
        <mo>+</mo>
        <mo stretchy=3D"false">(</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mstyle displaystyle=3D"false" scriptlevel=3D"0">
            <mtext>course rating</mtext>
          </mstyle>
        </mrow>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mstyle displaystyle=3D"false" scriptlevel=3D"0">
            <mtext>par</mtext>
          </mstyle>
        </mrow>
        <mo stretchy=3D"false">)</mo>
      </mstyle>
