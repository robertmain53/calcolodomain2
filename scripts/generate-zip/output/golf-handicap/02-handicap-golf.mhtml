            <mtext>Playing handicap</mtext>
          </mstyle>
        </mrow>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mo stretchy=3D"false">(</mo>
              <mrow class=3D"MJX-TeXAtom-ORD">
