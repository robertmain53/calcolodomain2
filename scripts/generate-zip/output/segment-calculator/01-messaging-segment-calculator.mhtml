@charset "utf-8";

body { max-width: 100%; font-family: Helvetica, sans-serif; font-size: 11pt=
; }

h1 { width: 100%; text-align: center; }

#calculator-header { background-color: rgb(35, 54, 89); padding: 10px; }

#calculator-header a { color: inherit; }

#message-box { color: white; margin-bottom: 10px; }

#message-box > textarea { resize: vertical; width: 100%; box-sizing: border=
-box; min-height: 5em; }

#information-box { display: grid; grid-template-columns: repeat(5, auto); c=
olumn-gap: 10px; grid-auto-flow: column; grid-template-rows: auto auto; jus=
tify-content: space-between; }

#information-box > .label { padding-top: 5px; text-align: center; font-size=
: small; font-variant: all-petite-caps; background-color: rgb(35, 54, 89); =
color: white; }

#information-box > .value { padding-top: 5px; font-size: medium; text-align=
: center; background-color: rgb(35, 54, 89); color: white; margin-bottom: 0=
px; }

#viewers { background-color: rgb(249, 249, 249); padding-top: 20px; }

#viewers-inner { color: black; padding: 5px; margin-bottom: 10px; }

.label { display: block; font-size: small; font-variant: all-petite-caps; p=
adding-bottom: 5px; }

.value { display: block; margin-bottom: 20px; }

#message-viewer, #segments-viewer { line-height: 0.8; }

.block { align-items: center; color: black; display: inline-flex; font-fami=
ly: monospace; justify-content: center; text-align: center; vertical-align:=
 middle; }

.block.selected { color: white; }

.block > span { cursor: default; }

.block > span.invisible::before { content: "=E2=80=A2"; }

#message-viewer > .block { font-size: 12px; height: 2em; }

#message-viewer > .block.error { background-color: red; }

#segments-viewer > .block { border-bottom: 1px solid rgba(0, 0, 0, 0.2); bo=
rder-right: 1px solid rgba(0, 0, 0, 0.2); font-size: 10px; height: 1em; pad=
ding: 4px; width: 6ch; }

#segments-viewer > .block.twilio > img { display: inline; height: 1em; }

[data-encoding=3D"GSM-7"] .segment-type-0 { background-color: rgb(204, 228,=
 255); }

[data-encoding=3D"GSM-7"] .segment-type-0.selected { background-color: rgb(=
2, 99, 224); }

[data-encoding=3D"GSM-7"] .segment-type-1 { background-color: rgb(209, 250,=
 224); }

[data-encoding=3D"GSM-7"] .segment-type-1.selected { background-color: rgb(=
20, 176, 83); }

[data-encoding=3D"GSM-7"] .segment-type-2 { background-color: rgb(253, 220,=
 196); }

[data-encoding=3D"GSM-7"] .segment-type-2.selected { background-color: rgb(=
244, 124, 34); }

[data-encoding=3D"GSM-7"] .segment-type-3 { background-color: rgb(255, 241,=
 179); }

[data-encoding=3D"GSM-7"] .segment-type-3.selected { background-color: rgb(=
232, 180, 7); }

[data-encoding=3D"GSM-7"] .segment-type-4 { background-color: rgb(231, 220,=
 250); }

[data-encoding=3D"GSM-7"] .segment-type-4.selected { background-color: rgb(=
109, 46, 209); }

[data-encoding=3D"UCS-2"] .segment-type-0 { background-color: rgb(255, 241,=
 179); }

[data-encoding=3D"UCS-2"] .segment-type-0.selected { background-color: rgb(=
232, 180, 7); }

[data-encoding=3D"UCS-2"] .segment-type-1 { background-color: rgb(231, 220,=
 250); }

[data-encoding=3D"UCS-2"] .segment-type-1.selected { background-color: rgb(=
109, 46, 209); }

[data-encoding=3D"UCS-2"] .segment-type-2 { background-color: rgb(204, 228,=
 255); }

[data-encoding=3D"UCS-2"] .segment-type-2.selected { background-color: rgb(=
2, 99, 224); }

[data-encoding=3D"UCS-2"] .segment-type-3 { background-color: rgb(209, 250,=
 224); }

[data-encoding=3D"UCS-2"] .segment-type-3.selected { background-color: rgb(=
20, 176, 83); }

[data-encoding=3D"UCS-2"] .segment-type-4 { background-color: rgb(253, 220,=
 196); }

[data-encoding=3D"UCS-2"] .segment-type-4.selected { background-color: rgb(=
244, 124, 34); }

.block.non-gsm { color: red; }

.recently-changed { animation: 1s ease-out 0s infinite normal none running =
pulseHighlight; }

@keyframes pulseHighlight {=20
  0% { color: yellow; }
  100% { color: white; }
}

.legend { font-size: 10px; background-color: rgb(249, 249, 249); padding: 0=
px 0px 5px 5px; }

