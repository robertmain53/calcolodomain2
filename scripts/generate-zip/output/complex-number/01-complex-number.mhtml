        <mo>=3D</mo>
        <mi>a</mi>
        <mi>c</mi>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mi>b</mi>
        <mi>d</mi>
        <mo>+</mo>
        <mo stretchy=3D"false">(</mo>
        <mi>a</mi>
        <mi>d</mi>
        <mo>+</mo>
        <mi>b</mi>
