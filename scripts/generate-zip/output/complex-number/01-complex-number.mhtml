            <mo>(</mo>
            <mtable rowspacing=3D"4pt" columnspacing=3D"1em">
              <mtr>
                <mtd>
                  <mi>a</mi>
                </mtd>
                <mtd>
                  <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                  <mi>b</mi>
                </mtd>
              </mtr>
              <mtr>
                <mtd>
                  <mi>b</mi>
                </mtd>
