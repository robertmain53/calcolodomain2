                  <mspace width=3D"thickmathspace"></mspace>
                  <mi>a</mi>
                </mtd>
              </mtr>
            </mtable>
            <mo>)</mo>
          </mrow>
        </mrow>
        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\begin{pmatr=
ix}a&amp;-b\\b&amp;\;\;a\end{pmatrix}}.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
