@charset "utf-8";

[class*=3D"wt-icon-"] { display: inline-block; min-width: 12px; min-height:=
 12px; pointer-events: none; }

.wt-icon { fill: currentcolor; transition: transform 0.3s ease-in-out; }

.wt-icon--2xs { height: 12px; width: 12px; }

.wt-icon--xs { height: 16px; width: 16px; }

.wt-icon--s { height: 20px; width: 20px; }

.wt-icon--m { height: 24px; width: 24px; }

.wt-icon--l { height: 32px; width: 32px; }

.wt-icon--xl { height: 40px; width: 40px; }

.wt-icon--2xl { height: 48px; width: 48px; }

.wt-icon--fluid { height: 1em; width: 1em; }

[class*=3D"wt-icon-flags-"] { max-width: 120px; }

.wt-img--flags { border: 1px solid rgb(213, 213, 212); max-width: 160px; he=
ight: auto; }

.wt-icon--primary :not([fill*=3D"#fff"], [fill=3D"none"]) { fill: var(--wt-=
c-p, #0E47CB); }

.wt-icon--inverted :not([fill*=3D"#fff"], [fill=3D"none"]) { fill: rgb(255,=
 255, 255); }

.wt-icon--inverted :is([fill*=3D"#fff"]) { fill: rgb(68, 68, 68); }

.wt-icon--inverted :is([stroke*=3D"#fff"]) { stroke: rgb(68, 68, 68); }

.wt-icon--monochrome :not([fill*=3D"#fff"], [fill=3D"none"]) { fill: var(--=
wt-ecl-color-dark, #262B38); }

.wt-icon--rotate-90 { transform: rotate(90deg); }

.wt-icon--rotate-180 { transform: rotate(180deg); }

.wt-icon--rotate-270 { transform: rotate(270deg); }

.wt-icon--rotate-animate { animation: 1.2s linear 0s infinite normal none r=
unning rotate; }

.wt-spinner { animation: 1.2s linear 0s infinite normal none running rotate=
; }

@keyframes rotate {=20
  100% { transform: rotate(360deg); }
}

