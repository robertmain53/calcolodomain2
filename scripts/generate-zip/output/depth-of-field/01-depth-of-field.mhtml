umb/3/38/DOF-ShallowDepthofField.jpg/250px-DOF-ShallowDepthofField.jpg" dec=
oding=3D"async" width=3D"250" height=3D"180" class=3D"mw-file-element" data=
-file-width=3D"997" data-file-height=3D"717"></a><figcaption>A <a href=3D"h=
ttps://en.wikipedia.org/wiki/Macro_photography" title=3D"Macro photography"=
>macro photograph</a> showing the <a href=3D"https://en.wikipedia.org/wiki/=
Defocus_aberration" title=3D"Defocus aberration">defocused effect</a> of a =
<a href=3D"https://en.wikipedia.org/wiki/Shallow_focus" title=3D"Shallow fo=
cus">shallow depth of field</a> on a tilted page of text</figcaption></figu=
re>
<figure class=3D"mw-default-size" typeof=3D"mw:File/Thumb"><a href=3D"https=
://en.wikipedia.org/wiki/File:Tree_bud_at_f22.jpg" class=3D"mw-file-descrip=
tion"><img src=3D"https://upload.wikimedia.org/wikipedia/commons/thumb/0/02=
/Tree_bud_at_f22.jpg/250px-Tree_bud_at_f22.jpg" decoding=3D"async" width=3D=
"250" height=3D"167" class=3D"mw-file-element" data-file-width=3D"6000" dat=
a-file-height=3D"4000"></a><figcaption>This photo was taken with an apertur=
e of <span class=3D"fnumber-fallback"><span class=3D"first-letter">f</span>=
/22</span>, creating a mostly in-focus background.</figcaption></figure>
<figure class=3D"mw-default-size" typeof=3D"mw:File/Thumb"><a href=3D"https=
://en.wikipedia.org/wiki/File:Tree_bud_in_spring_f1.8.jpg" class=3D"mw-file=
-description"><img src=3D"https://upload.wikimedia.org/wikipedia/commons/th=
umb/6/63/Tree_bud_in_spring_f1.8.jpg/250px-Tree_bud_in_spring_f1.8.jpg" dec=
oding=3D"async" width=3D"250" height=3D"167" class=3D"mw-file-element" data=
-file-width=3D"6000" data-file-height=3D"4000"></a><figcaption>The same sce=
ne as above with an aperture of <link rel=3D"mw-deduplicated-inline-style" =
href=3D"mw-data:TemplateStyles:r1299860632"><span class=3D"fnumber-fallback=
"><span class=3D"first-letter">f</span>/1.8</span>. Notice how much blurrie=
r the background appears in this photo.</figcaption></figure>
<p>The <b>depth of field</b> (<b>DOF</b>) is the distance between the neare=
st and the farthest objects that are in acceptably sharp <a href=3D"https:/=
/en.wikipedia.org/wiki/Focus_(optics)" title=3D"Focus (optics)">focus</a> i=
n an image captured with a <a href=3D"https://en.wikipedia.org/wiki/Camera"=
 title=3D"Camera">camera</a>. See also the closely related <b><a href=3D"ht=
tps://en.wikipedia.org/wiki/Depth_of_focus" title=3D"Depth of focus">depth =
of focus</a></b>.
</p>
<meta property=3D"mw:PageProp/toc">
<div class=3D"mw-heading mw-heading2"><h2 id=3D"Factors_affecting_depth_of_=
field">Factors affecting depth of field</h2><span class=3D"mw-editsection">=
<span class=3D"mw-editsection-bracket">[</span><a href=3D"https://en.wikipe=
dia.org/w/index.php?title=3DDepth_of_field&amp;action=3Dedit&amp;section=3D=
1" title=3D"Edit section: Factors affecting depth of field"><span>edit</spa=
n></a><span class=3D"mw-editsection-bracket">]</span></span></div>
<figure class=3D"mw-default-size" typeof=3D"mw:File/Thumb"><a href=3D"https=
://en.wikipedia.org/wiki/File:Depth_of_field_illustration.svg" class=3D"mw-=
file-description"><img src=3D"https://upload.wikimedia.org/wikipedia/common=
s/thumb/0/0c/Depth_of_field_illustration.svg/250px-Depth_of_field_illustrat=
ion.svg.png" decoding=3D"async" width=3D"250" height=3D"186" class=3D"mw-fi=
le-element" data-file-width=3D"498" data-file-height=3D"370"></a><figcaptio=
n>Effect of aperture on blur and DOF (Depth of Field). The points in focus&=
nbsp;(<b>2</b>) project points onto the image plane&nbsp;(<b>5</b>), but po=
ints at different distances&nbsp;(<b>1</b> and <b>3</b>) project blurred im=
ages, or <a href=3D"https://en.wikipedia.org/wiki/Circle_of_confusion" titl=
e=3D"Circle of confusion">circles of confusion</a>. Decreasing the aperture=
 size&nbsp;(<b>4</b>) reduces the size of the blur spots for points not in =
the focused plane, so that the blurring is imperceptible, and all points ar=
e within the <abbr title=3D"depth of field">DOF</abbr>.</figcaption></figur=
e>
<p>For cameras that can only focus on one object distance at a time, depth =
of field is the distance between the nearest and the farthest objects that =
are in acceptably sharp focus in the image.<sup id=3D"cite_ref-FOOTNOTESalv=
aggioStroebel2009110-_1-0" class=3D"reference"><a href=3D"https://en.wikipe=
dia.org/wiki/Depth_of_field#cite_note-FOOTNOTESalvaggioStroebel2009110--1">=
<span class=3D"cite-bracket">[</span>1<span class=3D"cite-bracket">]</span>=
</a></sup> "Acceptably sharp focus" is defined using a property called the =
"<a href=3D"https://en.wikipedia.org/wiki/Circle_of_confusion" title=3D"Cir=
cle of confusion">circle of confusion</a>".
</p><p>The depth of field can be determined by <a href=3D"https://en.wikipe=
dia.org/wiki/Focal_length" title=3D"Focal length">focal length</a>, distanc=
e to subject (object to be imaged), the acceptable circle of confusion size=
, and aperture.<sup id=3D"cite_ref-LondonStone2016_2-0" class=3D"reference"=
><a href=3D"https://en.wikipedia.org/wiki/Depth_of_field#cite_note-LondonSt=
one2016-2"><span class=3D"cite-bracket">[</span>2<span class=3D"cite-bracke=
t">]</span></a></sup> The approximate depth of field can be given by:
</p><p><span class=3D"mwe-math-element mwe-math-element-block"><span class=
=3D"mwe-math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;">=
<math display=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttex=
t=3D"{\displaystyle {\text{DOF}}\approx {\frac {2u^{2}Nc}{f^{2}}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mtext>DOF</mtext>
        </mrow>
        <mo>=E2=89=88<!-- =E2=89=88 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mn>2</mn>
              <msup>
                <mi>u</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mi>N</mi>
              <mi>c</mi>
            </mrow>
            <msup>
              <mi>f</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>2</mn>
              </mrow>
            </msup>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\text{DOF}}\=
approx {\frac {2u^{2}Nc}{f^{2}}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/187d5ad538cee7781bf148b2226c86317b83cd31" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -2.505ex; width:15.653ex; height:6.343ex;" alt=3D"{\displaystyle {=
\text{DOF}}\approx {\frac {2u^{2}Nc}{f^{2}}}}"></span>
</p><p>for a given maximum acceptable circle of confusion diameter <span cl=
ass=3D"texhtml mvar" style=3D"font-style:italic;">c</span>, focal length <s=
pan class=3D"texhtml mvar" style=3D"font-style:italic;">f</span>, <a href=
=3D"https://en.wikipedia.org/wiki/F-number" title=3D"F-number">f-number</a>=
 <span class=3D"texhtml mvar" style=3D"font-style:italic;">N</span>, and di=
stance to subject <span class=3D"texhtml mvar" style=3D"font-style:italic;"=
>u</span>.<sup id=3D"cite_ref-AllenTriantaphillidou2011_3-0" class=3D"refer=
ence"><a href=3D"https://en.wikipedia.org/wiki/Depth_of_field#cite_note-All=
enTriantaphillidou2011-3"><span class=3D"cite-bracket">[</span>3<span class=
=3D"cite-bracket">]</span></a></sup><sup id=3D"cite_ref-4" class=3D"referen=
ce"><a href=3D"https://en.wikipedia.org/wiki/Depth_of_field#cite_note-4"><s=
pan class=3D"cite-bracket">[</span>4<span class=3D"cite-bracket">]</span></=
a></sup>
</p><p>As distance or the size of the acceptable circle of confusion increa=
ses, the depth of field increases; however, increasing the size of the aper=
ture (i.e., reducing <span class=3D"nowrap">f-number</span>) or increasing =
the focal length reduces the depth of field. Depth of field changes linearl=
y with <span class=3D"nowrap">f-number</span> and circle of confusion, but =
changes in proportion to the square of the distance to the subject and inve=
rsely in proportion to the square of the focal length. As a result, photos =
taken at extremely close range (i.e., so small <span class=3D"texhtml mvar"=
 style=3D"font-style:italic;">u</span>) have a proportionally much smaller =
depth of field.
</p><p>Rearranging the <abbr title=3D"depth of field">DOF</abbr> equation s=
hows that it is the ratio between distance and focal length that affects <a=
bbr title=3D"depth of field">DOF</abbr>;
</p><p><span class=3D"mwe-math-element mwe-math-element-block"><span class=
=3D"mwe-math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;">=
<math display=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttex=
t=3D"{\displaystyle {\text{DOF}}\approx 2Nc\left({\frac {u}{f}}\right)^{2}=
=3D2Nc\left(1-{\frac {1}{M_{T}}}\right)^{2}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mtext>DOF</mtext>
        </mrow>
        <mo>=E2=89=88<!-- =E2=89=88 --></mo>
        <mn>2</mn>
        <mi>N</mi>
        <mi>c</mi>
        <msup>
          <mrow>
            <mo>(</mo>
            <mrow class=3D"MJX-TeXAtom-ORD">
              <mfrac>
                <mi>u</mi>
                <mi>f</mi>
              </mfrac>
            </mrow>
            <mo>)</mo>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>2</mn>
          </mrow>
        </msup>
        <mo>=3D</mo>
        <mn>2</mn>
        <mi>N</mi>
        <mi>c</mi>
        <msup>
          <mrow>
            <mo>(</mo>
            <mrow>
              <mn>1</mn>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mfrac>
                  <mn>1</mn>
                  <msub>
                    <mi>M</mi>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mi>T</mi>
                    </mrow>
                  </msub>
                </mfrac>
              </mrow>
            </mrow>
            <mo>)</mo>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>2</mn>
          </mrow>
        </msup>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle {\text{DOF}}\=
approx 2Nc\left({\frac {u}{f}}\right)^{2}=3D2Nc\left(1-{\frac {1}{M_{T}}}\r=
ight)^{2}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/68cc238e1c4c38d20220a5cac214402476f008d8" class=3D"mwe-math-fallback=
