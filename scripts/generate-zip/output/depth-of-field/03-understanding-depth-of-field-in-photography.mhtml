<th width=3D"35%">Rear</th>
<th width=3D"35%">Front</th>
</tr>
<tr>
<td>10</td>
<td>70.2 %</td>
<td>29.8 %</td>
</tr>
<tr>
<td>20</td>
<td>60.1 %</td>
<td>39.9 %</td>
</tr>
<tr>
<td>50</td>
<td>54.0 %</td>
<td>46.0 %</td>
</tr>
<tr>
<td>100</td>
<td>52.0 %</td>
<td>48.0 %</td>
</tr>
<tr>
<td>200</td>
<td>51.0 %</td>
<td>49.0 %</td>
</tr>
<tr>
<td>400</td>
<td>50.5 %</td>
<td>49.5 %</td>
</tr>
