@charset "utf-8";

@import url("https://fonts.googleapis.com/css?family=3DSource+Sans+Pro:400,=
700");

body { margin: 0px; padding: 0px; font-family: "Source Sans Pro", sans-seri=
f; }

.App { font-size: 16px; margin: 0px auto; max-width: 60rem; display: grid; =
grid-template-areas: "main"; }

.app-determine, .app-probability { padding: 0px 2rem; border: 1px solid rgb=
(221, 221, 221); border-radius: 0.5rem; margin-top: 1rem; }

label { font-size: 1.5rem; display: block; }

input { border-radius: 5px; font-size: 1rem; line-height: 1.5rem; }

input[type=3D"number"] { display: inline-block; margin: 0.5rem 0px 1rem; wi=
dth: 10rem; border: 1px solid rgb(0, 0, 0); }

input[type=3D"submit"] { background-color: rgb(81, 136, 18); color: rgb(255=
, 255, 255); width: 9rem; padding: 0.25rem 1rem; margin-bottom: 1rem; }

#outcomeProb { width: 3.5rem; }

.hint { font-size: 1rem; color: rgb(17, 17, 17); padding-left: 0.25rem; }

p { font-size: 18px; line-height: 1.2; }

.strong { font-weight: 700; }

.output p { margin-top: 0px; }

.determine-output input[type=3D"number"] { width: 4rem; }

.determine-output input[type=3D"submit"] { width: 12rem; }

form:last-child { margin-top: 1rem; }

.fraction-output { margin: 1rem 0px; display: grid; gap: 0.5rem; justify-co=
ntent: start; grid-auto-flow: row; grid-template-columns: repeat(5, 1fr); }

.fraction-entry { display: inline; font-size: 1.5rem; padding: 0.25rem; bor=
der: 1px solid rgb(221, 221, 221); border-radius: 0.25rem; text-align: cent=
er; }

.fraction-line { display: block; border: 1px solid rgb(221, 221, 221); marg=
in: 0.25rem 0px; width: 100%; }

.App-intro { line-height: 1.2; }
