			<a name=3D"faq"></a>
			<div class=3D"BlueBar">
				<h2 class=3D"BlueBarHeading">Frequently-Asked Questions</h2>
			</div>
			<br>
			<div align=3D"center">
				<a href=3D"https://stattrek.com/online-calculator/binomial#calculator">=
Calculator</a> | <a href=3D"https://stattrek.com/online-calculator/binomial=
#examples">
					Sample Problem
				</a>
