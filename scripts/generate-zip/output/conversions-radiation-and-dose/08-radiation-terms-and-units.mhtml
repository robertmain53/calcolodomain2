.facet-limit, .facets-soft-limit-link { cursor: pointer; display: block; fo=
nt-size: 0.93rem; margin-top: 2rem; text-decoration: none; width: 100%; }

.facet-list { list-style-type: none; margin: 0px; padding: 0px; }

.facet-list:last-child { margin-bottom: 0px; }

.facet-list li { margin: 0px; padding-left: 0px; }

.facet-list li::before { display: none; }

.facet-list .facet-list { padding: 1rem 0px 0px 1.5rem; }

.facet-list__item + .facet-list__item { margin-top: 1rem; }

