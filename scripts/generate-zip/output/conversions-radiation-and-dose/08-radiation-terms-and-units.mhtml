.facet { color: rgb(27, 27, 27); display: flex; font-size: 0.93rem; line-he=
ight: 1.2; text-decoration: none; }

.facet:visited, .facet:hover, .facet:focus, .facet:active { color: rgb(27, =
27, 27); }

.facet__icon { flex-shrink: 0; left: -1px; margin-right: 0.5rem; height: 1.=
2em !important; top: 0px !important; }

.facet__icon--empty { color: rgb(169, 174, 177); }

.facet.is-active > .facet__icon--empty { display: none !important; }

.facet__icon--selected { color: rgb(0, 94, 162); display: none !important; =
}

.facet.is-active > .facet__icon--selected { display: inline-block !importan=
t; }

