          <mo>/</mo>
        </mrow>
        <mi>=CF=83<!-- =CF=83 --></mi>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle (\mu -\nu )/\=
sigma ,}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/8136d7bffb8c7afb5fd3852aecd75f19007f448b" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.838ex; width:10.422ex; height:2.843ex;" alt=3D"{\displaystyle (\=
