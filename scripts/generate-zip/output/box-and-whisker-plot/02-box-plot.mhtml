                    <mn>3</mn>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mtext>MC</mtext>
                    </mrow>
                  </mrow>
                </msup>
                <mo>,</mo>
              </mtd>
              <mtd>
                <mn>1.5</mn>
