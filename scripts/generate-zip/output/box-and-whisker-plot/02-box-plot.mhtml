                <mn>0</mn>
                <mo>,</mo>
              </mtd>
            </mtr>
            <mtr>
              <mtd>
                <mn>1.5</mn>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mtext>IQR</mtext>
                </mrow>
                <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
                <msup>
                  <mi>e</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>4</mn>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mtext>MC</mtext>
                    </mrow>
                  </mrow>
                </msup>
                <mo>,</mo>
              </mtd>
              <mtd>
                <mn>1.5</mn>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mtext>&nbsp;IQR</mtext>
                </mrow>
                <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
                <msup>
                  <mi>e</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mo>=E2=88=92<!-- =E2=88=92 --></mo>
                    <mn>3</mn>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mtext>MC</mtext>
                    </mrow>
                  </mrow>
                </msup>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mtext>&nbsp;if&nbsp;</mtext>
                </mrow>
