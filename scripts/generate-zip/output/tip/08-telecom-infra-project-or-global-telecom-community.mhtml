.mejs-iframe-overlay { height: 100%; position: absolute; width: 100%; }

.mejs-embed, .mejs-embed body { background: rgb(0, 0, 0); height: 100%; mar=
gin: 0px; overflow: hidden; padding: 0px; width: 100%; }

