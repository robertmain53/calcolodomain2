" (also denoted "<span class=3D"texhtml">cosh<sup>=E2=88=921</sup></span>",=
 "<span class=3D"texhtml">acosh</span>" or sometimes "<span class=3D"texhtm=
l">arccosh</span>")</li>
<li><b>inverse hyperbolic tangent</b> "<span class=3D"texhtml">artanh</span=
>" (also denoted "<span class=3D"texhtml">tanh<sup>=E2=88=921</sup></span>"=
, "<span class=3D"texhtml">atanh</span>" or sometimes "<span class=3D"texht=
ml">arctanh</span>")</li>
<li><b>inverse hyperbolic cotangent</b> "<span class=3D"texhtml">arcoth</sp=
an>" (also denoted "<span class=3D"texhtml">coth<sup>=E2=88=921</sup></span=
>", "<span class=3D"texhtml">acoth</span>" or sometimes "<span class=3D"tex=
html">arccoth</span>")</li>
<li><b>inverse hyperbolic secant</b> "<span class=3D"texhtml">arsech</span>=
" (also denoted "<span class=3D"texhtml">sech<sup>=E2=88=921</sup></span>",=
 "<span class=3D"texhtml">asech</span>" or sometimes "<span class=3D"texhtm=
l">arcsech</span>")</li>
<li><b>inverse hyperbolic cosecant</b> "<span class=3D"texhtml">arcsch</spa=
n>" (also denoted "<span class=3D"texhtml">arcosech</span>", "<span class=
=3D"texhtml">csch<sup>=E2=88=921</sup></span>", "<span class=3D"texhtml">co=
sech<sup>=E2=88=921</sup></span>","<span class=3D"texhtml">acsch</span>", "=
<span class=3D"texhtml">acosech</span>", or sometimes "<span class=3D"texht=
ml">arccsch</span>" or "<span class=3D"texhtml">arccosech</span>")</li></ul=
>
<figure class=3D"mw-default-size" typeof=3D"mw:File/Thumb"><a href=3D"https=
