</select><input class=3D"number-only" id=3D"cshp" name=3D"cshp" type=3D"num=
ber" value=3D"0">
</div>
<label>Duty Cycle (<abbr title=3D"Maximum Injector Duty Cycle"> ? </abbr>)
<select id=3D"cycle" name=3D"cycle">
