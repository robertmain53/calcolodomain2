n}\cdot b.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/22becb6fbb370b056af0dc723f2af7e4db6a034a" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.338ex; width:12.955ex; height:2.676ex;" alt=3D"{\displaystyle b^=
{n+1}=3Db^{n}\cdot b.}"></span></dd></dl>
<p>The associativity of multiplication implies that for any positive intege=
rs <span class=3D"texhtml mvar" style=3D"font-style:italic;">m</span> and <=
span class=3D"texhtml mvar" style=3D"font-style:italic;">n</span>,
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e b^{m+n}=3Db^{m}\cdot b^{n},}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
