.cnotice { position: relative; overflow: hidden; background: var(--backgrou=
nd-color-neutral-subtle, #f8f9fa); border: 1px solid var(--border-color-bas=
e, #a2a9b1); border-radius: 2px; margin-bottom: 1em; cursor: pointer; color=
: var(--color-base, #202122); font-weight: 500; }

#cnotice-main { display: table; width: 100%; height: 80px; }

body.skin-minerva #cnotice-main { height: 100px; }

.cnotice-message-container, .cnotice-logo-container, .cnotice-misc-containe=
r { display: table-cell; height: 100%; vertical-align: middle; }

.cnotice-message { position: relative; margin: 0px; line-height: 1.2; paddi=
ng: 5px; }

