        <mi>=CE=B8<!-- =CE=B8 --></mi>
        <mo stretchy=3D"false">)</mo>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle z=3D\rho e^{i=
\theta }=3D\rho (\cos \theta +i\sin \theta ),}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
