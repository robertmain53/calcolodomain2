.tooltipexamples { align-items: center; display: flex; flex-direction: colu=
mn; height: 300px; justify-content: space-between; padding-top: 50px; }

.steps-indicator { display: flex; width: fit-content; }

.steps-indicator .dot { background-color: rgb(181, 209, 255); border-radius=
: 50%; height: 0.5rem; margin-right: 1rem; width: 0.5rem; }

.steps-indicator .dot.last-child { margin-right: 0px; }

.steps-indicator .dot.active { background-color: rgb(7, 76, 187); }

.chip { background-color: rgb(229, 229, 229); border-radius: 16px; box-sizi=
ng: border-box; color: rgb(0, 0, 0); font-size: 12px; }

.chip--size-sm { height: 24px; }

.chip--delete-show:hover { background-color: rgb(7, 76, 187); color: rgb(25=
5, 255, 255); cursor: pointer; }

.primary-chip, .user-chip { align-items: center; display: flex; flex-direct=
ion: row; height: 100%; }

.primary-chip__label, .user-chip__label { padding-left: 8px; white-space: n=
owrap; }

.primary-chip__delete, .user-chip__delete { align-items: center; border-rad=
ius: 16px; display: flex; height: 24px; padding: 0px 12px; }

.chip--delete-hide .primary-chip__label, .chip--delete-hide .user-chip__lab=
el { padding-right: 8px; }

.multiselect { border: 1px solid rgb(163, 163, 163); border-radius: 4px; di=
splay: flex; flex-wrap: wrap; gap: 8px; padding: 0px 16px; }

.multiselect__input { display: inline-block; padding: 10px 12px; width: 130=
px; }

.multiselect--has-chips { padding: 16px; }

.multiselect--has-chips .multiselect__input { padding: 0px; }

