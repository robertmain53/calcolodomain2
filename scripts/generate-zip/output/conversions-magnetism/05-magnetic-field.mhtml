 {M} \cdot \mathrm {d} {\boldsymbol {\ell }}=3DI_{\mathrm {b} },}</annotati=
on>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/8617b3ca2fd2f45af47797bd11b89dbaf75f14c9" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -2.338ex; width:15.107ex; height:5.676ex;" alt=3D"{\displaystyle \=
oint \mathbf {M} \cdot \mathrm {d} {\boldsymbol {\ell }}=3DI_{\mathrm {b} }=
,}"></span>
where the integral is a line integral over any closed loop and <span class=
=3D"texhtml"><i>I</i><sub>b</sub></span> is the bound current enclosed by t=
hat closed loop.
</p><p>In the magnetic pole model, magnetization begins at and ends at magn=
etic poles. If a given region, therefore, has a net positive "magnetic pole=
 strength" (corresponding to a north pole) then it has more magnetization f=
ield lines entering it than leaving it. Mathematically this is equivalent t=
o:
<span class=3D"mwe-math-element mwe-math-element-block"><span class=3D"mwe-=
math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;"><math di=
splay=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\d=
isplaystyle \oint _{S}\mu _{0}\mathbf {M} \cdot \mathrm {d} \mathbf {A} =3D=
-q_{\mathrm {M} },}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <msub>
          <mo>=E2=88=AE<!-- =E2=88=AE --></mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>S</mi>
          </mrow>
        </msub>
        <msub>
          <mi>=CE=BC<!-- =CE=BC --></mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>0</mn>
          </mrow>
        </msub>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mi mathvariant=3D"bold">M</mi>
        </mrow>
        <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mi mathvariant=3D"normal">d</mi>
        </mrow>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mi mathvariant=3D"bold">A</mi>
        </mrow>
