          <mfrac>
            <mrow>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mi mathvariant=3D"normal">d</mi>
              </mrow>
              <mi mathvariant=3D"normal">=CE=A6<!-- =CE=A6 --></mi>
            </mrow>
            <mrow>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mi mathvariant=3D"normal">d</mi>
              </mrow>
              <mi>t</mi>
            </mrow>
          </mfrac>
