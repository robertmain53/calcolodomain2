            <mi mathvariant=3D"bold">F</mi>
          </mrow>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mtext>magnetic</mtext>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <mi>q</mi>
        <mo stretchy=3D"false">(</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
