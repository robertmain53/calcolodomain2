        <mo>.</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \mathbf {F} _=
{\text{magnetic}}=3Dq(\mathbf {v} \times \mathbf {B} ).}</annotation>
