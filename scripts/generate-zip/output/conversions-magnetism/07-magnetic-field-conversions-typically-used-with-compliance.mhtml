.wpcc-btn { display: block; font-size: 0.9em; font-weight: 700; padding: 0.=
4em 0.8em; text-align: center; white-space: nowrap; transition: background-=
color 0.2s; }

.wpcc-btn:hover { text-decoration: none; }

