2em;">500</span></span><span class=3D"mjx-mtext"><span class=3D"mjx-char MJ=
Xc-TeX-main-R" style=3D"padding-top: 0.446em; padding-bottom: 0.372em;">&nb=
sp;feet</span></span></span></span></span></span>. But when it was measured=
 by three people, they got <span class=3D"mjpage"><span class=3D"mjx-chtml"=
><span class=3D"mjx-math" aria-label=3D"503.5\text{ feet}"><span class=3D"m=
jx-mrow" aria-hidden=3D"true"><span class=3D"mjx-mn"><span class=3D"mjx-cha=
r MJXc-TeX-main-R" style=3D"padding-top: 0.372em; padding-bottom: 0.372em;"=
>503.5</span></span><span class=3D"mjx-mtext"><span class=3D"mjx-char MJXc-=
TeX-main-R" style=3D"padding-top: 0.446em; padding-bottom: 0.372em;">&nbsp;=
feet</span></span></span></span></span></span>, <span class=3D"mjpage"><spa=
n class=3D"mjx-chtml"><span class=3D"mjx-math" aria-label=3D"502.8\text{ fe=
et}"><span class=3D"mjx-mrow" aria-hidden=3D"true"><span class=3D"mjx-mn"><=
span class=3D"mjx-char MJXc-TeX-main-R" style=3D"padding-top: 0.372em; padd=
ing-bottom: 0.372em;">502.8</span></span><span class=3D"mjx-mtext"><span cl=
ass=3D"mjx-char MJXc-TeX-main-R" style=3D"padding-top: 0.446em; padding-bot=
tom: 0.372em;">&nbsp;feet</span></span></span></span></span></span>, and <s=
pan class=3D"mjpage"><span class=3D"mjx-chtml"><span class=3D"mjx-math" ari=
