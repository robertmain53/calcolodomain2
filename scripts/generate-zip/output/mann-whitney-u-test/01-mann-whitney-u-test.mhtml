            <mn>2</mn>
          </mrow>
        </msub>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <msub>
                <mi>n</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msub>
              <mo stretchy=3D"false">(</mo>
              <msub>
                <mi>n</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msub>
              <mo>+</mo>
              <mn>1</mn>
              <mo stretchy=3D"false">)</mo>
            </mrow>
            <mn>2</mn>
          </mfrac>
        </mrow>
        <mspace width=3D"thinmathspace"></mspace>
        <mspace width=3D"negativethinmathspace"></mspace>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle U_{2}=3DR_{2}=
-{n_{2}(n_{2}+1) \over 2}\,\!}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/5c795689db8e8f7c32803bad679a34384b52b921" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.838ex; margin-right: -0.387ex; width:23.332ex; height:5.676ex;" =
alt=3D"{\displaystyle U_{2}=3DR_{2}-{n_{2}(n_{2}+1) \over 2}\,\!}"></span><=
/dd></dl></dd></dl></dd></dl>
<dl><dd><dl><dd>The smaller value of <i>U</i><sub>1</sub> and <i>U</i><sub>=
