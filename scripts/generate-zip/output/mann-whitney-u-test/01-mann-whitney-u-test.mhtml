                  <msub>
                    <mi>n</mi>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mn>1</mn>
                    </mrow>
                  </msub>
                  <mo>+</mo>
                  <msub>
                    <mi>n</mi>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mn>2</mn>
                    </mrow>
                  </msub>
                  <mo>+</mo>
                  <mn>1</mn>
                  <mo stretchy=3D"false">)</mo>
                </mrow>
                <mn>12</mn>
              </mfrac>
            </mrow>
            <mo>=E2=88=92<!-- =E2=88=92 --></mo>
            <mrow class=3D"MJX-TeXAtom-ORD">
              <mfrac>
                <mrow>
                  <msub>
                    <mi>n</mi>
                    <mrow class=3D"MJX-TeXAtom-ORD">
                      <mn>1</mn>
                    </mrow>
                  </msub>
                  <msub>
                    <mi>n</mi>
                    <mrow class=3D"MJX-TeXAtom-ORD">
