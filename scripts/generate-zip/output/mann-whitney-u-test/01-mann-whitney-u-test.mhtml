    <annotation encoding=3D"application/x-tex">{\displaystyle \sigma _{\tex=
t{ties}}=3D{\sqrt {{n_{1}n_{2}(n_{1}+n_{2}+1) \over 12}-{n_{1}n_{2}\sum _{k=
=3D1}^{K}(t_{k}^{3}-t_{k}) \over 12n(n-1)}}},\,}</annotation>
