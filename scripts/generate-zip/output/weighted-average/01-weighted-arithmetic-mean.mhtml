      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \mathbf {x} _=
{i}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/57d2ef3df60acdb53bdf90535264041fea7231cd" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.671ex; width:2.211ex; height:2.009ex;" alt=3D"{\displaystyle \ma=
thbf {x} _{i}}"></span> (each set of single observations on each of the <i>=
K</i> random variables) is assigned a weight <span class=3D"mwe-math-elemen=
t mwe-math-element-inline"><span class=3D"mwe-math-mathml-inline mwe-math-m=
athml-a11y" style=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/=
Math/MathML" alttext=3D"{\displaystyle w_{i}\geq 0}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <msub>
          <mi>w</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>i</mi>
          </mrow>
        </msub>
        <mo>=E2=89=A5<!-- =E2=89=A5 --></mo>
        <mn>0</mn>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle w_{i}\geq 0}<=
/annotation>
