    <annotation encoding=3D"application/x-tex">{\textstyle {\frac {1}{n}}\s=
um \limits _{i=3D1}^{n}{x_{i}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/ed8681c1d6278fe086ce3314c2665e15333e5cff" class=3D"mwe-math-fallback=
