l>
<p>The <a href=3D"https://en.wikipedia.org/wiki/Ordinary_mean" class=3D"mw-=
redirect" title=3D"Ordinary mean">ordinary mean</a> <span class=3D"mwe-math=
-element mwe-math-element-inline"><span class=3D"mwe-math-mathml-inline mwe=
-math-mathml-a11y" style=3D"display: none;"><math xmlns=3D"http://www.w3.or=
g/1998/Math/MathML" alttext=3D"{\textstyle {\frac {1}{n}}\sum \limits _{i=
=3D1}^{n}{x_{i}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"false" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mn>1</mn>
            <mi>n</mi>
