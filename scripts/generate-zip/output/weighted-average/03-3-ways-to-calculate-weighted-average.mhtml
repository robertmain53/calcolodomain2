.wh_up { background-position: -35px 0px; position: relative; top: 0.2em; }

.wh_down { position: relative; top: 8px; }

.wh_count { color: rgb(205, 205, 204); }

.wh_vote_container { margin: 0.5em 0px 0px; }

.wh_thumb_msg { width: 78px; white-space: nowrap; }

.wh_thumb_response { display: none; }

.wh_thumb_default { color: rgb(205, 205, 204); display: inline-block; }

.wh_vote_container.clicked .wh_thumb_default { display: none; }

.wh_vote_container.clicked .wh_thumb_response { display: inline-block; }

.wh_vote_container.up .wh_thumb_response { color: rgb(147, 184, 116); }

.wh_vote_container.down .wh_thumb_response { color: rgb(204, 137, 105); }

.wh_vote_up.clicked .wh_count { color: rgb(147, 184, 116); }

.wh_vote_up.clicked .wh_up { background-position: -35px -23px; }

.wh_vote_down.clicked .wh_count { color: rgb(204, 137, 105); }

.wh_vote_down.clicked .wh_down { background-position: 0px -23px; }

.wh_vote_box { display: inline-block; }

.wh_vote_down { margin-left: 15px; }

body { backface-visibility: hidden; }

.animated { animation-duration: 1.2s; animation-fill-mode: both; }

@-webkit-keyframes fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes fadeIn {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.fadeIn { animation-name: fadeIn; }

@-webkit-keyframes fadeInDownBig {=20
  0% { opacity: 0; transform: translateY(-2000px); }
  100% { opacity: 1; transform: translateY(0px); }
}

