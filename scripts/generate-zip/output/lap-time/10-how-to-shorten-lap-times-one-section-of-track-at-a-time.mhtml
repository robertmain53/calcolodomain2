.glider-dot, .glider-next, .glider-prev { border: 0px; padding: 0px; user-s=
elect: none; outline: 0px; }

.glider-contain { width: 100%; }

.glider { overflow-y: hidden; }

.glider-track { width: 100%; margin: 0px; padding: 0px; display: flex; z-in=
dex: 1; }

.glider.draggable { user-select: none; cursor: grab; }

.glider.draggable .glider-slide img { user-select: none; pointer-events: no=
ne; }

.glider.drag { cursor: grabbing; }

.glider-slide { user-select: none; place-content: center; width: 100%; min-=
width: 150px; }

.glider-slide img { max-width: 100%; }

.glider::-webkit-scrollbar { opacity: 0; height: 0px; }

.glider-next, .glider-prev { position: absolute; background: 0px 0px; z-ind=
ex: 2; font-size: 40px; text-decoration: none; left: -23px; top: 30%; curso=
r: pointer; color: rgb(102, 102, 102); opacity: 1; line-height: 1; transiti=
on: opacity 0.5s cubic-bezier(0.17, 0.67, 0.83, 0.67), color 0.5s cubic-bez=
ier(0.17, 0.67, 0.83, 0.67); }

.glider-next:focus, .glider-next:hover, .glider-prev:focus, .glider-prev:ho=
ver { color: rgb(204, 204, 204); }

.glider-next { right: -23px; left: auto; }

.glider-next.disabled, .glider-prev.disabled { opacity: 0.25; color: rgb(10=
2, 102, 102); cursor: default; }

.glider-hide { opacity: 0; }

.glider-dots { user-select: none; display: flex; flex-wrap: wrap; justify-c=
ontent: center; margin: 0px auto; padding: 0px; }

.glider-dot { display: block; cursor: pointer; color: rgb(204, 204, 204); b=
order-radius: 999px; background: rgb(204, 204, 204); width: 12px; height: 1=
2px; margin: 7px; }

.glider-dot:focus, .glider-dot:hover { background: rgb(221, 221, 221); }

.glider-dot.active { background: rgb(168, 156, 200); }

@media (max-width: 36em) {
  .glider::-webkit-scrollbar { opacity: 1; appearance: none; width: 7px; he=
ight: 3px; }
  .glider::-webkit-scrollbar-thumb { opacity: 1; border-radius: 99px; backg=
round-color: rgba(156, 156, 156, 0.25); box-shadow: rgba(255, 255, 255, 0.2=
