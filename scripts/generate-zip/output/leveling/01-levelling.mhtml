    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <msub>
          <mi>g</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>i</mi>
          </mrow>
        </msub>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle g_{i}}</annot=
ation>
