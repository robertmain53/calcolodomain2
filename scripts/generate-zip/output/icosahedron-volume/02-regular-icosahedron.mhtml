pan typeof=3D"mw:File"><a href=3D"https://en.wikipedia.org/wiki/File:Circog=
onia_icosahedra.jpg" class=3D"mw-file-description"><img alt=3D"" src=3D"htt=
ps://upload.wikimedia.org/wikipedia/commons/thumb/c/c1/Circogonia_icosahedr=
a.jpg/120px-Circogonia_icosahedra.jpg" decoding=3D"async" width=3D"100" hei=
