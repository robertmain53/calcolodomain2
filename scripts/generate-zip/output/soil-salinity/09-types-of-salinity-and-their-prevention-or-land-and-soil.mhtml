<div class=3D"nsw-accordion__title"><button type=3D"button" aria-expanded=
=3D"false" aria-controls=3D"accordion-b9cade06-584a-48d5-bf37-e30aa09a1962"=
 class=3D"nsw-accordion__button">Treatment
  <span class=3D"material-icons nsw-material-icons" focusable=3D"false" ari=
a-hidden=3D"true">keyboard_arrow_down</span>
  </button></div>

  </div>
