			<td style=3D"text-align: right; padding-right: 30px;">2</td>
			<td align=3D"center">13</td>
			<td align=3D"left">6</td>
		</tr>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">1</td>
			<td align=3D"center">14</td>
			<td align=3D"left">1</td>
		</tr>
