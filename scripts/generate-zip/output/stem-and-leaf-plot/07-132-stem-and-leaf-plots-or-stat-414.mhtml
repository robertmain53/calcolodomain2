			<td style=3D"text-align: right; padding-right: 30px;">32</td>
			<td align=3D"center">9</td>
			<td align=3D"left">667889999</td>
		</tr>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">32</td>
			<td align=3D"center">10</td>
			<td align=3D"left">0112244</td>
		</tr>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">25</td>
			<td align=3D"center">10</td>
			<td align=3D"left">5556667777789</td>
		</tr>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">12</td>
