		<tr>
			<th>Leaf Unit =3D 1.0</th>
		</tr>
	</thead>
	<tbody>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">1</td>
			<td align=3D"center">6</td>
			<td align=3D"left">8</td>
		</tr>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">1</td>
			<td align=3D"center">6</td>
			<td align=3D"left">8</td>
		</tr>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">1</td>
			<td align=3D"center">7</td>
			<td>&nbsp;</td>
		</tr>
		<tr>
			<td style=3D"text-align: right; padding-right: 30px;">3</td>
