        <mo stretchy=3D"false">)</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle z=3D{\sqrt {\=
frac {n-3}{1.06}}}F(r)}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/77dc7724cf43da71abf83d57678af71165b4ae19" class=3D"mwe-math-fallback=
