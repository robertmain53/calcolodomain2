@charset "utf-8";

* { padding: 0px; margin: 0px; }

header { border-bottom: 1px solid lightgrey; }

#menu li a { color: black; margin-left: 15px; font-weight: 600; }

#menu li a:hover { color: rgb(64, 84, 178); }

aside ul li { list-style-type: square; }

aside li a { color: black; text-decoration: none; }

#unitNotes { font-size: 14px; font-weight: 700; }

#inchesNotes { font-size: 13px; font-weight: 700; }

#inchesNotes a { text-decoration: none; }

h1 { font-size: 21px; font-weight: 600; }

h2 { font-size: 20px; font-weight: 600; }

h3 { font-size: 19px; font-weight: 600; }

p a { text-decoration: none; font-weight: 700; }

#response-msg { width: 70%; margin: 15px auto; padding: 10px; border-radius=
: 5px; display: none; }

.error-msg { background: rgb(242, 222, 223); color: rgb(156, 65, 80); text-=
align: center; border: 1px solid rgb(231, 206, 209); }

.process-msg { background: rgb(217, 237, 246); color: rgb(55, 112, 132); te=
xt-align: center; border: 1px solid rgb(200, 220, 229); }

.success-msg { background: rgb(224, 239, 218); color: rgb(64, 122, 74); tex=
t-align: center; border: 1px solid rgb(198, 223, 178); }

footer { font-size: 12px; }

footer a { color: white; text-decoration: none; }

@media screen and (max-width: 992px) {
  #left-sidebar { display: none; }
}
