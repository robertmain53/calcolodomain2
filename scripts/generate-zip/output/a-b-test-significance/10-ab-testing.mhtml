            </mrow>
            <mrow>
              <mn>500</mn>
              <mo>+</mo>
              <mn>500</mn>
            </mrow>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\textstyle 5\%=3D{\frac {40=
+10}{500+500}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/fe493c5da1e37575eb18cb57dd4752ea3f815bbb" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.338ex; width:13.243ex; height:3.843ex;" alt=3D"{\textstyle 5\%=
=3D{\frac {40+10}{500+500}}}"></span>  to <span class=3D"mwe-math-element m=
we-math-element-inline"><span class=3D"mwe-math-mathml-inline mwe-math-math=
ml-a11y" style=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Mat=
h/MathML" alttext=3D"{\textstyle 6.5\%=3D{\frac {40+25}{500+500}}}">
