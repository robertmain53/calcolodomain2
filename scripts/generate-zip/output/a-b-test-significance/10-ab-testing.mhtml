500</span></span>=E2=81=A0</span> (5%)</td>
<td><link rel=3D"mw-deduplicated-inline-style" href=3D"mw-data:TemplateStyl=
es:r1214402035"><span class=3D"sfrac">=E2=81=A0<span class=3D"tion"><span c=
lass=3D"num">5</span><span class=3D"sr-only">/</span><span class=3D"den"> 5=
00</span></span>=E2=81=A0</span> (1%)
</td></tr></tbody></table>
<p>In this case, while variant A attracted a higher response rate overall, =
variant B actually elicited a higher response rate with men.
</p><p>As a result, the company might select a segmented strategy as a resu=
lt of the A/B test, sending variant B to men and variant A to women in the =
future. In this example, a segmented strategy would yield a 30% increase in=
 expected response rates from <span class=3D"mwe-math-element mwe-math-elem=
ent-inline"><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" sty=
le=3D"display: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" al=
ttext=3D"{\textstyle 5\%=3D{\frac {40+10}{500+500}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"false" scriptlevel=3D"0">
        <mn>5</mn>
        <mi mathvariant=3D"normal">%<!-- % --></mi>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mn>40</mn>
              <mo>+</mo>
