.result-container { margin-top: 30px; display: none; }

.result-container.show { display: block; }

.step { background: rgb(248, 249, 250); border-left: 4px solid rgb(55, 81, =
111); border-radius: 8px; padding: 20px; margin-bottom: 20px; opacity: 0; t=
ransform: translateY(-10px); animation: 0.5s ease 0s 1 normal forwards runn=
ing slideIn; }

@keyframes slideIn {=20
  100% { opacity: 1; transform: translateY(0px); }
}

.step-label { font-weight: 600; color: rgb(55, 81, 111); margin-bottom: 12p=
x; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; }

.step-text { color: rgb(51, 51, 51); line-height: 1.8; font-size: 16px; }

.step-text .MathJax { font-size: 1.1em !important; }

.step-text .MathJax_Display { margin: 15px 0px !important; }

.progress-indicator { text-align: center; color: rgb(55, 81, 111); font-siz=
e: 14px; margin-top: 15px; font-weight: 500; }

.error { color: rgb(220, 53, 69); background: rgb(248, 215, 218); border-le=
ft: 4px solid rgb(220, 53, 69); padding: 20px; border-radius: 8px; }

#question { width: 100%; padding: 15px; border: 2px solid rgb(224, 224, 224=
); border-radius: 10px; font-size: 16px; font-family: "Segoe UI", Tahoma, G=
eneva, Verdana, sans-serif; resize: vertical; transition: 0.3s; background:=
 rgb(250, 250, 250); box-shadow: rgba(0, 0, 0, 0.05) 0px 2px 4px; line-heig=
ht: 1.6; }

#question:focus { outline: none; border-color: rgb(55, 81, 111); background=
: rgb(255, 255, 255); box-shadow: rgba(102, 126, 234, 0.15) 0px 4px 12px; t=
ransform: translateY(-1px); }

#question:hover:not(:focus) { border-color: rgb(184, 193, 236); background:=
 rgb(255, 255, 255); }
