e; }

pre { font-family: Inconsolata, monospace; margin: 0px 0px 1em; padding: 2p=
x; border: 1px dotted rgb(170, 170, 170); background-color: rgb(249, 249, 2=
49); white-space: pre-wrap; }

img { border: 0px; }

.menu ul { padding: 0px; margin: 0.5em; list-style: none; }

.menu ul li p { padding: 0px 0px 0px 0.3em; margin: 0px; }

.menu h2 { padding: 0px; margin: 0px; }

.link-prev { float: left; }

.link-next { float: right; }

.link-contents { width: 100%; text-align: center; }

.navbar { font-size: 90%; }

.plump { display: none; }

.main { padding-left: 0.2em; padding-right: 0.2em; margin-left: auto; margi=
n-right: auto; }

.main p { max-width: 70ch; margin-top: 0.1em; }

@media (min-width: 640px) {
  .main { max-width: 40em; padding-left: 1em; padding-right: 1em; }
}

@media (min-width: 896px) {
  .skinny { display: none; }
  .link-contents { visibility: hidden; }
  .rside { margin-left: 20ch; }
  .plump { font-size: 90%; float: left; width: 20ch; display: block; paddin=
g: 0.5em; }
  .main { max-width: 92ch; }
}

.quoteblock { border-left: 5px solid rgb(240, 240, 240); padding-left: 1em;=
 margin-left: 2em; }

td .listingblock { padding: 0px; margin: 0px; border: 0px; background-color=
: white; }

td p { padding: 0px; margin: 0px; }

.disabledlink { text-decoration: none; font-weight: bold; font-size: 95%; }

.footer { clear: both; border-top: 1px solid rgb(170, 170, 170); padding: 0=
.5em; font-size: 90%; }

#lightswitch { float: right; cursor: pointer; }
