@charset "utf-8";

.sectionContent { flex: 1 1 0%; display: flex; flex-direction: column; alig=
n-items: center; justify-content: center; min-height: 350px; }

.contactFlex { display: flex; align-items: flex-start; justify-content: cen=
ter; gap: 40px; flex-wrap: wrap; }

.contactInfo, .contactForm { flex: 1 1 300px; min-width: 250px; max-width: =
500px; }

@media (max-width: 768px) {
  .contactFlex { flex-direction: column; align-items: stretch; gap: 20px; }
  .contactInfo, .contactForm { max-width: 100%; min-width: 0px; }
}

body, html { background-color: rgb(255, 255, 255); font-family: Arial, Helv=
etica, sans-serif; height: 100%; width: 100%; line-height: 1.6em; font-size=
: 1em; padding: 0px; margin: 0px; }

p { line-height: 2em; }

.container-fluid { padding: 0px; margin: 0px; }

body, html, div, p, h1, h2, h3, h4, .row { padding: 0px; margin: 0px; }

.vcenterAdmin { display: inline-block; vertical-align: middle; float: none;=
 }

.sectionFlex { display: flex; align-items: center; }

.sectionAlignLeft .sectionImage { order: 0; }

.sectionAlignLeft .sectionContent { order: 1; }

.sectionAlignRight .sectionImage { order: 1; }

.sectionAlignRight .sectionContent { order: 0; }

#header { height: 400px; }

.vcenter { display: flex; align-items: center; justify-content: center; gap=
: 10px; }

.constrain { max-width: 1200px; margin: 0px auto; }

.spacer { margin: 20px 0px; }

.spacer-padding { padding: 20px 0px; }

.centered { position: relative; top: 50%; transform: translateY(-50%); text=
-align: center; }

.text-white { color: rgb(255, 255, 255); }

.text-dark { color: rgb(29, 29, 29); }

.text-faded { color: rgb(204, 204, 204); }

.text-red { color: rgb(208, 23, 29); }

.text-tiny { font-size: 80%; }

a { text-decoration: none; color: rgb(255, 255, 255); }

a:link { text-decoration: none; color: rgb(255, 255, 255); }

a:hover { text-decoration: none; color: rgb(204, 204, 204); }

a:active { text-decoration: none; color: rgb(204, 204, 204); }

a:visited { text-decoration: none; }

.bfsBtn { text-align: center; color: rgb(29, 29, 29); border: 2px solid rgb=
(29, 29, 29); padding: 10px; cursor: pointer; min-width: 200px; }

.bfsBtn:hover { text-align: center; color: rgb(255, 255, 255); background-c=
olor: rgb(29, 29, 29); border: 2px solid rgb(29, 29, 29); padding: 10px; cu=
rsor: pointer; }

.hideme { opacity: 0; }

.smallForm { max-width: 550px; margin: 0px auto; padding: 10px; }

.bg-dark { background-color: rgb(29, 29, 29); }

.bg-red { background-color: rgb(208, 23, 29); }

.bfsNavItem { cursor: pointer; padding: 5px; display: inline-block; backgro=
und-color: rgb(208, 23, 29) !important; }

.bfsNavItem > a > p { font-weight: 600; }

.bfsNavItem:hover { background-color: rgb(122, 21, 20) !important; }

.bfsNavItemLower { cursor: pointer; padding: 5px; display: inline-block; }

.homeOption { color: rgb(29, 29, 29); }

.homeOption:hover { color: rgb(208, 23, 29); }

.text-shadow { text-shadow: rgba(0, 0, 0, 0.8) 0px 2px 2px; }

@media screen and (max-width: 992px) {
  .detailPic { text-align: justify; background: none !important; }
  .bfsBtn { margin-bottom: 20px; }
  #headerText { font-size: 3em !important; }
}

.sidebar-nav { padding: 9px 0px; }

.dropdown-menu .sub-menu { left: 100%; position: absolute; top: 0px; visibi=
lity: hidden; margin-top: -1px; }

.dropdown-menu li:hover .sub-menu { visibility: visible; }

.dropdown:hover .dropdown-menu { display: block; }

.nav-tabs .dropdown-menu, .nav-pills .dropdown-menu, .navbar .dropdown-menu=
 { margin-top: 0px; }

.navbar .sub-menu::before { border-bottom: 7px solid transparent; border-le=
ft: none; border-right: 7px solid rgba(0, 0, 0, 0.2); border-top: 7px solid=
 transparent; left: -7px; top: 10px; }

.navbar .sub-menu::after { border-top: 6px solid transparent; border-left: =
none; border-right: 6px solid rgb(255, 255, 255); border-bottom: 6px solid =
transparent; top: 11px; left: -6px; }

.dropdown-menu { margin-top: 0px !important; }

.fw-bold { font-weight: bold; }

.terminalLocation:hover { background-color: rgb(204, 204, 204); }

.pointer { cursor: pointer; }

.noPadding { padding: 0px; }

.trans-black { background-color: rgba(0, 0, 0, 0.5); padding: 10px; }

.logoIcon { padding: 5px; }
