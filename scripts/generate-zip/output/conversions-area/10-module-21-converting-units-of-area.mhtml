:root { --sk-size: 40px; --sk-color: #333; }

.sk-center { margin: auto; }

.sk-plane { animation: 1.2s ease-in-out 0s infinite normal none running sk-=
plane; background-color: var(--sk-color); height: var(--sk-size); width: va=
r(--sk-size); }

@keyframes sk-plane {=20
  0% { transform: perspective(120px) rotateX(0deg) rotateY(0deg); }
  50% { transform: perspective(120px) rotateX(-180.1deg) rotateY(0deg); }
  100% { transform: perspective(120px) rotateX(-180deg) rotateY(-179.9deg);=
 }
}

.sk-chase { animation: 2.5s linear 0s infinite normal both running sk-chase=
; height: var(--sk-size); position: relative; width: var(--sk-size); }

.sk-chase-dot { animation: 2s ease-in-out 0s infinite normal both running s=
k-chase-dot; height: 100%; left: 0px; position: absolute; top: 0px; width: =
100%; }

