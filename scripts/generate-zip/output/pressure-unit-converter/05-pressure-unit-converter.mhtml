<h2 class=3D"wp-block-heading alignwide is-style-beamex-underline">Pressure=
 unit converter</h2>



<p class=3D"alignwide has-text-align-wide">Use the below pressure unit conv=
erter by entering the numerical pressure value to the =E2=80=9CValue=E2=80=
=9D field, the unit to the =E2=80=9CUnit=E2=80=9D field.&nbsp;Press the =E2=
=80=9CConvert=E2=80=9D button to view the results in the table below.&nbsp;=
Please&nbsp;use decimal dot (not a comma).&nbsp;Hover over the unit in the =
table to see its full name.</p>


<div class=3D"wp-block-gds-converter-pressure alignwide">
  <div class=3D"wp-block-gds-convertor-pressure__inner-container" id=3D"for=
mContainer">
    <form action=3D"https://www.beamex.com/us/resources/pressure-unit-conve=
rter/" id=3D"converterform">
      <fieldset id=3D"converter-value">
          <label class=3D"inlinelabel" for=3D"pressureValue">
            Value (numerical)
          </label>
          <input type=3D"text" id=3D"pressureValue" value=3D"1" name=3D"pre=
ssureValue" placeholder=3D"Value to convert">
      </fieldset>
      <fieldset id=3D"converter-unit">
        <label class=3D"inlinelabel" for=3D"pressureUnit">
          Unit
        </label>
        <select id=3D"pressureUnit" name=3D"pressureUnit">
          <option value=3D"0">Select pressure unit</option>
          <option value=3D"1">Technical atmosphere [at]</option>
          <option value=3D"2">Standard atmosphere [atm]</option>
          <option value=3D"3">Bar [bar]</option>
          <option value=3D"4">Centimeter of water [cmH=E2=82=820]</option>
