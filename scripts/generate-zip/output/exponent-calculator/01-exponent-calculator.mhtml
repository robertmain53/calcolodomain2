=3D"center"><td>a<sup>n</sup></td></tr></tbody></table></td>
</tr></tbody></table>
<table align=3D"center" class=3D"compacttable"><tbody><tr>
<td>EX: 2<sup>(-3)</sup> =3D 1 =C3=B7 2 =C3=B7 2 =C3=B7 2 </td>
<td>&nbsp;=3D&nbsp;</td>
<td><table cellspacing=3D"0" cellpadding=3D"0"><tbody><tr align=3D"center">=
