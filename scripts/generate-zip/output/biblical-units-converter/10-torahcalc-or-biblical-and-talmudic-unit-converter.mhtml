@charset "utf-8";

#cssmenu { width: auto; }

#cssmenu ul { z-index: 10; zoom: 1; background: rgb(12, 114, 195); margin: =
0px; padding: 0px 10px; }

#cssmenu ul::before { content: ""; display: block; }

#cssmenu ul::after { content: ""; display: table; clear: both; }

#cssmenu li { margin: 0px 5px 0px 0px; border: 1px solid transparent; displ=
ay: inline-block; position: relative; }

#cssmenu li a { margin: 8px 15px 9px; display: block; text-decoration: none=
; color: rgb(255, 255, 255); font-size: 16px; }

#cssmenu li.active { display: block; background: rgb(19, 92, 147); }

#cssmenu li:hover { background: rgb(19, 92, 147); }

#cssmenu li ul { position: absolute; display: none; opacity: 0; visibility:=
 hidden; border: 3px solid rgb(19, 92, 147); left: 0px; right: auto; }

#cssmenu li ul li { display: block; }

#cssmenu li:hover ul { display: block; opacity: 1; visibility: visible; }

#menuIconContainer { display: none; }

#cssmenu { overflow: visible !important; }

@media only screen and (max-width: 600px) {
  #cssmenu.open { max-height: 600px; transition: max-height 0.25s ease-in; =
}
  #cssmenu.open li { float: none; margin: 0px 5px 2px 0px; border: 1px soli=
d transparent; display: block; position: relative; }
  #cssmenu { max-height: 0px; transition: max-height 0.1s ease-out; backgro=
und: rgb(213, 213, 213); overflow: hidden !important; }
  #cssmenu li ul { right: 0px; left: auto; }
  #menuIconContainer { display: inline-block; cursor: pointer; position: ab=
solute; top: 18px; right: 18px; background: rgb(33, 150, 243); border: 4px =
solid rgb(33, 150, 243); }
  .menuIconBar1, .menuIconBar2, .menuIconBar3 { height: 5px; background-col=
or: rgb(255, 255, 255); transition: 0.4s; width: 35px !important; margin: -=
2px 0px 9px !important; }
  .menuIconChange .menuIconBar1 { transform: rotate(-45deg) translate(-9px,=
 9px); }
  .menuIconChange .menuIconBar2 { opacity: 0; }
  .menuIconChange .menuIconBar3 { transform: rotate(45deg) translate(-8px, =
-8px); }
}

#navBar { width: 100%; }

@media only screen and (max-width: 600px) {
  #navBar { width: 100%; position: fixed; top: 0px; left: 0px; right: 0px; =
z-index: 1000; }
  div.bodyDiv { margin-top: 80px; }
}

#navBar div a img { padding: 0px 0px 0px 14px !important; }
