            <mn>1</mn>
            <mn>2</mn>
          </mfrac>
        </mrow>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <msqrt>
            <msup>
              <mi>a</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>2</mn>
              </mrow>
            </msup>
            <msup>
              <mi>c</mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>2</mn>
              </mrow>
            </msup>
            <mo>=E2=88=92<!-- =E2=88=92 --></mo>
            <msup>
              <mrow>
                <mo>(</mo>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mfrac>
                    <mrow>
                      <msup>
                        <mi>a</mi>
                        <mrow class=3D"MJX-TeXAtom-ORD">
                          <mn>2</mn>
                        </mrow>
                      </msup>
                      <mo>+</mo>
                      <msup>
                        <mi>c</mi>
                        <mrow class=3D"MJX-TeXAtom-ORD">
                          <mn>2</mn>
                        </mrow>
                      </msup>
                      <mo>=E2=88=92<!-- =E2=88=92 --></mo>
