<h1>Significant Figures</h1>

<p class=3D"notecat"><b>Annotation category:</b><br>Chapter 5</p>

<!-- begin Note -->
<table cellspacing=3D"0" cellpadding=3D"0" border=3D"0" width=3D"100%">
<tbody><tr><td height=3D"1" bgcolor=3D"#cccccc"><spacer type=3D"block" widt=
