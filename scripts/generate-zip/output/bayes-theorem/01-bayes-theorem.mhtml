    <annotation encoding=3D"application/x-tex">{\displaystyle P(X_{C}|Y)=3D=
{\frac {P(Y|X_{C})P(X_{C})}{P(Y)}}=3D{\frac {0.01\cdot 0.50}{0.024}}=3D{\fr=
ac {5}{24}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/04d3d5182f6344e07323113d18c47afb33b227c1" class=3D"mwe-math-fallback=
