        <mo stretchy=3D"false">(</mo>
        <mi>B</mi>
        <mo>=E2=88=A9<!-- =E2=88=A9 --></mo>
        <msub>
          <mi>A</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>j</mi>
          </mrow>
        </msub>
        <mo stretchy=3D"false">)</mo>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle P(B)=3D\sum _=
{j}P(B\cap A_{j}),}</annotation>
  </semantics>
