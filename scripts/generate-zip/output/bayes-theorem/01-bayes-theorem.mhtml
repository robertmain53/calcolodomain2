        <mi>C</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=3D</mo>
        <mi>P</mi>
        <mo stretchy=3D"false">(</mo>
        <mi>B</mi>
        <mo>=E2=88=A9<!-- =E2=88=A9 --></mo>
        <mi>A</mi>
        <mo>=E2=88=A9<!-- =E2=88=A9 --></mo>
        <mi>C</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=3D</mo>
        <mi>P</mi>
        <mo stretchy=3D"false">(</mo>
        <mi>B</mi>
        <mo fence=3D"false" stretchy=3D"false">|</mo>
        <mi>A</mi>
        <mo>=E2=88=A9<!-- =E2=88=A9 --></mo>
        <mi>C</mi>
