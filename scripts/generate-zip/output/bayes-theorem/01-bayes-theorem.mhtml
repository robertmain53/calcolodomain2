<p>The denominator <span class=3D"mwe-math-element mwe-math-element-inline"=
><span class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"displ=
ay: none;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\=
displaystyle P({\text{Positive}})=3DP({\text{Positive}}\vert {\text{User}})=
P({\text{User}})+P({\text{Positive}}\vert {\text{Non-user}})P({\text{Non-us=
er}})}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>P</mi>
        <mo stretchy=3D"false">(</mo>
