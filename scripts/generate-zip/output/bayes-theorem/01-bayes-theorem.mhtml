              <mn>0.50</mn>
            </mrow>
            <mn>0.024</mn>
          </mfrac>
        </mrow>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mn>5</mn>
            <mn>24</mn>
          </mfrac>
