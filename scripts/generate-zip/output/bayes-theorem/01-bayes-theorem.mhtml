        <mrow class=3D"MJX-TeXAtom-ORD">
          <mo stretchy=3D"false">|</mo>
        </mrow>
        <mi mathvariant=3D"normal">=C2=AC<!-- =C2=AC --></mi>
        <mi>A</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>.</mo>
      </mstyle>
    </mrow>
