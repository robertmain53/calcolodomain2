      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle P({\text{User=
}}\vert {\text{Positive}})}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/d138c95f551ed76cc90c8a0592cd42768ec972b7" class=3D"mwe-math-fallback=
