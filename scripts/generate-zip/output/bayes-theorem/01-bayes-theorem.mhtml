        <mi>A</mi>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mo stretchy=3D"false">|</mo>
        </mrow>
        <mi>B</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=3D</mo>
        <mi>c</mi>
        <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
        <mi>P</mi>
        <mo stretchy=3D"false">(</mo>
        <mi mathvariant=3D"normal">=C2=AC<!-- =C2=AC --></mi>
        <mi>A</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=E2=8B=85<!-- =E2=8B=85 --></mo>
