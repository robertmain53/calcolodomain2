<td>k</td>
</tr>
<tr>
<td>10<sup>-2</sup></td>
<td>centi</td>
<td>c</td>
</tr>
<tr>
<td>10<sup>-3</sup></td>
<td>milli</td>
<td>m</td>
</tr>
<tr>
<td>10<sup>-6</sup></td>
<td>micro</td>
<td>=C2=B5</td>
</tr>
<tr>
<td>10<sup>-9</sup></td>
<td>nano</td>
<td>n</td>
</tr>
</tbody>
</table>
<p>&nbsp;</p>
