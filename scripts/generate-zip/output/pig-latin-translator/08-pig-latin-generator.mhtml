"sans-serif"; }

html { background-color: rgb(255, 209, 253); }

section { margin-bottom: 50px; }

h1 { font-size: 2rem; }

h2 { font-size: 1.75rem; }

p { font-size: 1.5rem; line-height: 2rem; margin-bottom: 15px; }

a { color: blue; }

.center { text-align: center; }

.title { font-weight: bold; padding: 20px 0px; }

.pseudo-link { color: blue; text-decoration: underline; }

.pseudo-link:hover { cursor: pointer; }

.navbar { display: flex; height: 50px; width: 100%; align-items: center; ba=
ckground-color: rgb(255, 209, 253); }

.brand-wrap { margin-left: 3vw; height: 40px; background-color: inherit; di=
splay: flex; justify-content: center; align-items: center; }

.brand { text-decoration: none; width: 100%; height: 100%; text-align: cent=
er; line-height: 40px; font-weight: bold; color: black; }

main { min-height: 100vh; background-color: white; padding-bottom: 100px; }

.abs-background { position: absolute; width: 100%; height: 100%; }

.background-rect { position: absolute; width: 80%; height: 80%; top: 10%; l=
eft: 10%; background-color: pink; border-radius: 15px; opacity: 0.2; transf=
orm: rotate(5deg); }

.text-boxes { width: 90%; left: 5%; display: grid; grid-template-columns: 1=
fr 1fr; gap: 2vw; }

.box { position: relative; width: 100%; min-height: 200px; overflow-y: scro=
ll; padding: 10px; }

.info-boxes { width: 90%; left: 5%; display: flex; flex-direction: row; gap=
: 2vw; }

.info-box { display: flex; flex-direction: column; align-items: flex-start;=
 }

.info-background { position: absolute; width: 100%; height: 100%; }

.f { background-color: rgb(255, 209, 253); padding-top: 20px; overflow: hid=
den; }

.f p { font-size: 1rem; }

.f-items { display: flex; flex-direction: column; justify-content: center; =
align-items: flex-start; margin-left: 5vw; width: 95vw; gap: 20px; backgrou=
nd-color: inherit; }

.f-links { height: 50px; display: flex; flex-direction: row; width: 50%; ga=
p: 5vw; align-items: center; justify-content: space-around; background-colo=
r: inherit; }

.f-link { list-style-type: none; background-color: inherit; height: 100%; l=
ine-height: 50px; }

.f-link a { text-decoration: none; color: black; width: 100%; height: 100%;=
 background-color: inherit; }

.f-link a p { padding: 0px 10px; border-radius: 5px; background-color: inhe=
rit; }

.f-link a:hover p { filter: brightness(1.1); }

.f-copy { min-height: 50px; line-height: 50px; }

@media screen and (max-width: 768px) {
  .text-boxes { grid-template-columns: 1fr; }
  .info-boxes { flex-direction: column; }
  .f-links { width: 100%; }
}
