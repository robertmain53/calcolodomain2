css/pigStyle.css">
        <link rel=3D"stylesheet" type=3D"text/css" href=3D"https://www.pigl=
atin.io/css/pigStyle.css">
        <link rel=3D"icon" type=3D"image/svg+xml" href=3D"https://www.pigla=
tin.io/favicon.svg">
        <link rel=3D"alternate icon" href=3D"https://www.piglatin.io/favico=
n.ico">
    </head>

    <body ng-controller=3D"filterAppController" class=3D"ng-scope">

        <header>
            <nav class=3D"navbar">
                <div class=3D"brand-wrap">
                    <span class=3D"brand">Pig Latin Generator</span>
                </div>
            </nav>
        </header>

        <main>
            <div class=3D"abs-background"></div>
            <section>
                <h1 class=3D"center title">Translate&nbsp;English to Pig&nb=
sp;Latin</h1>
                <div class=3D"text-boxes">
                    <div class=3D"input-box">
                        <label for=3D"englishBox"><h2 class=3D"text-center"=
>Enter English Below:</h2></label>
                        <textarea id=3D"englishBox" class=3D"box ng-pristin=
e ng-untouched ng-valid ng-empty" type=3D"text" ng-model=3D"string" ng-keyu=
p=3D"makePigString()"></textarea>
                    </div>
                    <div class=3D"output-box">
                        <label for=3D"pigBox"><h2 class=3D"text-center">Pig=
 Latin translation:</h2></label>
                        <textarea id=3D"pigBox" class=3D"box ng-binding" ty=
pe=3D"text"></textarea>
                    </div>
                </div>
            </section>

            <info-about class=3D"ng-isolate-scope"><section>
    <div class=3D"abs-background">
        <div class=3D"background-rect" style=3D"transform: rotate(5deg); ba=
ckground-color: rgb(238, 196, 255);"></div>
    </div>

    <h2 class=3D"center title">What is Pig Latin?</h2>
    <div class=3D"info-boxes">
        <div class=3D"info-box">
            <img alt=3D"cute pig pointing chalk at a chalkboard with 'Oink'=
 written on it" width=3D"300" height=3D"300" src=3D"https://www.piglatin.io=
/images/aboutPigLatin.svg">
        </div>

        <div class=3D"info-box">
            <div class=3D"info-background"></div>
            <p>
                Pig latin is an English language word game, or <a aria-labe=
l=3D"link to wikipedia page for argot" href=3D"https://en.wikipedia.org/wik=
i/Cant_(language)#Argot" target=3D"_blank" rel=3D"noreferrer">argot</a>.
                English words are altered by adjusting positions of one or =
more letters and adding additional suffixes. The goal is to end up
                with a word similar enough to the original to be understood=
 by someone who is familiar with the <em>language</em> but also different
                enough not to be understood by someone else.
            </p>
        </div>
    </div>
</section>
</info-about>
            <info-rules class=3D"ng-isolate-scope"><section>
    <div class=3D"abs-background">
        <div class=3D"background-rect" style=3D"transform: rotate(3deg); ba=
ckground-color: rgb(231, 183, 255);"></div>
    </div>

    <h2 class=3D"center title">How does it Work?</h2>
    <div class=3D"info-boxes">
        <div class=3D"info-box">
            <div class=3D"info-background"></div>
            <p>
                There is not an <em>official</em> set of rules, but the gen=
eral principal remains fairly consistent depending
                on who you talk to. We use the following method:
            </p>
            <p>
                Take the first letter of a word and move it to the end.
            </p>
            <p>
                Then add "-ay".
            </p>
            <p>
                And that's pretty much it! Pretty easy right?
                <!--
                    For a more detailed explanation of the rules with all s=
pecial cases and
                    exceptions you can <span class=3D"pseudo-link" id=3D"sh=
ow-rules" aria-label=3D"click to view our detailed list of rules for genera=
ting pig latin">view our algorithm here.</span>
                -->
            </p>
        </div>
        <div class=3D"info-box">
            <img alt=3D"cute pig with yellow hardhat and wrench" width=3D"3=
00" height=3D"300" src=3D"https://www.piglatin.io/images/howTo.svg">
        </div>
    </div>
</section>
</info-rules>
        </main>

        <pig-footer class=3D"ng-isolate-scope"><footer class=3D"f">
    <div class=3D"f-items">
        <ul class=3D"f-links">
            <li class=3D"f-link"><a rel=3D"noreferrer" href=3D"https://gith=
ub.com/csperando"><p>GitHub</p></a></li>
            <li class=3D"f-link"><a rel=3D"noreferrer" href=3D"https://twit=
ter.com/colemansperando"><p>Twitter</p></a></li>
            <li class=3D"f-link"><a rel=3D"noreferrer" href=3D"https://www.=
linkedin.com/in/csperando/"><p>Linkedin</p></a></li>
        </ul>
        <p class=3D"f-copy">Made for fun by Coleman Sperando</p>
    </div>
</footer>
</pig-footer>

        <mod-rules class=3D"ng-isolate-scope"><link rel=3D"preload" as=3D"s=
tyle" href=3D"https://www.piglatin.io/css/modRules.css">
<link rel=3D"stylesheet" type=3D"text/css" href=3D"https://www.piglatin.io/=
css/modRules.css">

<div class=3D"algo-modular-view" id=3D"algo-view">
    <div class=3D"algo-opaque-fill"></div>
    <div class=3D"algo-content">
        <ol class=3D"algo-list">
            <li class=3D"algo-list-item">
                <h3 class=3D"algo-rule-name">Words starting with a single c=
onsonent</h3>
                <p class=3D"algo-rule-text">
                    If a word begins with a single consonent followed by a =
vowel, then you simply need to move the first letter to
                    the end of the word and add -ay. For example:
                </p>
                <p class=3D"algo-rule-text algo-inset">pig</p>
                <p class=3D"algo-rule-text algo-inset">igpay</p>
            </li>
            <li class=3D"algo-list-item">
                <h3 class=3D"algo-rule-name">Words beginning with a vowel</=
h3>
                <p class=3D"algo-rule-text">
                    If a word begins with a vowel, then you do not need to =
manipulate the original order of the word's letters.
                    Instead, simply add <em>-way</em> to the end of the wor=
d. For example:
                </p>
                <p class=3D"algo-rule-text algo-inset">oink</p>
                <p class=3D"algo-rule-text algo-inset">oinkway</p>
            </li>
            <li class=3D"algo-list-item">
                <h3 class=3D"algo-rule-name">Words beginning with <em>ch-</=
em>, <em>qu-</em>, etc.</h3>
                <p class=3D"algo-rule-text">
                    Some words begin with multiple consonents or multiple l=
etter sounds, like <b>quilt</b>, <b>chair</b>, etc. In
                    these cases, we treat the sound like it is a single con=
sonent. Move both letters to the end of the word and
                    add <em>-ay</em>. For example:
                </p>
                <p class=3D"algo-rule-text algo-inset">chair</p>
                <p class=3D"algo-rule-text algo-inset">airchay</p>
            </li>
            <li class=3D"algo-list-item">
                <h3 class=3D"algo-rule-name">Special characters</h3>
                <p class=3D"algo-rule-text">
                    Pig latin does not try to be grammatically correct. It =
is meant to be a spoken language. If punctuation
                    is present in your input at the beginning or end of a w=
ord <em>(i.e. periods, commas)</em>, then it
                    will remain in the output. However, characters like the=
 apostrophe in <b>it's</b> will be lost when
                    converting to <b>itsway</b>.
                </p>
            </li>
        </ol>
    </div>
    <div class=3D"algo-close" id=3D"algo-close">
        <img alt=3D"red X icon to close pig latin rules" width=3D"50" heigh=
t=3D"50" src=3D"https://www.piglatin.io/images/close.svg">
    </div>
</div>
</mod-rules>

