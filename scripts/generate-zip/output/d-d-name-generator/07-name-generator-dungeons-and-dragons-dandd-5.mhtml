Content-Type: text/css
Content-Transfer-Encoding: quoted-printable
Content-Location: https://www.aidedd.org/dnd-commun/style.css?v=2

@charset "utf-8";

* { box-sizing: border-box; margin: 0px; padding: 0px; outline: none; }

html { font-size: 10px; }

body { font-family: Verdana, Arial, sans-serif; background-color: white; li=
ne-height: 1.5rem; }

.header { background: rgb(22, 22, 22); width: 100%; padding: 28px 10px 10px=
; }

.header h1 { font-family: Helvetica, Arial, sans-serif; font-size: 48px; li=
ne-height: 48px; font-weight: bold; color: white; }

.header h1 a:link, h1 a:visited, h1 a:hover { text-decoration: none; color:=
 rgb(255, 255, 255); }

.header p { font-family: Verdana, Arial, sans-serif; font-size: 12px; color=
: rgb(187, 187, 187); padding-top: 5px; }

hr { display: block; clear: both; border: 0px; }

div.col { display: inline-block; width: 100%; vertical-align: top; font-siz=
e: 1.2rem; padding: 10px 10px 70px; }

textarea, select, input, span { font-family: Verdana, Arial, sans-serif; fo=
nt-size: 1.2rem; padding: 2px; }

button { margin: 2px; background-color: rgb(184, 0, 0); color: rgb(255, 255=
, 255); padding: 7px 14px; border: 0px solid rgb(184, 0, 0); border-radius:=
 4px; }

.center { text-align: center; }

.gras { font-weight: bold; }

.red { color: rgb(184, 0, 0); }

div.ads { text-align: center; margin: 8px; }

@media only screen and (max-width: 1099px) {
  .header { padding-top: 18px; }
  .header h1 { font-size: 32px; line-height: 32px; }
  .header { padding-left: 10px; padding-bottom: 0px; }
  .header p { margin-top: 0px; }
}

.header .menu { max-height: 0px; transition: max-height 0.2s ease-out; }

.header .menu-icon { position: absolute; right: 10px; top: 24px; padding: 4=
px; color: white; font-size: 20px; cursor: pointer; transition: background =
0.2s ease-out; }

.header .menu-btn { display: none; }

.header .menu-btn:checked ~ .menu { max-height: 400px; }

.header ul { list-style: none; overflow: hidden; padding-top: 2px; padding-=
bottom: 6px; }

.header li { display: block; padding: 10px 6px; font-family: Helvetica, Ari=
al, sans-serif; text-transform: uppercase; font-size: 18px; font-weight: bo=
ld; }

.header li a, .header li { text-decoration: none; color: rgb(152, 152, 152)=
; }

.header li a:hover, .header li:hover { color: rgb(208, 208, 208); }

.header li a.current, .header li.current { color: white; }

@media (min-width: 1099px) {
  .header ul { position: absolute; right: 10px; top: 76px; overflow: visibl=
e; padding: 0px; }
  .header li { float: left; padding: 6px 12px; white-space: nowrap; text-tr=
ansform: none; font-size: 15px; }
  .header .menu { clear: none; float: right; max-height: none; }
  .header .menu-icon { display: none; }
  ul.menu li { cursor: pointer; }
}
------MultipartBoundary--9MEX8qRcGkPQQ64cdUh9WrBl2jztmoLB70y0BYVH6t----
Content-Type: text/css
Content-Transfer-Encoding: quoted-printable
Content-Location: https://www.aidedd.org/dnd-gen/style.css?v=7

@charset "utf-8";

a:link, a:visited, a:hover { text-decoration: none; font-weight: bold; colo=
r: rgb(184, 0, 0); }

div.col1 { width: 50%; padding: 10px; margin-top: 10px; border: 0px; }

div.col2 { width: 50%; padding: 10px; margin: 10px 0px 110px; border-left: =
1px solid rgb(221, 221, 221); }

div.col h2 { margin: 15px 0px 10px; line-height: 32px; }

div.col h3 { margin: 20px 0px 10px; }

div.col p { margin-bottom: 6px; }

.choix { text-align: center; width: 19%; margin: 0px; padding: 10px 5px; di=
splay: inline-block; }

.choix i { font-size: 64px; cursor: pointer; margin-top: 5px; }

.choix i:hover { color: rgb(136, 136, 136); }

.result { margin: 20px; }

input#texte, select#langue { font-size: 14px; padding: 4px; margin: 10px 1%=
 0px; border: 1px solid rgb(160, 160, 160); }

input#texte { width: 95%; }

div#output { padding: 20px; line-height: 64px; }

@font-face { font-family: nain; src: url("webfonts/nain.woff"); }

@font-face { font-family: elfique; src: url("webfonts/elfique.woff"); }

@font-face { font-family: draconique; src: url("webfonts/draconique.woff");=
 }

@font-face { font-family: infernal; src: url("webfonts/infernal.woff"); }

@font-face { font-family: celeste; src: url("webfonts/celeste.woff"); }

@media only screen and (max-width: 999px) {
  .nocel { display: none !important; }
  div.col1 { width: 100%; border: 0px; margin-top: 5px; }
  div.col2 { width: 100%; border: 0px; margin-top: 15px; }
  .result { margin: 10px; }
  div#output { padding: 10px; }
  input#texte { width: 98%; }
  .choix { width: 18%; }
  .choix i { font-size: 48px; }
}
