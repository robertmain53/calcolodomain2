<!-- WordPress Compatible Horsepower Calculator -->
<!-- This version uses simpler JavaScript that's more compatible with WordP=
ress themes -->

<div class=3D"hp-calculator-container" id=3D"wpHorsepowerCalculator">
    <h2 class=3D"hp-calc-title">Free Online Torque to Horsepower Calculator=
</h2>
    <p class=3D"hp-calc-subtitle">Calculate your vehicle=E2=80=99s horsepow=
er using torque and RPM values</p>
   =20
    <form class=3D"hp-calc-form" id=3D"wpHpCalculatorForm">
        <div class=3D"hp-calc-row">
            <div class=3D"hp-calc-field">
                <label class=3D"hp-calc-label" for=3D"wpTorque">Torque</lab=
el>
                <input type=3D"number" id=3D"wpTorque" class=3D"hp-calc-inp=
ut" placeholder=3D"Enter torque value" step=3D"0.1" min=3D"0" required=3D""=
>
            </div>
            <div class=3D"hp-calc-field">
                <label class=3D"hp-calc-label" for=3D"wpTorqueUnit">Torque =
Unit</label>
                <select id=3D"wpTorqueUnit" class=3D"hp-calc-select">
                    <option value=3D"lb-ft">lb-ft (Pound-feet)</option>
                    <option value=3D"nm">Nm (Newton-meters)</option>
                </select>
            </div>
        </div>

        <div class=3D"hp-calc-row">
            <div class=3D"hp-calc-field">
                <label class=3D"hp-calc-label" for=3D"wpRpm">RPM (Revolutio=
ns Per Minute)</label>
                <input type=3D"number" id=3D"wpRpm" class=3D"hp-calc-input"=
 placeholder=3D"Enter RPM value" step=3D"1" min=3D"0" max=3D"15000" require=
d=3D"">
            </div>
            <div class=3D"hp-calc-field">
                <label class=3D"hp-calc-label" for=3D"wpCalculationType">Ca=
lculation Type</label>
                <select id=3D"wpCalculationType" class=3D"hp-calc-select">
                    <option value=3D"standard">Standard Horsepower</option>
                    <option value=3D"metric">Metric Horsepower (PS)</option=
>
                    <option value=3D"both">Both Types</option>
                </select>
            </div>
        </div>

        <div class=3D"hp-calc-button-row">
            <button type=3D"submit" class=3D"hp-calc-button">Calculate Hors=
epower</button>
            <button type=3D"button" class=3D"hp-calc-reset-button">Reset Ca=
lculator</button>
        </div>
