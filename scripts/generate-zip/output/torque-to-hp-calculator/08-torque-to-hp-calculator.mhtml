get elementor-widget-text-editor" data-id=3D"ed92cce" data-element_type=3D"=
widget" data-widget_type=3D"text-editor.default">
				<div class=3D"elementor-widget-container">
									<p><span style=3D"font-weight: 400;">Converting torque to horsepow=
er is useful in many real-world situations. Here is a table with some typic=
al examples.</span></p>								</div>
				</div>
				<div class=3D"elementor-element elementor-element-ba94d27 elementor-wid=
get elementor-widget-text-editor" data-id=3D"ba94d27" data-element_type=3D"=
widget" data-widget_type=3D"text-editor.default">
				<div class=3D"elementor-widget-container">
									<table><tbody><tr><td><p><b>Application</b></p></td><td><p><b>Torq=
ue Input</b></p></td><td><p><b>RPM Range</b></p></td><td><p><b>Approx HP</b=
></p></td></tr><tr><td><p><span style=3D"font-weight: 400;">Car Engine</spa=
n></p></td><td><p><span style=3D"font-weight: 400;">250 lb-ft</span></p></t=
d><td><p><span style=3D"font-weight: 400;">3500</span></p></td><td><p><span=
 style=3D"font-weight: 400;">~167 HP</span></p></td></tr><tr><td><p><span s=
tyle=3D"font-weight: 400;">Motorcycle Engine</span></p></td><td><p><span st=
yle=3D"font-weight: 400;">90 Nm</span></p></td><td><p><span style=3D"font-w=
eight: 400;">7000</span></p></td><td><p><span style=3D"font-weight: 400;">~=
