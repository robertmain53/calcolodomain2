>1</sub></span>|<sup><i>=CE=B1</i></sup> + =E2=8B=AF + |<span class=3D"nowr=
ap" style=3D"padding-left:0.1em; padding-right:0.1em;"><i>x<sub>n</sub></i>=
</span>|<sup><i>=CE=B1</i></sup>)<sup><i>=CE=B2</i></sup>)</span> where <sp=
an class=3D"texhtml"><i>=CE=B1</i> &gt; 1</span> and <span class=3D"texhtml=
"><i>=CE=B1=CE=B2</i> &gt; 1</span>. If <span class=3D"texhtml"><i>=CE=B2</=
i> =3D 1</span> then <span class=3D"texhtml"><i>f</i>(<i>x</i><sub>1</sub>,=
 ..., <i>x<sub>n</sub></i>)</span> factorizes into <span class=3D"texhtml">=
const =C2=B7 exp (=E2=88=92|<span class=3D"nowrap" style=3D"padding-left:0.=
1em; padding-right:0.1em;"><i>x</i><sub>1</sub></span>|<sup><i>=CE=B1</i></=
sup>) =E2=80=A6 exp(=E2=88=92|<span class=3D"nowrap" style=3D"padding-left:=
0.1em; padding-right:0.1em;"><i>x<sub>n</sub></i></span>|<sup><i>=CE=B1</i>=
</sup>), </span> which means <span class=3D"texhtml"><i>X</i><sub>1</sub>, =
..., <i>X<sub>n</sub></i></span> are independent. In general, however, they=
 are dependent.
</p><p>The condition <span class=3D"texhtml"><i>f</i>(<i>x</i><sub>1</sub>,=
 ..., <i>x<sub>n</sub></i>) =3D <i>f</i>(|<span class=3D"nowrap" style=3D"p=
adding-left:0.1em; padding-right:0.1em;"><i>x</i><sub>1</sub></span>|, ...,=
