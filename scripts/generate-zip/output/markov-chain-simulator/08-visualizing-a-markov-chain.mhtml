<h3>Animating the Triple State Markov Chain</h3>
<p>Animation proceeds much as before. I decided against the smoothing this =
time around because it started to look a bit too messy with three states.</=
p>
<pre class=3D"r"><code class=3D"hljs">df_long2 &lt;- df2 %&gt;%
  rowid_to_column(var =3D <span class=3D"hljs-string">"iter"</span>) %&gt;%
  pivot_longer(cols =3D V1:V100) %&gt;%
  group_by(name) %&gt;%
  mutate(x =3D value + rnorm(<span class=3D"hljs-number">1</span>, <span cl=
ass=3D"hljs-number">0</span>, <span class=3D"hljs-number">.10</span>) + rno=
rm(n(), <span class=3D"hljs-number">0</span>, <span class=3D"hljs-number">.=
01</span>),
         y =3D value %% <span class=3D"hljs-number">2</span> + rnorm(<span =
class=3D"hljs-number">1</span>, <span class=3D"hljs-number">0</span>, <span=
 class=3D"hljs-number">.10</span>) + rnorm(n(), <span class=3D"hljs-number"=
>0</span>, <span class=3D"hljs-number">.01</span>),
         initial =3D value[<span class=3D"hljs-number">1</span>],
         is_0 =3D ifelse(value =3D=3D <span class=3D"hljs-number">0</span>,=
 <span class=3D"hljs-literal">TRUE</span>, <span class=3D"hljs-literal">FAL=
SE</span>),
         is_1 =3D ifelse(value =3D=3D <span class=3D"hljs-number">1</span>,=
 <span class=3D"hljs-literal">TRUE</span>, <span class=3D"hljs-literal">FAL=
SE</span>)) %&gt;%
  group_by(iter) %&gt;%
  mutate(prop0 =3D mean(is_0),
         prop1 =3D mean(is_1),
         prop2 =3D <span class=3D"hljs-number">1</span> - prop0 - prop1) %&=
gt;%
  ungroup()

anim2 &lt;- df_long2 %&gt;%
  plot_ly(
    x =3D ~x,
    y =3D ~y,
    color =3D ~factor(initial),
    size =3D <span class=3D"hljs-number">2</span>,
    colors =3D c(<span class=3D"hljs-string">"#32CD32"</span>, <span class=
=3D"hljs-string">"#1C86EE"</span>, <span class=3D"hljs-string">"#FF7F00"</s=
pan>),
    frame =3D ~iter,
