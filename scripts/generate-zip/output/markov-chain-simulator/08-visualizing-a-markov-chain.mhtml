"hljs-number">.35</span>, text =3D ~prop0, textfont =3D list(color =3D <spa=
n class=3D"hljs-string">"#32CD32"</span>, size =3D <span class=3D"hljs-numb=
er">24</span>, opacity =3D <span class=3D"hljs-number">.6</span>)) %&gt;%
  add_text(x =3D <span class=3D"hljs-number">1</span>, y =3D <span class=3D=
"hljs-number">1.25</span>, text =3D ~prop1, textfont =3D list(color =3D <sp=
an class=3D"hljs-string">"#1C86EE"</span>, size =3D <span class=3D"hljs-num=
ber">24</span>, opacity =3D <span class=3D"hljs-number">.6</span>)) %&gt;%
  add_text(x =3D <span class=3D"hljs-number">2</span>, y =3D <span class=3D=
"hljs-number">.35</span>, text =3D ~prop2, textfont =3D list(color =3D <spa=
n class=3D"hljs-string">"#FF7F00"</span>, size =3D <span class=3D"hljs-numb=
er">24</span>, opacity =3D <span class=3D"hljs-number">.6</span>))

ax2 &lt;- list(
  zeroline =3D <span class=3D"hljs-literal">FALSE</span>,
  showline =3D <span class=3D"hljs-literal">FALSE</span>,
  showticklabels =3D <span class=3D"hljs-literal">FALSE</span>,
  showgrid =3D <span class=3D"hljs-literal">FALSE</span>,
