@charset "utf-8";

html, body { width: 100%; height: 100%; margin: auto; color: rgb(51, 51, 51=
); font-family: "Open Sans", sans-serif; overflow: hidden; }

.main { margin: auto; width: 960px; }

a { color: inherit; }

.st-diagram { width: 100%; height: 100%; display: block; float: left; box-s=
izing: border-box; }

.node { stroke: rgb(255, 255, 255); stroke-width: 1.5px; opacity: 1; }

.currentState { fill: rgba(0, 0, 0, 0.4); stroke: rgb(255, 255, 255); point=
er-events: none; }

.node text { text-anchor: middle; }

.links { fill: none; }

.link { opacity: 0.4; transition: opacity 0.25s; }

.link.active { opacity: 0.8; }

.link.inactive { opacity: 0.1; }

pre { pointer-events: none; position: absolute; left: 0px; top: 0px; opacit=
y: 0.3; }

.stateTable { color: white; }

.stateTable tr { box-sizing: border-box; }

.stateTable td { text-align: center; box-sizing: border-box; width: 25%; he=
ight: 25%; }

.grid { width: 100%; height: 100%; }

.sequence { width: 100%; height: 100%; display: block; overflow: hidden; ma=
rgin: auto; }

.controls { position: absolute; top: 10px; left: 10px; }
