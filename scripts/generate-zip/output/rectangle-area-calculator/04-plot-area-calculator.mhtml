            <option>Yard</option>
            <option>Cent</option>
        </select><br><br>
        <h4 style=3D"text-align: center;">Atleast one diagonal is required<=
/h4>
        <input type=3D"number" id=3D"AC" placeholder=3D"Diagonal (meters)">
