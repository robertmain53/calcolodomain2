        <mo stretchy=3D"false">[</mo>
        <mi>X</mi>
        <mo stretchy=3D"false">]</mo>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mn>1</mn>
            <msup>
              <mi>=CE=BB<!-- =CE=BB --></mi>
              <mrow class=3D"MJX-TeXAtom-ORD">
                <mn>2</mn>
              </mrow>
            </msup>
          </mfrac>
        </mrow>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \operatorname=
 {Var} [X]=3D{\frac {1}{\lambda ^{2}}},}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/3c450db5013b1cfdaf5ea71106c9d13834e02d61" class=3D"mwe-math-fallback=
