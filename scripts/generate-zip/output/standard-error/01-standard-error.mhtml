an><a href=3D"https://en.wikipedia.org/w/index.php?title=3DStandard_error&a=
mp;action=3Dedit&amp;section=3D5" title=3D"Edit section: Derivation"><span>=
edit</span></a><span class=3D"mw-editsection-bracket">]</span></span></div>
