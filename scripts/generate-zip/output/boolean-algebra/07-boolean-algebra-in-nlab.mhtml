=A8</mo><mi>b</mi><mo stretchy=3D"false">)</mo><mo>=E2=88=A7</mo><mo stretc=
hy=3D"false">(</mo><mi>a</mi><mo>=E2=88=A8</mo><mi>c</mi><mo stretchy=3D"fa=
lse">)</mo></mrow><annotation encoding=3D"application/x-tex">a \vee (b \wed=
ge c) =3D (a \vee b) \wedge (a \vee c)</annotation></semantics></math>,</li=
>

<li><math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" c=
lass=3D"maruku-mathml"><semantics><mrow><mi>a</mi><mo>=E2=88=A7</mo><mo>=C2=
=AC</mo><mi>a</mi><mo>=3D</mo><mo>=E2=8A=A5</mo></mrow><annotation encoding=
=3D"application/x-tex">a \wedge \neg{a} =3D \bot</annotation></semantics></=
math>,</li>

<li><math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" c=
lass=3D"maruku-mathml"><semantics><mrow><mi>a</mi><mo>=E2=88=A8</mo><mo>=C2=
=AC</mo><mi>a</mi><mo>=3D</mo><mo>=E2=8A=A4</mo></mrow><annotation encoding=
=3D"application/x-tex">a \vee \neg{a} =3D \top</annotation></semantics></ma=
th>.</li>
</ol>

<p>We can recover the poset structure: <math xmlns=3D"http://www.w3.org/199=
8/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow>=
<mi>a</mi><mo>=E2=89=A4</mo><mi>b</mi></mrow><annotation encoding=3D"applic=
ation/x-tex">a \leq b</annotation></semantics></math> iff <math xmlns=3D"ht=
tp://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml=
"><semantics><mrow><mi>a</mi><mo>=E2=88=A7</mo><mi>b</mi><mo>=3D</mo><mi>a<=
/mi></mrow><annotation encoding=3D"application/x-tex">a \wedge b =3D a</ann=
otation></semantics></math>. There is a certain amount of redundancy or ove=
rkill in this axiom list; for example, it suffices to give just axioms 1, 2=
, 5, 6, 9, 10, 11, 12.</p>

<p>A very distilled algebraic definition was conjectured by Herbert Robbins=
: any <em>nonempty</em> set equipped with a binary operation <math xmlns=3D=
"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mat=
hml"><semantics><mrow><mo>=E2=88=A8</mo></mrow><annotation encoding=3D"appl=
ication/x-tex">\vee</annotation></semantics></math> and a unary operation <=
math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=
=3D"maruku-mathml"><semantics><mrow><mo>=C2=AC</mo></mrow><annotation encod=
ing=3D"application/x-tex">\neg</annotation></semantics></math> obeying</p>

<ol>
<li>associativity: <math xmlns=3D"http://www.w3.org/1998/Math/MathML" displ=
ay=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>a</mi><mo>=E2=88=
=A8</mo><mrow><mo>(</mo><mi>b</mi><mo>=E2=88=A8</mo><mi>c</mi><mo>)</mo></m=
row><mo>=3D</mo><mrow><mo>(</mo><mi>a</mi><mo>=E2=88=A8</mo><mi>b</mi><mo>)=
</mo></mrow><mo>=E2=88=A8</mo><mi>c</mi></mrow><annotation encoding=3D"appl=
ication/x-tex">a\vee \left(b\vee c\right)=3D\left(a\vee b\right)\vee c</ann=
otation></semantics></math></li>

<li>commutativity: <math xmlns=3D"http://www.w3.org/1998/Math/MathML" displ=
ay=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>a</mi><mo>=E2=88=
=A8</mo><mi>b</mi><mo>=3D</mo><mi>b</mi><mo>=E2=88=A8</mo><mi>a</mi></mrow>=
<annotation encoding=3D"application/x-tex">a \vee b =3D b \vee a</annotatio=
n></semantics></math></li>

<li>the Robbins equation: <math xmlns=3D"http://www.w3.org/1998/Math/MathML=
" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo>=C2=AC</m=
o><mrow><mo>(</mo><mo>=C2=AC</mo><mrow><mo>(</mo><mi>a</mi><mo>=E2=88=A8</m=
o><mi>b</mi><mo>)</mo></mrow><mo>=E2=88=A8</mo><mo>=C2=AC</mo><mrow><mo>(</=
mo><mi>a</mi><mo>=E2=88=A8</mo><mo>=C2=AC</mo><mi>b</mi><mo>)</mo></mrow><m=
o>)</mo></mrow><mo>=3D</mo><mi>a</mi></mrow><annotation encoding=3D"applica=
tion/x-tex">\neg \left(\neg \left(a\vee b\right)\vee \neg \left(a\vee \neg =
b\right)\right)=3Da </annotation></semantics></math></li>
</ol>

<p>is a Boolean algebra. William McCune proved the conjecture in 1996, usin=
g the automated theorem prover EQP. A short proof was found by Allan Mann (=
see the references).</p>

<h4 id=3D"principle_of_duality">Principle of duality</h4>

<p>However it is defined, the theory of Boolean algebras is <strong>self-du=
al</strong> in the sense that for any sentence stated in the language <math=
 xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"m=
aruku-mathml"><semantics><mrow><mo stretchy=3D"false">(</mo><mo>=E2=89=A4</=
mo><mo>,</mo><mo>=E2=88=A7</mo><mo>,</mo><mo>=E2=88=A8</mo><mo>,</mo><mo>=
=E2=8A=A5</mo><mo>,</mo><mo>=E2=8A=A4</mo><mo>,</mo><mo>=C2=AC</mo><mo stre=
tchy=3D"false">)</mo></mrow><annotation encoding=3D"application/x-tex">(\le=
q, \wedge, \vee, \bot, \top, \neg)</annotation></semantics></math>, the sen=
tence is a theorem in the theory of Boolean algebras iff the dual sentence,=
 obtained by interchanging <math xmlns=3D"http://www.w3.org/1998/Math/MathM=
L" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo>=E2=88=
=A7</mo></mrow><annotation encoding=3D"application/x-tex">\wedge</annotatio=
n></semantics></math> and <math xmlns=3D"http://www.w3.org/1998/Math/MathML=
" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo>=E2=88=A8=
</mo></mrow><annotation encoding=3D"application/x-tex">\vee</annotation></s=
emantics></math>, <math xmlns=3D"http://www.w3.org/1998/Math/MathML" displa=
y=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo>=E2=8A=A5</mo></m=
row><annotation encoding=3D"application/x-tex">\bot</annotation></semantics=
></math> and <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"=
inline" class=3D"maruku-mathml"><semantics><mrow><mo>=E2=8A=A4</mo></mrow><=
annotation encoding=3D"application/x-tex">\top</annotation></semantics></ma=
th>, and replacing <math xmlns=3D"http://www.w3.org/1998/Math/MathML" displ=
ay=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo>=E2=89=A4</mo></=
mrow><annotation encoding=3D"application/x-tex">\leq</annotation></semantic=
s></math> by the opposite relation <math xmlns=3D"http://www.w3.org/1998/Ma=
th/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><msu=
p><mo>=E2=89=A4</mo> <mi>op</mi></msup></mrow><annotation encoding=3D"appli=
cation/x-tex">\leq^{op}</annotation></semantics></math>, is also a theorem.=
</p>

<p>This incredibly useful result can be rephrased in several ways; for exam=
ple, if a poset <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=
=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>B</mi></mrow><anno=
tation encoding=3D"application/x-tex">B</annotation></semantics></math> is =
a Boolean algebra, then so is its opposite <math xmlns=3D"http://www.w3.org=
/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><m=
row><msup><mi>B</mi> <mi>op</mi></msup></mrow><annotation encoding=3D"appli=
cation/x-tex">B^{op}</annotation></semantics></math>.</p>

<h4 id=3D"boolean_rings">Boolean rings</h4>

<p>A <a class=3D"existingWikiWord" href=3D"https://ncatlab.org/nlab/show/Bo=
olean+ring">Boolean ring</a> is a <a class=3D"existingWikiWord" href=3D"htt=
ps://ncatlab.org/nlab/show/ring">ring</a> (with <a class=3D"existingWikiWor=
d" href=3D"https://ncatlab.org/nlab/show/identity">identity</a>) for which =
every element is idempotent: <math xmlns=3D"http://www.w3.org/1998/Math/Mat=
hML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><msup><mi>=
x</mi> <mn>2</mn></msup><mo>=3D</mo><mi>x</mi></mrow><annotation encoding=
=3D"application/x-tex">x^2 =3D x</annotation></semantics></math>. Notice th=
at from</p>
<div class=3D"maruku-equation"><math xmlns=3D"http://www.w3.org/1998/Math/M=
athML" display=3D"block" class=3D"maruku-mathml" style=3D"min-width: 367px;=
"><semantics><mrow><msup><mi>x</mi> <mn>2</mn></msup><mo>+</mo><mn>1</mn><m=
o>=3D</mo><mi>x</mi><mo>+</mo><mn>1</mn><mo>=3D</mo><mo stretchy=3D"false">=
(</mo><mi>x</mi><mo>+</mo><mn>1</mn><msup><mo stretchy=3D"false">)</mo> <mn=
>2</mn></msup><mo>=3D</mo><msup><mi>x</mi> <mn>2</mn></msup><mo>+</mo><mn>2=
</mn><mi>x</mi><mo>+</mo><mn>1</mn></mrow><annotation encoding=3D"applicati=
on/x-tex">x^2 + 1 =3D x + 1 =3D (x + 1)^2 =3D x^2 + 2 x + 1</annotation></s=
emantics></math></div>
<p>the equation <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=
=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mn>2</mn><mi>x</mi><m=
o>=3D</mo><mn>0</mn></mrow><annotation encoding=3D"application/x-tex">2 x =
=3D 0</annotation></semantics></math> follows. Also notice that commutativi=
ty comes for free, since</p>
<div class=3D"maruku-equation"><math xmlns=3D"http://www.w3.org/1998/Math/M=
athML" display=3D"block" class=3D"maruku-mathml" style=3D"min-width: 452px;=
"><semantics><mrow><msup><mi>x</mi> <mn>2</mn></msup><mo>+</mo><msup><mi>y<=
/mi> <mn>2</mn></msup><mo>=3D</mo><mi>x</mi><mo>+</mo><mi>y</mi><mo>=3D</mo=
><mo stretchy=3D"false">(</mo><mi>x</mi><mo>+</mo><mi>y</mi><msup><mo stret=
chy=3D"false">)</mo> <mn>2</mn></msup><mo>=3D</mo><msup><mi>x</mi> <mn>2</m=
n></msup><mo>+</mo><mi>x</mi><mi>y</mi><mo>+</mo><mi>y</mi><mi>x</mi><mo>+<=
/mo><msup><mi>y</mi> <mn>2</mn></msup></mrow><annotation encoding=3D"applic=
ation/x-tex">x^2 + y^2 =3D x + y =3D (x + y)^2 =3D x^2 + x y + y x + y^2</a=
nnotation></semantics></math></div>
<p>whence <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inl=
ine" class=3D"maruku-mathml"><semantics><mrow><mi>x</mi><mi>y</mi><mo>+</mo=
><mi>y</mi><mi>x</mi><mo>=3D</mo><mn>0</mn><mo>=3D</mo><mi>x</mi><mi>y</mi>=
<mo>+</mo><mi>x</mi><mi>y</mi></mrow><annotation encoding=3D"application/x-=
tex">x y + y x =3D 0 =3D x y + x y</annotation></semantics></math>.</p>

<p>Parallel to the way free commutative rings are polynomial rings, which a=
re free <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inlin=
e" class=3D"maruku-mathml"><semantics><mrow><mi>=E2=84=A4</mi></mrow><annot=
ation encoding=3D"application/x-tex">\mathbb{Z}</annotation></semantics></m=
ath>-modules generated from free commutative monoids, the free Boolean ring=
 on <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" c=
lass=3D"maruku-mathml"><semantics><mrow><mi>n</mi></mrow><annotation encodi=
ng=3D"application/x-tex">n</annotation></semantics></math> generators may b=
e constructed, =C3=A0 la Beck <a class=3D"existingWikiWord" href=3D"https:/=
/ncatlab.org/nlab/show/distributive+law">distributive law</a>s, as the free=
 <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" clas=
s=3D"maruku-mathml"><semantics><mrow><msub><mi>=E2=84=A4</mi> <mn>2</mn></m=
sub></mrow><annotation encoding=3D"application/x-tex">\mathbb{Z}_2</annotat=
ion></semantics></math>-vector space <math xmlns=3D"http://www.w3.org/1998/=
Math/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><m=
sub><mi>=E2=84=A4</mi> <mn>2</mn></msub><mo stretchy=3D"false">[</mo><msub>=
<mi>M</mi> <mi>n</mi></msub><mo stretchy=3D"false">]</mo></mrow><annotation=
 encoding=3D"application/x-tex">\mathbb{Z}_2[M_n]</annotation></semantics><=
/math> generated from the <a class=3D"existingWikiWord" href=3D"https://nca=
tlab.org/nlab/show/semilattice">semilattice</a> <math xmlns=3D"http://www.w=
3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><semanti=
cs><mrow><msub><mi>M</mi> <mi>n</mi></msub></mrow><annotation encoding=3D"a=
pplication/x-tex">M_n</annotation></semantics></math> on <math xmlns=3D"htt=
p://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"=
><semantics><mrow><mi>n</mi></mrow><annotation encoding=3D"application/x-te=
x">n</annotation></semantics></math> generators. The latter can be identifi=
ed with the function set from an <math xmlns=3D"http://www.w3.org/1998/Math=
/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>n<=
/mi></mrow><annotation encoding=3D"application/x-tex">n</annotation></seman=
tics></math>-element set to the 2-element <a class=3D"existingWikiWord" hre=
f=3D"https://ncatlab.org/nlab/show/boolean+domain">boolean domain</a> <math=
 xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"m=
aruku-mathml"><semantics><mrow><mo stretchy=3D"false">{</mo><mn>0</mn><mo>,=
</mo><mn>1</mn><mo stretchy=3D"false">}</mo></mrow><annotation encoding=3D"=
application/x-tex">\{0, 1\}</annotation></semantics></math> with multiplica=
tion defined elementwise from the <a class=3D"existingWikiWord" href=3D"htt=
ps://ncatlab.org/nlab/show/meet">meet</a> of <math xmlns=3D"http://www.w3.o=
rg/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics>=
<mrow><mo stretchy=3D"false">{</mo><mn>0</mn><mo>,</mo><mn>1</mn><mo stretc=
hy=3D"false">}</mo></mrow><annotation encoding=3D"application/x-tex">\{0, 1=
\}</annotation></semantics></math>, and <math xmlns=3D"http://www.w3.org/19=
98/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow=
><msub><mi>=E2=84=A4</mi> <mn>2</mn></msub><mo stretchy=3D"false">[</mo><ms=
ub><mi>M</mi> <mi>n</mi></msub><mo stretchy=3D"false">]</mo></mrow><annotat=
ion encoding=3D"application/x-tex">\mathbb{Z}_2[M_n]</annotation></semantic=
s></math> therefore has <math xmlns=3D"http://www.w3.org/1998/Math/MathML" =
display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><msup><mn>2</mn=
> <mrow><msup><mn>2</mn> <mi>n</mi></msup></mrow></msup></mrow><annotation =
encoding=3D"application/x-tex">2^{2^n}</annotation></semantics></math> elem=
ents.</p>

<p>The theory of Boolean algebras is equivalent to the theory of Boolean ri=
ngs in the sense that their categories of models are equivalent. Given a Bo=
olean ring, we define the operation <math xmlns=3D"http://www.w3.org/1998/M=
ath/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo=
>=E2=88=A7</mo></mrow><annotation encoding=3D"application/x-tex">\wedge</an=
notation></semantics></math> to be multiplication, and the operation <math =
xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"ma=
ruku-mathml"><semantics><mrow><mo>=E2=88=A8</mo></mrow><annotation encoding=
=3D"application/x-tex">\vee</annotation></semantics></math> by <math xmlns=
=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-=
mathml"><semantics><mrow><mi>x</mi><mo>=E2=88=A8</mo><mi>y</mi><mo>=3D</mo>=
<mi>x</mi><mo>+</mo><mi>y</mi><mo>+</mo><mi>x</mi><mi>y</mi></mrow><annotat=
ion encoding=3D"application/x-tex">x \vee y =3D x + y + x y</annotation></s=
emantics></math>, and the operation <math xmlns=3D"http://www.w3.org/1998/M=
ath/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo=
>=C2=AC</mo></mrow><annotation encoding=3D"application/x-tex">\neg</annotat=
ion></semantics></math> by <math xmlns=3D"http://www.w3.org/1998/Math/MathM=
L" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo>=C2=AC</=
mo><mi>x</mi><mo>=3D</mo><mn>1</mn><mo>+</mo><mi>x</mi></mrow><annotation e=
ncoding=3D"application/x-tex">\neg x =3D 1 + x</annotation></semantics></ma=
th>. The relation <math xmlns=3D"http://www.w3.org/1998/Math/MathML" displa=
y=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>x</mi><mo>=E2=89=
=A4</mo><mi>y</mi></mrow><annotation encoding=3D"application/x-tex">x \leq =
y</annotation></semantics></math> may be defined by the condition <math xml=
ns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruk=
u-mathml"><semantics><mrow><mi>x</mi><mi>y</mi><mo>=3D</mo><mi>x</mi></mrow=
><annotation encoding=3D"application/x-tex">x y =3D x</annotation></semanti=
cs></math>. In the other direction, given a Boolean algebra, we may define =
addition by <a class=3D"existingWikiWord" href=3D"https://ncatlab.org/nlab/=
show/symmetric+difference">symmetric difference</a>: <math xmlns=3D"http://=
www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><se=
mantics><mrow><mi>x</mi><mo>+</mo><mi>y</mi><mo>=3D</mo><mo stretchy=3D"fal=
se">(</mo><mi>x</mi><mo>=E2=88=A8</mo><mi>y</mi><mo stretchy=3D"false">)</m=
o><mo>=E2=88=A7</mo><mo>=C2=AC</mo><mo stretchy=3D"false">(</mo><mi>x</mi><=
mo>=E2=88=A7</mo><mi>y</mi><mo stretchy=3D"false">)</mo></mrow><annotation =
encoding=3D"application/x-tex">x + y =3D (x \vee y) \wedge \neg(x \wedge y)=
</annotation></semantics></math>. According to this equivalence, the free B=
oolean ring on <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=
=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>n</mi></mrow><anno=
tation encoding=3D"application/x-tex">n</annotation></semantics></math> gen=
erators may be identified with the Boolean algebra <math xmlns=3D"http://ww=
w.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><sema=
ntics><mrow><msup><mn>2</mn> <mrow><msup><mn>2</mn> <mi>n</mi></msup></mrow=
></msup></mrow><annotation encoding=3D"application/x-tex">2^{2^n}</annotati=
on></semantics></math>, the function set from a set with <math xmlns=3D"htt=
p://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"=
><semantics><mrow><msup><mn>2</mn> <mi>n</mi></msup></mrow><annotation enco=
ding=3D"application/x-tex">2^n</annotation></semantics></math> elements to =
the <a class=3D"existingWikiWord" href=3D"https://ncatlab.org/nlab/show/boo=
lean+domain">boolean domain</a> <math xmlns=3D"http://www.w3.org/1998/Math/=
MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mo str=
etchy=3D"false">{</mo><mn>0</mn><mo>,</mo><mn>1</mn><mo stretchy=3D"false">=
}</mo></mrow><annotation encoding=3D"application/x-tex">\{0,1\}</annotation=
></semantics></math>.</p>

<h3 id=3D"elements_of_stone_duality">Elements of Stone duality</h3>

<p>The equivalence of Boolean rings and Boolean algebras was exploited by <=
a class=3D"existingWikiWord" href=3D"https://ncatlab.org/nlab/show/Marshall=
+Stone">Marshall Stone</a> to give his theory of <a class=3D"existingWikiWo=
rd" href=3D"https://ncatlab.org/nlab/show/Stone+duality">Stone duality</a>,=
 in which every Boolean algebra <math xmlns=3D"http://www.w3.org/1998/Math/=
MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>B</=
mi></mrow><annotation encoding=3D"application/x-tex">B</annotation></semant=
ics></math> is a Boolean algebra of sets; more particularly the Boolean alg=
ebra of clopen (closed and open) sets of a topological space <math xmlns=3D=
"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mat=
hml"><semantics><mrow><mi>Spec</mi><mo stretchy=3D"false">(</mo><mi>B</mi><=
mo stretchy=3D"false">)</mo></mrow><annotation encoding=3D"application/x-te=
x">Spec(B)</annotation></semantics></math>, the <strong>Stone space</strong=
> of <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" =
class=3D"maruku-mathml"><semantics><mrow><mi>B</mi></mrow><annotation encod=
ing=3D"application/x-tex">B</annotation></semantics></math>. The notation i=
ntentionally suggests that the Stone space is the underlying space of the <=
a class=3D"existingWikiWord" href=3D"https://ncatlab.org/nlab/show/spectrum=
+%28geometry%29">spectrum</a> of <math xmlns=3D"http://www.w3.org/1998/Math=
/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>B<=
/mi></mrow><annotation encoding=3D"application/x-tex">B</annotation></seman=
tics></math> as Boolean ring, taking =E2=80=9Cspectrum=E2=80=9D in the sens=
e of algebraic geometry.</p>

<p>A Stone space may be characterized abstractly as a <a class=3D"existingW=
ikiWord" href=3D"https://ncatlab.org/nlab/show/topological+space">topologic=
al space</a> that is <a class=3D"existingWikiWord" href=3D"https://ncatlab.=
org/nlab/show/compact+space">compact</a>, <a class=3D"existingWikiWord" hre=
f=3D"https://ncatlab.org/nlab/show/Hausdorff+space">Hausdorff</a>, and <a c=
lass=3D"existingWikiWord" href=3D"https://ncatlab.org/nlab/show/totally+dis=
connected+space">totally disconnected</a>. Stone duality asserts among othe=
r things that every such space is the <a class=3D"existingWikiWord" href=3D=
"https://ncatlab.org/nlab/show/prime+spectrum">prime spectrum</a> of the Bo=
olean algebra of its clopen subsets.</p>

<div class=3D"num_lemma" id=3D"aremax">


<p><span class=3D"theorem_label" theoremNumber=3D"2.1">Lemma 2.1</span><spa=
n>. </span>All prime ideals in <math xmlns=3D"http://www.w3.org/1998/Math/M=
athML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>B</m=
i></mrow><annotation encoding=3D"application/x-tex">B</annotation></semanti=
cs></math> are kernels <math xmlns=3D"http://www.w3.org/1998/Math/MathML" d=
isplay=3D"inline" class=3D"maruku-mathml"><semantics><mrow><msup><mi>=CF=95=
</mi> <mrow><mo lspace=3D"verythinmathspace" rspace=3D"0em">=E2=88=92</mo><=
mn>1</mn></mrow></msup><mo stretchy=3D"false">(</mo><mn>0</mn><mo stretchy=
=3D"false">)</mo></mrow><annotation encoding=3D"application/x-tex">\phi^{-1=
}(0)</annotation></semantics></math> of homomorphisms <math xmlns=3D"http:/=
/www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><s=
emantics><mrow><mi>=CF=95</mi><mo>:</mo><mi>B</mi><mo>=E2=86=92</mo><mstyle=
 mathvariant=3D"bold"><mn>2</mn></mstyle></mrow><annotation encoding=3D"app=
lication/x-tex">\phi: B \to \mathbf{2}</annotation></semantics></math> (and=
 thus are maximal ideals, in bijective correspondence with <a class=3D"exis=
tingWikiWord" href=3D"https://ncatlab.org/nlab/show/ultrafilters">ultrafilt=
ers</a> <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inlin=
e" class=3D"maruku-mathml"><semantics><mrow><msup><mi>=CF=95</mi> <mrow><mo=
 lspace=3D"verythinmathspace" rspace=3D"0em">=E2=88=92</mo><mn>1</mn></mrow=
></msup><mo stretchy=3D"false">(</mo><mn>1</mn><mo stretchy=3D"false">)</mo=
></mrow><annotation encoding=3D"application/x-tex">\phi^{-1}(1)</annotation=
></semantics></math> in <math xmlns=3D"http://www.w3.org/1998/Math/MathML" =
display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><mi>B</mi></mro=
w><annotation encoding=3D"application/x-tex">B</annotation></semantics></ma=
th>).</p>
</div>

<div class=3D"proof">


<p><span class=3D"theorem_label">Proof</span><span>. </span>If <math xmlns=
=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-=
mathml"><semantics><mrow><mi>p</mi></mrow><annotation encoding=3D"applicati=
on/x-tex">p</annotation></semantics></math> is a prime ideal in a Boolean r=
ing, then <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inl=
ine" class=3D"maruku-mathml"><semantics><mrow><mi>B</mi><mo stretchy=3D"fal=
se">/</mo><mi>p</mi></mrow><annotation encoding=3D"application/x-tex">B/p</=
annotation></semantics></math> is an integral domain in which every element=
 <math xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" clas=
s=3D"maruku-mathml"><semantics><mrow><mi>x</mi></mrow><annotation encoding=
=3D"application/x-tex">x</annotation></semantics></math> is idempotent: <ma=
th xmlns=3D"http://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D=
"maruku-mathml"><semantics><mrow><mi>x</mi><mo stretchy=3D"false">(</mo><mi=
>x</mi><mo>=E2=88=92</mo><mn>1</mn><mo stretchy=3D"false">)</mo><mo>=3D</mo=
><mn>0</mn></mrow><annotation encoding=3D"application/x-tex">x(x-1) =3D 0</=
annotation></semantics></math>. Hence <math xmlns=3D"http://www.w3.org/1998=
/Math/MathML" display=3D"inline" class=3D"maruku-mathml"><semantics><mrow><=
mi>B</mi><mo stretchy=3D"false">/</mo><mi>p</mi><mo>=3D</mo><mo stretchy=3D=
"false">{</mo><mn>0</mn><mo>,</mo><mn>1</mn><mo stretchy=3D"false">}</mo></=
mrow><annotation encoding=3D"application/x-tex">B/p =3D \{0, 1\}</annotatio=
n></semantics></math>.<span>=C2=A0=C2=A0=E2=96=AE</span></p>
</div>

<p>(To be continued at some point.)</p>

<h2 id=3D"homomorphisms_and_the_category_of_boolean_algebras">3. Homomorphi=
sms and the category of Boolean algebras</h2>

<p>Any <a class=3D"existingWikiWord" href=3D"https://ncatlab.org/nlab/show/=
lattice">lattice</a> homomorphism automatically preserves <math xmlns=3D"ht=
tp://www.w3.org/1998/Math/MathML" display=3D"inline" class=3D"maruku-mathml=
"><semantics><mrow><mo>=C2=AC</mo></mrow><annotation encoding=3D"applicatio=
n/x-tex">\neg</annotation></semantics></math> and is therefore a Boolean al=
gebra homomorphism.</p>

<p>Boolean algebras and Boolean algebra homomorphisms form a <a class=3D"ex=
istingWikiWord" href=3D"https://ncatlab.org/nlab/show/concrete+category">co=
ncrete category</a> <a class=3D"existingWikiWord" href=3D"https://ncatlab.o=
rg/nlab/show/BoolAlg">BoolAlg</a>.</p>

