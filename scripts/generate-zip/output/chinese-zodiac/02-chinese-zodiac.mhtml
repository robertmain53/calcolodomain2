body { margin: 0px; }

hr { box-sizing: content-box; height: 0px; overflow: visible; }

abbr[title] { border-bottom: 1px dotted; cursor: help; }

@supports (text-decoration:underline dotted) {
  abbr[title] { border-bottom: 0px; text-decoration: underline dotted; }
}

pre, code, tt, kbd, samp { font-family: monospace, monospace; }

sub, sup { line-height: 1; }

figure { margin: 0px; }

button, input, optgroup, select, textarea { margin: 0px; }

legend { padding: 0px; }

div.tright, div.floatright, table.floatright { clear: right; float: right; =
}

@media (max-width: calc(639px)) {
  body.skin--responsive div.tright, body.skin--responsive div.floatright, b=
ody.skin--responsive table.floatright { clear: both; float: none; }
}

div.tleft, div.floatleft, table.floatleft { float: left; clear: left; }

@media (max-width: calc(639px)) {
  body.skin--responsive div.tleft, body.skin--responsive div.floatleft, bod=
y.skin--responsive table.floatleft { clear: both; float: none; }
}

div.floatright, table.floatright { margin: 0px 0px 0.5em 0.5em; }

div.floatleft, table.floatleft { margin: 0px 0.5em 0.5em 0px; }

div.thumb { width: auto; background-color: transparent; margin-bottom: 0.5e=
m; }

div.tleft { margin: 0.5em 1.4em 1.3em 0px; }

div.tright { margin: 0.5em 0px 1.3em 1.4em; }

.thumbcaption { text-align: start; line-height: 1.4em; padding: 3px; }

.thumbcaption:empty { padding: 0px; }

div.thumbinner { padding: 3px; text-align: center; overflow: hidden; }

@media (max-width: calc(639px)) {
  body.skin--responsive .mw-parser-output .thumb .thumbinner { display: fle=
