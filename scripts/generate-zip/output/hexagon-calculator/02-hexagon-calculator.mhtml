</mrow><annotation encoding=3D"application/x-tex">P =3D 6a</annotation></se=
mantics></math></span><span class=3D"katex-html" aria-hidden=3D"true"><span=
 class=3D"base"><span class=3D"strut" style=3D"height: 0.6833em;"></span><s=
