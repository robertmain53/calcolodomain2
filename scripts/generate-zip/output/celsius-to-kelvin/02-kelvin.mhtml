@media (prefers-reduced-motion: reduce) {
  *, ::before, ::after { animation-delay: -0.01ms !important; animation-dur=
ation: 0.01ms !important; animation-iteration-count: 1 !important; scroll-b=
ehavior: auto !important; transition-duration: 0ms !important; }
