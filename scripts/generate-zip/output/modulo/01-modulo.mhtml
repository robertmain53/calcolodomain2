          <mo>)</mo>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle q=3D\operator=
name {trunc} \left({\frac {a}{n}}\right)}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
