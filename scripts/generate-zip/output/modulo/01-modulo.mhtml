er/svg/d7a842cab18be465dda3798f42dd382e3057859c" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.838ex; width:8.854ex; height:4.843ex;" alt=3D"{\displaystyle q=
=3D\left\lceil {\frac {a}{n}}\right\rceil }"></span></dd></dl>
<p>where =E2=8C=88=E2=8C=89 is the <a href=3D"https://en.wikipedia.org/wiki=
/Ceiling_function" class=3D"mw-redirect" title=3D"Ceiling function">ceiling=
 function</a> (<a href=3D"https://en.wikipedia.org/wiki/Rounding#Rounding_u=
p" title=3D"Rounding">rounding up</a>).
Thus according to equation (<b><a href=3D"https://en.wikipedia.org/wiki/Mod=
ulo#math_1">1</a></b>), the remainder has the <i>opposite sign of that of t=
he divisor</i>:
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e r=3Da-n\left\lceil {\frac {a}{n}}\right\rceil }">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>r</mi>
        <mo>=3D</mo>
        <mi>a</mi>
        <mo>=E2=88=92<!-- =E2=88=92 --></mo>
        <mi>n</mi>
        <mrow>
          <mo>=E2=8C=88</mo>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mfrac>
              <mi>a</mi>
              <mi>n</mi>
            </mfrac>
          </mrow>
          <mo>=E2=8C=89</mo>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle r=3Da-n\left\=
lceil {\frac {a}{n}}\right\rceil }</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/11bd7c338a1cee1ab548508404dc460df2b7077d" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.838ex; width:14.685ex; height:4.843ex;" alt=3D"{\displaystyle r=
=3Da-n\left\lceil {\frac {a}{n}}\right\rceil }"></span></dd></dl></li></ul>=
</div>
<p>If both the dividend and divisor are positive, then the truncated, floor=
ed, and Euclidean definitions agree.
If the dividend is positive and the divisor is negative, then the truncated=
 and Euclidean definitions agree.
If the dividend is negative and the divisor is positive, then the floored a=
nd Euclidean definitions agree.
If both the dividend and divisor are negative, then the truncated and floor=
ed definitions agree.
</p><p>However, truncated division satisfies the identity <span class=3D"mw=
e-math-element mwe-math-element-inline"><span class=3D"mwe-math-mathml-inli=
ne mwe-math-mathml-a11y" style=3D"display: none;"><math xmlns=3D"http://www=
.w3.org/1998/Math/MathML" alttext=3D"{\displaystyle ({-a})/b=3D{-(a/b)}=3Da=
/({-b})}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mo stretchy=3D"false">(</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mo>=E2=88=92<!-- =E2=88=92 --></mo>
          <mi>a</mi>
        </mrow>
        <mo stretchy=3D"false">)</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mo>/</mo>
        </mrow>
        <mi>b</mi>
        <mo>=3D</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mo>=E2=88=92<!-- =E2=88=92 --></mo>
          <mo stretchy=3D"false">(</mo>
          <mi>a</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mo>/</mo>
          </mrow>
          <mi>b</mi>
          <mo stretchy=3D"false">)</mo>
        </mrow>
        <mo>=3D</mo>
        <mi>a</mi>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mo>/</mo>
        </mrow>
        <mo stretchy=3D"false">(</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mo>=E2=88=92<!-- =E2=88=92 --></mo>
          <mi>b</mi>
        </mrow>
        <mo stretchy=3D"false">)</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle ({-a})/b=3D{-=
(a/b)}=3Da/({-b})}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/0c17b403df86515893e20dc9a2eb128516de8312" class=3D"mwe-math-fallback=
