@keyframes fade-in {=20
  100% { opacity: 1; }
}

@keyframes fade-in-bloom {=20
  0% { filter: brightness(1) blur(20px); opacity: 0; }
  10% { filter: brightness(2) blur(10px); opacity: 1; }
  100% { filter: brightness(1) blur(0px); opacity: 1; }
}

@keyframes fade-out {=20
  100% { opacity: 0; }
}

@keyframes fade-out-bloom {=20
  100% { filter: brightness(1) blur(20px); opacity: 0; }
  10% { filter: brightness(2) blur(10px); opacity: 1; }
  0% { filter: brightness(1) blur(0px); opacity: 1; }
}

@keyframes scale-up {=20
  100% { transform: scale(1.25); }
}

@keyframes scale-down {=20
  100% { transform: scale(0.75); }
}

@keyframes slide-out-up {=20
  100% { transform: translateY(-100%); }
}

@keyframes slide-out-down {=20
  100% { transform: translateY(100%); }
}

@keyframes slide-out-right {=20
  100% { transform: translateX(100%); }
}

@keyframes slide-out-left {=20
  100% { transform: translateX(-100%); }
}

@keyframes slide-in-up {=20
  0% { transform: translateY(100%); }
}

@keyframes slide-in-down {=20
  0% { transform: translateY(-100%); }
}

@keyframes slide-in-right {=20
  0% { transform: translateX(-100%); }
}

@keyframes slide-in-left {=20
  0% { transform: translateX(100%); }
}

@keyframes shake-x {=20
  0%, 100% { transform: translateX(0px); }
  20% { transform: translateX(-5%); }
  40% { transform: translateX(5%); }
  60% { transform: translateX(-5%); }
  80% { transform: translateX(5%); }
}

@keyframes shake-y {=20
  0%, 100% { transform: translateY(0px); }
  20% { transform: translateY(-5%); }
  40% { transform: translateY(5%); }
  60% { transform: translateY(-5%); }
  80% { transform: translateY(5%); }
}

@keyframes shake-z {=20
  0%, 100% { transform: rotate(0deg); }
  20% { transform: rotate(-2deg); }
  40% { transform: rotate(2deg); }
  60% { transform: rotate(-2deg); }
  80% { transform: rotate(2deg); }
}

@keyframes spin {=20
  100% { transform: rotate(1turn); }
}

@keyframes ping {=20
  90%, 100% { opacity: 0; transform: scale(2); }
}

@keyframes blink {=20
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes float {=20
  50% { transform: translateY(-25%); }
}

@keyframes bounce {=20
  25% { transform: translateY(-20%); }
  40% { transform: translateY(-3%); }
  0%, 60%, 100% { transform: translateY(0px); }
}

@keyframes pulse {=20
  50% { transform: scale(0.9); }
}

@media (prefers-color-scheme: dark) {
  @keyframes fade-in-bloom {=20
  0% { filter: brightness(1) blur(20px); opacity: 0; }
  10% { filter: brightness(0.5) blur(10px); opacity: 1; }
  100% { filter: brightness(1) blur(0px); opacity: 1; }
}
}

@media (prefers-color-scheme: dark) {
  @keyframes fade-out-bloom {=20
  100% { filter: brightness(1) blur(20px); opacity: 0; }
  10% { filter: brightness(0.5) blur(10px); opacity: 1; }
  0% { filter: brightness(1) blur(0px); opacity: 1; }
}
}

