      <div class=3D"field field--name-field-primary-content field--type-ent=
ity-reference-revisions field--label-hidden field__items">
              <div class=3D"field__item">  <div class=3D"paragraph paragrap=
h--type--text-editor paragraph--view-mode--default container">
          <article class=3D"align-right media media--type-image media--view=
-mode-default">
 =20
     =20
  <div class=3D"field field--name-field-media-image field--type-image field=
--label-visually_hidden">
    <div class=3D"field__label visually-hidden">Image</div>
              <div class=3D"field__item">  <img loading=3D"lazy" src=3D"htt=
ps://lcb.wa.gov/sites/default/files/styles/large/public/Education/Health2/a=
lc-drink-variety.jpeg?itok=3DIQAPocOc" width=3D"480" height=3D"137" class=
=3D"image-style-large">


</div>
