        <mi>o</mi>
        <mi>r</mi>
        <mo>=C3=97<!-- =C3=97 --></mo>
        <mi>S</mi>
        <mi>G</mi>
        <mi>d</mi>
        <mi>r</mi>
        <mi>o</mi>
        <mi>p</mi>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle ABV\approx fa=
ctor\times SGdrop}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/7aa24ec5aeb5104e2713103be27cb231345420f8" class=3D"mwe-math-fallback=
