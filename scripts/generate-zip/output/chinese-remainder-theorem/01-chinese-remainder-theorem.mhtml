        </mrow>
        <mo>,</mo>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \mathbb {Z} /=
N\mathbb {Z} ,}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/341b93009d0a623d7b5df95b80ad8133fdbae32b" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -0.838ex; width:6.974ex; height:2.843ex;" alt=3D"{\displaystyle \ma=
thbb {Z} /N\mathbb {Z} ,}"></span> one may do the same computation independ=
ently in each <span class=3D"mwe-math-element mwe-math-element-inline"><spa=
n class=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: n=
one;"><math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displ=
aystyle \mathbb {Z} /n_{i}\mathbb {Z} }">
