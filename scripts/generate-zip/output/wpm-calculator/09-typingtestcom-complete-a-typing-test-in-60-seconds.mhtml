duration: 0s; }

.dropcontainer .dropdownvisible { max-height: 500px; border: 1px solid rgb(=
91, 99, 102); }

.dropcontainer ul li { padding-left: 15px; }

.dropcontainer ul .selected { background-color: rgb(4, 178, 213); }

.dropcontainer ul .selected a { color: rgb(255, 255, 255); }

.dropcontainer ul li a { text-decoration: none; color: rgb(91, 99, 102); }

.dropcontainer ul li .line { border-top: 2px solid rgb(185, 185, 185); disp=
lay: block; margin-right: 20px; }

.dropcontainer ul li:hover { background: rgb(4, 178, 213); color: rgb(255, =
255, 255); outline: none; }

.dropcontainer ul li:hover a { color: rgb(255, 255, 255); }

