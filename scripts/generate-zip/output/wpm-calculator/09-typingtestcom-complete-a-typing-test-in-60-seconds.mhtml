@charset "utf-8";

:host { --font-menu: #1794AD; --t-logo: url('/assets/images/logo-light.svg'=
); }

:host(.alternate) { --font-menu: #ffffff; --t-logo: url('/assets/images/t-l=
ogo.png'); }

footer-text { width: 100%; }

#footer { display: flex; flex-direction: column; align-items: center; gap: =
10px; margin: 36px 0px 24px; width: 100%; }

#footer .logo { text-decoration: none; color: var(--font-menu); display: fl=
ex; align-items: center; flex-shrink: 0; }

#footer .logo .logo-txt { font-size: 17px; }

#footer .logo .logo-txt span { font-family: system-ui, -apple-system, Blink=
MacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; font-weight: 700; fon=
t-style: italic; font-size: 21px; }

hr.dotted { border-right: none; border-bottom: none; border-left: none; bor=
der-image: initial; border-top: 2px solid; color: var(--font-menu); width: =
97%; margin: 10px auto; }

#footer .footer-top { display: flex; align-items: center; justify-content: =
center; width: 97%; margin: 0px auto; gap: 20px; flex-wrap: wrap; }

#footer .nav-links { display: flex; justify-content: center; align-items: c=
enter; width: 97%; margin: 0px auto; gap: 20px; }

#footer span, #footer a { color: var(--font-menu); font-size: 16px; font-fa=
mily: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Ari=
al, sans-serif; line-height: 1 !important; }

#footer a { font-weight: 700; text-decoration: none; }

#footer a:hover { text-decoration: underline; }

#footer #privacy-link { width: 100%; }

@media (max-width: 768px) {
  #footer .nav-links { flex-direction: column; gap: 15px; text-align: cente=
r; }
  #footer .social-link { margin-left: 0px; margin-top: 10px; }
}
