Content-Transfer-Encoding: quoted-printable
Content-Location: https://www.typingtest.com/components/styles/leftNav.css?v=4

@charset "utf-8";

aside { display: block; width: 224px; height: 100%; margin: 0px; }

aside.regular { --font-color: #0D6073; --font-menu: #0D6073; --font-menu-ac=
tive: #fff; --back-menu-active: #0D6073; --t-logo: url('/assets/images/logo=
-light.svg'); }

aside.alternate { --font-color: #ffffff; --font-menu: #ffffff; --font-menu-=
active: #156a89; --back-menu-active: #c6e7ed; --t-logo: url('/assets/images=
/t-logo.png'); }

html[data-theme=3D"dark"] aside { --font-color: #D8F8FF; --font-menu: #D8F8=
FF; --font-menu-active: #156a89; --back-menu-active: #c6e7ed; --t-logo: url=
('/assets/images/t-logo.png'); }

aside nav { left: 0px; position: fixed; width: 210px; height: 100%; line-he=
ight: 1.2; font-family: system-ui, -apple-system, BlinkMacSystemFont, "Sego=
e UI", Roboto, Arial, sans-serif; }

aside a.logo { text-decoration: none; color: var(--font-color); text-align:=
 center; }

aside a.logo .logo-img { width: 38px; height: 38px; margin: 24px auto 0px; =
background-image: var(--t-logo); background-repeat: no-repeat; background-s=
ize: contain; }

aside a.logo .logo-txt { font-size: 17px; margin-top: 5px; }

aside a.logo .logo-txt span { font-family: system-ui, -apple-system, BlinkM=
acSystemFont, "Segoe UI", Roboto, Arial, sans-serif; font-weight: 700; font=
-style: italic; font-size: 21px; }

aside ul { list-style-type: none; padding: 0px; margin: 0px; }

aside ul li { text-align: center; margin: 10px 0px; }

aside ul a { color: var(--font-menu); display: block; padding: 10px; margin=
: 18px 10px; border-radius: 20px; background: transparent; font-size: 16px;=
 text-decoration: none; }

aside ul a.link-active { color: var(--font-menu-active); background-color: =
var(--back-menu-active); }

aside ul a:hover { color: var(--font-menu-active); background-color: var(--=
back-menu-active); }

@media (max-width: 1356px) {
  aside, aside nav { width: 184px; }
}

@media (max-width: 1153px) {
  aside { display: none; }
}
