us: 50px; font-size: 20px; outline: none; color: rgb(91, 99, 102); margin-l=
eft: 45px; margin-bottom: 20px; padding-left: 15px; font-family: system-ui,=
 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; =
border: none; display: inline-block; text-decoration: none; line-height: 49=
px; transition: 0.3s; }

.disabled-trigger { color: rgb(139, 148, 151); background-color: lightgray;=
 pointer-events: none; cursor: default; }

.trigger:hover { color: rgb(119, 119, 119); background: url("../images/sele=
ct-arrow-open.png") 98% center no-repeat rgb(245, 245, 245); }

.dropcontainer ul { width: 312px; font-size: 20px; color: rgb(91, 99, 102);=
 border-radius: 10px; background-color: rgb(255, 255, 255); margin-left: 45=
px; margin-bottom: 20px; font-family: system-ui, -apple-system, BlinkMacSys=
temFont, "Segoe UI", Roboto, Arial, sans-serif; text-decoration: none; line=
-height: 45px; list-style-type: none; padding-left: 0px; transition: 0.3s l=
inear; overflow: hidden; height: auto; }

