def print_solution(manager, routing, solution):
    """Prints solution on console."""
    print(f"Objective: {solution.ObjectiveValue()} miles")
    index =3D routing.Start(0)
    plan_output =3D "Route for vehicle 0:\n"
    route_distance =3D 0
    while not routing.IsEnd(index):
        plan_output +=3D f" {manager.IndexToNode(index)} -&gt;"
        previous_index =3D index
        index =3D solution.Value(routing.NextVar(index))
        route_distance +=3D routing.GetArcCostForVehicle(previous_index, in=
dex, 0)
    plan_output +=3D f" {manager.IndexToNode(index)}\n"
    print(plan_output)
    plan_output +=3D f"Route distance: {route_distance}miles\n"


def main():
    """Entry point of the program."""
    # Instantiate the data problem.
    data =3D create_data_model()

    # Create the routing index manager.
    manager =3D pywrapcp.RoutingIndexManager(
        len(data["distance_matrix"]), data["num_vehicles"], data["depot"]
    )

    # Create Routing Model.
    routing =3D pywrapcp.RoutingModel(manager)


    def distance_callback(from_index, to_index):
        """Returns the distance between the two nodes."""
        # Convert from routing variable Index to distance matrix NodeIndex.
        from_node =3D manager.IndexToNode(from_index)
        to_node =3D manager.IndexToNode(to_index)
        return data["distance_matrix"][from_node][to_node]

    transit_callback_index =3D routing.RegisterTransitCallback(distance_cal=
lback)

    # Define cost of each arc.
    routing.SetArcCostEvaluatorOfAllVehicles(transit_callback_index)

    # Setting first solution heuristic.
