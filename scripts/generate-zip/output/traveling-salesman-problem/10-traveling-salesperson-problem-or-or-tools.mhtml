    /// &lt;summary&gt;
    ///   Euclidean distance implemented as a callback. It uses an array of
    ///   positions and computes the Euclidean distance between the two
    ///   positions of two different indices.
    /// &lt;/summary&gt;
    static long[,] ComputeEuclideanDistanceMatrix(in int[,] locations)
    {
        // Calculate the distance matrix using Euclidean distance.
        int locationNumber =3D locations.GetLength(0);
        long[,] distanceMatrix =3D new long[locationNumber, locationNumber]=
;
        for (int fromNode =3D 0; fromNode &lt; locationNumber; fromNode++)
        {
            for (int toNode =3D 0; toNode &lt; locationNumber; toNode++)
            {
                if (fromNode =3D=3D toNode)
                    distanceMatrix[fromNode, toNode] =3D 0;
                else
                    distanceMatrix[fromNode, toNode] =3D
                        (long)Math.Sqrt(Math.Pow(locations[toNode, 0] - loc=
ations[fromNode, 0], 2) +
                                        Math.Pow(locations[toNode, 1] - loc=
ations[fromNode, 1], 2));
            }
        }
        return distanceMatrix;
    }

    /// &lt;summary&gt;
    ///   Print the solution.
    /// &lt;/summary&gt;
    static void PrintSolution(in RoutingModel routing, in RoutingIndexManag=
er manager, in Assignment solution)
    {
        Console.WriteLine("Objective: {0}", solution.ObjectiveValue());
        // Inspect solution.
        Console.WriteLine("Route:");
        long routeDistance =3D 0;
        var index =3D routing.Start(0);
        while (routing.IsEnd(index) =3D=3D false)
        {
            Console.Write("{0} -&gt; ", manager.IndexToNode((int)index));
            var previousIndex =3D index;
            index =3D solution.Value(routing.NextVar(index));
            routeDistance +=3D routing.GetArcCostForVehicle(previousIndex, =
index, 0);
        }
        Console.WriteLine("{0}", manager.IndexToNode((int)index));
        Console.WriteLine("Route distance: {0}m", routeDistance);
    }

    public static void Main(String[] args)
    {
        // Instantiate the data problem.
        DataModel data =3D new DataModel();

        // Create Routing Index Manager
        RoutingIndexManager manager =3D
            new RoutingIndexManager(data.Locations.GetLength(0), data.Vehic=
leNumber, data.Depot);

        // Create Routing Model.
        RoutingModel routing =3D new RoutingModel(manager);

        // Define cost of each arc.
        long[,] distanceMatrix =3D ComputeEuclideanDistanceMatrix(data.Loca=
tions);
        int transitCallbackIndex =3D routing.RegisterTransitCallback((long =
fromIndex, long toIndex) =3D&gt;
                                                                   {
                                                                       // C=
onvert from routing variable Index to
                                                                       // d=
istance matrix NodeIndex.
                                                                       var =
fromNode =3D manager.IndexToNode(fromIndex);
                                                                       var =
toNode =3D manager.IndexToNode(toIndex);
                                                                       retu=
rn distanceMatrix[fromNode, toNode];
                                                                   });

        routing.SetArcCostEvaluatorOfAllVehicles(transitCallbackIndex);

        // Setting first solution heuristic.
        RoutingSearchParameters searchParameters =3D
            operations_research_constraint_solver.DefaultRoutingSearchParam=
eters();
        searchParameters.FirstSolutionStrategy =3D FirstSolutionStrategy.Ty=
pes.Value.PathCheapestArc;

        // Solve the problem.
        Assignment solution =3D routing.SolveWithParameters(searchParameter=
s);

        // Print solution on console.
        PrintSolution(routing, manager, solution);
    }
