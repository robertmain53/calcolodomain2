				<div class=3D"pmsymbol">CL =3D </div>
				<div class=3D"pmvalue"><input class=3D"inputparameter" id=3D"cl" value=
=3D"95">%</div>
				<div class=3D"pmdescript">Confidence level</div>

<!--Using fixed-->
				<div class=3D"pmsymbol"></div>
				<div class=3D"pmvalue"><span id=3D"pi"></span></div>
				<div class=3D"pmdescript"></div>

