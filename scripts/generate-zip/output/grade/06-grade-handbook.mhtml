s=3D"c0">&nbsp;1 level</span></p>
        </td>
      </tr>

      <tr class=3D"c3">
        <td class=3D"c48">
          <p class=3D"c1"><span class=3D"c0">Dose-response
          gradient</span></p>
        </td>

        <td class=3D"c10">
          <p class=3D"c1"><span class=3D"c0 c15">=E2=86=91</span><span clas=
s=3D"c0">&nbsp;1 level</span></p>
        </td>
