r; min-height: 25px; }

.message_close { float: left; width: 25px; font-weight: bold; font-size: 16=
pt; color: rgb(221, 221, 221); }

.message_close:hover { color: rgb(255, 255, 0); }

.message_contents { padding-left: 10px; margin-top: 5px; margin-bottom: 5px=
; }

.progressbar_fg { position: absolute; border-radius: 8px; display: inline-b=
lock; height: 30px; width: 0%; background-color: rgb(204, 204, 255); }

.progressbar_bg { border-radius: 8px; display: inline-block; line-height: 3=
0px; height: 30px; width: 100%; background-color: rgb(238, 238, 238); }

.solve_options_button { user-select: none; display: inline-block; line-heig=
ht: 30px; height: 30px; width: 20px; border-radius: 0px 8px 8px 0px; text-a=
lign: center; cursor: pointer; background-color: rgb(119, 119, 255); positi=
on: relative; }

.solve_options_button:hover { background-color: rgb(221, 221, 255); }

.solve_options_dropdown { border-radius: 8px; display: none; position: abso=
lute; top: 0px; left: -120px; width: 150px; background-color: rgb(119, 119,=
 255); z-index: 1; }

.solve_options_dropdown_item { font-size: 10pt; line-height: 15pt; color: r=
gb(0, 0, 0); cursor: pointer; }

.solve_options_dropdown_item:hover { color: rgb(248, 248, 255); }

.solve_button { user-select: none; display: inline-block; line-height: 30px=
; height: 30px; width: 100px; background-color: rgb(170, 170, 255); border-=
radius: 8px 0px 0px 8px; text-align: center; cursor: pointer; vertical-alig=
n: top; position: relative; }

.solve_button:hover { background-color: rgb(221, 221, 255); }

.solve_button_disabled { display: inline-block; line-height: 30px; height: =
30px; width: 19%; background-color: rgb(221, 221, 221); color: rgb(85, 85, =
85); border-radius: 8px; text-align: center; }

.solve_button_wrapper { float: right; }

.solve_gray { background-color: rgb(170, 170, 170); pointer-events: none; }

#soltable { background-color: rgb(248, 248, 255); width: 100%; display: blo=
ck; margin-left: auto; margin-right: auto; overflow: auto; padding-left: 15=
px; padding-right: 15px; margin-top: 20px; }

.soltable_logp, .soltable_index { font-family: monospace; color: rgb(136, 1=
36, 136); padding-right: 15px; padding-top: 5px; vertical-align: top; }

.soltable_plaintext { font-family: monospace; padding-top: 5px; padding-bot=
tom: 10px; }

.toggle_button { background-color: rgb(51, 51, 51); display: inline-block; =
height: 30px; border-radius: 8px 0px 0px 8px; text-align: center; width: 9.=
5%; line-height: 30px; vertical-align: middle; }

.mode { color: rgb(238, 238, 238); background-color: rgb(136, 170, 136); bo=
rder-radius: 8px; cursor: pointer; padding-left: 10px; padding-right: 10px;=
 margin: auto; display: inline-block; text-align: center; line-height: 30px=
; height: 30px; font-size: 10pt; vertical-align: 10px; }

.mode:hover { color: rgb(255, 255, 187); }
