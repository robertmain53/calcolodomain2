            <mi>S</mi>
          </msqrt>
        </mrow>
        <mo>+</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <msqrt>
            <mi>T</mi>
          </msqrt>
        </mrow>
        <mo>,</mo>
      </mstyle>
    </mrow>
