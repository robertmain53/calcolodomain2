    <annotation encoding=3D"application/x-tex">{\displaystyle \deg A_{1}&lt=
;\nu _{1},\ldots ,\deg A_{r}&lt;\nu _{r},\quad {\text{and}}\quad \deg(P)&lt=
;\deg(Q)=3D\sum _{j=3D1}^{r}\nu _{j}.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
