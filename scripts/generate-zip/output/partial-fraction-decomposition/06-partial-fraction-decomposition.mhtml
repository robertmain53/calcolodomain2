    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle D=3D{\frac {1=
+i}{2i}}=3D{\frac {1-i}{2}},\qquad E=3D{\frac {1-i}{-2i}}=3D{\frac {1+i}{2}=
}.}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/2fd73daff7442693e5f2590b22fe6969cebc6576" class=3D"mwe-math-fallback=
