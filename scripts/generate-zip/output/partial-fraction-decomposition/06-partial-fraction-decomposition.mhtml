=3D"mwe-math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;">=
<math display=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttex=
t=3D"{\displaystyle f(x)=3D{\frac {p(x)}{q(x)}}=3DP(x)+\sum _{i=3D1}^{m}\su=
m _{r=3D1}^{j_{i}}{\frac {A_{ir}}{(x-a_{i})^{r}}}+\sum _{i=3D1}^{n}\sum _{r=
=3D1}^{k_{i}}{\frac {B_{ir}x+C_{ir}}{(x^{2}+b_{i}x+c_{i})^{r}}}}">
