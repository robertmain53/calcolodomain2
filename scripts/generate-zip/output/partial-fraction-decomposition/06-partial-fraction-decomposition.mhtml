            <mrow>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>9</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>2</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>6</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>2</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>5</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>7</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>4</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>13</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>3</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>11</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>12</mn>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>4</mn>
            </mrow>
            <mrow>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>7</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>3</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>6</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>5</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>5</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>7</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>4</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>7</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>3</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>5</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>3</mn>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
            </mrow>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle f(x)=3D{\frac=
 {x^{9}-2x^{6}+2x^{5}-7x^{4}+13x^{3}-11x^{2}+12x-4}{x^{7}-3x^{6}+5x^{5}-7x^=
{4}+7x^{3}-5x^{2}+3x-1}}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/bab1352cc2df8d1d3de8bd9c673c33bc2101b8f3" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -2.338ex; width:55.493ex; height:6.176ex;" alt=3D"{\displaystyle f=
(x)=3D{\frac {x^{9}-2x^{6}+2x^{5}-7x^{4}+13x^{3}-11x^{2}+12x-4}{x^{7}-3x^{6=
}+5x^{5}-7x^{4}+7x^{3}-5x^{2}+3x-1}}}"></span>
</p><p>After <a href=3D"https://en.wikipedia.org/wiki/Polynomial_long_divis=
ion" title=3D"Polynomial long division">long division</a> and <a href=3D"ht=
tps://en.wikipedia.org/wiki/Polynomial_factorization" class=3D"mw-redirect"=
 title=3D"Polynomial factorization">factoring</a> the denominator, we have
</p><p><span class=3D"mwe-math-element mwe-math-element-block"><span class=
=3D"mwe-math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;">=
<math display=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttex=
t=3D"{\displaystyle f(x)=3Dx^{2}+3x+4+{\frac {2x^{6}-4x^{5}+5x^{4}-3x^{3}+x=
^{2}+3x}{(x-1)^{3}(x^{2}+1)^{2}}}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mi>f</mi>
        <mo stretchy=3D"false">(</mo>
        <mi>x</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>=3D</mo>
        <msup>
          <mi>x</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>2</mn>
          </mrow>
        </msup>
        <mo>+</mo>
        <mn>3</mn>
        <mi>x</mi>
        <mo>+</mo>
        <mn>4</mn>
        <mo>+</mo>
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mn>2</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>6</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>4</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>5</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>5</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>4</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>3</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>3</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>3</mn>
              <mi>x</mi>
            </mrow>
            <mrow>
              <mo stretchy=3D"false">(</mo>
              <mi>x</mi>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>1</mn>
              <msup>
                <mo stretchy=3D"false">)</mo>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>3</mn>
                </mrow>
              </msup>
              <mo stretchy=3D"false">(</mo>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>1</mn>
              <msup>
                <mo stretchy=3D"false">)</mo>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
            </mrow>
          </mfrac>
        </mrow>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle f(x)=3Dx^{2}+=
3x+4+{\frac {2x^{6}-4x^{5}+5x^{4}-3x^{3}+x^{2}+3x}{(x-1)^{3}(x^{2}+1)^{2}}}=
}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/943d9346332989c98f9748717b9557256b1155f9" class=3D"mwe-math-fallback=
-image-display mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertica=
l-align: -2.671ex; width:56.175ex; height:6.509ex;" alt=3D"{\displaystyle f=
(x)=3Dx^{2}+3x+4+{\frac {2x^{6}-4x^{5}+5x^{4}-3x^{3}+x^{2}+3x}{(x-1)^{3}(x^=
{2}+1)^{2}}}}"></span>
</p><p>The partial fraction decomposition takes the form
</p><p><span class=3D"mwe-math-element mwe-math-element-block"><span class=
=3D"mwe-math-mathml-display mwe-math-mathml-a11y" style=3D"display: none;">=
<math display=3D"block" xmlns=3D"http://www.w3.org/1998/Math/MathML" alttex=
t=3D"{\displaystyle {\frac {2x^{6}-4x^{5}+5x^{4}-3x^{3}+x^{2}+3x}{(x-1)^{3}=
(x^{2}+1)^{2}}}=3D{\frac {A}{x-1}}+{\frac {B}{(x-1)^{2}}}+{\frac {C}{(x-1)^=
{3}}}+{\frac {Dx+E}{x^{2}+1}}+{\frac {Fx+G}{(x^{2}+1)^{2}}}.}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <mrow class=3D"MJX-TeXAtom-ORD">
          <mfrac>
            <mrow>
              <mn>2</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>6</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>4</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>5</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <mn>5</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>4</mn>
                </mrow>
              </msup>
              <mo>=E2=88=92<!-- =E2=88=92 --></mo>
              <mn>3</mn>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>3</mn>
                </mrow>
              </msup>
              <mo>+</mo>
              <msup>
                <mi>x</mi>
                <mrow class=3D"MJX-TeXAtom-ORD">
                  <mn>2</mn>
                </mrow>
              </msup>
              <mo>+</mo>
