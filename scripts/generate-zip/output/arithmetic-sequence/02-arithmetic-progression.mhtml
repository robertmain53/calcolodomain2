Bn.gif/250px-Animated_proof_for_the_formula_giving_the_sum_of_the_first_int=
egers_1%2B2%2B...%2Bn.gif" decoding=3D"async" width=3D"250" height=3D"70" c=
lass=3D"mw-file-element" data-file-width=3D"1860" data-file-height=3D"518">=
</a><figcaption>Animated proof for the formula giving the sum of the first =
integers 1+2+...+n.</figcaption></figure>
<p>To derive the above formula, begin by expressing the arithmetic series i=
n two different ways:
</p>
<dl><dd><span class=3D"mwe-math-element mwe-math-element-inline"><span clas=
s=3D"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;">=
<math xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyl=
e S_{n}=3Da+a_{2}+a_{3}+\dots +a_{(n-1)}+a_{n}}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <msub>
          <mi>S</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>n</mi>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <mi>a</mi>
        <mo>+</mo>
        <msub>
          <mi>a</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>2</mn>
          </mrow>
        </msub>
        <mo>+</mo>
        <msub>
          <mi>a</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mn>3</mn>
          </mrow>
        </msub>
        <mo>+</mo>
        <mo>=E2=8B=AF<!-- =E2=8B=AF --></mo>
        <mo>+</mo>
        <msub>
          <mi>a</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mo stretchy=3D"false">(</mo>
            <mi>n</mi>
            <mo>=E2=88=92<!-- =E2=88=92 --></mo>
            <mn>1</mn>
            <mo stretchy=3D"false">)</mo>
          </mrow>
        </msub>
        <mo>+</mo>
        <msub>
          <mi>a</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>n</mi>
          </mrow>
        </msub>
      </mstyle>
    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle S_{n}=3Da+a_{=
2}+a_{3}+\dots +a_{(n-1)}+a_{n}}</annotation>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
er/svg/d881a0d6399b898963b0a51b10b6ce19b483a0c1" class=3D"mwe-math-fallback=
-image-inline mw-invert skin-invert" aria-hidden=3D"true" style=3D"vertical=
-align: -1.171ex; width:36.741ex; height:3.009ex;" alt=3D"{\displaystyle S_=
{n}=3Da+a_{2}+a_{3}+\dots +a_{(n-1)}+a_{n}}"></span></dd>
<dd><span class=3D"mwe-math-element mwe-math-element-inline"><span class=3D=
"mwe-math-mathml-inline mwe-math-mathml-a11y" style=3D"display: none;"><mat=
h xmlns=3D"http://www.w3.org/1998/Math/MathML" alttext=3D"{\displaystyle S_=
{n}=3Da+(a+d)+(a+2d)+\dots +(a+(n-2)d)+(a+(n-1)d).}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
      <mstyle displaystyle=3D"true" scriptlevel=3D"0">
        <msub>
          <mi>S</mi>
          <mrow class=3D"MJX-TeXAtom-ORD">
            <mi>n</mi>
          </mrow>
        </msub>
        <mo>=3D</mo>
        <mi>a</mi>
        <mo>+</mo>
        <mo stretchy=3D"false">(</mo>
        <mi>a</mi>
        <mo>+</mo>
        <mi>d</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>+</mo>
        <mo stretchy=3D"false">(</mo>
        <mi>a</mi>
        <mo>+</mo>
        <mn>2</mn>
        <mi>d</mi>
        <mo stretchy=3D"false">)</mo>
        <mo>+</mo>
