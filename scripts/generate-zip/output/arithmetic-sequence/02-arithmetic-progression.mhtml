    </mrow>
    <annotation encoding=3D"application/x-tex">{\displaystyle \left(-{\frac=
 {3}{2}}\right)+\left(-{\frac {1}{2}}\right)+{\frac {1}{2}}=3D{\frac {3\lef=
t(-{\frac {3}{2}}+{\frac {1}{2}}\right)}{2}}=3D-{\frac {3}{2}}.}</annotatio=
n>
  </semantics>
</math></span><img src=3D"https://wikimedia.org/api/rest_v1/media/math/rend=
