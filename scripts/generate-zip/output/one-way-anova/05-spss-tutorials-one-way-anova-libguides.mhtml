			<th class=3D"rowLabels hCR role3" scope=3D"row" style=3D"text-align: lef=
t;">Total</th>
			<td class=3D"o dataAreaLeft hCR vCC" style=3D"text-align: right;">353</t=
d>
			<td class=3D"o hCR vCC" style=3D"text-align: right;">6.569</td>
