>flat_image<span class=3D"token punctuation">)</span>

k <span class=3D"token operator">=3D</span> <span class=3D"token number">10=
0</span>
plt<span class=3D"token punctuation">.</span>plot<span class=3D"token punct=
uation">(</span>np<span class=3D"token punctuation">.</span>arange<span cla=
