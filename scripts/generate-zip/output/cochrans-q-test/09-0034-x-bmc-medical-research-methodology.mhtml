.unused { font-family: Merriweather, serif; }

body { font-family: "Merriweather Sans", "Helvetica Neue", Helvetica, Arial=
, sans-serif; line-height: 1.8; min-height: 100%; color: rgb(34, 34, 34); b=
ackground: rgb(255, 255, 255); }

a { color: rgb(2, 94, 141); text-decoration: underline 0.0625rem; text-deco=
ration-skip-ink: auto; text-underline-offset: 0.25rem; padding: initial; }

button { cursor: pointer; }

img { border: 0px; max-width: 100%; height: auto; vertical-align: middle; }

html { height: 100%; overflow-y: scroll; font-size: 100%; box-sizing: borde=
r-box; }

h1 { font-size: clamp(1.75rem, 4vw, 2.25rem); }

h2 { font-size: clamp(1.5rem, 4vw, 1.75rem); }

h1, h2, h3, h4, h5 { line-height: 1.2; font-weight: 700; }

h3 { font-size: clamp(1.25rem, 4vw, 1.5rem); }

h4, h5 { font-size: 1.25rem; }

body, h5 { font-size: 1.125rem; }

*, ::after, ::before { box-sizing: inherit; }

.c-article-change-list__item > ins, abbr[title] { text-decoration: none; }

dd { margin: 0px; }

p { margin-top: 0px; margin-bottom: 2rem; }

p:last-of-type { margin-bottom: 0px; }

a.visited, a:visited { color: rgb(1, 50, 75); }

a.hover, a:hover { color: rgb(1, 50, 75); text-decoration-thickness: 0.25re=
m; text-underline-offset: 0.25rem; }

a.active, a:active { color: rgb(2, 94, 141); }

a.focus, a:focus { outline: rgb(0, 136, 204) solid 4px; }

table { font-size: 1rem; line-height: 1.8; border-collapse: collapse; borde=
r: 0px; width: 100%; margin-bottom: 32px; }

td, th { padding: 8px; vertical-align: top; }

th { text-align: left; border-bottom: 3px solid rgb(1, 50, 75); }

td { font-family: "Merriweather Sans", "Helvetica Neue", Helvetica, Arial, =
sans-serif; border-bottom: 2px solid rgb(218, 218, 218); }

.c-ad { text-align: center; }

@media only screen and (min-width: 480px) {
  .c-ad { padding: 8px; }
}

.c-ad--728x90, .c-ad--970x90 { display: none; }

.c-ad--728x90 .c-ad__inner, .c-ad--970x90 .c-ad__inner { min-height: calc(1=
.5em + 94px); }

.c-ad--728x90 iframe, .c-ad--970x90 iframe { max-width: 970px; height: 90px=
; }

@media only screen and (min-width: 876px) {
  .js .c-ad--728x90 { display: none; }
  .js .u-show-following-ad + .c-ad--728x90 { display: block; }
}

.c-ad--160x600 { display: none; padding: 0px; text-align: left; }

.c-ad--160x600 iframe { width: 160px; height: 600px; }

@media only screen and (min-width: 876px) {
  .js .c-ad--160x600 { display: block; }
}

.c-ad--300x250 { display: none; }

.c-ad--300x250 iframe { width: 300px; height: 250px; }

.c-ad--300x250 .c-ad__inner { min-height: calc(1.5em + 254px); }

@media only screen and (min-width: 480px) {
  .js .c-ad--300x250 { display: block; }
}

.c-ad iframe { border: 0px; overflow: auto; vertical-align: top; }

.c-ad__label { font-size: 0.875rem; font-family: "Merriweather Sans", "Helv=
etica Neue", Helvetica, Arial, sans-serif; font-weight: 400; margin-bottom:=
 4px; color: rgb(51, 51, 51); line-height: 1.5; }

.c-status-message { display: flex; align-items: center; width: 100%; box-si=
zing: border-box; }

.c-status-message :last-child { }

.c-status-message__heading { font-family: "Merriweather Sans", "Helvetica N=
eue", Helvetica, Arial, sans-serif; font-size: 1rem; font-weight: 700; }

.c-status-message__icon { fill: currentcolor; transform: translate(0px, 0px=
); display: inline-block; vertical-align: text-top; flex: 0 0 auto; }

.c-status-message--boxed.c-status-message--info { border-bottom: 4px solid =
rgb(0, 63, 141); }

.c-status-message--boxed.c-status-message--error { border-bottom: 4px solid=
 rgb(196, 6, 6); }

.c-status-message--boxed.c-status-message--success { border-bottom: 4px sol=
id rgb(0, 184, 176); }

.c-status-message--boxed.c-status-message--warning { border-bottom: 4px sol=
id rgb(237, 188, 83); }

.eds-c-card { position: relative; text-decoration: none; display: flex; col=
or: rgb(34, 34, 34); }

.eds-c-card.eds-c-card--stretch-height { height: 100%; }

.eds-c-card:focus { border-radius: 8px; }

