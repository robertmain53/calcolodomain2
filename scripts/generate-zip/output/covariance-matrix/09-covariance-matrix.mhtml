ht=3D"38" src=3D"data:image/gif;base64,R0lGODlhAQABAIAAANvf7wAAACH5BAEAAAAA=
LAAAAAABAAEAAAICRAEAOw=3D=3D" alt=3D"[eq23]" style=3D"background-position:0=
px -1709px;"></span>
