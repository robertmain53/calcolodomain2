ead><tbody><tr><td style=3D"text-align: center;"><b><strong>Anna</strong></=
b></td><td style=3D"text-align: center;"><b><strong>80</strong></b></td><td=
 style=3D"text-align: center;"><b><strong>70</strong></b></td></tr><tr><td =
style=3D"text-align: center;"><b><strong>Caroline</strong></b></td><td styl=
e=3D"text-align: center;"><b><strong>63</strong></b></td><td style=3D"text-=
