.rc-2fa-response-field-error input { border: 1px solid rgb(217, 48, 37); }

.rc-2fa-response-field-error input:focus { border: 1px solid rgb(217, 48, 3=
7); }

.rc-2fa-error-message { height: 36px; font-size: 12px; color: rgb(217, 48, =
37); margin: 2px 40px; }

