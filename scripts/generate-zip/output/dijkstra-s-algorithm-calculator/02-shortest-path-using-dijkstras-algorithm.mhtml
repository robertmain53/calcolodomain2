		<td><input type=3D"radio" name=3D"radWorkMode" value=3D"drawEdge"></td>
		<td>Draw edge</td>
		<td><input type=3D"radio" name=3D"radWorkMode" value=3D"setStart"></td>
		<td>Set Start</td>
	</tr>
	<tr>
		<td><input type=3D"radio" name=3D"radWorkMode" value=3D"delVertexEdge"></=
td>
		<td>Delete vertex or edge</td>
		<td><input type=3D"radio" name=3D"radWorkMode" value=3D"setCostLabel"></t=
d>
		<td>Set cost or label</td>
		<td>&nbsp;</td>
		<td>&nbsp;</td>
	</tr>
</tbody></table>

<table id=3D"dijkstraSteps"></table>

<!-- The Modal -->
<div id=3D"divEdgeCost" class=3D"modal">
  <!-- Modal content -->
  <div class=3D"modal-content">
    <span class=3D"close">=C3=97</span>
    <label>Edge Cost</label>
        <input type=3D"number" maxlength=3D"4" required=3D"required" autoco=
mplete=3D"off" min=3D"1" max=3D"1000" name=3D"inputEdgeCost" id=3D"inputEdg=
eCost">
        <button id=3D"btnSetEdgeCost">Set value</button>
       =20
  </div>
</div>

<div id=3D"divVertexLabel" class=3D"modal">
  <!-- Modal content -->
  <div class=3D"modal-content">
    <span class=3D"close">=C3=97</span>
