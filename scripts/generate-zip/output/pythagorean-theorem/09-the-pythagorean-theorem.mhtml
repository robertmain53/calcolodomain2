@charset "utf-8";

html { font-size: 8px; }

body { padding: 0px; box-shadow: none !important; }

#book, body { background: none !important; }

#book { border-radius: 0px; box-shadow: none; margin: 0px 60px; padding: 20=
px; border: none !important; }

#header { border-color: rgb(153, 153, 153); margin: 0px; max-width: 100%; m=
in-height: 0px; padding: 0px; }

#article, .menubreadcrumbs + #article { margin: 0px; max-width: 100%; min-h=
eight: 0px; overflow: visible; padding: 20px 0px 30px; }

.menubreadcrumbs > :first-child, .menubreadcrumbs > :first-child + span { d=
isplay: none; }

.menubreadcrumbs { font-size: 20px; margin: 0px; padding: 30px 0px 0px; }

.menubreadcrumbs a { color: rgb(0, 0, 0); }

a { color: inherit !important; }

#main, .corner, .cover, .sheet, .sheet .sheet, .sheet .sheet .sheet { borde=
r: none; border-radius: 0px; box-shadow: none; margin: 0px; padding: 0px; b=
ackground: none !important; position: relative !important; }

.iframe > * { display: none !important; }

.iframe { background: rgb(204, 204, 204); height: 100px; }

.payoff { padding: 10px 40px; }

#MathJax_Message, #footer, #header p.question, #main > .corner, #menunextse=
ction, #menusite, #menuslider, #share, .exercises, .framed, .interact, .mat=
hexerciseengine .box > .monitor, .related, nav.languages { display: none !i=
mportant; }
