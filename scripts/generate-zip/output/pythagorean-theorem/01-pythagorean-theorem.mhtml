            <mrow class=3D"MJX-TeXAtom-ORD">
              <msqrt>
                <msup>
                  <mi>x</mi>
                  <mrow class=3D"MJX-TeXAtom-ORD">
                    <mn>2</mn>
                  </mrow>
                </msup>
                <mo>+</mo>
                <msup>
