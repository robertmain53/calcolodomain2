isplaystyle \cos {\frac {c}{R}}=3D\cos {\frac {a}{R}}\,\cos {\frac {b}{R}}+=
\sin {\frac {a}{R}}\,\sin {\frac {b}{R}}\,\cos {\gamma }.}">
  <semantics>
    <mrow class=3D"MJX-TeXAtom-ORD">
