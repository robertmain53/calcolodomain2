<h2 class=3D"wp-block-heading alignwide is-style-beamex-underline">Temperat=
ure Unit Converter</h2>



<p class=3D"alignwide has-text-align-wide">Use the below unit converter by =
entering the temperature numerical value to the =E2=80=9CValue=E2=80=9D fie=
ld and select the unit in the =E2=80=9CUnit=E2=80=9D field.&nbsp;Press the =
=E2=80=9CConvert=E2=80=9D button to view the results in a table below.&nbsp=
;Please&nbsp;use a decimal dot (not a comma).</p>


<div class=3D"wp-block-gds-converter-temperature alignwide">
  <div class=3D"wp-block-gds-convertor-temperature__inner-container" id=3D"=
formContainer">
    <form action=3D"https://www.beamex.com/us/resources/temperature-unit-co=
nverter/" id=3D"tempConverterform">
      <fieldset id=3D"converter-value">
          <label class=3D"inlinelabel" for=3D"tempValue">
            Value (numerical)
          </label>
          <input type=3D"text" id=3D"tempValue" value=3D"1" name=3D"tempVal=
ue" placeholder=3D"Value to convert">
      </fieldset>
      <fieldset id=3D"converter-unit">
        <label class=3D"inlinelabel" for=3D"pressureUnit">
          Unit
        </label>
        <select id=3D"tempUnit" name=3D"tempUnit">
          <option value=3D"0">Select temperature unit</option>
          <option value=3D"1" selected=3D"">Celsius [=C2=B0C]</option>
