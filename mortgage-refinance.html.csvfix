<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Mortgage Refinance Calculator | Payment, Savings, Break-Even, Interest Saved</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="description" content="Compare your current mortgage to a refinance: new payment, monthly savings, break-even time, and total interest saved. Professional, mobile-first, WCAG-compliant."/>
  <meta name="author" content="Ugo Candido"/>
  <meta name="robots" content="index,follow,max-image-preview:large"/>
