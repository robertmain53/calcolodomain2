  <!-- Calculator logic -->
  <script>
    (function(){
      'use strict';
      const $ = (sel, ctx=document) => ctx.querySelector(sel);
      const curr = new Intl.NumberFormat(undefined,{style:'currency',currency:guessCurrency()});
      function guessCurrency(){
        try{
          const r = Intl.DateTimeFormat().resolvedOptions().locale?.split('-')[1] || '';
          if(r==='GB') return 'GBP';
          if(r==='CA') return 'CAD';
          if(r==='AU') return 'AUD';
          if(['EU','DE','FR','ES','IT','NL','IE','PT'].includes(r)) return 'EUR';
        }catch(e){}
        return 'USD';
      }

      // Inputs
      const currentBalance = $('#currentBalance');
      const currentRate = $('#currentRate');
      const monthsRemaining = $('#monthsRemaining');
      const newRate = $('#newRate');
      const newTermYears = $('#newTermYears');
      const pointsCosts = $('#pointsCosts');

      // Errors
      const balErr = $('#balErr');
      const crErr = $('#crErr');
      const mrErr = $('#mrErr');
      const nrErr = $('#nrErr');
      const ntErr = $('#ntErr');
      const pcErr = $('#pcErr');

      // Results
      const newPay = $('#newPay');
      const monthlySave = $('#monthlySave');
      const breakeven = $('#breakeven');
      const interestSave = $('#interestSave');
      const currPay = $('#currPay');
      const piOut = $('#piOut');
      const costsOut = $('#costsOut');

      // Helpers
      const parseNum = (input)=>{ const v = parseFloat(input.value); return Number.isFinite(v) ? v : NaN; };
      function setError(input, el, msg){ input?.setAttribute('aria-invalid','true'); if(el) el.textContent = msg||''; }
      function clearError(input, el){ input?.setAttribute('aria-invalid','false'); if(el) el.textContent = ''; }

      function PI(L, aprPct, n){
        if(n<=0) return NaN;
        const r = (aprPct/100)/12;
        if(r===0) return L/n;
        return L * (r / (1 - Math.pow(1+r, -n)));
      }

      function validate(){
        let ok = true;
        const B = parseNum(currentBalance);
        if(!(B>0)){ setError(currentBalance, balErr, 'Enter a positive balance.'); ok=false; } else clearError(currentBalance, balErr);

        const CR = parseNum(currentRate);
        if(!(CR>=0 && CR<100)){ setError(currentRate, crErr, 'APR must be between 0 and 100.'); ok=false; } else clearError(currentRate, crErr);

        const Nrem = parseNum(monthsRemaining);
        if(!(Number.isFinite(Nrem) && Nrem>=1)){ setError(monthsRemaining, mrErr, 'Enter remaining months (≥ 1).'); ok=false; } else clearError(monthsRemaining, mrErr);

        const NR = parseNum(newRate);
        if(!(NR>=0 && NR<100)){ setError(newRate, nrErr, 'New APR must be between 0 and 100.'); ok=false; } else clearError(newRate, nrErr);

        const NY = parseNum(newTermYears);
        if(!(Number.isFinite(NY) && NY>=1 && NY<=50)){ setError(newTermYears, ntErr, 'Term in years (1–50).'); ok=false; } else clearError(newTermYears, ntErr);

        const C = parseNum(pointsCosts); if(C<0){ setError(pointsCosts, pcErr, 'Costs cannot be negative.'); ok=false; } else clearError(pointsCosts, pcErr);

        return ok;
      }

      function calculate(){
        if(!validate()) return;

        const B = parseNum(currentBalance);
        const CR = parseNum(currentRate);
        const Nrem = parseNum(monthsRemaining);
        const NR = parseNum(newRate);
        const NY = parseNum(newTermYears);
        const C = Math.max(0, parseNum(pointsCosts) || 0);

        const piCurr = PI(B, CR, Nrem);

        const Lnew = B + C;
        const nNew = NY*12;
        const piNew = PI(Lnew, NR, nNew);

        const save = Math.max(piCurr - piNew, 0);
        const beMonths = save>0 ? (C / save) : Infinity;

        currPay.textContent = Number.isFinite(piCurr) ? curr.format(piCurr) : '—';
        piOut.textContent   = Number.isFinite(piNew) ? curr.format(piNew) : '—';
        newPay.textContent  = Number.isFinite(piNew) ? curr.format(piNew) : '—';
        monthlySave.textContent = Number.isFinite(save) ? curr.format(save) : '—';
        costsOut.textContent = curr.format(C);
        breakeven.textContent = (beMonths===Infinity) ? '—' : `${beMonths.toFixed(1)} mo`;

        const totalIntNew = Number.isFinite(piNew) ? (piNew*nNew - Lnew) : NaN;
        const totalIntCurrRem = Number.isFinite(piCurr) ? (piCurr*Nrem - B) : NaN;
        const diff = (Number.isFinite(totalIntNew) && Number.isFinite(totalIntCurrRem)) ? Math.max(totalIntCurrRem - totalIntNew, 0) : NaN;
        interestSave.textContent = Number.isFinite(diff) ? curr.format(diff) : '—';
      }

      // Debounced live calc
      let t; const debounced = ()=>{ clearTimeout(t); t=setTimeout(calculate, 120); };
      [currentBalance,currentRate,monthsRemaining,newRate,newTermYears,pointsCosts].forEach(i=>{
        i.addEventListener('input', debounced);
        i.addEventListener('blur', debounced);
      });

      document.getElementById('calcBtn').addEventListener('click', calculate);
      document.getElementById('resetBtn').addEventListener('click', ()=>{
        [currentBalance,currentRate,monthsRemaining,newRate,newTermYears,pointsCosts].forEach(i=>{ i.value=''; i.setAttribute('aria-invalid','false'); });
        [ '#balErr','#crErr','#mrErr','#nrErr','#ntErr','#pcErr' ].forEach(s=>{ const el=$(s); if(el) el.textContent=''; });
        newPay.textContent='$0'; monthlySave.textContent='$0'; breakeven.textContent='—'; interestSave.textContent='$0';
        currPay.textContent='$0'; piOut.textContent='$0'; costsOut.textContent='$0';
      });

      // Mobile menu
      document.getElementById('mobile-menu-toggle')?.addEventListener('click', ()=>{
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      // Nice defaults
      currentBalance.value='280000';
      currentRate.value='5.75';
      monthsRemaining.value='300';
      newRate.value='5.25';
      newTermYears.value='30';
      pointsCosts.value='3500';
      calculate();
    })();
  </script>

    <script>
        // Mobile menu toggle
        (function() {
            const mobileToggle = document.getElementById('mobile-menu-toggle');
            const mobileMenu = document.getElementById('mobile-menu');
            if (mobileToggle && mobileMenu) {
                mobileToggle.addEventListener('click', () => {
                    mobileMenu.classList.toggle('hidden');
                });
            }
        })();
    </script>
</body>
</html>
