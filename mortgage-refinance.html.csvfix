    "description":"Refinance calculator showing new payment, monthly savings, break-even time, and interest saved.",
    "author":{"@type":"Person","name":"Ugo Candido"},
    "publisher":{"@type":"Organization","name":"CalcDomain"},
    "breadcrumb":{
      "@type":"BreadcrumbList",
      "itemListElement":[
        {"@type":"ListItem","position":1,"name":"Home","item":"https://calcdomain.com/index.html"},
        {"@type":"ListItem","position":2,"name":"Finance","item":"https://calcdomain.com/finance.html"},
        {"@type":"ListItem","position":3,"name":"Mortgage & Real Estate","item":"https://calcdomain.com/mortgage-real-estate.html"},
        {"@type":"ListItem","position":4,"name":"Mortgage Refinance Calculator","item":"https://calcdomain.com/mortgage-refinance.html"}
      ]
    },
    "mainEntity":{
      "@type":"FAQPage",
      "mainEntity":[
        {"@type":"Question","name":"How do I know if refinancing is worth it?","acceptedAnswer":{"@type":"Answer","text":"Compare monthly savings to total closing costs. The shorter the break-even time, the more attractive the refinance."}},
        {"@type":"Question","name":"Should I reset to 30 years?","acceptedAnswer":{"@type":"Answer","text":"Longer terms lower the payment but increase lifetime interest. Consider shorter terms (15–20 years) if cash flow allows."}},
        {"@type":"Question","name":"Are taxes, insurance, and PMI included?","acceptedAnswer":{"@type":"Answer","text":"This tool models principal and interest. It excludes escrow items and prepayment penalties—check your note and lender."}}
      ]
    }
  }
  </script>

