---
import type { PageEntry } from "../data/pages";

const { items }: { items: PageEntry[] } = Astro.props;
---
{items.length > 0 && (
  <section class="related">
    <div class="head">
      <span>Related calculators</span>
      <span class="tag">{items.length}</span>
    </div>
    <div class="grid">
      {items.map((item) => (
        <a class="card" href={`/en/${item.slug.join("/")}`}>
          <div class="title">{item.title}</div>
          <div class="meta">
            <span>{item.primary.hub}</span>
            <span>·</span>
            <span>{item.primary.cluster}</span>
          </div>
          <p>{item.description}</p>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related {
    margin-top: 2rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
  }
  .head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .tag {
    background: rgba(56, 189, 248, 0.12);
    color: #7dd3fc;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    font-size: 0.85rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.75rem;
  }
  .card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.85rem;
    background: rgba(255, 255, 255, 0.02);
    color: inherit;
    text-decoration: none;
    transition: 0.15s ease;
  }
  .card:hover {
    border-color: rgba(56, 189, 248, 0.35);
    transform: translateY(-1px);
  }
  .title {
    font-weight: 600;
    color: #e2e8f0;
    margin-bottom: 0.25rem;
  }
  .meta {
    font-size: 0.9rem;
    color: #94a3b8;
    display: flex;
    gap: 0.35rem;
    margin-bottom: 0.35rem;
  }
  p {
    margin: 0;
    color: #cbd5e1;
    font-size: 0.95rem;
  }
</style>
