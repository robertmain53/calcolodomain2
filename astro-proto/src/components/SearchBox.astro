---
import { pages } from "../data/pages";

const suggestions = pages
  .filter((p) => p.locale === "en")
  .map((p) => ({
    title: p.title,
    hub: p.primary.hub,
    cluster: p.primary.cluster,
    path: `/en/${p.slug.join("/")}`,
    desc: p.description,
  }));
---
<div class="search-box">
  <input
    type="search"
    placeholder="Search calculators, clusters, guides..."
    aria-label="Search calculators"
  />
  <div class="pill tone">Predictive, faceted search (hub/cluster/tool)</div>
  <div class="list" hidden></div>
</div>

<style>
  .search-box {
    display: grid;
    gap: 0.35rem;
  }
  .search-box input {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.8rem 0.9rem;
    color: #fff;
    font-size: 1rem;
  }
  .list {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(15, 23, 42, 0.95);
    padding: 0.4rem;
    display: grid;
    gap: 0.25rem;
    max-height: 260px;
    overflow: auto;
  }
  .item {
    padding: 0.55rem 0.65rem;
    border-radius: 10px;
    color: #e2e8f0;
    border: 1px solid transparent;
    text-decoration: none;
  }
  .item:hover {
    border-color: rgba(56, 189, 248, 0.35);
    background: rgba(255, 255, 255, 0.04);
  }
  .meta {
    color: #94a3b8;
    font-size: 0.9rem;
  }
</style>

<script is:inline>
  const data = {JSON.stringify(suggestions)};
  const root = document.currentScript?.parentElement;
  if (root) {
    const input = root.querySelector("input");
    const list = root.querySelector(".list");
    const render = (q) => {
      const query = q.trim().toLowerCase();
      const matches = data
        .filter(
          (d) =>
            d.title.toLowerCase().includes(query) ||
            d.cluster.toLowerCase().includes(query) ||
            d.hub.toLowerCase().includes(query),
        )
        .slice(0, 8);
      list.innerHTML = "";
      if (!query || !matches.length) {
        list.hidden = true;
        return;
      }
      matches.forEach((m) => {
        const a = document.createElement("a");
        a.href = m.path;
        a.className = "item";
        a.innerHTML = `<div>${m.title}</div><div class="meta">${m.hub} · ${m.cluster}</div><div class="meta">${m.desc}</div>`;
        list.appendChild(a);
      });
      list.hidden = false;
    };
    input?.addEventListener("input", (e) => render(e.target.value));
  }
</script>
