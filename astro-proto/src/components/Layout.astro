---
import { siteName, siteDescription } from "../config/site";
import { getTaxonomy } from "../data/taxonomy";

const taxonomy = await getTaxonomy();
const year = new Date().getFullYear();

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteName,
  description = siteDescription,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    <slot name="head" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="brand">
          <a class="brand-link" href="/en/">{siteName}</a>
          <p>{siteDescription}</p>
        </div>
        <nav class="main-nav" aria-label="Primary">
          <a class="nav-link" href="/en/">Home</a>
          <details class="nav-categories">
            <summary>Browse categories</summary>
            <div class="nav-categories-panel">
              {taxonomy.map((hub) => (
                <article>
                  <a class="hub-link" href={`/en/${hub.slug}`}>{hub.name}</a>
                  <div class="cluster-list">
                    {hub.clusters.map((cluster) => (
                      <a href={`/en/${hub.slug}/${cluster.slug}`}>{cluster.name}</a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </details>
        </nav>
        <div class="header-actions">
          <a class="btn primary" href="/en/science-and-mathematics">Browse calculators</a>
          <a
            class="btn ghost"
            href="/en/science-and-mathematics/unit-conversion/mm-to-inches"
          >
            Try a converter
          </a>
        </div>
      </header>

      <main class="content-shell">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-grid">
          <div>
            <p class="eyebrow">Categories</p>
            <h3>Deep topical structures for every calculator</h3>
            <p>
              Navigate via hubs, clusters, and tools that mirror the research-grade
              hierarchy used by engineering and finance teams.
            </p>
          </div>

          <div class="footer-cats">
            {taxonomy.map((hub) => (
              <div class="footer-hub">
                <a class="footer-hub-label" href={`/en/${hub.slug}`}>{hub.name}</a>
                <p>{hub.description}</p>
                <ul>
                  {hub.clusters.map((cluster) => (
                    <li>
                      <a href={`/en/${hub.slug}/${cluster.slug}`}>{cluster.name}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <div class="footer-meta">
          <p>&copy; {year} {siteName}. All rights reserved.</p>
          <p>Crafted for calculators that demand accuracy, performance, and clarity.</p>
        </div>
      </footer>
    </div>
    <style is:global>
      :root {
        color-scheme: dark;
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background-color: #01040a;
        color: #e2e8f0;
      }
      *, *::before, *::after {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: radial-gradient(circle at top, rgba(56, 189, 248, 0.2), transparent 45%),
          #01040a;
      }
      a {
        color: inherit;
      }
    </style>
    <style>
      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        padding: 0 1rem;
        gap: 2rem;
      }
      .site-header {
        width: min(1200px, 100%);
        margin: 0 auto;
        padding: 1.5rem 0;
        display: flex;
        gap: 1rem;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        position: sticky;
        top: 0;
        background: rgba(1, 4, 10, 0.85);
        backdrop-filter: blur(12px);
        z-index: 10;
      }
      .brand {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .brand-link {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #38bdf8;
        text-decoration: none;
      }
      .brand p {
        margin: 0;
        color: #94a3b8;
        font-size: 0.95rem;
        max-width: 260px;
      }
      .main-nav {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        font-weight: 500;
      }
      .nav-link {
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        color: #e2e8f0;
        text-decoration: none;
        transition: background 0.2s ease;
      }
      .nav-link:hover,
      .hub-link:hover,
      .cluster-list a:hover {
        background: rgba(56, 189, 248, 0.12);
      }
      .nav-categories {
        position: relative;
      }
      .nav-categories summary {
        list-style: none;
        cursor: pointer;
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.5);
        color: #e2e8f0;
        background: rgba(15, 23, 42, 0.65);
      }
      .nav-categories summary::-webkit-details-marker {
        display: none;
      }
      .nav-categories summary::marker {
        content: "";
      }
      .nav-categories[open] summary {
        background: rgba(14, 165, 233, 0.15);
      }
      .nav-categories-panel {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        z-index: 20;
        background: rgba(2, 6, 23, 0.95);
        border: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 1rem;
        padding: 1rem;
        min-width: 280px;
        box-shadow: 0 12px 30px rgba(2, 6, 23, 0.5);
        display: grid;
        gap: 0.75rem;
      }
      .nav-categories-panel article {
        border-bottom: 1px solid rgba(148, 163, 184, 0.1);
        padding-bottom: 0.5rem;
      }
      .nav-categories-panel article:last-of-type {
        border-bottom: none;
        padding-bottom: 0;
      }
      .hub-link {
        font-weight: 600;
        color: #f8fafc;
        text-decoration: none;
      }
      .cluster-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-top: 0.35rem;
      }
      .cluster-list a {
        font-size: 0.85rem;
        padding: 0.25rem 0.45rem;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.15);
        text-decoration: none;
        color: #cbd5f5;
      }
      .header-actions {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
      }
      .btn {
        border-radius: 999px;
        padding: 0.55rem 1.25rem;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid transparent;
        transition: transform 0.2s ease, background 0.2s ease;
      }
      .btn.primary {
        background: linear-gradient(135deg, #22d3ee, #2563eb);
        color: #0f172a;
      }
      .btn.ghost {
        border-color: rgba(148, 163, 184, 0.4);
        color: #e2e8f0;
      }
      .btn:hover {
        transform: translateY(-1px);
      }
      .content-shell {
        width: min(1200px, 100%);
        margin: 0 auto;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 3rem;
      }
      .site-footer {
        width: min(1200px, 100%);
        margin: 0 auto 2rem;
        padding: 2rem 0 1rem;
        border-top: 1px solid rgba(148, 163, 184, 0.2);
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }
      .footer-grid {
        display: grid;
        gap: 1.5rem;
      }
      .footer-grid h3 {
        margin: 0.4rem 0;
        font-size: 1.25rem;
      }
      .eyebrow {
        font-size: 0.85rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #94a3b8;
      }
      .footer-cats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.25rem;
      }
      .footer-hub-label {
        font-weight: 600;
        color: #e0f2fe;
        text-decoration: none;
      }
      .footer-hub p {
        margin: 0.35rem 0 0.45rem;
        color: #cbd5f5;
        font-size: 0.9rem;
      }
      .footer-hub ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.25rem;
      }
      .footer-hub li a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.9rem;
      }
      .footer-hub li a:hover {
        color: #38bdf8;
      }
      .footer-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: space-between;
        color: #94a3b8;
        font-size: 0.85rem;
      }
      @media (max-width: 980px) {
        .site-header {
          flex-direction: column;
          align-items: flex-start;
        }
        .content-shell,
        .site-footer {
          width: 100%;
        }
      }
      @media (max-width: 720px) {
        .main-nav {
          flex-direction: column;
          width: 100%;
          gap: 0.5rem;
        }
        .nav-categories-panel {
          position: static;
          width: 100%;
          box-shadow: none;
          margin-top: 0.75rem;
        }
        .nav-categories summary {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
