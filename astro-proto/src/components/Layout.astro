---
import { siteName, siteDescription } from "../config/site";
import { getTaxonomy } from "../data/taxonomy";

const taxonomy = await getTaxonomy();

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteName,
  description = siteDescription,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/en/">Home</a>
        <!-- You can add more nav links here -->
      </nav>
    </header>

    <slot />

    <footer>
      <div class="sitemap">
        <h3>Categories</h3>
        <ul>
          {taxonomy.map(hub => (
            <li>
              <a href={`/en/${hub.slug}`}>{hub.name}</a>
              <ul>
                {hub.clusters.map(cluster => (
                  <li>
                    <a href={`/en/${hub.slug}/${cluster.slug}`}>{cluster.name}</a>
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
      </div>
      <p>&copy; {new Date().getFullYear()} {siteName}. All rights reserved.</p>
    </footer>
  </body>
</html>