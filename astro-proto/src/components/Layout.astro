---
import { siteName, siteDescription } from "../config/site";
import { taxonomy } from "../data/taxonomy";

interface Props {
  title?: string;
  description?: string;
}

const { title, description }: Props = Astro.props;

const navHubs = taxonomy.map((hub) => ({
  name: hub.name,
  href: `/en/${hub.slug}`,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | ${siteName}` : siteName}</title>
    <meta
      name="description"
      content={description ?? siteDescription}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/vendor/tailwind.min.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light;
        --bg: #0f172a;
        --panel: #111827;
        --text: #e2e8f0;
        --muted: #94a3b8;
        --accent: #38bdf8;
        --accent-2: #a78bfa;
        --border: #1f2937;
        --radius: 14px;
        --max: 1200px;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Inter", sans-serif;
        background: radial-gradient(circle at 20% 20%, #0b1224, #070b15 45%),
          radial-gradient(circle at 80% 10%, #0a152e, transparent 45%),
          #0a0f1f;
        color: var(--text);
        min-height: 100vh;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      header {
        border-bottom: 1px solid var(--border);
        background: rgba(15, 23, 42, 0.75);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .shell {
        max-width: var(--max);
        margin: 0 auto;
        padding: 1rem 1.25rem;
      }
      nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
      }
      nav a.brand {
        font-weight: 700;
        letter-spacing: 0.02em;
        color: #fff;
      }
      nav .links {
        display: flex;
        gap: 0.75rem;
        font-size: 0.95rem;
        flex-wrap: wrap;
      }
      nav .links a {
        padding: 0.4rem 0.65rem;
        border-radius: 999px;
        border: 1px solid transparent;
        color: var(--muted);
        transition: 0.15s ease;
      }
      nav .links a:hover {
        color: #fff;
        border-color: var(--border);
        background: rgba(255, 255, 255, 0.04);
      }
      main {
        max-width: var(--max);
        margin: 0 auto;
        padding: 1.5rem 1.25rem 3rem;
      }
      footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        padding: 1.25rem 1.25rem 2rem;
        max-width: var(--max);
        margin: 0 auto;
        font-size: 0.95rem;
      }
      footer .footer-grid {
        display: grid;
        gap: 0.6rem;
      }
      footer .links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }
      footer .links a {
        color: #cbd5e1;
      }
      footer .links a:hover {
        color: #fff;
      }
      .hero {
        background: linear-gradient(135deg, rgba(56, 189, 248, 0.18), rgba(167, 139, 250, 0.15));
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        margin-bottom: 1rem;
      }
      /* Minimal utility fallbacks in case legacy Tailwind classes are missing */
      .w-4 { width: 1rem; }
      .h-4 { height: 1rem; }
      .w-5 { width: 1.25rem; }
      .h-5 { height: 1.25rem; }
      .w-6 { width: 1.5rem; }
      .h-6 { height: 1.5rem; }
      .w-8 { width: 2rem; }
      .h-8 { height: 2rem; }
      .w-10 { width: 2.5rem; }
      .h-10 { height: 2.5rem; }
      .text-gray-400 { color: #9ca3af; }
      .text-gray-700 { color: #374151; }
      .text-blue-600 { color: #2563eb; }
      .text-blue-600:hover { color: #1d4ed8; }
      /* Constrain any legacy SVG icons to avoid oversized rendering */
      .legacy svg {
        max-width: 24px;
        max-height: 24px;
      }
      .menu-toggle {
        display: none;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.04);
        color: #fff;
        border-radius: 10px;
        padding: 0.4rem 0.6rem;
        cursor: pointer;
      }
      @media (max-width: 720px) {
        nav {
          flex-wrap: wrap;
        }
        nav .links {
          width: 100%;
          display: none;
        }
        nav .links.open {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        }
        .menu-toggle {
          display: inline-flex;
          align-items: center;
          gap: 0.35rem;
          margin-left: auto;
        }
      }
    </style>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7MB5V1LZRN"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7MB5V1LZRN');
    </script>
    <slot name="head" />
  </head>
  <body>
    <header>
      <div class="shell">
        <nav>
          <a class="brand" href="/en">CalcDomain</a>
          <button class="menu-toggle" type="button" onclick="document.querySelector('nav .links').classList.toggle('open')">Menu</button>
          <div class="links" aria-label="Primary navigation">
            {navHubs.map((hub) => (
              <a href={hub.href}>{hub.name}</a>
            ))}
          </div>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-grid">
        <div>CalcDomain - Your trusted source for free online calculators. Accurate, fast, and reliable calculations for every need.</div>
        <div class="links">
          <a href="/support">Support</a>
          <a href="/about">About Us</a>
          <a href="/support">Contact</a>
          <a href="/privacy">Privacy Policy</a>
          <a href="/tos">Terms of Service</a>
          <a href="/sitemap">Site Map</a>
        </div>
        <div>© 2025 CalcDomain. All Rights Reserved.</div>
      </div>
    </footer>
  </body>
</html>
