---
interface Crumb {
  href: string;
  label: string;
}
const { items }: { items: Crumb[] } = Astro.props;
---
<nav aria-label="Breadcrumb" class="crumbs">
  <ol>
    {items.map((item, idx) => (
      <li>
        <a href={item.href} aria-current={idx === items.length - 1 ? "page" : "false"}>
          {item.label}
        </a>
        {idx < items.length - 1 && <span class="sep">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .crumbs {
    color: #9ca3af;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }
  .crumbs ol {
    list-style: none;
    display: flex;
    gap: 0.35rem;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }
  .crumbs a {
    color: #cbd5e1;
    text-decoration: none;
    padding: 0.15rem 0.25rem;
    border-radius: 6px;
  }
  .crumbs a[aria-current="page"] {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
  }
  .crumbs a:hover {
    color: #fff;
  }
  .sep {
    color: #6b7280;
  }
</style>
