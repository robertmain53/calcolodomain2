---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "mathematics";
const slug = "exponent-calculator";

const pageTitle = "Exponent calculator: compute powers in seconds";
const pageDescription =
  "Use this exponent calculator to quickly compute powers for any base and exponent, including negative exponents. See the result, scientific notation, and real-world examples.";

const calculatorConfig = {
  id: "exponent-calculator",
  mode: "custom-formula",
  ui: {
    layout: "cockpit",
    showAdvancedToggle: true,
    stickyResultBar: true,
    primaryActionLabel: "Calculate exponent",
    resetLabel: "Reset",
    shareLabel: "Share",
    verifiedBadge: "Verified by math formulas for exponentiation",
  },
  share: {
    enabled: true,
    paramMapping: {
      base: "base",
      exponent: "exponent",
    },
  },
  inputs: [
    {
      id: "base",
      label: "Base",
      type: "number",
      inputmode: "decimal",
      placeholder: "e.g. 2",
      defaultValue: 2,
      min: null,
      max: null,
      step: "any",
      helperText: "Enter the base number. It can be any real number.",
      required: true,
    },
    {
      id: "exponent",
      label: "Exponent",
      type: "number",
      inputmode: "decimal",
      placeholder: "e.g. 3",
      defaultValue: 3,
      min: null,
      max: null,
      step: 1,
      helperText:
        "Enter the exponent. It can be negative, zero, or positive. Integers are recommended.",
      required: true,
    },
  ],
  results: {
    primary: {
      id: "powerResult",
      label: "Result",
      format: "auto",
      helperText: "This is base raised to the power of exponent.",
      highlightOnChange: true,
    },
    secondary: [
      {
        id: "scientificNotation",
        label: "Scientific notation",
        format: "string",
        helperText: "Result written as a &#34;mantissa * 10^exponent&#34; style value.",
      },
      {
        id: "reciprocalInfo",
        label: "Negative exponent interpretation",
        format: "string",
        helperText:
          "For negative exponents, the result is the reciprocal of the corresponding positive power.",
      },
    ],
    tables: [
      {
        id: "powersTable",
        label: "Powers of the base (common exponents)",
        helperText: "Quick reference for a few nearby integer exponents.",
        columns: [
          { id: "exp", label: "Exponent" },
          { id: "value", label: "Base^exponent" },
        ],
        rowsConfig: {
          type: "exponent-neighborhood",
          countBelow: 2,
          countAbove: 3,
        },
      },
    ],
  },
  logic: {
    type: "exponent",
    expression: "result = base ^ exponent",
    notes:
      "Compute powerResult as base raised to exponent. For negative exponents, result = 1 / (base ^ abs(exponent)) when base is not zero.",
  },
};

const faqs = [
  {
    question: "What is an exponent in math?",
    answer:
      "An exponent tells you how many times to multiply a base by itself. For example, 2 raised to the power of 3 means 2 * 2 * 2, which equals 8.",
  },
  {
    question: "How do negative exponents work?",
    answer:
      "A negative exponent means you take the reciprocal of the base raised to the corresponding positive exponent. For example, 2 raised to the power of -3 equals 1 / (2^3) which is 1 / 8.",
  },
  {
    question: "Can the base or exponent be a decimal?",
    answer:
      "Yes, the base can be any real number and the exponent can be any real number in advanced math. This calculator focuses on real-number bases and works best with integer exponents for clear, exact results.",
  },
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/",
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/",
  },
  {
    position: 3,
    name: "Mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/mathematics/",
  },
  {
    position: 4,
    name: "Exponent calculator",
    item: "https://calcdomain.com/en/science-and-mathematics/mathematics/exponent-calculator",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Exponent calculator",
  url: "https://calcdomain.com/en/science-and-mathematics/mathematics/exponent-calculator",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description: pageDescription,
  featureList: [
    "Compute base raised to any exponent",
    "Support for negative exponents",
    "Scientific notation output",
    "Quick powers table for nearby exponents",
    "Shareable URL with prefilled inputs",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((crumb) => ({
    "@type": "ListItem",
    position: crumb.position,
    name: crumb.name,
    item: crumb.item,
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Exponent calculator</h1>
        <p class="hero-subtitle">
          Calculate powers for any base and exponent in seconds, with instant results and clear explanations.
        </p>
        <p class="hero-trust">
          Fast, mobile-friendly exponent calculator, aligned with standard exponentiation rules for 2025 curricula.
        </p>
      </div>
      <aside class="hero-meta">
        <p class="meta-item"><strong>Category:</strong> Mathematics</p>
        <p class="meta-item"><strong>Use cases:</strong> algebra, compound growth, scientific notation</p>
      </aside>
    </header>

    <section class="layout">
      <div class="layout-main">
        <section aria-label="Exponent calculator">
          <CalculatorIsland slug={slug} config={calculatorConfig} />
        </section>

        <section class="content-section" aria-labelledby="how-it-works">
          <h2 id="how-it-works">How the exponent calculator works</h2>
          <p>
            This tool computes the value of a base raised to an exponent. In plain terms, it answers the question:
            &#34;What is base to the power of exponent?&#34;
          </p>
          <p>
            The core formula is:
          </p>
          <pre>result = base ^ exponent</pre>
          <p>
            When the exponent is a positive integer, this means repeated multiplication:
          </p>
          <pre>base ^ 3 = base * base * base</pre>
          <p>
            Some important special cases:
          </p>
          <ul>
            <li>
              Zero exponent (base not zero): base ^ 0 = 1. Any nonzero number to the power of zero equals 1.
            </li>
            <li>
              Negative exponent (base not zero): base ^ (-n) = 1 / (base ^ n). A negative exponent means you take the reciprocal.
            </li>
            <li>
              Exponent 1: base ^ 1 = base. The number stays the same.
            </li>
          </ul>
          <p>
            The calculator also shows the result in scientific notation when the value is very large or very small. Scientific notation
            writes a number as mantissa * 10^k, where mantissa is between 1 and 10 and k is an integer.
          </p>
        </section>

        <section class="content-section" aria-labelledby="real-world-example">
          <h2 id="real-world-example">Real world example</h2>
          <p>
            Imagine a population of bacteria that doubles every hour. If you start with a base of 2 and want to know how many times larger
            the population will be after 5 hours, you can model this with an exponent:
          </p>
          <pre>base = 2
exponent = 5
result = 2 ^ 5 = 32</pre>
          <p>
            After 5 hours, the population is 32 times larger than it was at the start. You can use the same idea for compound interest,
            repeated growth, or scaling factors in physics and engineering.
          </p>
        </section>

        <section class="content-section" aria-labelledby="faq">
          <h2 id="faq">Frequently asked questions</h2>
          <dl class="faq-list">
            {faqs.map((faq) => (
              <div class="faq-item">
                <dt>{faq.question}</dt>
                <dd>{faq.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      </div>

      <aside class="layout-sidebar" aria-label="Related tools and ads">
        <section class="sidebar-section">
          <h2 class="sidebar-heading">About this tool</h2>
          <p>
            This exponent calculator is designed for students, teachers, and professionals who need quick, accurate power calculations
            without distractions.
          </p>
        </section>
        <section class="sidebar-section sidebar-ads">
          <h2 class="sidebar-heading">Sponsored</h2>
          <div class="ad-slot">Right rail ad slot</div>
        </section>
      </aside>
    </section>
  </main>

  <style>
    .page {
      padding: 1.5rem 1rem 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .hero-main h1 {
      font-size: 2rem;
      line-height: 1.2;
      margin: 0 0 0.5rem;
    }

    .hero-subtitle {
      margin: 0 0 0.5rem;
      color: #333333;
    }

    .hero-trust {
      margin: 0;
      font-size: 0.95rem;
      color: #555555;
    }

    .hero-meta {
      font-size: 0.9rem;
      color: #444444;
    }

    .meta-item {
      margin: 0;
    }

    .layout {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .layout-main {
      flex: 1 1 auto;
      min-width: 0;
    }

    .layout-sidebar {
      flex: 0 0 280px;
    }

    .content-section {
      margin-top: 2rem;
    }

    .content-section h2 {
      margin-bottom: 0.75rem;
    }

    pre {
      background: #f5f5f5;
      padding: 0.75rem;
      border-radius: 4px;
      font-size: 0.9rem;
      overflow-x: auto;
    }

    .faq-list {
      margin: 0;
      padding: 0;
    }

    .faq-item {
      margin-bottom: 1rem;
    }

    .faq-item dt {
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .faq-item dd {
      margin: 0;
    }

    .sidebar-section {
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .sidebar-heading {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .sidebar-ads .ad-slot {
      background: #f0f0f0;
      border-radius: 4px;
      min-height: 250px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #777777;
      font-size: 0.85rem;
    }

    @media (min-width: 900px) {
      .hero {
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-start;
      }

      .hero-main {
        flex: 1 1 auto;
        padding-right: 2rem;
      }

      .hero-meta {
        flex: 0 0 260px;
        border-left: 1px solid #e0e0e0;
        padding-left: 1.5rem;
      }

      .layout {
        flex-direction: row;
        align-items: flex-start;
      }

      .layout-main {
        flex: 1 1 auto;
        padding-right: 2rem;
      }

      .layout-sidebar {
        flex: 0 0 300px;
      }
    }
  </style>
</Layout>
