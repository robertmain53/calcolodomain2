---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "mathematics";
const slug = "exponent-calculator";

const pageTitle = "Exponent Calculator: compute powers in seconds";
const pageDescription =
  "Use this exponent calculator to quickly compute powers of any real number. Enter a base and an exponent to get instant results, including scientific notation and related values.";

const calculatorConfig = {
  id: "exponent-calculator",
  mode: "math-power",
  ui: {
    layout: "cockpit",
    showAdvancedToggle: true,
    stickyResultBar: true,
    primaryActionLabel: "Calculate exponent",
    resetLabel: "Reset",
    shareLabel: "Share",
    verifiedBadgeLabel: "Verified by math formulas",
  },
  inputs: [
    {
      id: "base",
      label: "Base",
      type: "number",
      inputMode: "decimal",
      placeholder: "e.g. 2",
      min: -1e9,
      max: 1e9,
      step: "any",
      defaultValue: 2,
      helperText: "The number that is multiplied by itself.",
    },
    {
      id: "exponent",
      label: "Exponent",
      type: "number",
      inputMode: "decimal",
      placeholder: "e.g. 3",
      min: -1e6,
      max: 1e6,
      step: "any",
      defaultValue: 3,
      helperText: "How many times the base is used as a factor. Can be negative or fractional.",
    },
  ],
  advancedInputs: [],
  outputs: [
    {
      id: "powerResult",
      label: "Result",
      type: "number",
      precision: 12,
      highlight: true,
      helperText: "Value of base raised to the given exponent.",
    },
    {
      id: "scientificResult",
      label: "Scientific notation",
      type: "text",
      helperText: "Result written as a * 10^n.",
    },
    {
      id: "reciprocalResult",
      label: "Reciprocal (if exponent is negative)",
      type: "text",
      helperText: "Shows 1 divided by base^abs(exponent) when exponent is negative.",
    },
    {
      id: "rootResult",
      label: "Equivalent root (if exponent is a fraction)",
      type: "text",
      helperText: "For exponent m/n, shows the n-th root of base^m when defined.",
    },
  ],
  logic: {
    type: "exponent",
    // Pseudo-code description for CalculatorIsland implementation:
    // 1. Read base and exponent as real numbers.
    // 2. Compute main result: power = base ** exponent.
    // 3. If power is finite, format:
    //    - powerResult: numeric value.
    //    - scientificResult: mantissa * 10^exponent10.
    // 4. If exponent < 0 and power is finite:
    //    - reciprocalResult = "1 / (" + base + "^" + absExponent + ") = " + power.
    // 5. If exponent is a rational number m/n and base^m is defined:
    //    - rootResult = "n-th root of (base^m) = " + value.
    // 6. Handle invalid cases (like negative base with non-integer exponent) with user-friendly messages.
  },
  share: {
    enabled: true,
    paramMapping: {
      base: "b",
      exponent: "e",
    },
  },
};

const faqs = [
  {
    question: "What is an exponent in math?",
    answer:
      "An exponent tells you how many times a base number is multiplied by itself. For example, 2^3 means 2 * 2 * 2, which equals 8.",
  },
  {
    question: "Can exponents be negative or fractional?",
    answer:
      "Yes. A negative exponent means you take the reciprocal, so 2^-3 equals 1 divided by 2^3, which is 1/8. A fractional exponent represents a root, so 9^(1/2) is the square root of 9, which is 3.",
  },
  {
    question: "How do I calculate exponents without a calculator?",
    answer:
      "For small integer exponents, you can multiply the base by itself repeatedly. For example, 3^4 is 3 * 3 * 3 * 3, which equals 81. For large, negative, or fractional exponents, a calculator is usually faster and less error-prone.",
  },
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/",
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/",
  },
  {
    position: 3,
    name: "Mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/mathematics/",
  },
  {
    position: 4,
    name: "Exponent calculator",
    item: "https://calcdomain.com/en/science-and-mathematics/mathematics/exponent-calculator",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Exponent calculator",
  url: "https://calcdomain.com/en/science-and-mathematics/mathematics/exponent-calculator",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description:
    "Interactive exponent calculator to compute powers of real numbers, including scientific notation and related values.",
  featureList: [
    "Instant exponent calculation",
    "Scientific notation output",
    "Support for negative and fractional exponents",
    "Mobile-friendly numeric inputs",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((b) => ({
    "@type": "ListItem",
    position: b.position,
    name: b.name,
    item: b.item,
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Exponent calculator</h1>
        <p class="hero-subtitle">
          Calculate powers of any real number in seconds, with instant results and clear explanations.
        </p>
        <p class="hero-meta">
          Fast, mobile-friendly exponent tool for students, engineers, and anyone working with powers.
        </p>
        <div class="hero-trust">
          <span class="trust-pill">Accurate math formulas</span>
          <span class="trust-pill">Optimized for 2025 curricula</span>
          <span class="trust-pill">No sign-up required</span>
        </div>
      </div>
      <aside class="hero-aside">
        <p class="hero-aside-title">What this tool does</p>
        <ul class="hero-aside-list">
          <li>Computes base^exponent for any real base and exponent.</li>
          <li>Shows the result in standard and scientific notation.</li>
          <li>Explains negative and fractional exponents with examples.</li>
        </ul>
      </aside>
    </header>

    <section class="calculator-section" aria-label="Exponent calculator">
      <CalculatorIsland slug={slug} config={calculatorConfig} />
    </section>

    <section class="content-grid">
      <article class="content-main">
        <h2>How to use the exponent calculator</h2>
        <ol>
          <li>Enter the base, which is the number being multiplied by itself.</li>
          <li>Enter the exponent, which tells you how many times the base is used as a factor.</li>
          <li>Review the main result and, if needed, open the advanced section for more details.</li>
        </ol>

        <h2>Exponent formula explained</h2>
        <p>
          An exponent tells you how many times a base number is multiplied by itself. The general
          form is:
        </p>
        <pre>result = base^exponent</pre>
        <p>
          For example, if the base is 2 and the exponent is 5, you compute:
        </p>
        <pre>2^5 = 2 * 2 * 2 * 2 * 2 = 32</pre>
        <p>
          When the exponent is 1, the result is just the base. When the exponent is 0 and the base
          is not zero, the result is 1.
        </p>

        <h3>Negative exponents</h3>
        <p>
          A negative exponent means you take the reciprocal of the corresponding positive power.
          The rule is:
        </p>
        <pre>base^-n = 1 / (base^n)</pre>
        <p>
          For example:
        </p>
        <pre>2^-3 = 1 / (2^3) = 1 / 8 = 0.125</pre>

        <h3>Fractional exponents and roots</h3>
        <p>
          A fractional exponent represents a root. If the exponent is 1/2, you are taking the
          square root. If the exponent is 1/3, you are taking the cube root. In general:
        </p>
        <pre>base^(1/n) = n-th root of base</pre>
        <p>
          and
        </p>
        <pre>base^(m/n) = n-th root of (base^m)</pre>
        <p>
          For example:
        </p>
        <pre>9^(1/2) = square root of 9 = 3</pre>
        <pre>27^(2/3) = cube root of (27^2) = cube root of 729 = 9</pre>

        <h3>Scientific notation</h3>
        <p>
          Very large or very small results are easier to read in scientific notation. In this
          format, a number is written as:
        </p>
        <pre>result = a * 10^n</pre>
        <p>
          where a is between 1 and 10 in absolute value, and n is an integer. For example:
        </p>
        <pre>2^20 = 1.048576 * 10^6</pre>

        <h2>Real world example</h2>
        <p>
          Imagine you are working with digital storage and want to know how many possible values a
          16-bit number can represent. Each bit has 2 possible states, so the total number of
          combinations is:
        </p>
        <pre>2^16 = 65,536</pre>
        <p>
          Enter base 2 and exponent 16 into the calculator, and it will instantly show 65,536 as
          the result, along with the scientific notation 6.5536 * 10^4.
        </p>

        <h2>Frequently asked questions</h2>
        {faqs.map((item) => (
          <section class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </section>
        ))}
      </article>

      <aside class="content-sidebar" aria-label="Additional information and ads">
        <div class="sidebar-card">
          <h2>Tips for working with exponents</h2>
          <ul>
            <li>Use parentheses to avoid ambiguity when combining exponents with other operations.</li>
            <li>Remember that any nonzero number to the power of 0 equals 1.</li>
            <li>
              When multiplying powers with the same base, you can add the exponents: base^a * base^b
              = base^(a + b).
            </li>
            <li>
              When raising a power to another power, you can multiply the exponents: (base^a)^b =
              base^(a * b).
            </li>
          </ul>
        </div>

        <div class="sidebar-card sidebar-ad-slot" aria-label="Advertisement">
          <p>Ad space</p>
        </div>
      </aside>
    </section>
  </main>

  <style>
    .page {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding: 1.5rem 1rem 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 2fr);
      gap: 1.5rem;
      align-items: flex-start;
    }

    .hero-main h1 {
      font-size: 2rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .hero-meta {
      font-size: 0.9rem;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .hero-trust {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .trust-pill {
      font-size: 0.8rem;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      background: #eef3ff;
      color: #1a3fa0;
      border: 1px solid #d0ddff;
    }

    .hero-aside {
      border-left: 3px solid #e0e4f2;
      padding-left: 1rem;
      font-size: 0.9rem;
    }

    .hero-aside-title {
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .hero-aside-list {
      padding-left: 1.1rem;
      margin: 0;
    }

    .calculator-section {
      position: relative;
      z-index: 1;
    }

    .content-grid {
      display: grid;
      grid-template-columns: minmax(0, 3fr);
      gap: 2rem;
      align-items: flex-start;
    }

    .content-main {
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .content-main pre {
      background: #f7f7fb;
      border-radius: 4px;
      padding: 0.5rem 0.75rem;
      font-size: 0.9rem;
      overflow-x: auto;
    }

    .content-sidebar {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .sidebar-card {
      border: 1px solid #e1e4ec;
      border-radius: 6px;
      padding: 0.75rem 0.9rem;
      background: #fafbff;
      font-size: 0.9rem;
    }

    .sidebar-ad-slot {
      min-height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #777;
      background: #f3f4f8;
    }

    .faq-item + .faq-item {
      margin-top: 1rem;
    }

    @media (min-width: 768px) {
      .page {
        padding: 2rem 1.5rem 3.5rem;
      }

      .hero {
        grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      }

      .hero-main h1 {
        font-size: 2.3rem;
      }

      .content-grid {
        grid-template-columns: minmax(0, 3fr) minmax(260px, 1.4fr);
      }
    }

    @media (min-width: 1024px) {
      .page {
        padding-top: 2.5rem;
      }

      .hero-main h1 {
        font-size: 2.5rem;
      }
    }
  </style>
</Layout>
