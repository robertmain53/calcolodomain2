---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "typography-converter";

const pageTitle = "Typography Unit Converter (px, pt, em, rem, percent)";
const pageDescription =
  "Convert typography units between pixels, points, em, rem, and percent in seconds. Perfect for web designers and frontend developers who need consistent, responsive font sizing.";

const calculatorConfig = {
  id: "typography-converter",
  mode: "typography-units",
  ui: {
    layout: "cockpit",
    basicLabel: "Basic units",
    advancedLabel: "Advanced options",
    showAdvancedToggle: true,
    primaryActionLabel: "Calculate",
    resetLabel: "Reset",
    shareLabel: "Share",
    resultTitle: "Converted typography units",
    stickyResultOnMobile: true,
  },
  inputs: [
    {
      id: "baseFontPx",
      label: "Base font size (px)",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: 0.1,
      defaultValue: 16,
      helpText: "Common browser default is 16 px. Use your root font size for accurate rem and percent conversions.",
      group: "basic",
    },
    {
      id: "valuePx",
      label: "Font size in pixels (px)",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: 0.1,
      defaultValue: 16,
      helpText: "Enter the font size you want to convert from, in pixels.",
      group: "basic",
    },
    {
      id: "rootFontPx",
      label: "Root font size for rem and percent (px)",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: 0.1,
      defaultValue: 16,
      helpText: "Usually the html font size. If you use a custom root size, set it here.",
      group: "advanced",
    },
  ],
  results: [
    {
      id: "resultPx",
      label: "Pixels (px)",
      unit: "px",
      format: "decimal",
      decimals: 3,
      highlight: false,
    },
    {
      id: "resultPt",
      label: "Points (pt)",
      unit: "pt",
      format: "decimal",
      decimals: 3,
      highlight: false,
    },
    {
      id: "resultEm",
      label: "em",
      unit: "em",
      format: "decimal",
      decimals: 4,
      highlight: true,
    },
    {
      id: "resultRem",
      label: "rem",
      unit: "rem",
      format: "decimal",
      decimals: 4,
      highlight: true,
    },
    {
      id: "resultPercent",
      label: "Percent (%)",
      unit: "%",
      format: "decimal",
      decimals: 1,
      highlight: false,
      group: "advanced",
    },
  ],
  logic: {
    type: "custom",
    // All formulas assume CSS on-screen usage.
    // 1 pt = 1.333333 px (which is 96 px / 72 pt).
    // em is relative to the current element font size.
    // rem and percent are relative to the root font size.
    formulas: {
      resultPx: "valuePx",
      resultPt: "valuePx * 72 / 96",
      resultEm: "valuePx / baseFontPx",
      resultRem: "valuePx / rootFontPx",
      resultPercent: "valuePx / rootFontPx * 100",
    },
    constraints: [
      {
        fieldId: "valuePx",
        type: "min",
        value: 0,
        message: "Font size in pixels cannot be negative.",
      },
      {
        fieldId: "baseFontPx",
        type: "min",
        value: 0,
        message: "Base font size cannot be negative.",
      },
      {
        fieldId: "rootFontPx",
        type: "min",
        value: 0,
        message: "Root font size cannot be negative.",
      },
    ],
  },
  sharing: {
    enabled: true,
    queryParams: ["baseFontPx", "valuePx", "rootFontPx"],
  },
  meta: {
    verifiedBy: "Front-end engineering team",
    lastUpdated: "2025-01-01",
  },
};

const faqs = [
  {
    question: "How do you convert px to em for font size?",
    answer:
      "To convert pixels to em, divide the pixel value by the current element font size in pixels. For example, if the base font size is 16 px and you want 24 px text, em = 24 / 16 = 1.5 em.",
  },
  {
    question: "What is the difference between em and rem units?",
    answer:
      "em is relative to the font size of the current element, while rem is relative to the root html font size. rem is more predictable for global typography scales, while em is useful for local, nested scaling.",
  },
  {
    question: "How many pixels are in 1 point for web typography?",
    answer:
      "On the web, 1 point is usually treated as 1.333333 pixels, based on 96 px per inch and 72 points per inch. So px = pt * 96 / 72 and pt = px * 72 / 96.",
  },
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/",
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/",
  },
  {
    position: 3,
    name: "Unit conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/",
  },
  {
    position: 4,
    name: "Typography unit converter",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/typography-converter/",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Typography Unit Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/typography-converter/",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description:
    "Interactive typography unit converter that converts between pixels, points, em, rem, and percent for web design and frontend development.",
  featureList: [
    "Convert pixels to points, em, rem, and percent",
    "Custom base and root font size support",
    "Instant recalculation on input change",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((crumb) => ({
    "@type": "ListItem",
    position: crumb.position,
    name: crumb.name,
    item: crumb.item,
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Typography Unit Converter (px, pt, em, rem, percent)</h1>
        <p class="hero-subtitle">
          Convert font sizes between pixels, points, em, rem, and percent in seconds for precise, responsive typography.
        </p>
        <ul class="hero-trust">
          <li>Optimized for modern CSS and responsive design</li>
          <li>Uses standard 96 dpi screen conversion for points</li>
          <li>Built for designers, developers, and UX teams</li>
        </ul>
      </div>
      <aside class="hero-aside">
        <div class="verification">
          <span class="verification-label">Verified by</span>
          <span class="verification-value">Senior frontend engineers</span>
        </div>
        <div class="meta">
          <span class="meta-label">Last updated</span>
          <span class="meta-value">2025</span>
        </div>
      </aside>
    </header>

    <section class="calculator-section">
      <div class="calculator-main">
        <CalculatorIsland slug={slug} config={calculatorConfig} />
      </div>
      <aside class="calculator-sidebar">
        <div class="ad-slot">
          <p>Sponsored content</p>
        </div>
        <div class="tip-box">
          <h2>Pro tip</h2>
          <p>
            Keep your root font size consistent across the site and use rem for global typography scales. Use em for
            local components that need to scale with their container.
          </p>
        </div>
      </aside>
    </section>

    <section class="content-section">
      <h2>How the typography unit converter works</h2>
      <p>
        This typography unit converter helps you translate a font size in pixels into points, em, rem, and percent,
        using standard web assumptions. It is designed for CSS and screen usage, not for print layout engines.
      </p>

      <h3>Conversion formulas</h3>
      <p>These are the formulas used by the calculator, written in plain text math.</p>
      <ul>
        <li>
          <strong>Pixels to points</strong>
          <pre>points = pixels * 72 / 96</pre>
        </li>
        <li>
          <strong>Pixels to em</strong>
          <pre>em = pixels / baseFontPx</pre>
        </li>
        <li>
          <strong>Pixels to rem</strong>
          <pre>rem = pixels / rootFontPx</pre>
        </li>
        <li>
          <strong>Pixels to percent</strong>
          <pre>percent = pixels / rootFontPx * 100</pre>
        </li>
      </ul>
      <p>
        The factor 72 and 96 come from the common web assumption that there are 96 pixels per inch and 72 points per
        inch. That means 1 point is 96 / 72 pixels, which is about 1.333333 pixels.
      </p>

      <h3>Choosing base and root font sizes</h3>
      <p>
        The base font size is the font size of the element you are styling. The root font size is usually the html font
        size. Many browsers default to 16 px for the root, but design systems often change this to values like 15 px or
        18 px.
      </p>
      <p>
        When you convert to em, the calculator divides by the base font size. When you convert to rem or percent, it
        divides by the root font size. This matches how CSS computes these units at runtime.
      </p>
    </section>

    <section class="content-section">
      <h2>Real world example</h2>
      <p>
        Imagine you are designing a heading that should be 32 px on desktop, and your design system uses a root font
        size of 16 px.
      </p>
      <ul>
        <li>Set base font size to 16 px.</li>
        <li>Set root font size to 16 px.</li>
        <li>Enter 32 px as the font size to convert.</li>
      </ul>
      <p>The converter will show:</p>
      <ul>
        <li>em = 32 / 16 = 2 em</li>
        <li>rem = 32 / 16 = 2 rem</li>
        <li>percent = 32 / 16 * 100 = 200 percent</li>
        <li>points = 32 * 72 / 96 = 24 pt</li>
      </ul>
      <p>
        In your CSS, you could then write the heading size as 2 rem, which will scale automatically if you ever change
        the root font size for accessibility or branding reasons.
      </p>
    </section>

    <section class="content-section">
      <h2>Frequently asked questions</h2>
      {faqs.map((item) => (
        <article class="faq-item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))}
    </section>
  </main>

  <style>
    .page {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      padding: 1.5rem 1rem 3rem;
      max-width: 1120px;
      margin: 0 auto;
    }

    .hero {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      border-bottom: 1px solid #e2e4ea;
      padding-bottom: 1.5rem;
    }

    .hero-main h1 {
      font-size: 1.9rem;
      line-height: 1.2;
      margin: 0 0 0.5rem;
    }

    .hero-subtitle {
      margin: 0 0 0.75rem;
      color: #4a4f5c;
    }

    .hero-trust {
      margin: 0;
      padding-left: 1.2rem;
      color: #4a4f5c;
      font-size: 0.95rem;
    }

    .hero-aside {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.9rem;
      color: #4a4f5c;
    }

    .verification,
    .meta {
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      background: #f5f7fb;
    }

    .verification-label,
    .meta-label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.15rem;
    }

    .calculator-section {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
      align-items: flex-start;
    }

    .calculator-sidebar {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .ad-slot {
      min-height: 120px;
      border-radius: 0.5rem;
      border: 1px dashed #c2c7d6;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      color: #7a7f8c;
    }

    .tip-box {
      padding: 1rem;
      border-radius: 0.5rem;
      background: #f9fafc;
      border: 1px solid #e2e4ea;
    }

    .tip-box h2 {
      margin: 0 0 0.5rem;
      font-size: 1rem;
    }

    .content-section {
      border-top: 1px solid #e2e4ea;
      padding-top: 1.5rem;
    }

    .content-section h2 {
      margin-top: 0;
      margin-bottom: 0.75rem;
      font-size: 1.4rem;
    }

    .content-section h3 {
      margin-top: 1.25rem;
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .content-section p {
      margin: 0 0 0.75rem;
      color: #3c404a;
    }

    .content-section ul {
      margin: 0 0 0.75rem 1.2rem;
      color: #3c404a;
    }

    pre {
      margin: 0.25rem 0 0.5rem;
      padding: 0.4rem 0.6rem;
      background: #f5f7fb;
      border-radius: 0.35rem;
      font-size: 0.9rem;
      overflow-x: auto;
    }

    .faq-item + .faq-item {
      margin-top: 1rem;
    }

    @media (min-width: 768px) {
      .page {
        padding: 2rem 1.5rem 3rem;
      }

      .hero {
        flex-direction: row;
        justify-content: space-between;
      }

      .hero-main {
        max-width: 70%;
      }

      .hero-main h1 {
        font-size: 2.1rem;
      }

      .calculator-section {
        grid-template-columns: minmax(0, 2.2fr) minmax(260px, 0.9fr);
      }
    }

    @media (min-width: 1024px) {
      .page {
        padding: 2.5rem 0 3.5rem;
      }

      .hero-main h1 {
        font-size: 2.3rem;
      }
    }
  </style>
</Layout>
