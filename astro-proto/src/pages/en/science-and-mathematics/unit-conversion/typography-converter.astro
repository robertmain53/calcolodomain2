---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "typography-converter";

const pageTitle = "Typography Unit Converter: px, pt, em, rem and percent";
const pageDescription =
  "Convert typography units between px, pt, em, rem and percent in seconds. Perfect for web designers and frontend developers who need consistent, responsive type scales.";

const calculatorConfig = {
  id: "typography-converter",
  mode: "typography-units",
  primaryInputLabel: "Font size value",
  primaryInputUnitLabel: "From unit",
  primaryOutputUnitLabel: "To unit",
  units: [
    {
      value: "px",
      label: "Pixels (px)",
      type: "absolute"
    },
    {
      value: "pt",
      label: "Points (pt)",
      type: "absolute"
    },
    {
      value: "em",
      label: "Em (relative to element font size)",
      type: "relative"
    },
    {
      value: "rem",
      label: "Rem (relative to root font size)",
      type: "relative"
    },
    {
      value: "percent",
      label: "Percent (%)",
      type: "relative"
    }
  ],
  defaults: {
    fromUnit: "px",
    toUnit: "rem",
    value: 16,
    baseFontSize: 16,
    rootFontSize: 16
  },
  advancedFields: [
    {
      name: "baseFontSize",
      label: "Base font size for em (px)",
      min: 1,
      max: 200,
      step: 0.1,
      inputMode: "decimal",
      tooltip:
        "Base font size in pixels used to interpret em values. For body text this is often 16 px."
    },
    {
      name: "rootFontSize",
      label: "Root font size for rem (px)",
      min: 1,
      max: 200,
      step: 0.1,
      inputMode: "decimal",
      tooltip:
        "Root html font size in pixels used to interpret rem values. Browsers commonly default to 16 px."
    }
  ],
  behavior: {
    autoCalculate: true,
    showCalculateButton: true,
    showResetButton: true,
    showShareButton: true,
    layout: "cockpit",
    stickyResultBar: true
  },
  formula: {
    description:
      "All units are converted through pixels as the internal base unit. Points use 1 pt = 1.333333 px (96 dpi). Em and rem are relative to base and root font sizes.",
    steps: [
      "1. Convert the input value to pixels based on the selected from unit.",
      "2. Convert the pixel value to the selected to unit.",
      "3. Show all equivalent values in px, pt, em, rem and percent."
    ]
  },
  // The CalculatorIsland implementation is expected to use these rules:
  // px to pt: pt = px * 0.75
  // pt to px: px = pt * 1.333333
  // px to em: em = px / baseFontSize
  // em to px: px = em * baseFontSize
  // px to rem: rem = px / rootFontSize
  // rem to px: px = rem * rootFontSize
  // px to percent: percent = (px / baseFontSize) * 100
  // percent to px: px = (percent / 100) * baseFontSize
  validation: {
    minValue: 0,
    maxValue: 1000,
    valueHelp:
      "Font sizes should be zero or positive. Negative values are not valid for typography units."
  },
  uiTexts: {
    mainLabel: "Typography unit converter",
    valuePlaceholder: "Enter font size",
    fromLabel: "From unit",
    toLabel: "To unit",
    resultLabel: "Converted size",
    advancedToggleLabel: "Advanced settings",
    resetLabel: "Reset",
    calculateLabel: "Calculate",
    shareLabel: "Share",
    copiedLabel: "Link copied",
    errorOutOfRange:
      "Font size is outside the supported range. Try a value between 0 and 1000."
  }
};

const faqs = [
  {
    question: "How do you convert px to rem for typography?",
    answer:
      "To convert px to rem, divide the pixel value by the root font size in pixels. For example, if the root html font size is 16 px, then 24 px is 24 / 16 = 1.5 rem."
  },
  {
    question: "What is the difference between em and rem units?",
    answer:
      "Em is relative to the font size of the current element, while rem is relative to the root html font size. This means rem values stay consistent across the page, while em values can compound when nested."
  },
  {
    question: "When should I use percent instead of px for font size?",
    answer:
      "Percent font sizes are relative to the parent element font size. They are useful when you want text to scale with a container. For example, 125 percent means 1.25 times the parent font size."
  }
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/"
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    position: 3,
    name: "Unit conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    position: 4,
    name: "Typography unit converter",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/typography-converter/"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Typography Unit Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/typography-converter/",
  applicationCategory: "DesignApplication",
  operatingSystem: "Any",
  description:
    "Interactive typography unit converter that transforms font sizes between px, pt, em, rem and percent for web design and frontend development.",
  featureList: [
    "Convert between px, pt, em, rem and percent",
    "Advanced base font size and root font size controls",
    "Instant autocalculation on input change",
    "Shareable URL with prefilled inputs"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((crumb) => ({
    "@type": "ListItem",
    position: crumb.position,
    name: crumb.name,
    item: crumb.item
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Typography Unit Converter (px, pt, em, rem, percent)</h1>
        <p class="hero-subtitle">
          Convert font sizes between px, pt, em, rem and percent in seconds, with clear explanations tailored for web designers and frontend developers.
        </p>
        <ul class="hero-trust">
          <li>Optimized for modern CSS and responsive design</li>
          <li>Uses 96 dpi for point conversions</li>
          <li>Updated for 2025 frontend best practices</li>
        </ul>
      </div>
      <aside class="hero-aside">
        <div class="verify-badge">
          <span class="verify-label">Reviewed by</span>
          <span class="verify-name">Senior Frontend Engineer</span>
        </div>
        <div class="hero-meta">
          <span>Category: Typography and unit conversion</span>
          <span>Difficulty: Beginner friendly</span>
        </div>
      </aside>
    </header>

    <section class="layout">
      <div class="layout-main">
        <section aria-labelledby="calculator-heading" class="calculator-section">
          <div class="calculator-header">
            <h2 id="calculator-heading">Interactive typography unit converter</h2>
            <p>
              Enter a font size, pick the units you want to convert from and to, and see all equivalent values across px, pt, em, rem and percent. Advanced settings let you control the base and root font sizes used for relative units.
            </p>
          </div>

          <CalculatorIsland slug={slug} config={calculatorConfig} />

          <section class="tips" aria-label="Typography tips">
            <h3>Quick tips for accurate typography conversions</h3>
            <ul>
              <li>
                For most browsers, the default root font size is 16 px. That means 1 rem is usually 16 px unless you override it on the html element.
              </li>
              <li>
                Em values are relative to the current element font size, so nested elements can compound sizes. Rem values stay consistent because they always reference the root.
              </li>
              <li>
                Points are a print unit. On the web, 1 pt is treated as 1.333333 px based on 96 dpi, so 12 pt is 16 px.
              </li>
            </ul>
          </section>
        </section>

        <section class="theory" aria-labelledby="theory-heading">
          <h2 id="theory-heading">How the typography unit converter works</h2>
          <p>
            This converter uses pixels as the internal base unit. Every input is first converted to pixels, then from pixels to the target unit. This keeps the logic simple and consistent across all unit pairs.
          </p>

          <h3>Conversion relationships between units</h3>
          <p>The following relationships are used for the calculations:</p>
          <pre>
1 pt = 1.333333 px  (based on 96 dpi)
pt = px * 0.75
px = pt * 1.333333

em = px / baseFontSize
px = em * baseFontSize

rem = px / rootFontSize
px = rem * rootFontSize

percent = (px / baseFontSize) * 100
px = (percent / 100) * baseFontSize
          </pre>

          <p>
            The baseFontSize is the font size of the element that em and percent are relative to. The rootFontSize is the font size of the html element that rem is relative to. In many designs both are 16 px, but this converter lets you change them to match your CSS.
          </p>

          <h3>Step by step example</h3>
          <p>
            Suppose you want to convert 24 px to rem and em, with a base font size of 16 px and a root font size of 18 px:
          </p>
          <ol>
            <li>Convert 24 px to em: em = 24 / 16 = 1.5 em.</li>
            <li>Convert 24 px to rem: rem = 24 / 18 = 1.333333 rem.</li>
            <li>Convert 24 px to percent: percent = (24 / 16) * 100 = 150 percent.</li>
          </ol>
          <p>
            The converter performs these steps instantly and also shows the equivalent value in points using the 1 pt = 1.333333 px relationship.
          </p>
        </section>

        <section class="examples" aria-labelledby="examples-heading">
          <h2 id="examples-heading">Real world example: designing a responsive heading</h2>
          <p>
            Imagine you are designing a heading that should be 32 px on desktop, but your design system uses rem units and a root font size of 18 px.
          </p>
          <ol>
            <li>Set the value to 32 and the from unit to px.</li>
            <li>Set the to unit to rem and the root font size to 18 px.</li>
            <li>The converter shows rem = 32 / 18 = 1.777777 rem.</li>
          </ol>
          <p>
            In your CSS you can then write:
          </p>
          <pre>
h1 &#123;
  font-size: 1.78rem;
&#125;
          </pre>
          <p>
            If you later change the root font size for accessibility, the heading will scale automatically, while the rem value in your stylesheet stays the same.
          </p>
        </section>

        <section class="faq" aria-labelledby="faq-heading">
          <h2 id="faq-heading">Frequently asked questions</h2>
          <dl>
            {faqs.map((item) => (
              <div class="faq-item">
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      </div>

      <aside class="layout-sidebar" aria-label="Additional resources and ads">
        <div class="sidebar-block">
          <h2>Designer resources</h2>
          <ul>
            <li>Responsive type scales and modular rhythm</li>
            <li>Accessibility guidelines for readable font sizes</li>
            <li>CSS clamp patterns for fluid typography</li>
          </ul>
        </div>
        <div class="sidebar-ad-slot">
          <p>Ad space: high-visibility right rail placement.</p>
        </div>
      </aside>
    </section>
  </main>

  <style>
    .page {
      padding: 1.5rem 1rem 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .hero-main h1 {
      font-size: 1.9rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      margin: 0.25rem 0 0.75rem;
      color: #333333;
    }

    .hero-trust {
      list-style: disc;
      padding-left: 1.25rem;
      margin: 0;
      color: #444444;
      font-size: 0.95rem;
    }

    .hero-aside {
      border-left: 4px solid #2563eb;
      padding-left: 0.75rem;
      font-size: 0.9rem;
      color: #444444;
    }

    .verify-badge {
      display: inline-flex;
      flex-direction: column;
      padding: 0.4rem 0.6rem;
      border-radius: 0.4rem;
      background: #eff6ff;
      margin-bottom: 0.4rem;
    }

    .verify-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #1d4ed8;
    }

    .verify-name {
      font-weight: 600;
      color: #1e293b;
    }

    .hero-meta {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }

    .layout {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .layout-main {
      flex: 1 1 auto;
      min-width: 0;
    }

    .layout-sidebar {
      flex: 0 0 260px;
    }

    .calculator-section {
      margin-bottom: 2rem;
    }

    .calculator-header h2 {
      font-size: 1.4rem;
      margin-bottom: 0.25rem;
    }

    .calculator-header p {
      margin: 0 0 1rem;
      color: #374151;
    }

    .tips,
    .theory,
    .examples,
    .faq {
      margin-top: 2rem;
    }

    .tips ul {
      padding-left: 1.25rem;
    }

    .tips li {
      margin-bottom: 0.4rem;
    }

    .theory pre,
    .examples pre {
      background: #0f172a;
      color: #e5e7eb;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-size: 0.85rem;
      overflow-x: auto;
    }

    .examples ol,
    .theory ol {
      padding-left: 1.25rem;
    }

    .faq-item {
      margin-bottom: 1rem;
    }

    .faq-item dt {
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .faq-item dd {
      margin: 0;
      color: #374151;
    }

    .layout-sidebar .sidebar-block {
      padding: 1rem;
      border-radius: 0.5rem;
      background: #f9fafb;
      margin-bottom: 1rem;
    }

    .sidebar-ad-slot {
      min-height: 200px;
      border-radius: 0.5rem;
      border: 1px dashed #cbd5f5;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      color: #6b7280;
      padding: 1rem;
    }

    @media (min-width: 900px) {
      .hero {
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-start;
      }

      .hero-main {
        flex: 1 1 auto;
        padding-right: 1.5rem;
      }

      .hero-aside {
        flex: 0 0 260px;
      }

      .layout {
        flex-direction: row;
        align-items: flex-start;
      }
    }
  </style>
</Layout>
