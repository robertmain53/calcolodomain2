---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "btu-to-kwh";

const pageTitle = "BTU to kWh Converter";
const pageDescription =
  "Instantly convert BTU to kWh and kWh to BTU with this precise energy unit converter. Understand the BTU to kWh formula, see real-world examples, and compare energy usage.";

const calculatorConfig = {
  mode: "unit-conversion",
  primaryUnitFrom: "BTU",
  primaryUnitTo: "kWh",
  allowSwapUnits: true,
  inputs: [
    {
      id: "energyValue",
      label: "Energy amount",
      type: "number",
      inputMode: "decimal",
      placeholder: "Enter value",
      min: 0,
      step: "any",
      defaultValue: 1000
    },
    {
      id: "direction",
      label: "Conversion direction",
      type: "select",
      options: [
        { value: "btu-to-kwh", label: "BTU to kWh" },
        { value: "kwh-to-btu", label: "kWh to BTU" }
      ],
      defaultValue: "btu-to-kwh",
      helpText: "Choose whether you want to convert from BTU to kWh or from kWh to BTU."
    },
    {
      id: "decimals",
      label: "Decimal places",
      type: "number",
      inputMode: "decimal",
      min: 0,
      max: 6,
      step: 1,
      defaultValue: 4,
      helpText: "Control the rounding of the result. Common choices are 2 to 4 decimal places.",
      advanced: true
    }
  ],
  results: [
    {
      id: "convertedValue",
      label: "Converted value",
      unitDynamic: true,
      highlightOnChange: true
    }
  ],
  formula: {
    type: "piecewise",
    description:
      "For BTU to kWh: kWh = BTU / 3412.142. For kWh to BTU: BTU = kWh * 3412.142.",
    constants: {
      BTU_PER_KWH: 3412.142
    }
  },
  behavior: {
    autoCalculate: true,
    showCalculateButton: false,
    allowReset: true,
    allowShare: true,
    layout: "cockpit",
    stickyResultOnMobile: true
  },
  ux: {
    verifiedBy: "Energy engineering team",
    lastReviewed: "2025-01-01",
    showVerifiedBadge: true
  }
};

const faqs = [
  {
    question: "How do you convert BTU to kWh?",
    answer:
      "To convert BTU to kWh, divide the energy in BTU by 3412.142. For example, 10,000 BTU is approximately 2.93 kWh because 10,000 / 3412.142 is about 2.93."
  },
  {
    question: "Why convert BTU to kWh?",
    answer:
      "BTU is common in heating and cooling, while kWh is used on electricity bills. Converting BTU to kWh helps you compare the energy use of air conditioners, heaters, and other appliances with the cost shown on your electricity bill."
  },
  {
    question: "How many BTU are in 1 kWh?",
    answer:
      "One kilowatt hour is approximately 3412.142 BTU. This means that if an appliance uses 1 kWh of electricity, it delivers about 3412 BTU of heat energy."
  }
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/"
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    position: 3,
    name: "Unit conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    position: 4,
    name: "BTU to kWh Converter",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/btu-to-kwh"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "BTU to kWh Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/btu-to-kwh",
  applicationCategory: "ScienceApplication",
  operatingSystem: "Any",
  description:
    "Interactive BTU to kWh and kWh to BTU converter with instant results, precision control, and clear explanation of the energy conversion formula.",
  featureList: [
    "BTU to kWh conversion",
    "kWh to BTU conversion",
    "Adjustable decimal precision",
    "Mobile friendly numeric keypad",
    "Shareable calculator state"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((b) => ({
    "@type": "ListItem",
    position: b.position,
    name: b.name,
    item: b.item
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>BTU to kWh Converter</h1>
        <p class="hero-subtitle">
          Convert BTU to kWh and kWh to BTU in seconds, with precise rounding and clear explanations of every step.
        </p>
        <div class="hero-trust">
          <span class="badge">Verified energy formula</span>
          <span class="badge">Updated for 2025 efficiency standards</span>
        </div>
      </div>
      <aside class="hero-meta">
        <p><strong>Use this when:</strong> you want to compare heating or cooling output in BTU with electricity use in kWh on your energy bill.</p>
      </aside>
    </header>

    <section class="calculator-section" aria-label="BTU to kWh calculator">
      <div class="calculator-layout">
        <div class="calculator-main">
          <CalculatorIsland slug={slug} config={calculatorConfig} />
        </div>
        <aside class="calculator-aside">
          <div class="tip-card">
            <h2>Quick tips</h2>
            <ul>
              <li>Room air conditioners are often rated in BTU per hour, while your electricity bill is in kWh.</li>
              <li>Use BTU to kWh to estimate how much an appliance will cost to run.</li>
              <li>For most comparisons, 2 to 3 decimal places are enough precision.</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section class="content-section" id="formula">
      <h2>BTU to kWh formula explained</h2>
      <p>
        Both BTU and kilowatt hour are units of energy. BTU is common in heating and cooling, while kWh is used for
        electricity billing. The conversion is based on the fixed relationship between these units.
      </p>
      <p>The core relationships are:</p>
      <pre>1 kWh = 3412.142 BTU</pre>
      <p>From this, we can write two practical formulas:</p>
      <pre>kWh = BTU / 3412.142</pre>
      <pre>BTU = kWh * 3412.142</pre>
      <p>
        When you enter a value in BTU and choose the BTU to kWh direction, the calculator divides your BTU value by
        3412.142 to give the equivalent energy in kilowatt hours. When you choose kWh to BTU, it multiplies your kWh
        value by 3412.142 to give the equivalent in BTU.
      </p>
      <p>
        The decimal places setting in the advanced options simply rounds the final result to the number of digits you
        prefer, without changing the underlying conversion factor.
      </p>
    </section>

    <section class="content-section" id="example">
      <h2>Real world example: air conditioner energy use</h2>
      <p>
        Suppose you have a window air conditioner rated at 12,000 BTU per hour. You want to estimate how much energy it
        uses in kWh so you can compare it with your electricity bill.
      </p>
      <ol>
        <li>Enter 12000 as the energy amount.</li>
        <li>Select the BTU to kWh direction.</li>
        <li>Leave decimal places at 4 for a precise result.</li>
      </ol>
      <p>The calculator applies the formula:</p>
      <pre>kWh = 12000 / 3412.142</pre>
      <p>
        This gives approximately 3.517 kWh. If the air conditioner runs for 3 hours, the total energy use is about
        3.517 * 3 = 10.551 kWh. You can then multiply this by your electricity price per kWh to estimate the running
        cost.
      </p>
    </section>

    <section class="content-section" id="faq">
      <h2>BTU to kWh conversion FAQs</h2>
      <dl class="faq-list">
        {faqs.map((item) => (
          <div class="faq-item">
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </div>
        ))}
      </dl>
    </section>
  </main>

  <style>
    .page {
      padding: 1.5rem 1rem 3rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .hero-main h1 {
      font-size: 1.9rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      margin: 0 0 0.75rem;
      color: #333;
    }

    .hero-trust {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .badge {
      display: inline-block;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      background: #eef6ff;
      color: #174ea6;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .hero-meta {
      font-size: 0.9rem;
      color: #444;
      border-left: 3px solid #e0e7ff;
      padding-left: 0.75rem;
    }

    .calculator-section {
      margin-bottom: 2.5rem;
    }

    .calculator-layout {
      display: grid;
      gap: 1.5rem;
    }

    .calculator-aside {
      order: 2;
    }

    .tip-card {
      border-radius: 0.75rem;
      border: 1px solid #e5e7eb;
      padding: 1rem;
      background: #fafafa;
    }

    .tip-card h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .tip-card ul {
      padding-left: 1.1rem;
      margin: 0;
    }

    .tip-card li {
      font-size: 0.9rem;
      margin-bottom: 0.25rem;
    }

    .content-section {
      margin-bottom: 2.5rem;
    }

    .content-section h2 {
      font-size: 1.3rem;
      margin-bottom: 0.75rem;
    }

    pre {
      background: #f9fafb;
      border-radius: 0.5rem;
      padding: 0.6rem 0.8rem;
      font-size: 0.9rem;
      overflow-x: auto;
    }

    ol {
      padding-left: 1.2rem;
    }

    .faq-list {
      margin: 0;
    }

    .faq-item {
      margin-bottom: 1rem;
    }

    .faq-item dt {
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .faq-item dd {
      margin: 0;
      color: #333;
    }

    @media (min-width: 768px) {
      .hero {
        grid-template-columns: minmax(0, 2fr) minmax(0, 1.2fr);
        align-items: flex-start;
      }

      .calculator-layout {
        grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
        align-items: flex-start;
      }

      .calculator-aside {
        order: 1;
      }
    }
  </style>
</Layout>
