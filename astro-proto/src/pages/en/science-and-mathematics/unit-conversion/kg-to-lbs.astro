---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "kg-to-lbs";

const pageTitle = "Kilograms to Pounds Converter (kg to lbs)";
const pageDescription =
  "Fast kilograms to pounds converter. Convert kg to lbs and lbs to kg instantly, understand the formula, and see real-world examples.";

const calculatorConfig = {
  mode: "unit-conversion",
  primaryConversion: {
    fromUnit: "kilogram",
    fromUnitSymbol: "kg",
    toUnit: "pound",
    toUnitSymbol: "lb",
    direction: "kg-to-lb",
    factor: 2.2046226218,
    expression: "pounds = kilograms * 2.2046226218",
  },
  secondaryConversion: {
    enabled: true,
    fromUnit: "pound",
    fromUnitSymbol: "lb",
    toUnit: "kilogram",
    toUnitSymbol: "kg",
    direction: "lb-to-kg",
    factor: 0.45359237,
    expression: "kilograms = pounds * 0.45359237",
  },
  ui: {
    layout: "cockpit",
    showAdvancedToggle: true,
    showResetButton: true,
    showShareButton: true,
    stickyResultOnMobile: true,
    primaryInputLabel: "Weight in kilograms",
    primaryInputPlaceholder: "Enter weight in kg",
    secondaryInputLabel: "Weight in pounds",
    secondaryInputPlaceholder: "Enter weight in lb",
    resultLabelPrimary: "Result in pounds",
    resultLabelSecondary: "Result in kilograms",
    decimalPlacesDefault: 3,
    decimalPlacesMin: 0,
    decimalPlacesMax: 6,
    autoCalculate: true,
    showCalculateButton: true,
    tips: [
      "For everyday use, rounding to 1 or 2 decimal places is usually enough.",
      "1 kilogram is approximately 2.205 pounds.",
      "Use the advanced options to convert from pounds back to kilograms.",
    ],
  },
  validation: {
    minValue: 0,
    maxValue: 1000000,
    allowZero: true,
    errorMessages: {
      belowMin: "Weight cannot be negative.",
      aboveMax: "Weight is too large for this simple converter. Try a smaller value.",
      notNumber: "Please enter a valid number for the weight.",
    },
  },
  meta: {
    topic: "Mass unit conversion",
    formulaSummary: "pounds = kilograms * 2.2046226218",
    verifiedBy: "Based on the international avoirdupois pound definition (1 lb = 0.45359237 kg).",
    lastReviewed: "2025-01-01",
  },
};

const faqs = [
  {
    question: "How do you convert kilograms to pounds?",
    answer:
      "To convert kilograms to pounds, multiply the weight in kilograms by 2.2046226218. For example, 10 kg is 10 * 2.2046226218 which is about 22.046 pounds.",
  },
  {
    question: "Is 1 kg exactly 2.2 pounds?",
    answer:
      "No. By definition, 1 pound is exactly 0.45359237 kilograms. This means 1 kilogram is about 2.2046226218 pounds, so 2.2 pounds is only an approximation.",
  },
  {
    question: "How do you convert pounds back to kilograms?",
    answer:
      "To convert pounds to kilograms, multiply the weight in pounds by 0.45359237. For example, 150 lb is 150 * 0.45359237 which is about 68.04 kg.",
  },
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/",
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/",
  },
  {
    position: 3,
    name: "Unit Conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/",
  },
  {
    position: 4,
    name: "Kilograms to Pounds Converter",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/kg-to-lbs",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Kilograms to Pounds Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/kg-to-lbs",
  applicationCategory: "ScienceApplication",
  operatingSystem: "Any",
  description:
    "Interactive kilograms to pounds converter that also supports pounds to kilograms, with instant results and adjustable precision.",
  featureList: [
    "Kilograms to pounds conversion",
    "Pounds to kilograms conversion",
    "Adjustable decimal precision",
    "Mobile friendly numeric inputs",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((crumb) => ({
    "@type": "ListItem",
    position: crumb.position,
    name: crumb.name,
    item: crumb.item,
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Kilograms to Pounds Converter</h1>
        <p class="hero-subtitle">
          Convert kilograms to pounds (and back) in seconds with instant, high-precision results.
        </p>
        <p class="hero-trust">
          Verified against the international avoirdupois pound definition. Updated for 2025 reference values.
        </p>
      </div>
      <aside class="hero-meta">
        <div class="badge">Mass unit converter</div>
        <div class="badge badge-secondary">Science and mathematics &#8250; Unit Conversion</div>
        <p class="hero-note">
          Ideal for science homework, fitness tracking, shipping labels, and engineering estimates.
        </p>
      </aside>
    </header>

    <section class="layout">
      <div class="layout-main">
        <section aria-labelledby="calculator-heading" class="calculator-section">
          <div class="calculator-header">
            <h2 id="calculator-heading">Kilograms to pounds calculator</h2>
            <p class="calculator-intro">
              Enter a weight in kilograms to see the equivalent in pounds. Use the advanced options to reverse the
              conversion or fine-tune decimal precision.
            </p>
          </div>

          <CalculatorIsland slug={slug} config={calculatorConfig} />

          <section class="theory" aria-labelledby="theory-heading">
            <h2 id="theory-heading">How the kilograms to pounds conversion works</h2>
            <p>
              The kilogram is the base unit of mass in the International System of Units, while the pound is a common
              unit of mass used in the United States and a few other countries. The relationship between them is fixed
              by an international agreement.
            </p>
            <p>
              By definition, 1 pound is exactly 0.45359237 kilograms. From this, you can derive the factor to convert
              kilograms to pounds.
            </p>

            <h3>Formula to convert kilograms to pounds</h3>
            <p>The core formula is:</p>
            <pre>pounds = kilograms * 2.2046226218</pre>
            <p>
              This factor comes from dividing 1 by 0.45359237. In other words, 1 kilogram is about 2.2046226218 pounds.
              For most everyday calculations, you can round this factor to 2.205 or even 2.2, but the calculator uses
              the more precise value internally.
            </p>

            <h3>Formula to convert pounds to kilograms</h3>
            <p>To go the other way, from pounds back to kilograms, use:</p>
            <pre>kilograms = pounds * 0.45359237</pre>
            <p>
              This is the exact definition of the international avoirdupois pound. Using this factor ensures that your
              conversions are consistent with scientific and engineering references.
            </p>
          </section>

          <section class="examples" aria-labelledby="example-heading">
            <h2 id="example-heading">Real world example: body weight conversion</h2>
            <p>
              Imagine you are reading a fitness article that lists recommended weights in kilograms, but your bathroom
              scale shows pounds. You want to know what 70 kg corresponds to in pounds.
            </p>
            <ol>
              <li>Enter 70 in the "Weight in kilograms" field.</li>
              <li>The calculator applies the formula pounds = kilograms * 2.2046226218.</li>
              <li>
                The result is:
                <strong>70 kg &#8776; 154.324 pounds</strong> (rounded to three decimal places).
              </li>
            </ol>
            <p>
              If you instead know your weight in pounds, for example 150 lb, switch to the advanced options and enter
              150 in the pounds field. Using kilograms = pounds * 0.45359237, the calculator shows that
              <strong>150 lb &#8776; 68.039 kg</strong>.
            </p>
          </section>

          <section class="faq" aria-labelledby="faq-heading">
            <h2 id="faq-heading">Frequently asked questions about kg to lbs</h2>
            {faqs.map((item) => (
              <article class="faq-item">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))}
          </section>
        </section>
      </div>

      <aside class="layout-sidebar" aria-label="Sponsored content">
        <div class="ad-slot ad-slot--top">
          <div class="ad-placeholder">
            Right rail ad space
          </div>
        </div>
        <div class="ad-slot ad-slot--sticky">
          <div class="ad-placeholder">
            Sticky sidebar ad
          </div>
        </div>
      </aside>
    </section>
  </main>

  <style>
    .page {
      padding: 1.5rem 1rem 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .hero-main h1 {
      font-size: 2rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      margin: 0 0 0.5rem;
      font-size: 1rem;
      color: #333333;
    }

    .hero-trust {
      margin: 0;
      font-size: 0.9rem;
      color: #555555;
    }

    .hero-meta {
      font-size: 0.9rem;
      color: #444444;
    }

    .badge {
      display: inline-block;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      background: #eef4ff;
      color: #1a3a8a;
      font-weight: 600;
      font-size: 0.8rem;
      margin-bottom: 0.4rem;
    }

    .badge-secondary {
      background: #f3f4f6;
      color: #374151;
    }

    .hero-note {
      margin: 0.4rem 0 0;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
    }

    .layout-main {
      min-width: 0;
    }

    .layout-sidebar {
      display: none;
    }

    .calculator-section {
      background: #ffffff;
      border-radius: 0.75rem;
      padding: 1.25rem;
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
    }

    .calculator-header h2 {
      margin: 0 0 0.5rem;
      font-size: 1.4rem;
    }

    .calculator-intro {
      margin: 0 0 1rem;
      font-size: 0.95rem;
      color: #374151;
    }

    .theory,
    .examples,
    .faq {
      margin-top: 1.75rem;
    }

    .theory h2,
    .examples h2,
    .faq h2 {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .theory h3 {
      font-size: 1.05rem;
      margin-top: 1rem;
      margin-bottom: 0.25rem;
    }

    pre {
      background: #f9fafb;
      padding: 0.6rem 0.75rem;
      border-radius: 0.5rem;
      font-size: 0.9rem;
      overflow-x: auto;
    }

    .examples ol {
      padding-left: 1.25rem;
    }

    .examples li {
      margin-bottom: 0.25rem;
    }

    .faq-item + .faq-item {
      margin-top: 1rem;
    }

    .ad-slot {
      margin-bottom: 1rem;
    }

    .ad-placeholder {
      background: #f3f4f6;
      border-radius: 0.5rem;
      padding: 1rem;
      text-align: center;
      font-size: 0.85rem;
      color: #6b7280;
      border: 1px dashed #d1d5db;
    }

    @media (min-width: 768px) {
      .page {
        padding: 2rem 1.5rem 3rem;
      }

      .hero {
        grid-template-columns: minmax(0, 2fr) minmax(0, 1.2fr);
        align-items: flex-start;
      }

      .hero-main h1 {
        font-size: 2.4rem;
      }

      .layout {
        grid-template-columns: minmax(0, 3fr) minmax(260px, 1fr);
        align-items: flex-start;
      }

      .layout-sidebar {
        display: block;
        position: relative;
      }

      .ad-slot--sticky {
        position: sticky;
        top: 1rem;
      }
    }

    @media (min-width: 1024px) {
      .page {
        padding-top: 2.5rem;
      }

      .calculator-section {
        padding: 1.5rem 1.75rem;
      }
    }
  </style>
</Layout>
