---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "kg-to-lbs";

const pageTitle = "Kilograms to Pounds Converter (kg to lbs) – Fast and Accurate";
const pageDescription =
  "Convert kilograms to pounds (kg to lbs) and pounds to kilograms instantly. Learn the exact conversion factor, see examples, and use our precise weight converter.";

const calculatorConfig = {
  mode: "unit-conversion",
  primaryConversion: {
    fromUnit: "kilogram",
    fromUnitSymbol: "kg",
    toUnit: "pound",
    toUnitSymbol: "lb",
    factor: 2.2046226218,
    expression: "pounds = kilograms * 2.2046226218"
  },
  secondaryConversion: {
    enabled: true,
    fromUnit: "pound",
    fromUnitSymbol: "lb",
    toUnit: "kilogram",
    toUnitSymbol: "kg",
    factor: 0.45359237,
    expression: "kilograms = pounds * 0.45359237"
  },
  ui: {
    layout: "cockpit",
    showAdvancedToggle: true,
    defaultPrecision: 2,
    minPrecision: 0,
    maxPrecision: 6,
    primaryInputLabel: "Weight in kilograms",
    primaryInputPlaceholder: "Enter weight in kg",
    secondaryInputLabel: "Weight in pounds",
    secondaryInputPlaceholder: "Enter weight in lb",
    resultLabelPrimary: "Result in pounds",
    resultLabelSecondary: "Result in kilograms",
    showResetButton: true,
    showShareButton: true,
    autocalculate: true,
    stickyResultOnMobile: true,
    inputMode: "decimal",
    tips: [
      "For everyday use, rounding to 1 or 2 decimal places is usually enough.",
      "1 kilogram is approximately equal to 2.2 pounds.",
      "Use the advanced options to convert from pounds back to kilograms."
    ]
  },
  validation: {
    minValue: 0,
    allowZero: true,
    errorMessages: {
      belowMin: "Weight cannot be negative. Please enter a value of 0 or higher.",
      notANumber: "Please enter a valid numeric value for the weight."
    }
  },
  share: {
    enabled: true,
    queryParams: ["kg", "lb", "precision"]
  },
  meta: {
    topic: "weight-conversion",
    verifiedBy: "Staff mathematician",
    lastReviewed: "2025-01-01"
  }
};

const faqs = [
  {
    question: "How do you convert kilograms to pounds?",
    answer:
      "To convert kilograms to pounds, multiply the weight in kilograms by 2.2046226218. For example, 10 kg * 2.2046226218 is about 22.05 lb."
  },
  {
    question: "Is 1 kg exactly 2.2 pounds?",
    answer:
      "No. The exact conversion is 1 kilogram = 2.2046226218 pounds. The value 2.2 pounds is a rounded approximation that is fine for quick mental math but not for precise calculations."
  },
  {
    question: "How many kilograms are in a pound?",
    answer:
      "One pound is defined as exactly 0.45359237 kilograms. To convert pounds to kilograms, multiply the weight in pounds by 0.45359237."
  }
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/"
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    position: 3,
    name: "Unit conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    position: 4,
    name: "Kilograms to pounds converter",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/kg-to-lbs"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Kilograms to Pounds Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/kg-to-lbs",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description:
    "Interactive kilograms to pounds and pounds to kilograms converter with adjustable precision and instant results.",
  featureList: [
    "Kilograms to pounds conversion",
    "Pounds to kilograms conversion",
    "Adjustable decimal precision",
    "Shareable results with URL parameters"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((b) => ({
    "@type": "ListItem",
    position: b.position,
    name: b.name,
    item: b.item
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Kilograms to Pounds Converter (kg to lbs)</h1>
        <p class="hero-subtitle">
          Convert kilograms to pounds and pounds to kilograms in seconds with a precise, mobile-friendly weight converter.
        </p>
        <ul class="hero-trust">
          <li>Uses the exact factor: 1 kg = 2.2046226218 lb</li>
          <li>Suitable for science, engineering, and everyday use</li>
          <li>Reviewed and updated for 2025 reference standards</li>
        </ul>
      </div>
      <aside class="hero-meta">
        <div class="verified-badge">
          <span class="verified-label">Verified by</span>
          <span class="verified-name">Staff mathematician</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Last review</span>
          <span class="meta-value">January 2025</span>
        </div>
      </aside>
    </header>

    <section class="calculator-section" aria-label="Kilograms to pounds converter">
      <div class="calculator-layout">
        <div class="calculator-main">
          <CalculatorIsland slug={slug} config={calculatorConfig} />
        </div>
        <aside class="calculator-sidebar">
          <div class="sidebar-card">
            <h2>How this kg to lbs converter works</h2>
            <p>
              Enter a weight in kilograms and the tool instantly converts it to pounds using the exact international
              conversion factor. Open the advanced options to convert from pounds back to kilograms or to change the
              number of decimal places.
            </p>
            <p>
              On mobile, the numeric keypad appears automatically for faster input, and the latest result stays visible
              in a sticky bar while you scroll.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section class="content-section" id="formula">
      <h2>Formula for converting kilograms to pounds</h2>
      <p>
        The relationship between kilograms and pounds is defined by the international avoirdupois pound. One pound is
        exactly 0.45359237 kilograms. From this definition we can derive both conversion directions.
      </p>

      <h3>From kilograms to pounds</h3>
      <p>
        To convert a mass from kilograms to pounds, multiply the value in kilograms by 2.2046226218.
      </p>
      <pre>pounds = kilograms * 2.2046226218</pre>
      <p>
        Example: if you have 10 kilograms:
      </p>
      <pre>pounds = 10 * 2.2046226218 = 22.046226218</pre>
      <p>
        Rounded to two decimal places, this is 22.05 lb.
      </p>

      <h3>From pounds to kilograms</h3>
      <p>
        To convert a mass from pounds to kilograms, multiply the value in pounds by 0.45359237.
      </p>
      <pre>kilograms = pounds * 0.45359237</pre>
      <p>
        Example: if you have 150 pounds:
      </p>
      <pre>kilograms = 150 * 0.45359237 = 68.0388555</pre>
      <p>
        Rounded to two decimal places, this is 68.04 kg.
      </p>

      <p>
        For quick mental estimates, many people use 1 kg ≈ 2.2 lb and 1 lb ≈ 0.45 kg. For scientific or engineering
        work, you should use the exact factors shown above, which this calculator applies internally.
      </p>
    </section>

    <section class="content-section" id="example">
      <h2>Real world example: converting body weight from kg to lbs</h2>
      <p>
        Imagine you are reading a fitness plan that lists recommended weights in pounds, but your scale shows kilograms.
        You weigh 72 kg and want to know your weight in pounds.
      </p>
      <ol>
        <li>Enter 72 in the field labeled "Weight in kilograms".</li>
        <li>The calculator applies the formula pounds = kilograms * 2.2046226218.</li>
        <li>It computes pounds = 72 * 2.2046226218 = 158.73282877.</li>
      </ol>
      <p>
        With the default precision of two decimal places, the result is 158.73 lb. You can adjust the precision if you
        need a more rounded or more detailed value.
      </p>
      <p>
        You can also switch to the advanced view, type your target weight in pounds, and instantly see the equivalent in
        kilograms to set a clear goal on your metric scale.
      </p>
    </section>

    <section class="content-section" id="faq">
      <h2>Frequently asked questions about kg to lbs conversion</h2>
      <dl class="faq-list">
        {faqs.map((item) => (
          <div class="faq-item">
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </div>
        ))}
      </dl>
    </section>
  </main>
</Layout>

<style>
  .page {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 1.5rem 1rem 2.5rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 2fr);
    gap: 1.5rem;
    align-items: flex-start;
  }

  .hero-main h1 {
    font-size: 1.9rem;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    margin: 0.25rem 0 0.75rem;
    color: var(--text-muted, #4b5563);
  }

  .hero-trust {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0.5rem 0 0;
    color: var(--text-muted, #4b5563);
    font-size: 0.95rem;
  }

  .hero-meta {
    border-radius: 0.75rem;
    border: 1px solid var(--border-subtle, #e5e7eb);
    padding: 0.75rem 1rem;
    background: var(--surface-subtle, #f9fafb);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 320px;
  }

  .verified-badge {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .verified-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted, #6b7280);
  }

  .verified-name {
    font-weight: 600;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--text-muted, #6b7280);
  }

  .meta-label {
    font-weight: 500;
  }

  .calculator-section {
    margin-top: 0.5rem;
  }

  .calculator-layout {
    display: grid;
    grid-template-columns: minmax(0, 2fr);
    gap: 1.5rem;
    align-items: flex-start;
  }

  .calculator-main {
    min-width: 0;
  }

  .calculator-sidebar {
    display: none;
  }

  .sidebar-card {
    border-radius: 0.75rem;
    border: 1px solid var(--border-subtle, #e5e7eb);
    padding: 1rem 1.1rem;
    background: var(--surface-subtle, #f9fafb);
    font-size: 0.95rem;
    color: var(--text-muted, #4b5563);
  }

  .sidebar-card h2 {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }

  .content-section {
    max-width: 760px;
  }

  .content-section h2 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }

  .content-section h3 {
    font-size: 1.15rem;
    margin-top: 1rem;
    margin-bottom: 0.35rem;
  }

  .content-section p {
    margin: 0.4rem 0;
    color: var(--text-main, #111827);
  }

  pre {
    background: #0f172a;
    color: #e5e7eb;
    padding: 0.6rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    overflow-x: auto;
    margin: 0.5rem 0;
  }

  ol {
    padding-left: 1.25rem;
    margin: 0.4rem 0 0.6rem;
  }

  .faq-list {
    margin: 0.5rem 0 0;
  }

  .faq-item {
    margin-bottom: 0.75rem;
  }

  .faq-item dt {
    font-weight: 600;
  }

  .faq-item dd {
    margin: 0.15rem 0 0;
    color: var(--text-muted, #4b5563);
  }

  @media (min-width: 900px) {
    .page {
      padding: 2rem 2.5rem 3rem;
    }

    .hero {
      grid-template-columns: minmax(0, 3fr) minmax(260px, 1fr);
    }

    .hero-main h1 {
      font-size: 2.1rem;
    }

    .calculator-layout {
      grid-template-columns: minmax(0, 3fr) minmax(260px, 1.4fr);
    }

    .calculator-sidebar {
      display: block;
    }
  }
</style>
