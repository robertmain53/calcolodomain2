---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const title = "Millimeters to Inches Converter";
const description =
  "Convert millimeters to inches (and inches to millimeters) instantly with high precision. Perfect for science, engineering, woodworking, and everyday measurements.";
const slug = "mm-to-inches";

const canonicalUrl = `https://calcdomain.com/en/science-and-mathematics/unit-conversion/${slug}`;

const faqs = [
  {
    question: "How do you convert millimeters to inches?",
    answer:
      "To convert millimeters to inches, divide the length in millimeters by 25.4. This is because 1 inch is exactly defined as 25.4 millimeters. For example, 50 mm ÷ 25.4 ≈ 1.9685 in."
  },
  {
    question: "What is 10 mm in inches?",
    answer:
      "10 millimeters is approximately 0.3937 inches. Using the formula, 10 mm ÷ 25.4 ≈ 0.3937 in."
  },
  {
    question: "Why is 25.4 used to convert mm to inches?",
    answer:
      "The value 25.4 comes from the international standard definition of the inch. Since 1959, 1 inch has been defined as exactly 25.4 millimeters, so dividing by 25.4 converts millimeters to inches and multiplying by 25.4 converts inches to millimeters."
  }
];

const breadcrumbItems = [
  {
    name: "Home",
    item: "https://calcdomain.com/"
  },
  {
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics"
  },
  {
    name: "Unit Conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion"
  },
  {
    name: title,
    item: canonicalUrl
  }
];

const webAppJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: title,
  url: canonicalUrl,
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description,
  featureList: [
    "Instant millimeters to inches conversion",
    "Instant inches to millimeters conversion",
    "Adjustable decimal precision",
    "Mobile-friendly numeric keypad",
    "Shareable URL with prefilled inputs"
  ]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer
    }
  }))
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.item
  }))
};

const inputConfig = {
  primary: {
    label: "Length in millimeters",
    name: "millimeters",
    placeholder: "e.g. 25",
    inputmode: "decimal",
    tooltip:
      "Enter the length in millimeters (mm). Common in technical drawings, 3D printing, and engineering.",
    min: 0
  },
  secondary: {
    label: "Length in inches",
    name: "inches",
    placeholder: "e.g. 1",
    inputmode: "decimal",
    tooltip:
      "Enter the length in inches (in) to convert back to millimeters.",
    min: 0
  },
  precision: {
    label: "Decimal places",
    name: "precision",
    tooltip: "Choose how many decimal places to show in the result.",
    min: 0,
    max: 6,
    defaultValue: 4
  }
};

const behavior = {
  autoCalculate: true,
  showCalculateButton: true,
  showResetButton: true,
  showShareButton: true,
  stickyResultBar: true,
  layout: "cockpit",
  hasAdvancedToggle: true
};

const formula = {
  description:
    "Millimeters to inches and inches to millimeters using the exact definition 1 in = 25.4 mm.",
  fromTo: "inches = millimeters ÷ 25.4",
  toFrom: "millimeters = inches × 25.4"
};
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  hub="science-and-mathematics"
  cluster="unit-conversion"
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppJsonLd)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqJsonLd)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbJsonLd)}
    </script>
  </Fragment>

  <main class="page">
    <section class="hero">
      <div class="hero-main">
        <h1 class="hero-title">Millimeters to Inches Converter</h1>
        <p class="hero-subtitle">
          Convert millimeters to inches (and back) in seconds with precise,
          standards-based formulas.
        </p>
        <p class="hero-meta">
          Verified against the international inch definition (1 in = 25.4 mm).
          Updated for 2025.
        </p>
      </div>
      <div class="hero-aside">
        <div class="trust-card">
          <p class="trust-label">Trusted by</p>
          <p class="trust-value">
            engineers, students, and makers worldwide
          </p>
          <p class="trust-note">
            Fast, accurate, mobile-friendly unit conversion.
          </p>
        </div>
      </div>
    </section>

    <section class="tool-section">
      <div class="tool-layout">
        <div class="tool-main">
          <CalculatorIsland
            id="mm-to-inches"
            title={title}
            mode="unit-conversion"
            primaryUnitFrom="millimeter"
            primaryUnitTo="inch"
            hub="science-and-mathematics"
            cluster="unit-conversion"
            slug={slug}
            inputConfig={inputConfig}
            behavior={behavior}
            formula={formula}
          />
        </div>

        <aside class="tool-sidebar">
          <div class="sidebar-card">
            <h2 class="sidebar-title">Conversion quick facts</h2>
            <ul class="sidebar-list">
              <li>1 millimeter = 0.0393701 inches</li>
              <li>1 inch = 25.4 millimeters (exact by definition)</li>
              <li>
                Common in: machining, woodworking, 3D printing, and science
                labs
              </li>
            </ul>
          </div>

          <div class="sidebar-card">
            <h3 class="sidebar-subtitle">Pro tip</h3>
            <p class="sidebar-text">
              When working from imperial plans but using metric tools, convert
              all key dimensions up front and keep both values visible to avoid
              rounding mistakes.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section class="content-section" id="theory">
      <h2>How to convert millimeters to inches</h2>
      <p>
        The relationship between millimeters and inches is fixed by
        international agreement. Since 1959, the inch has been defined as
        exactly 25.4 millimeters. This gives us a simple, precise conversion
        factor.
      </p>
      <p>To convert a length from millimeters to inches, divide by 25.4:</p>
      <pre class="math-block">$$
\text{inches} = \frac{\text{millimeters}}{25.4}
$$</pre>
      <p>To convert a length from inches to millimeters, multiply by 25.4:</p>
      <pre class="math-block">$$
\text{millimeters} = \text{inches} \times 25.4
$$</pre>
      <p>
        Because 25.4 is an exact value, these formulas introduce no theoretical
        error. Any difference you see between tools comes from rounding choices
        (for example, showing 2, 3, or 4 decimal places).
      </p>

      <h3>Why 1 inch equals 25.4 millimeters</h3>
      <p>
        Historically, the inch was defined in several slightly different ways.
        In 1959, major English-speaking countries agreed on a unified standard:
        the international inch. This standard sets:
      </p>
      <pre class="math-block">$$
1 \text{ inch} = 25.4 \text{ millimeters (exact)}
$$</pre>
      <p>
        This definition ties imperial measurements directly to the metric
        system, making conversions like millimeters to inches straightforward
        and reliable across engineering, manufacturing, and science.
      </p>
    </section>

    <section class="content-section" id="example">
      <h2>Real-world example: Converting a 50 mm part to inches</h2>
      <p>
        Imagine you are reading a technical drawing that specifies a shaft
        diameter of 50 mm, but your machining tools and reference tables are in
        inches. You want to know the equivalent size in inches.
      </p>
      <ol>
        <li>
          Enter <strong>50</strong> in the “Length in millimeters” field.
        </li>
        <li>Leave the decimal places at the default (for example, 4).</li>
        <li>The calculator shows the result in inches instantly.</li>
      </ol>
      <p>Using the formula:</p>
      <pre class="math-block">$$
\text{inches} = \frac{50}{25.4} \approx 1.9685 \text{ in}
$$</pre>
      <p>
        You can now compare this value with standard imperial shaft sizes (such
        as 1&#x00A0;15&#x2044;16 in) and decide whether the part matches an
        off-the-shelf component or needs custom machining.
      </p>
    </section>

    <section class="content-section" id="faq">
      <h2>Millimeters to inches converter: FAQs</h2>
      {faqs.map((item) => (
        <details class="faq-item">
          <summary class="faq-question">{item.question}</summary>
          <p class="faq-answer">{item.answer}</p>
        </details>
      ))}
    </section>
  </main>

  <style>
    .page {
      padding: 1.5rem 1rem 3rem;
      max-width: 1120px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .hero-title {
      font-size: 2rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      font-size: 1rem;
      margin-bottom: 0.5rem;
      color: var(--color-text-muted, #555);
    }

    .hero-meta {
      font-size: 0.9rem;
      color: var(--color-text-muted, #666);
    }

    .hero-aside {
      display: flex;
      align-items: stretch;
    }

    .trust-card {
      border-radius: 0.75rem;
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, #0f172a, #1e293b);
      color: #f9fafb;
      font-size: 0.9rem;
      width: 100%;
    }

    .trust-label {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.7rem;
      opacity: 0.8;
      margin-bottom: 0.25rem;
    }

    .trust-value {
      font-weight: 600;
      margin-bottom: 0.25rem;
    }

    .trust-note {
      font-size: 0.8rem;
      opacity: 0.9;
    }

    .tool-section {
      margin-bottom: 2.5rem;
    }

    .tool-layout {
      display: grid;
      gap: 1.5rem;
    }

    .tool-main {
      min-width: 0;
    }

    .tool-sidebar {
      min-width: 0;
    }

    .sidebar-card {
      border-radius: 0.75rem;
      padding: 1rem 1.25rem;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      margin-bottom: 1rem;
    }

    .sidebar-title {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .sidebar-subtitle {
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
    }

    .sidebar-list {
      padding-left: 1.1rem;
      margin: 0;
      font-size: 0.9rem;
      color: #374151;
    }

    .sidebar-list li + li {
      margin-top: 0.25rem;
    }

    .sidebar-text {
      font-size: 0.9rem;
      color: #374151;
      margin: 0;
    }

    .content-section {
      margin-bottom: 2.5rem;
    }

    .content-section h2 {
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }

    .content-section h3 {
      font-size: 1.1rem;
      margin-top: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .content-section p {
      margin-bottom: 0.75rem;
      color: #111827;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .content-section ol {
      padding-left: 1.25rem;
      margin-bottom: 0.75rem;
      font-size: 0.95rem;
    }

    .math-block {
      background: #0b1120;
      color: #e5e7eb;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
        "Liberation Mono", "Courier New", monospace;
      font-size: 0.9rem;
      overflow-x: auto;
      margin: 0.75rem 0;
    }

    .faq-item {
      border-radius: 0.5rem;
      border: 1px solid #e5e7eb;
      padding: 0.75rem 0.9rem;
      background: #f9fafb;
    }

    .faq-item + .faq-item {
      margin-top: 0.5rem;
    }

    .faq-question {
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
    }

    .faq-answer {
      margin-top: 0.5rem;
      font-size: 0.9rem;
      color: #111827;
    }

    @media (min-width: 768px) {
      .page {
        padding: 2rem 1.5rem 3rem;
      }

      .hero {
        grid-template-columns: minmax(0, 2fr) minmax(0, 1.2fr);
        align-items: center;
      }

      .hero-title {
        font-size: 2.3rem;
      }

      .tool-layout {
        grid-template-columns: minmax(0, 2.1fr) minmax(0, 1.2fr);
        align-items: flex-start;
      }
    }

    @media (min-width: 1024px) {
      .page {
        padding-top: 2.5rem;
      }

      .hero-title {
        font-size: 2.5rem;
      }
    }
  </style>
</Layout>
