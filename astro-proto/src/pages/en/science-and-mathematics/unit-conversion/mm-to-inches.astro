---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "mm-to-inches";

const pageTitle = "Millimeters to Inches Converter";
const pageDescription =
  "Convert millimeters to inches and inches to millimeters instantly. Precise mm to inch conversion with adjustable decimal precision.";

const calculatorConfig = {
  mode: "unit-conversion",
  primaryInputLabel: "Length in millimeters",
  primaryInputName: "millimeters",
  primaryInputPlaceholder: "Enter length in mm",
  primaryInputUnit: "mm",
  secondaryInputLabel: "Length in inches",
  secondaryInputName: "inches",
  secondaryInputPlaceholder: "Enter length in inches",
  secondaryInputUnit: "in",
  showAdvancedToggle: true,
  advancedFields: [
    {
      type: "number",
      name: "precision",
      label: "Decimal places",
      min: 0,
      max: 6,
      step: 1,
      defaultValue: 3,
      helperText: "Choose how many decimal places to show in the result."
    }
  ],
  formula: {
    type: "linear",
    expressionForward: "inches = millimeters / 25.4",
    expressionBackward: "millimeters = inches * 25.4",
    factorForward: 1 / 25.4,
    factorBackward: 25.4
  },
  ui: {
    layout: "cockpit",
    autocalculate: true,
    showCalculateButton: true,
    showResetButton: true,
    showShareButton: true,
    highlightResultOnChange: true,
    mobileStickyResult: true
  },
  validation: {
    millimeters: {
      min: -1000000000,
      max: 1000000000,
      message: "Millimeter value must be a real number between -1e9 and 1e9."
    },
    inches: {
      min: -1000000000,
      max: 1000000000,
      message: "Inch value must be a real number between -1e9 and 1e9."
    }
  },
  tips: [
    {
      field: "millimeters",
      text: "Use millimeters for small, precise lengths such as mechanical parts or technical drawings."
    },
    {
      field: "inches",
      text: "Inches are common in the United States and the United Kingdom for everyday measurements."
    }
  ],
  meta: {
    verifiedBy: "Engineering team",
    lastReviewed: "2025-01-01",
    standards: [
      "1 inch = exactly 25.4 millimeters (international yard and pound agreement, 1959)"
    ]
  }
};

const faqs = [
  {
    question: "How do you convert millimeters to inches?",
    answer:
      "To convert millimeters to inches, divide the length in millimeters by 25.4. For example, 50 millimeters is 50 / 25.4 which is about 1.969 inches."
  },
  {
    question: "What is 1 millimeter in inches?",
    answer:
      "One millimeter is equal to about 0.03937 inches. This comes from the exact definition 1 inch = 25.4 millimeters, so 1 millimeter = 1 / 25.4 inches."
  },
  {
    question: "When should I use millimeters instead of inches?",
    answer:
      "Use millimeters when you need metric precision, for example in engineering drawings, 3D printing, or technical specifications. Use inches when working with hardware, woodworking, or consumer products that follow imperial standards."
  }
];

const breadcrumbItems = [
  {
    name: "Home",
    url: "https://calcdomain.com/en/"
  },
  {
    name: "Science and mathematics",
    url: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    name: "Unit conversion",
    url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    name: "Millimeters to Inches Converter",
    url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/mm-to-inches/"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Millimeters to Inches Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/mm-to-inches/",
  applicationCategory: "ScienceApplication",
  operatingSystem: "Any",
  description:
    "Interactive millimeters to inches and inches to millimeters converter with instant results and adjustable precision.",
  featureList: [
    "Millimeters to inches conversion",
    "Inches to millimeters conversion",
    "Adjustable decimal precision",
    "Mobile friendly numeric keypad",
    "Shareable URL with prefilled values"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.url
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Millimeters to Inches Converter</h1>
        <p class="hero-subtitle">
          Convert millimeters to inches and back in seconds with precise, standards-based results.
        </p>
        <ul class="hero-trust">
          <li>Uses exact definition 1 inch = 25.4 millimeters</li>
          <li>Optimized for mobile and desktop</li>
          <li>Instant results as you type</li>
        </ul>
      </div>
      <aside class="hero-meta">
        <p class="verified">Verified by engineering team</p>
        <p class="updated">Updated for current international unit standards</p>
      </aside>
    </header>

    <section class="layout">
      <div class="layout-main">
        <section aria-label="Millimeters to inches calculator" class="calculator-section">
          <CalculatorIsland slug={slug} config={calculatorConfig} />
        </section>

        <section class="content-section" aria-labelledby="theory-heading">
          <h2 id="theory-heading">How the millimeters to inches conversion works</h2>
          <p>
            The relationship between millimeters and inches is fixed by international agreement.
            One inch is defined as exactly 25.4 millimeters. This gives two simple conversion
            formulas.
          </p>
          <h3>From millimeters to inches</h3>
          <p>To convert a length from millimeters to inches, divide by 25.4:</p>
          <pre>inches = millimeters / 25.4</pre>
          <p>
            For example, if you have 100 millimeters, the length in inches is 100 / 25.4 which is
            about 3.937 inches.
          </p>

          <h3>From inches to millimeters</h3>
          <p>To convert a length from inches to millimeters, multiply by 25.4:</p>
          <pre>millimeters = inches * 25.4</pre>
          <p>
            For example, 2 inches is 2 * 25.4 which is 50.8 millimeters. Because the factor 25.4 is
            exact, these conversions are precise and repeatable.
          </p>
        </section>

        <section class="content-section" aria-labelledby="example-heading">
          <h2 id="example-heading">Real world example</h2>
          <p>
            Imagine you download a technical drawing for a 3D printed part that lists a hole
            diameter of 12 millimeters, but your drill bits are labeled in inches.
          </p>
          <p>
            Enter 12 in the millimeters field. The converter shows:
          </p>
          <pre>inches = 12 / 25.4 = 0.4724 inches (rounded to 4 decimal places)</pre>
          <p>
            You can then choose the closest drill bit size in inches, for example 15&#47;32 inch
            which is about 0.4688 inches, or 31&#47;64 inch which is about 0.4844 inches, depending
            on the tolerance you need.
          </p>
        </section>

        <section class="content-section" aria-labelledby="faq-heading">
          <h2 id="faq-heading">Millimeters to inches converter FAQ</h2>
          <dl class="faq-list">
            {faqs.map((item) => (
              <div class="faq-item">
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      </div>

      <aside class="layout-sidebar" aria-label="Related tools and ads">
        <section class="sidebar-block">
          <h2 class="sidebar-heading">Related unit converters</h2>
          <ul class="sidebar-list">
            <li>Centimeters to inches</li>
            <li>Inches to millimeters</li>
            <li>Meters to feet</li>
          </ul>
        </section>

        <section class="sidebar-block sidebar-ads" aria-label="Sponsored">
          <div class="ad-slot">Ad space</div>
        </section>
      </aside>
    </section>
  </main>

<style>
  .page {
    padding: 1.5rem 1rem 3rem;
    max-width: 1120px;
    margin: 0 auto;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .hero-main h1 {
    font-size: 1.9rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }

  .hero-subtitle {
    margin: 0 0 0.75rem;
    color: #334155;
  }

  .hero-trust {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    color: #475569;
    font-size: 0.95rem;
  }

  .hero-meta {
    font-size: 0.85rem;
    color: #64748b;
  }

  .verified {
    font-weight: 600;
  }

  .layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .layout-main {
    flex: 1 1 auto;
    min-width: 0;
  }

  .layout-sidebar {
    flex: 0 0 280px;
  }

  .calculator-section {
    margin-bottom: 2rem;
  }

  .content-section {
    margin-bottom: 2rem;
  }

  .content-section h2 {
    margin-bottom: 0.75rem;
  }

  .content-section h3 {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  pre {
    background: #0f172a;
    color: #e5e7eb;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    overflow-x: auto;
  }

  .faq-list {
    margin: 0;
  }

  .faq-item {
    margin-bottom: 1rem;
  }

  .faq-item dt {
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .faq-item dd {
    margin: 0;
    color: #475569;
  }

  .sidebar-block {
    margin-bottom: 1.5rem;
  }

  .sidebar-heading {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.9rem;
    color: #475569;
  }

  .sidebar-list li {
    margin-bottom: 0.25rem;
  }

  .sidebar-ads .ad-slot {
    width: 100%;
    min-height: 250px;
    background: #e2e8f0;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-size: 0.9rem;
  }

  @media (min-width: 900px) {
    .hero {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }

    .hero-main {
      max-width: 70%;
    }

    .layout {
      flex-direction: row;
      align-items: flex-start;
    }

    .layout-main {
      flex: 1 1 auto;
    }

    .layout-sidebar {
      position: sticky;
      top: 1.5rem;
    }
  }
</style>
</Layout>
