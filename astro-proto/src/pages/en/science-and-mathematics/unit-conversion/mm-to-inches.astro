---
import Layout from '../../../../layouts/Layout.astro';
import CalculatorIsland from '../../../../components/CalculatorIsland.astro';

const title = 'Millimeters to Inches Converter';
const description =
  'Convert millimeters to inches (mm to in) instantly with high precision. Includes reverse inches to millimeters conversion, fraction breakdown, and reference table.';
const slug = 'mm-to-inches';
const hub = 'Science and mathematics';
const cluster = 'Unit Conversion';

const canonicalUrl = `https://calcdomain.com/en/science-and-mathematics/unit-conversion/${slug}`;
const updatedYear = '2025';

const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: 'https://calcdomain.com/',
  },
  {
    '@type': 'ListItem',
    position: 2,
    name: 'Science and mathematics',
    item: 'https://calcdomain.com/en/science-and-mathematics',
  },
  {
    '@type': 'ListItem',
    position: 3,
    name: 'Unit Conversion',
    item: 'https://calcdomain.com/en/science-and-mathematics/unit-conversion',
  },
  {
    '@type': 'ListItem',
    position: 4,
    name: title,
    item: canonicalUrl,
  },
];

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  url: canonicalUrl,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Any',
  description,
  inLanguage: 'en',
  featureList: [
    'Instant millimeters to inches conversion',
    'Reverse inches to millimeters conversion',
    'Fractional inches breakdown',
    'Reference table for common mm to inch values',
    'Mobile-friendly numeric keypad inputs',
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do you convert millimeters to inches?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'To convert millimeters to inches, divide the length in millimeters by 25.4, because 1 inch is exactly 25.4 millimeters. The formula is: inches = millimeters ÷ 25.4.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is 10 mm in inches?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          '10 mm is approximately 0.3937 inches. Using the formula inches = millimeters ÷ 25.4, we get 10 ÷ 25.4 ≈ 0.3937 in.',
      },
    },
    {
      '@type': 'Question',
      name: 'How accurate is the millimeters to inches conversion?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'The conversion between millimeters and inches is exact because 1 inch is defined as exactly 25.4 millimeters. Any rounding happens only when you limit the number of decimal places in the result.',
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl}
  lang="en"
>
  <script type="application/ld+json">
    {JSON.stringify(webAppSchema)}
  </script>
  <script type="application/ld+json">
    {JSON.stringify(faqSchema)}
  </script>
  <script type="application/ld+json">
    {JSON.stringify(breadcrumbSchema)}
  </script>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1 class="hero-title">{title}</h1>
        <p class="hero-subtitle">
          Convert millimeters to inches (and back) in seconds with precise results, fraction breakdowns, and a handy reference table — updated with the exact 25.4 mm per inch definition.
        </p>
        <div class="hero-meta">
          <span class="hero-badge">High-precision · Engineering-ready</span>
          <span class="hero-updated">Verified with NIST definition · Updated {updatedYear}</span>
        </div>
      </div>
    </header>

    <section class="calculator-section" aria-labelledby="mm-to-inches-calculator-heading">
      <div class="calculator-layout">
        <div class="calculator-main">
          <h2 id="mm-to-inches-calculator-heading" class="section-title">
            Millimeters to inches calculator
          </h2>
          <p class="section-intro">
            Enter a length in millimeters to see the equivalent in inches instantly. Use the advanced options to get fractional inches and reverse inches to millimeters conversion.
          </p>

          <CalculatorIsland
            id="mm-to-inches-calculator"
            calculatorType="unit-conversion"
            primaryUnitFrom="mm"
            primaryUnitTo="in"
            title={title}
            slug={slug}
            inputConfig={{
              mode: 'cockpit',
              fields: [
                {
                  id: 'millimeters',
                  label: 'Length in millimeters',
                  placeholder: 'e.g. 25.4',
                  inputMode: 'decimal',
                  type: 'number',
                  min: 0,
                  step: 'any',
                  tooltip: 'A millimeter (mm) is one-thousandth of a meter. It is commonly used for precise technical and engineering measurements.',
                  required: true,
                },
                {
                  id: 'inchesReverse',
                  label: 'Length in inches (reverse conversion)',
                  placeholder: 'e.g. 1',
                  inputMode: 'decimal',
                  type: 'number',
                  min: 0,
                  step: 'any',
                  tooltip: 'Use this field to convert from inches back to millimeters. Leave blank if you only need mm to inches.',
                  advanced: true,
                },
              ],
              actions: {
                autoCalculate: true,
                showCalculateButton: true,
                showResetButton: true,
                showShareButton: true,
              },
              ui: {
                showAdvancedToggle: true,
                stickyResultOnMobile: true,
              },
            }}
            logicConfig={{
              formula: 'inches = millimeters / 25.4',
              reverseFormula: 'millimeters = inches * 25.4',
              precision: 4,
              allowNegative: false,
              errorMessages: {
                negative: 'Length cannot be negative. Please enter a value greater than or equal to 0.',
                invalid: 'Please enter a valid numeric value for the length.',
              },
              derivedOutputs: [
                {
                  id: 'inchesDecimal',
                  label: 'Length in inches',
                  unit: 'in',
                  highlight: true,
                },
                {
                  id: 'inchesFraction',
                  label: 'Inches as a fraction',
                  description: 'Rounded to the nearest 1/16 of an inch',
                  advanced: true,
                },
                {
                  id: 'mmFromInches',
                  label: 'Millimeters from inches (reverse)',
                  unit: 'mm',
                  advanced: true,
                },
              ],
            }}
          />
        </div>

        <aside class="calculator-side" aria-label="Conversion summary and quick reference">
          <div class="result-summary-card">
            <h3 class="side-title">Quick reference</h3>
            <p class="side-text">
              1 inch is defined as exactly <strong>25.4 millimeters</strong>. This converter uses that exact factor for every calculation.
            </p>
            <table class="ref-table">
              <thead>
                <tr>
                  <th scope="col">Millimeters (mm)</th>
                  <th scope="col">Inches (in)</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>1 mm</td>
                  <td>0.03937 in</td>
                </tr>
                <tr>
                  <td>10 mm</td>
                  <td>0.39370 in</td>
                </tr>
                <tr>
                  <td>25.4 mm</td>
                  <td>1 in</td>
                </tr>
                <tr>
                  <td>50 mm</td>
                  <td>1.96850 in</td>
                </tr>
                <tr>
                  <td>100 mm</td>
                  <td>3.93701 in</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="verification-card">
            <h3 class="side-title">Verified conversion</h3>
            <p class="side-text">
              This tool uses the internationally agreed definition of the inch:
            </p>
            <ul class="side-list">
              <li>1 inch = 25.4 millimeters (exact)</li>
              <li>Standardized by ISO and NIST</li>
              <li>Suitable for engineering and technical drawings</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section class="content-section" aria-labelledby="mm-to-inches-formula-heading">
      <h2 id="mm-to-inches-formula-heading">Millimeters to inches formula</h2>
      <p>
        The relationship between millimeters and inches is fixed by international agreement. One inch is defined as exactly
        <strong>25.4 millimeters</strong>. This leads directly to the conversion formulas.
      </p>
      <h3>From millimeters to inches</h3>
      <p>
        To convert a length from millimeters to inches, divide the value in millimeters by 25.4:
      </p>
      <p class="math-block">
        $$ \text{inches} = \frac{\text{millimeters}}{25.4} $$
      </p>
      <p>
        For example, to convert 50 mm to inches:
      </p>
      <p class="math-block">
        $$ \text{inches} = \frac{50}{25.4} \approx 1.9685 \text{ in} $$
      </p>

      <h3>From inches to millimeters</h3>
      <p>
        To convert a length from inches to millimeters, multiply the value in inches by 25.4:
      </p>
      <p class="math-block">
        $$ \text{millimeters} = \text{inches} \times 25.4 $$
      </p>
      <p>
        For example, to convert 2 inches to millimeters:
      </p>
      <p class="math-block">
        $$ \text{millimeters} = 2 \times 25.4 = 50.8 \text{ mm} $$
      </p>

      <h3>Fractional inches</h3>
      <p>
        In many technical drawings and woodworking plans, dimensions are given in fractional inches such as
        <code>1/8"</code>, <code>1/4"</code>, or <code>3/16"</code>. To express a decimal inch value as a fraction:
      </p>
      <ol>
        <li>Multiply the decimal part by 16 (for sixteenths of an inch).</li>
        <li>Round to the nearest whole number.</li>
        <li>Simplify the fraction if possible.</li>
      </ol>
      <p>
        For example, 0.375 in:
      </p>
      <p class="math-block">
        $$ 0.375 \times 16 = 6 \Rightarrow \frac{6}{16} = \frac{3}{8} $$
      </p>
      <p>
        So 0.375 in = 3/8 in.
      </p>
    </section>

    <section class="content-section" aria-labelledby="mm-to-inches-example-heading">
      <h2 id="mm-to-inches-example-heading">Real-world example: converting a 600 mm board to inches</h2>
      <p>
        Imagine you are following a woodworking plan from the US that specifies a board length of 24 inches, but your tape
        measure is in millimeters. You have a board that measures 600 mm and want to check if it matches the plan.
      </p>
      <ol>
        <li>Enter <strong>600</strong> in the “Length in millimeters” field above.</li>
        <li>The calculator converts it to inches using:
          <span class="inline-math">\text{inches} = \frac{600}{25.4} \approx 23.6220 \text{ in}</span>
        </li>
        <li>
          You see that 600 mm is slightly shorter than 24 in (which is exactly 609.6 mm), so you know the board is about
          0.378 in (≈ 9.6 mm) too short.
        </li>
      </ol>
      <p>
        This kind of precise conversion is essential when mixing metric and imperial measurements in carpentry, 3D
        printing, mechanical design, or when reading datasheets that use different unit systems.
      </p>
    </section>

    <section class="content-section" aria-labelledby="mm-to-inches-faq-heading">
      <h2 id="mm-to-inches-faq-heading">Millimeters to inches converter FAQ</h2>

      <div class="faq-item">
        <h3>How do you convert millimeters to inches without a calculator?</h3>
        <p>
          To convert millimeters to inches by hand, remember that 25 mm is just under 1 inch. Divide the millimeter value
          by 25.4, or approximate by dividing by 25 for a quick mental estimate. For example, 50 mm is about 2 inches
          (exactly 1.9685 in).
        </p>
      </div>

      <div class="faq-item">
        <h3>What is 10 mm, 20 mm, and 30 mm in inches?</h3>
        <p>
          Using the exact conversion factor:
        </p>
        <ul>
          <li>10 mm ≈ 0.3937 in</li>
          <li>20 mm ≈ 0.7874 in</li>
          <li>30 mm ≈ 1.1811 in</li>
        </ul>
        <p>
          You can use the converter above to get more decimal places or to convert any other millimeter value.
        </p>
      </div>

      <div class="faq-item">
        <h3>Is 1 inch exactly 25.4 mm?</h3>
        <p>
          Yes. Since 1959, the inch has been defined internationally as exactly 25.4 millimeters. This means the
          millimeter–inch relationship is not approximate; it is exact. Any small differences you see come only from
          rounding the decimal representation.
        </p>
      </div>
    </section>
  </main>

  <style lang="scss">
    .page {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .hero {
      padding: 1.5rem 0 0.5rem;
      border-bottom: 1px solid var(--border-subtle, #e2e4ea);
    }

    .hero-main {
      max-width: 720px;
    }

    .hero-title {
      font-size: clamp(1.9rem, 2.4vw, 2.4rem);
      line-height: 1.15;
      margin: 0 0 0.5rem;
    }

    .hero-subtitle {
      margin: 0 0 0.75rem;
      color: var(--text-muted, #4b5563);
      font-size: 0.98rem;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      align-items: center;
      font-size: 0.8rem;
      color: var(--text-soft, #6b7280);
    }

    .hero-badge {
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      background: var(--badge-bg, #eef2ff);
      color: var(--badge-text, #3730a3);
      font-weight: 600;
    }

    .hero-updated {
      white-space: nowrap;
    }

    .calculator-section {
      padding: 0.5rem 0 0;
    }

    .calculator-layout {
      display: grid;
      grid-template-columns: minmax(0, 2.1fr) minmax(260px, 1.2fr);
      gap: 1.5rem;
      align-items: flex-start;
    }

    .calculator-main {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .section-title {
      font-size: 1.3rem;
      margin: 0;
    }

    .section-intro {
      margin: 0 0 0.5rem;
      color: var(--text-muted, #4b5563);
      font-size: 0.95rem;
    }

    .calculator-side {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .side-title {
      font-size: 1rem;
      margin: 0 0 0.25rem;
    }

    .side-text {
      margin: 0 0 0.5rem;
      font-size: 0.9rem;
      color: var(--text-muted, #4b5563);
    }

    .result-summary-card,
    .verification-card {
      border-radius: 0.75rem;
      border: 1px solid var(--border-subtle, #e5e7eb);
      padding: 0.75rem 0.9rem;
      background: var(--surface-subtle, #f9fafb);
    }

    .ref-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }

    .ref-table th,
    .ref-table td {
      padding: 0.25rem 0.35rem;
      text-align: left;
      border-bottom: 1px solid var(--border-subtle, #e5e7eb);
    }

    .ref-table th {
      font-weight: 600;
      background: rgba(0, 0, 0, 0.01);
    }

    .side-list {
      margin: 0;
      padding-left: 1.1rem;
      font-size: 0.9rem;
      color: var(--text-muted, #4b5563);
    }

    .side-list li + li {
      margin-top: 0.15rem;
    }

    .content-section {
      padding: 0.75rem 0 0.25rem;
      border-top: 1px solid var(--border-subtle, #e5e7eb);
    }

    .content-section h2 {
      font-size: 1.2rem;
      margin: 0 0 0.5rem;
    }

    .content-section h3 {
      font-size: 1rem;
      margin: 0.75rem 0 0.25rem;
    }

    .content-section p {
      margin: 0.25rem 0;
      font-size: 0.95rem;
      color: var(--text-main, #111827);
    }

    .content-section ol,
    .content-section ul {
      margin: 0.25rem 0 0.25rem 1.25rem;
      font-size: 0.95rem;
      color: var(--text-main, #111827);
    }

    .math-block {
      margin: 0.4rem 0;
      padding: 0.4rem 0.6rem;
      border-radius: 0.5rem;
      background: var(--surface-subtle, #f9fafb);
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      font-size: 0.9rem;
    }

    .inline-math {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    }

    .faq-item + .faq-item {
      margin-top: 0.75rem;
    }

    .faq-item h3 {
      font-size: 1rem;
      margin: 0 0 0.25rem;
    }

    .faq-item p {
      margin: 0.1rem 0;
    }

    @media (max-width: 960px) {
      .calculator-layout {
        grid-template-columns: minmax(0, 1fr);
      }

      .calculator-side {
        order: 2;
      }
    }

    @media (max-width: 640px) {
      .hero {
        padding-top: 1rem;
      }

      .hero-title {
        font-size: 1.6rem;
      }

      .hero-meta {
        flex-direction: column;
        align-items: flex-start;
      }

      .result-summary-card,
      .verification-card {
        padding: 0.7rem 0.75rem;
      }
    }
  </style>
</Layout>
