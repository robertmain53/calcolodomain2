---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "mm-to-inches";

const pageTitle = "Millimeters to Inches Converter";
const pageDescription =
  "Instantly convert millimeters to inches with this precise mm to inches calculator. Supports decimal and fractional inch outputs for engineering, DIY, and machining.";

const calculatorConfig = {
  id: "mm-to-inches",
  mode: "unit-conversion",
  primaryUnitFrom: "millimeter",
  primaryUnitTo: "inch",
  title: "Millimeters to Inches Converter",
  description:
    "Enter a length in millimeters to see the equivalent value in inches. Toggle advanced mode to see decimal and fractional inch formats.",
  inputs: [
    {
      name: "millimeters",
      label: "Length in millimeters",
      type: "number",
      inputMode: "decimal",
      placeholder: "e.g. 25.4",
      min: 0,
      step: "any",
      defaultValue: 25.4,
      tooltip: "Enter the length you want to convert from millimeters to inches."
    },
    {
      name: "precision",
      label: "Decimal places",
      type: "number",
      inputMode: "decimal",
      min: 0,
      max: 6,
      step: 1,
      defaultValue: 3,
      advanced: true,
      tooltip: "Choose how many decimal places to show in the inch result."
    }
  ],
  outputs: [
    {
      name: "inches",
      label: "Inches",
      unit: "in",
      type: "number",
      precisionSource: "precision",
      highlight: true
    },
    {
      name: "inchesFraction",
      label: "Inches (fractional)",
      unit: "in",
      type: "text",
      advanced: true,
      tooltip:
        "Approximate fractional inch value, rounded to the nearest 1&#8260;16 of an inch."
    }
  ],
  behavior: {
    autoCalculate: true,
    showCalculateButton: true,
    showResetButton: true,
    showShareButton: true,
    layout: "cockpit",
    hasAdvancedToggle: true
  },
  formula: {
    type: "linear",
    expression: "inches = millimeters / 25.4",
    factor: 1 / 25.4
  },
  logic: {
    calculate: "mmToInchesWithFraction"
  },
  meta: {
    category: "Science and mathematics",
    subcategory: "Unit Conversion",
    keywords: ["mm to inches", "millimeters to inches", "mm in", "metric to imperial"],
    verifiedBy: "Staff engineer review",
    lastUpdated: "2025-01-01"
  }
};

const faqs = [
  {
    question: "How do you convert millimeters to inches?",
    answer:
      "To convert millimeters to inches, divide the length in millimeters by 25.4. For example, 50 millimeters is 50 / 25.4 which is about 1.969 inches."
  },
  {
    question: "What is 1 millimeter in inches?",
    answer:
      "One millimeter is equal to about 0.03937 inches. This comes from the exact definition that 1 inch is 25.4 millimeters."
  },
  {
    question: "Why is 25.4 used to convert millimeters to inches?",
    answer:
      "The inch is defined internationally as exactly 25.4 millimeters. This fixed relationship means you always convert millimeters to inches by dividing by 25.4."
  }
];

const breadcrumbItems = [
  {
    name: "Home",
    url: "https://calcdomain.com/"
  },
  {
    name: "Science and mathematics",
    url: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    name: "Unit Conversion",
    url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    name: "Millimeters to Inches Converter",
    url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/mm-to-inches/"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Millimeters to Inches Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/mm-to-inches/",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description:
    "Interactive millimeters to inches converter that provides precise decimal and fractional inch values for engineering, DIY, and machining.",
  featureList: [
    "Millimeters to inches conversion",
    "Configurable decimal precision",
    "Fractional inch approximation",
    "Shareable URL with prefilled values"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.url
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Millimeters to Inches Converter</h1>
        <p class="hero-tagline">
          Convert millimeters to inches in seconds with precise decimal and fractional results.
        </p>
        <p class="hero-meta">
          Accurate by definition: 1 inch = 25.4 millimeters. Optimized for 2025 engineering and DIY workflows.
        </p>
      </div>
      <div class="hero-trust">
        <p class="trust-label">Trusted conversion</p>
        <ul class="trust-list">
          <li>Based on international inch definition</li>
          <li>Instant results as you type</li>
          <li>Mobile-friendly numeric keypad</li>
        </ul>
      </div>
    </header>

    <section class="calculator-section" aria-label="Millimeters to inches calculator">
      <CalculatorIsland slug={slug} config={calculatorConfig} />
    </section>

    <section class="content-section" aria-labelledby="mm-to-inches-theory">
      <h2 id="mm-to-inches-theory">How the millimeters to inches formula works</h2>
      <p>
        The relationship between millimeters and inches is fixed by an international standard:
        one inch is defined as exactly 25.4 millimeters. This lets you convert any length in
        millimeters to inches with a simple division.
      </p>
      <p>The core formula is:</p>
      <pre>inches = millimeters / 25.4</pre>
      <p>
        For example, if you have 25.4 millimeters, you compute:
      </p>
      <pre>inches = 25.4 / 25.4 = 1</pre>
      <p>
        The calculator applies this formula directly and then rounds the result to the number of
        decimal places you choose. In advanced mode, it also approximates the value as a
        fractional inch, rounded to the nearest 1&#8260;16 of an inch, which is useful when
        working with tape measures, woodworking plans, or imperial-only tools.
      </p>
    </section>

    <section class="content-section" aria-labelledby="mm-to-inches-example">
      <h2 id="mm-to-inches-example">Real world example: converting a 50 mm part</h2>
      <p>
        Imagine you are ordering a replacement bolt from a supplier that lists sizes only in
        inches, but your design drawing shows a length of 50 millimeters.
      </p>
      <ol>
        <li>Enter 50 in the millimeters field.</li>
        <li>Leave the decimal places at 3 for a practical engineering value.</li>
        <li>Read the result: the calculator shows about 1.969 inches.</li>
      </ol>
      <p>
        If you enable advanced mode, you will also see the fractional inch approximation, which
        is about 1 31&#8260;32 inches. This helps you choose the closest standard imperial size
        when exact metric dimensions are not available.
      </p>
    </section>

    <section class="content-section" aria-labelledby="mm-to-inches-faq">
      <h2 id="mm-to-inches-faq">Millimeters to inches converter FAQ</h2>
      <dl class="faq-list">
        {faqs.map((item) => (
          <Fragment>
            <dt class="faq-question">{item.question}</dt>
            <dd class="faq-answer">{item.answer}</dd>
          </Fragment>
        ))}
      </dl>
    </section>
  </main>
