---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "mm-to-inches";

const pageTitle = "Millimeters to Inches Converter";
const pageDescription =
  "Convert millimeters to inches (and back) instantly. Precise mm to inch conversion for engineering, woodworking, 3D printing, and everyday measurements.";

const inputFields = [
  {
    id: "millimeters",
    label: "Millimeters",
    placeholder: "Enter length in millimeters",
    inputMode: "decimal",
    type: "number",
    min: "0",
    step: "0.01",
    helperText: "Type the length in millimeters you want to convert to inches."
  },
  {
    id: "inches",
    label: "Inches",
    placeholder: "Enter length in inches",
    inputMode: "decimal",
    type: "number",
    min: "0",
    step: "0.0001",
    helperText: "Optional: convert from inches back to millimeters in Advanced mode."
  },
  {
    id: "precision",
    label: "Decimal places",
    placeholder: "e.g. 3",
    inputMode: "decimal",
    type: "number",
    min: "0",
    max: "6",
    step: "1",
    helperText: "Choose how many decimal places to show in the result."
  }
];

const resultFields = [
  {
    id: "resultInchesFromMm",
    label: "Inches (from millimeters)",
    helperText: "Primary result: millimeters converted to inches."
  },
  {
    id: "resultMmFromInches",
    label: "Millimeters (from inches)",
    helperText: "Reverse conversion: inches converted back to millimeters."
  },
  {
    id: "resultInchesFraction",
    label: "Inches as fraction",
    helperText: "Approximate fractional inch (e.g. 1 1/2 in)."
  }
];

const calculatorConfig = {
  toolSlug: slug,
  primaryInputId: "millimeters",
  autoCalculate: true,
  showAdvancedToggle: true,
  showShareButton: true,
  showResetButton: true,
  stickyResultBar: true,
  unitCategory: "length",
  verifiedBy: "Unit conversion formulas based on the international inch definition (25.4 mm).",
  errorMessages: "Length cannot be negative; please enter a value greater than or equal to zero."
};

const faqs = [
  {
    question: "How do you convert millimeters to inches?",
    answer:
      "To convert millimeters to inches, divide the length in millimeters by 25.4. This is because one international inch is defined as exactly 25.4 millimeters."
  },
  {
    question: "What is 1 mm in inches?",
    answer:
      "One millimeter is equal to approximately 0.03937 inches. In formula form, 1 mm &#215; (1 in &#47; 25.4 mm) &#61; 0.03937 in."
  },
  {
    question: "Why is 25.4 mm exactly one inch?",
    answer:
      "Since 1959, the international yard and pound agreement defined 1 inch as exactly 25.4 millimeters to standardize measurements across countries and ensure consistent engineering and manufacturing dimensions."
  }
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/"
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    position: 3,
    name: "Unit Conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    position: 4,
    name: "Millimeters to Inches Converter",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/mm-to-inches"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Millimeters to Inches Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/mm-to-inches",
  applicationCategory: "ScienceApplication",
  operatingSystem: "Any",
  description:
    "Interactive millimeters to inches converter with bidirectional conversion, fractional inches, and precision control.",
  featureList: [
    "Instant millimeters to inches conversion",
    "Inches to millimeters reverse conversion",
    "Adjustable decimal precision",
    "Fractional inch approximation",
    "Shareable URL with prefilled values"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((b) => ({
    "@type": "ListItem",
    position: b.position,
    name: b.name,
    item: b.item
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
<Fragment slot="head">
  <script type="application/ld+json">
    {JSON.stringify(webAppSchema)}
  </script>
  <script type="application/ld+json">
    {JSON.stringify(faqSchema)}
  </script>
  <script type="application/ld+json">
    {JSON.stringify(breadcrumbSchema)}
  </script>
</Fragment>


  <main class="calc-page">
    <section class="hero">
      <div class="hero-content">
        <h1>Millimeters to Inches Converter</h1>
        <p class="hero-subtitle">
          Convert millimeters to inches (and back) in seconds with engineering-grade precision.
        </p>
        <p class="hero-meta">
          Trusted unit converter &#8226; Based on the international inch definition (25.4 mm) &#8226; Optimized for 2025 standards.
        </p>
      </div>
    </section>

    <section class="calculator-section">
      <div class="calculator-layout">
        <div class="calculator-main">
          <CalculatorIsland
            title={pageTitle}
            inputFields={inputFields}
            resultFields={resultFields}
            config={calculatorConfig}
          />
        </div>
        <aside class="calculator-sidebar">
          <div class="sidebar-card">
            <h2>How this mm to inches converter works</h2>
            <p>
              This tool uses the exact international definition of the inch: one inch is equal to 25.4 millimeters.
              As you type a value in millimeters, the calculator instantly converts it to inches and can also show
              the reverse conversion from inches back to millimeters.
            </p>
            <p>
              Use the Advanced options to control decimal precision and see an approximate fractional inch
              representation, which is especially useful in woodworking and construction.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section class="theory-section">
      <h2>Millimeters to inches formula</h2>
      <p>
        Millimeters (mm) are part of the metric system, while inches (in) belong to the imperial system. The
        relationship between them is fixed by international agreement.
      </p>
      <pre class="math-block">
$$ 1 \text{ inch} = 25.4 \text{ millimeters} $$

$$ \text{inches} = \frac{\text{millimeters}}{25.4} $$

$$ \text{millimeters} = \text{inches} \times 25.4 $$
      </pre>
      <p>
        To convert from millimeters to inches, divide the length in millimeters by 25.4. To go the other way,
        multiply the length in inches by 25.4. Because 25.4 is an exact value, these conversions are precise and
        suitable for engineering, manufacturing, and scientific work.
      </p>
    </section>

    <section class="example-section">
      <h2>Real world example: 3D printing part dimensions</h2>
      <p>
        Imagine you download a 3D model whose dimensions are specified in millimeters, but your workshop tools and
        documentation use inches.
      </p>
      <p>
        Suppose the model lists a key dimension as 50 mm. To understand this in inches:
      </p>
      <pre class="math-block">
$$ \text{inches} = \frac{50 \text{ mm}}{25.4} \approx 1.9685 \text{ in} $$
      </pre>
      <p>
        Rounding to two decimal places, you would treat this as about 1.97 inches. If you enable fractional inches in
        the converter, you might see an approximation close to 1 &#190; in or 2 in, depending on your chosen precision.
        This helps you decide which standard imperial size or tool setting is the best match.
      </p>
    </section>

    <section class="faq-section">
      <h2>Frequently asked questions about mm to inches</h2>
      <div class="faq-list">
        {faqs.map((item) => (
          <article class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <style>
    .calc-page {
      padding: 1.5rem 1rem 3rem 1rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero {
      margin-bottom: 1.5rem;
    }

    .hero-content h1 {
      font-size: 2rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      font-size: 1rem;
      margin-bottom: 0.5rem;
      color: #333333;
    }

    .hero-meta {
      font-size: 0.875rem;
      color: #666666;
    }

    .calculator-section {
      margin-top: 1.5rem;
      margin-bottom: 2rem;
    }

    .calculator-layout {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .calculator-main {
      flex: 2;
    }

    .calculator-sidebar {
      flex: 1;
    }

    .sidebar-card {
      border: 1px solid #e0e0e0;
      border-radius: 0.75rem;
      padding: 1rem;
      background: #fafafa;
    }

    .sidebar-card h2 {
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
    }

    .theory-section,
    .example-section,
    .faq-section {
      margin-top: 2rem;
    }

    .theory-section h2,
    .example-section h2,
    .faq-section h2 {
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }

    .math-block {
      background: #111827;
      color: #f9fafb;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 0.9rem;
      overflow-x: auto;
      margin: 0.75rem 0 1rem 0;
      white-space: pre-wrap;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item h3 {
      font-size: 1rem;
      margin-bottom: 0.25rem;
    }

    .faq-item p {
      margin: 0;
    }

    @media (min-width: 768px) {
      .calc-page {
        padding: 2rem 1.5rem 4rem 1.5rem;
      }

      .hero-content h1 {
        font-size: 2.4rem;
      }

      .hero-subtitle {
        font-size: 1.1rem;
      }

      .calculator-layout {
        flex-direction: row;
        align-items: flex-start;
      }

      .calculator-main {
        max-width: 60%;
      }

      .calculator-sidebar {
        max-width: 40%;
        position: sticky;
        top: 5rem;
      }
    }
  </style>
</Layout>
