---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const title = "Centimeters to Inches Converter";
const description =
  "Convert centimeters to inches (and inches to centimeters) instantly. Precise, mobile-friendly cm to inches calculator with adjustable decimal places.";
const slug = "cm-to-inches";
const hub = "Science and mathematics";
const cluster = "Unit Conversion";

const canonicalUrl = `https://calcdomain.com/en/science-and-mathematics/unit-conversion/${slug}`;
const updatedYear = "2025";

const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/",
  },
  {
    "@type": "ListItem",
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics",
  },
  {
    "@type": "ListItem",
    position: 3,
    name: "Unit Conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion",
  },
  {
    "@type": "ListItem",
    position: 4,
    name: title,
    item: canonicalUrl,
  },
];

const webAppJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: title,
  url: canonicalUrl,
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description,
  inLanguage: "en",
  featureList: [
    "Centimeters to inches conversion",
    "Inches to centimeters reverse conversion",
    "Adjustable decimal precision",
    "Mobile-friendly numeric keypad inputs",
    "Instant calculation on input change",
    "Shareable URL with prefilled values",
  ],
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do you convert centimeters to inches?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "To convert centimeters to inches, divide the length value in centimeters by 2.54. One inch is exactly 2.54 centimeters, so the formula is: inches = centimeters &#47; 2.54.",
      },
    },
    {
      "@type": "Question",
      name: "What is 1 cm in inches?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "1 centimeter is approximately 0.3937 inches. Using the exact formula, 1 &#47; 2.54 = 0.3937007874 inches, which is often rounded to 0.39 or 0.394 inches depending on the required precision.",
      },
    },
    {
      "@type": "Question",
      name: "Should I round centimeters to inches for everyday use?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "For everyday measurements like height or furniture dimensions, rounding centimeters to inches to two decimal places is usually enough. For technical or engineering work, you may want three or more decimal places to reduce rounding error.",
      },
    },
  ],
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};
---

<html lang="en">
  <head>
    <title>{title} | calcdomain.com</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="cm to inches, centimeters to inches converter, convert cm to in" />
    <link rel="canonical" href={canonicalUrl} />

    <script type="application/ld+json">
      {JSON.stringify(webAppJsonLd)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqJsonLd)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbJsonLd)}
    </script>
  </head>
  <body>
    <Layout
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      hub={hub}
      cluster={cluster}
      slug={slug}
      tier="A"
    >
      <main class="page">
        <section class="hero">
          <div class="hero-main">
            <h1 class="hero-title">Centimeters to Inches Converter</h1>
            <p class="hero-subtitle">
              Convert centimeters to inches (and back) in seconds with a precise, mobile-friendly calculator updated for {updatedYear}.
            </p>
            <div class="hero-trust">
              <span class="hero-badge">Verified formula: 1 inch = 2.54 cm</span>
              <span class="hero-meta">Optimized for fast unit conversion and classroom use</span>
            </div>
          </div>
          <aside class="hero-aside">
            <div class="verification-card">
              <p class="verification-title">Verified by</p>
              <p class="verification-name">Science &amp; Mathematics Editorial Team</p>
              <p class="verification-note">
                Based on the international definition of the inch (exactly 2.54 centimeters).
              </p>
            </div>
          </aside>
        </section>

        <section class="tool-section">
          <div class="tool-layout">
            <div class="tool-main">
              <CalculatorIsland
                id="cm-to-inches"
                title={title}
                mode="unit-conversion"
                primaryInputLabel="Length in centimeters"
                primaryInputName="centimeters"
                primaryInputPlaceholder="e.g. 170"
                primaryInputUnit="cm"
                secondaryInputLabel="Length in inches"
                secondaryInputName="inches"
                secondaryInputUnit="in"
                showAdvancedToggle={true}
                advancedOptions={{
                  precision: {
                    label: "Decimal places",
                    name: "precision",
                    min: 0,
                    max: 6,
                    defaultValue: 2,
                  },
                  bidirectional: {
                    label: "Enable inches → centimeters",
                    name: "enableReverse",
                    defaultValue: true,
                  },
                }}
                conversionType="length"
                fromUnit="cm"
                toUnit="in"
                formula="inches = centimeters &#47; 2.54"
                reverseFormula="centimeters = inches × 2.54"
                inputMode="decimal"
                showCalculateButton={true}
                showResetButton={true}
                showShareButton={true}
                stickyResultBar={true}
                tips={[
                  "Use the main field to enter the length in centimeters. The result in inches updates instantly.",
                  "Adjust the decimal places in Advanced options if you need more precise results.",
                  "Enable reverse mode to convert from inches back to centimeters.",
                ]}
                validationMessages={{
                  required: "Please enter a length in centimeters.",
                  negativeNotAllowed: "Length cannot be negative. Use a positive value.",
                  tooLarge: "The value is very large. Check if you entered the correct number of digits.",
                }}
              />
            </div>

            <aside class="tool-sidebar">
              <div class="sidebar-card">
                <h2 class="sidebar-title">Conversion quick facts</h2>
                <ul class="sidebar-list">
                  <li>1 inch = 2.54 centimeters (exact, by international agreement).</li>
                  <li>10 cm ≈ 3.94 in &mdash; about the width of an adult hand.</li>
                  <li>30 cm ≈ 11.81 in &mdash; roughly the length of a standard ruler.</li>
                </ul>
              </div>

              <div class="sidebar-card">
                <h2 class="sidebar-title">Related tools</h2>
                <ul class="sidebar-list">
                  <li><a href="/en/science-and-mathematics/unit-conversion/inches-to-cm">Inches to centimeters converter</a></li>
                  <li><a href="/en/science-and-mathematics/unit-conversion/mm-to-inches">Millimeters to inches converter</a></li>
                  <li><a href="/en/science-and-mathematics/unit-conversion/m-to-feet">Meters to feet converter</a></li>
                </ul>
              </div>
            </aside>
          </div>
        </section>

        <section class="content-section" id="how-it-works">
          <h2>How to convert centimeters to inches</h2>
          <p>
            The centimeter (cm) and the inch (in) are both units of length. The centimeter is part of the
            metric system, while the inch is part of the imperial and US customary systems. By international
            definition, one inch is exactly equal to 2.54 centimeters.
          </p>
          <p>
            This leads to a simple conversion formula from centimeters to inches:
          </p>
          <p class="formula">
            As LaTeX-style text: <br />
            <code>$$ \text{inches} = \frac{\text{centimeters}}{2.54} $$</code>
          </p>
          <p>
            To go the other way, from inches back to centimeters, you multiply by 2.54:
          </p>
          <p class="formula">
            <code>$$ \text{centimeters} = \text{inches} \times 2.54 $$</code>
          </p>
          <p>
            Our converter applies these formulas directly. You can also control how many decimal places are
            shown, which is useful when you need either quick approximations or more precise technical values.
          </p>
        </section>

        <section class="content-section" id="example">
          <h2>Real-world example: converting height from cm to inches</h2>
          <p>
            Suppose your height is 170 cm and you want to know it in inches for a form that uses imperial units.
          </p>
          <ol>
            <li>Enter <strong>170</strong> in the &ldquo;Length in centimeters&rdquo; field.</li>
            <li>Leave the decimal places at the default value of 2.</li>
            <li>The calculator applies the formula: inches = 170 &#47; 2.54.</li>
          </ol>
          <p>
            Numerically, this is:
          </p>
          <p class="formula">
            <code>170 &#47; 2.54 ≈ 66.9291 \text{ inches}</code>
          </p>
          <p>
            Rounded to two decimal places, your height is <strong>66.93 inches</strong>. If you prefer feet and
            inches, that is about 5 feet 6.9 inches, but for most forms the decimal inches value is sufficient.
          </p>
        </section>

        <section class="content-section" id="faq">
          <h2>Frequently asked questions about converting cm to inches</h2>

          <div class="faq-item">
            <h3>How do you convert centimeters to inches?</h3>
            <p>
              To convert centimeters to inches, divide the number of centimeters by 2.54. This works because
              1 inch is defined as exactly 2.54 centimeters. For example, 10 cm &#47; 2.54 ≈ 3.94 inches.
            </p>
          </div>

          <div class="faq-item">
            <h3>What is 1 cm in inches?</h3>
            <p>
              1 centimeter is approximately 0.3937 inches. Using the exact conversion, 1 &#47; 2.54 =
              0.3937007874 inches. In everyday use, it is common to round this to 0.39 or 0.394 inches.
            </p>
          </div>

          <div class="faq-item">
            <h3>How many decimal places should I use when converting cm to inches?</h3>
            <p>
              For everyday tasks like body measurements, clothing sizes, or furniture dimensions, two decimal
              places are usually enough. For engineering, machining, or scientific work, you may want three or
              more decimal places to reduce rounding error. The converter&#39;s Advanced options let you choose
              the precision that fits your use case.
            </p>
          </div>
        </section>
      </main>

      <style>
        .page {
          display: flex;
          flex-direction: column;
          gap: 2rem;
          padding: 1.5rem 1rem 3rem;
        }

        .hero {
          display: grid;
          grid-template-columns: minmax(0, 2fr);
          gap: 1.5rem;
          align-items: flex-start;
        }

        .hero-main {
          display: flex;
          flex-direction: column;
          gap: 0.75rem;
        }

        .hero-title {
          font-size: clamp(1.9rem, 3vw, 2.4rem);
          line-height: 1.1;
        }

        .hero-subtitle {
          font-size: 1rem;
          color: var(--color-text-muted, #555);
        }

        .hero-trust {
          display: flex;
          flex-wrap: wrap;
          gap: 0.75rem;
          align-items: center;
          font-size: 0.9rem;
        }

        .hero-badge {
          background: var(--color-accent-soft, #eef6ff);
          color: var(--color-accent-strong, #0b63ce);
          padding: 0.35rem 0.7rem;
          border-radius: 999px;
          font-weight: 600;
        }

        .hero-meta {
          color: var(--color-text-muted, #666);
        }

        .hero-aside {
          display: none;
        }

        .verification-card {
          border-radius: 0.75rem;
          border: 1px solid var(--color-border-subtle, #e0e0e0);
          padding: 0.9rem 1rem;
          background: var(--color-surface-subtle, #fafafa);
        }

        .verification-title {
          font-size: 0.8rem;
          text-transform: uppercase;
          letter-spacing: 0.08em;
          color: var(--color-text-muted, #777);
          margin-bottom: 0.25rem;
        }

        .verification-name {
          font-weight: 600;
          margin-bottom: 0.25rem;
        }

        .verification-note {
          font-size: 0.85rem;
          color: var(--color-text-muted, #666);
        }

        .tool-section {
          margin-top: 0.5rem;
        }

        .tool-layout {
          display: grid;
          grid-template-columns: minmax(0, 1fr);
          gap: 1.5rem;
        }

        .tool-main {
          min-width: 0;
        }

        .tool-sidebar {
          display: flex;
          flex-direction: column;
          gap: 1rem;
        }

        .sidebar-card {
          border-radius: 0.75rem;
          border: 1px solid var(--color-border-subtle, #e0e0e0);
          padding: 1rem 1.1rem;
          background: var(--color-surface, #fff);
        }

        .sidebar-title {
          font-size: 1rem;
          margin-bottom: 0.5rem;
        }

        .sidebar-list {
          list-style: disc;
          padding-left: 1.2rem;
          font-size: 0.9rem;
          color: var(--color-text-muted, #555);
        }

        .content-section {
          max-width: 760px;
          display: flex;
          flex-direction: column;
          gap: 0.75rem;
        }

        .content-section h2 {
          font-size: 1.3rem;
        }

        .content-section p {
          font-size: 0.98rem;
          line-height: 1.6;
          color: var(--color-text-main, #333);
        }

        .content-section ol {
          padding-left: 1.2rem;
          font-size: 0.96rem;
          color: var(--color-text-main, #333);
        }

        .formula {
          font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
            "Courier New", monospace;
          font-size: 0.9rem;
          background: #f7f7f9;
          padding: 0.6rem 0.75rem;
          border-radius: 0.5rem;
          overflow-x: auto;
        }

        .faq-item {
          margin-top: 0.75rem;
        }

        .faq-item h3 {
          font-size: 1.05rem;
          margin-bottom: 0.25rem;
        }

        .faq-item p {
          font-size: 0.95rem;
        }

        @media (min-width: 768px) {
          .page {
            padding: 2rem 2.5rem 3.5rem;
          }

          .hero {
            grid-template-columns: minmax(0, 3fr) minmax(260px, 1.4fr);
          }

          .hero-aside {
            display: block;
          }

          .tool-layout {
            grid-template-columns: minmax(0, 3fr) minmax(260px, 1.4fr);
            align-items: flex-start;
          }
        }

        @media (min-width: 1200px) {
          .page {
            padding-inline: 3.5rem;
          }
        }
      </style>
    </Layout>
  </body>
</html>