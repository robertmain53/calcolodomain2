---
import { Fragment } from "astro/jsx-runtime";
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "cm-to-inches";

const pageTitle = "Centimeters to Inches Converter – cm to in Online Calculator";
const pageDescription =
  "Fast centimeters to inches converter. Convert cm to inches instantly, understand the cm to inch formula, and see real world examples of metric to imperial length conversion.";

const faqs = [
  {
    question: "How do you convert centimeters to inches?",
    answer:
      "To convert centimeters to inches, divide the length value in centimeters by 2.54. One inch is defined as exactly 2.54 centimeters, so inches = centimeters / 2.54.",
  },
  {
    question: "How many inches is 10 cm?",
    answer:
      "10 centimeters is equal to 10 / 2.54 inches, which is about 3.94 inches. In general, you can divide any centimeter value by 2.54 to get inches.",
  },
  {
    question: "Is 1 cm the same as 0.4 inches?",
    answer:
      "1 centimeter is approximately 0.39 inches, not exactly 0.4 inches. The precise conversion is 1 cm = 1 / 2.54 inches, which is about 0.3937 inches.",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Centimeters to Inches Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/cm-to-inches",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description:
    "Interactive centimeters to inches converter that instantly converts cm to inches using the exact 1 in = 2.54 cm definition.",
  featureList: [
    "Instant centimeters to inches conversion",
    "Metric to imperial length comparison",
    "Step by step cm to inch formula explanation",
  ],
  inLanguage: "en",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://calcdomain.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Science and mathematics",
      item: "https://calcdomain.com/en/science-and-mathematics",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Unit Conversion",
      item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion",
    },
    {
      "@type": "ListItem",
      position: 4,
      name: "Centimeters to Inches Converter",
      item:
        "https://calcdomain.com/en/science-and-mathematics/unit-conversion/cm-to-inches",
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="calc-page">
    <header class="calc-hero">
      <h1>Centimeters to Inches Converter</h1>
      <p class="calc-hero__subtitle">
        Convert centimeters to inches in seconds using the exact 1 inch = 2.54 centimeters definition, with clear steps and real world examples.
      </p>
      <p class="calc-hero__meta">
        Precision based on the international inch standard (1 in = 2.54 cm).
      </p>
    </header>

    <section class="calculator-section" aria-label="Centimeters to inches converter tool">
      <CalculatorIsland slug={slug} />
    </section>

    <section class="calc-copy">
      <h2>How to convert centimeters to inches</h2>
      <p>
        Centimeters and inches are both units of length. Centimeters belong to
        the metric system, while inches are part of the imperial and US
        customary systems. The relationship between them is fixed by
        international agreement.
      </p>
      <p>
        The exact definition is:
      </p>
      <pre>1 inch = 2.54 centimeters</pre>
      <p>
        From this, you can derive the basic conversion formula from centimeters
        to inches:
      </p>
      <pre>inches = centimeters / 2.54</pre>
      <p>
        To use this formula, take your length in centimeters and divide by
        2.54. The result is the same length expressed in inches.
      </p>

      <h3>Reverse formula: inches to centimeters</h3>
      <p>
        If you ever need to go the other way, from inches back to centimeters,
        you can rearrange the same relationship:
      </p>
      <pre>centimeters = inches * 2.54</pre>
      <p>
        Our centimeters to inches converter focuses on cm to in, but this
        reverse formula is useful when you want to check your results or
        convert measurements from imperial to metric.
      </p>
    </section>

    <section class="calc-copy">
      <h2>Real world example: converting height from cm to inches</h2>
      <p>
        Imagine your height is 170 centimeters and you want to know how tall
        that is in inches for a form that uses imperial units.
      </p>
      <ol>
        <li>Start with the value in centimeters: 170 cm.</li>
        <li>Apply the formula inches = centimeters / 2.54.</li>
        <li>Compute 170 / 2.54 = 66.9291 inches.</li>
      </ol>
      <p>
        So a height of 170 cm is about 66.93 inches. If you prefer feet and
        inches, you can divide by 12:
      </p>
      <pre>feet = inches / 12</pre>
      <p>
        66.93 inches is 5 full feet (5 * 12 = 60 inches) plus 6.93 inches, so
        you are about 5 feet 7 inches tall.
      </p>
      <p>
        Our online converter performs the centimeters to inches step instantly,
        helping you avoid manual division and rounding mistakes.
      </p>
    </section>

    <section class="calc-copy">
      <h2>Why use an online centimeters to inches converter?</h2>
      <p>
        While the formula inches = centimeters / 2.54 is simple, doing the math
        by hand or on a basic calculator can be slow and error prone,
        especially when you work with many measurements.
      </p>
      <ul>
        <li>Instant conversion for any value in centimeters.</li>
        <li>Consistent use of the exact 2.54 factor for high precision.</li>
        <li>No need to remember the formula or do repeated division.</li>
      </ul>
      <p>
        This is particularly helpful for students, engineers, designers, and
        anyone who frequently switches between metric and imperial units.
      </p>
    </section>

    <section class="calc-faq">
      <h2>Frequently asked questions about converting cm to inches</h2>
      {faqs.map((item) => (
        <article class="calc-faq__item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))}
    </section>
  </main>
</Layout>
