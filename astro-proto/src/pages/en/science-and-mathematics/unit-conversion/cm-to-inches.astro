---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "cm-to-inches";

const pageTitle = "Centimeters to Inches Converter";
const pageDescription =
  "Fast centimeters to inches converter. Convert cm to inches and inches to cm instantly, see the formula, and understand how to switch between metric and imperial lengths.";

const calculatorConfig = {
  id: "cm-to-inches",
  mode: "unit-conversion",
  primaryInputLabel: "Length in centimeters",
  primaryInputName: "centimeters",
  primaryInputUnit: "cm",
  secondaryInputLabel: "Length in inches",
  secondaryInputName: "inches",
  secondaryInputUnit: "in",
  inputMode: "decimal",
  layout: "cockpit",
  autoCalculate: true,
  showCalculateButton: true,
  showResetButton: true,
  showShareButton: true,
  hasAdvancedMode: true,
  advancedTitle: "Reverse conversion and details",
  formula: {
    type: "linear-bidirectional",
    expressionForward: "inches = centimeters / 2.54",
    expressionBackward: "centimeters = inches * 2.54",
    factorForward: 1 / 2.54,
    factorBackward: 2.54,
    precision: 4
  },
  fields: [
    {
      name: "centimeters",
      label: "Centimeters",
      unit: "cm",
      placeholder: "Enter length in centimeters",
      inputMode: "decimal",
      role: "primary",
      tooltip: "Type the length in centimeters that you want to convert to inches."
    },
    {
      name: "inches",
      label: "Inches",
      unit: "in",
      placeholder: "Or enter length in inches",
      inputMode: "decimal",
      role: "secondary",
      tooltip: "You can also enter inches to convert back to centimeters."
    }
  ],
  result: {
    primaryResultLabel: "Result in inches",
    secondaryResultLabel: "Result in centimeters",
    stickyOnMobile: true,
    highlightOnChange: true
  },
  ui: {
    theme: "default",
    showVerifiedBadge: true,
    verifiedText: "Formula based on the international inch definition (1 inch = 2.54 cm).",
    showMiniSummary: true
  },
  share: {
    enabled: true,
    paramMap: {
      centimeters: "cm",
      inches: "in"
    }
  }
};

const faqs = [
  {
    question: "How do you convert centimeters to inches?",
    answer:
      "To convert centimeters to inches, divide the length in centimeters by 2.54. For example, 10 cm / 2.54 is about 3.937 inches."
  },
  {
    question: "What is 1 centimeter in inches?",
    answer:
      "One centimeter is equal to about 0.3937 inches. This comes from the exact definition 1 inch = 2.54 centimeters."
  },
  {
    question: "Why is 2.54 used to convert between centimeters and inches?",
    answer:
      "The inch is officially defined as exactly 2.54 centimeters in the International System of Units. That fixed relationship is why every cm to inch conversion uses the factor 2.54."
  }
];

const breadcrumbItems = [
  {
    name: "Home",
    url: "https://calcdomain.com/"
  },
  {
    name: "Science and mathematics",
    url: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    name: "Unit Conversion",
    url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    name: "Centimeters to Inches Converter",
    url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/cm-to-inches/"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Centimeters to Inches Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/cm-to-inches/",
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description:
    "Interactive centimeters to inches converter that instantly converts cm to inches and inches to cm using the official 1 inch = 2.54 cm definition.",
  featureList: [
    "Centimeters to inches conversion",
    "Inches to centimeters reverse conversion",
    "Instant calculation while typing",
    "Shareable URL with prefilled values"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.url
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Centimeters to Inches Converter</h1>
        <p class="hero-subtitle">
          Convert centimeters to inches and back in seconds with an instant, mobile-friendly length converter.
        </p>
        <p class="hero-trust">
          Uses the official definition 1 inch = 2.54 centimeters. Optimized for fast, accurate unit conversion.
        </p>
      </div>
      <div class="hero-meta">
        <p class="meta-pill">Science and mathematics &#8250; Unit conversion</p>
        <p class="meta-updated">Updated for 2025 reference standards</p>
      </div>
    </header>

    <section class="layout">
      <div class="layout-main">
        <section aria-label="Centimeters to inches calculator" class="calculator-section">
          <CalculatorIsland slug={slug} config={calculatorConfig} />
        </section>

        <section class="content-section" aria-labelledby="how-it-works">
          <h2 id="how-it-works">How the centimeters to inches formula works</h2>
          <p>
            The centimeter is part of the metric system, while the inch belongs to the imperial system. The
            relationship between them is fixed by an international agreement that defines one inch as exactly
            2.54 centimeters.
          </p>
          <p>The core formulas are:</p>
          <pre>inches = centimeters / 2.54</pre>
          <pre>centimeters = inches * 2.54</pre>
          <p>
            This means that every time you convert from centimeters to inches, you divide by 2.54. When you go
            from inches back to centimeters, you multiply by 2.54. Because the factor is exact, any rounding in
            your result only comes from how many decimal places you choose to keep.
          </p>
        </section>

        <section class="content-section" aria-labelledby="real-world-example">
          <h2 id="real-world-example">Real world example: converting height from cm to inches</h2>
          <p>
            Suppose your height is 170 centimeters and you want to know the equivalent in inches for a form that
            uses imperial units.
          </p>
          <p>Apply the formula:</p>
          <pre>inches = centimeters / 2.54</pre>
          <p>
            Plug in the value:
          </p>
          <pre>inches = 170 / 2.54</pre>
          <p>
            The result is about 66.93 inches. If you prefer to round to one decimal place, you can say your
            height is about 66.9 inches.
          </p>
        </section>

        <section class="content-section" aria-labelledby="faq">
          <h2 id="faq">Centimeters to inches converter: frequently asked questions</h2>
          <dl class="faq-list">
            {faqs.map((item) => (
              <div class="faq-item">
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      </div>

      <aside class="layout-sidebar" aria-label="Related tools and information">
        <div class="ad-slot">
          <p class="ad-label">Sponsored</p>
          <div class="ad-placeholder">
            Right rail ad space reserved for high-visibility campaigns.
          </div>
        </div>
      </aside>
    </section>
  </main>

<style>
  .page {
    padding: 1.5rem 1rem 3rem;
    max-width: 1120px;
    margin: 0 auto;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .hero-main h1 {
    font-size: 1.9rem;
    line-height: 1.2;
    margin: 0 0 0.35rem 0;
  }

  .hero-subtitle {
    margin: 0 0 0.35rem 0;
    color: #333333;
  }

  .hero-trust {
    margin: 0;
    font-size: 0.95rem;
    color: #555555;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #666666;
  }

  .meta-pill {
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: #f3f4f6;
  }

  .meta-updated {
    padding: 0.15rem 0.5rem;
  }

  .layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .layout-main {
    flex: 1 1 auto;
    min-width: 0;
  }

  .layout-sidebar {
    flex: 0 0 auto;
  }

  .calculator-section {
    margin-bottom: 1.75rem;
  }

  .content-section {
    margin-bottom: 1.75rem;
  }

  .content-section h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  pre {
    background: #f9fafb;
    padding: 0.6rem 0.75rem;
    border-radius: 0.35rem;
    font-size: 0.9rem;
    overflow-x: auto;
  }

  .faq-list {
    margin: 0;
    padding: 0;
  }

  .faq-item {
    margin-bottom: 1rem;
  }

  .faq-item dt {
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .faq-item dd {
    margin: 0;
  }

  .ad-slot {
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    padding: 0.75rem;
    background: #ffffff;
  }

  .ad-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9ca3af;
    margin: 0 0 0.5rem 0;
  }

  .ad-placeholder {
    min-height: 180px;
    background: repeating-linear-gradient(
      45deg,
      #f3f4f6,
      #f3f4f6 10px,
      #e5e7eb 10px,
      #e5e7eb 20px
    );
    border-radius: 0.35rem;
  }

  @media (min-width: 900px) {
    .page {
      padding: 2rem 1.5rem 3rem;
    }

    .hero {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }

    .hero-main {
      max-width: 70%;
    }

    .hero-main h1 {
      font-size: 2.1rem;
    }

    .layout {
      flex-direction: row;
      align-items: flex-start;
    }

    .layout-main {
      flex: 1 1 auto;
    }

    .layout-sidebar {
      flex: 0 0 280px;
      position: sticky;
      top: 1.5rem;
    }
  }
</style>
</Layout>
