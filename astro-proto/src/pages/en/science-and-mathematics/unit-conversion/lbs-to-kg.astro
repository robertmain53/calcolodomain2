---
import { Fragment } from "astro/jsx-runtime";
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "lbs-to-kg";

const pageTitle = "Pounds to Kilograms Converter (lbs to kg)";
const pageDescription =
  "Instantly convert pounds to kilograms with this precise lbs to kg calculator. Includes formula, step-by-step examples, and common weight conversions.";

const faqs = [
  {
    question: "How do you convert pounds to kilograms?",
    answer:
      "To convert pounds to kilograms, multiply the weight in pounds by 0.45359237. For example, 150 pounds * 0.45359237 is about 68.04 kilograms.",
  },
  {
    question: "What is 1 pound in kilograms?",
    answer:
      "One pound is exactly 0.45359237 kilograms according to the international avoirdupois pound definition.",
  },
  {
    question: "Why do scientists prefer kilograms instead of pounds?",
    answer:
      "Kilograms are part of the International System of Units, which is the global standard in science and engineering. Using kilograms keeps measurements consistent and avoids confusion between different local units like pounds or stones.",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Pounds to Kilograms Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/lbs-to-kg",
  applicationCategory: "ScienceApplication",
  operatingSystem: "Any",
  description:
    "Interactive pounds to kilograms converter that instantly converts lbs to kg using the standard conversion factor.",
  featureList: [
    "Instant pounds to kilograms conversion",
    "Reverse kilograms to pounds conversion",
    "Step-by-step conversion explanation",
  ],
  creator: {
    "@type": "Organization",
    name: "calcdomain.com",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://calcdomain.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Science and mathematics",
      item: "https://calcdomain.com/en/science-and-mathematics",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Unit Conversion",
      item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion",
    },
    {
      "@type": "ListItem",
      position: 4,
      name: "Pounds to Kilograms Converter",
      item:
        "https://calcdomain.com/en/science-and-mathematics/unit-conversion/lbs-to-kg",
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="calc-page">
    <section class="hero">
      <div class="hero-content">
        <h1>Pounds to Kilograms Converter (lbs to kg)</h1>
        <p class="hero-subtitle">
          Convert pounds to kilograms in seconds with a precise, standards-based
          lbs to kg calculator.
        </p>
        <p class="hero-meta">
          Uses the international avoirdupois pound definition and SI kilogram
          standard.
        </p>
      </div>
    </section>

    <section class="calculator-section">
      <h2>Use the lbs to kg calculator</h2>
      <p>
        Enter a weight in pounds to instantly see the equivalent value in
        kilograms. The tool updates as you type and is optimized for mobile
        numeric input.
      </p>
      <CalculatorIsland slug={slug} />
    </section>

    <section class="theory-section">
      <h2>How the pounds to kilograms conversion works</h2>
      <p>
        Pounds and kilograms are both units of mass. Pounds are commonly used
        in the United States and a few other countries, while kilograms are the
        base unit of mass in the International System of Units.
      </p>
      <p>
        By international agreement, one avoirdupois pound is defined as exactly
        0.45359237 kilograms. This fixed relationship gives the standard
        conversion factor between the two units.
      </p>
      <h3>Formula for converting lbs to kg</h3>
      <p>The general conversion formula is:</p>
      <pre>kilograms = pounds * 0.45359237</pre>
      <p>
        To go in the opposite direction, from kilograms to pounds, you can use
        the inverse factor:
      </p>
      <pre>pounds = kilograms / 0.45359237</pre>
      <p>
        For quick mental estimates, many people round the factor to 0.45, but
        this introduces a small error. The calculator uses the exact factor
        0.45359237 for accurate results.
      </p>
    </section>

    <section class="examples-section">
      <h2>Real world example: body weight conversion</h2>
      <p>
        Imagine you are reading a fitness plan that lists recommended body
        weights in kilograms, but your bathroom scale shows pounds. You want to
        know what 180 pounds is in kilograms.
      </p>
      <p>Apply the formula:</p>
      <pre>kilograms = 180 * 0.45359237</pre>
      <p>
        Multiplying gives approximately 81.65 kilograms. If you enter 180 lbs
        into the calculator, it will return the same value instantly, without
        you needing to do the math by hand.
      </p>
      <p>
        This type of conversion is also common in medicine, nutrition, and
        sports science, where dosage, energy expenditure, or performance tables
        are often given in kilograms.
      </p>
    </section>

    <section class="tips-section">
      <h2>Practical tips for using lbs to kg conversions</h2>
      <ul>
        <li>
          For everyday use, rounding the result to one or two decimal places is
          usually enough. For example, 68.04 kg can be reported as 68.0 kg.
        </li>
        <li>
          When converting for medical dosing or scientific work, keep more
          decimal places or follow the precision recommended by your
          institution.
        </li>
        <li>
          Remember that weight shown on a scale can fluctuate during the day due
          to hydration and other factors, even though the conversion factor
          between pounds and kilograms is fixed.
        </li>
      </ul>
    </section>

    <section class="faq-section">
      <h2>Pounds to kilograms: frequently asked questions</h2>
      {faqs.map((item) => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </section>
  </main>
</Layout>
