---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "science-and-mathematics";
const cluster = "unit-conversion";
const slug = "lbs-to-kg";

const pageTitle = "Pounds to Kilograms Converter (lbs to kg)";
const pageDescription =
  "Instantly convert pounds to kilograms and kilograms to pounds with this precise lbs to kg converter. Includes formula, examples, and common weight conversions.";

const calculatorConfig = {
  mode: "unit-conversion",
  primaryConversion: {
    fromUnit: "pound",
    fromUnitSymbol: "lb",
    toUnit: "kilogram",
    toUnitSymbol: "kg",
    direction: "lbs-to-kg"
  },
  secondaryConversion: {
    enabled: true,
    fromUnit: "kilogram",
    fromUnitSymbol: "kg",
    toUnit: "pound",
    toUnitSymbol: "lb",
    direction: "kg-to-lbs"
  },
  formula: {
    type: "linear",
    expressionForward: "kilograms = pounds * 0.45359237",
    expressionReverse: "pounds = kilograms / 0.45359237",
    factorForward: 0.45359237,
    factorReverse: 1 / 0.45359237
  },
  ui: {
    layout: "cockpit",
    showAdvancedToggle: true,
    showPrecisionControl: true,
    defaultDecimals: 3,
    maxDecimals: 6,
    stickyResultBar: true,
    showShareButton: true,
    showResetButton: true,
    showSwapButton: true,
    highlightResultOnChange: true,
    inputMode: "decimal"
  },
  fields: [
    {
      id: "pounds",
      label: "Weight in pounds",
      placeholder: "Enter weight in lb",
      type: "number",
      inputmode: "decimal",
      role: "primary-input",
      min: 0,
      step: "any",
      tooltip: "Enter the weight in pounds (lb). Use a decimal point for fractions, for example 2.5 lb."
    },
    {
      id: "kilograms",
      label: "Weight in kilograms",
      placeholder: "Result in kg",
      type: "number",
      inputmode: "decimal",
      role: "primary-output",
      readOnly: true,
      tooltip: "Calculated weight in kilograms (kg) using kilograms = pounds * 0.45359237."
    },
    {
      id: "kilogramsAdvanced",
      label: "Weight in kilograms",
      placeholder: "Enter weight in kg",
      type: "number",
      inputmode: "decimal",
      role: "secondary-input",
      min: 0,
      step: "any",
      advanced: true,
      tooltip: "Enter the weight in kilograms (kg) to convert back to pounds."
    },
    {
      id: "poundsAdvanced",
      label: "Weight in pounds",
      placeholder: "Result in lb",
      type: "number",
      inputmode: "decimal",
      role: "secondary-output",
      readOnly: true,
      advanced: true,
      tooltip: "Calculated weight in pounds (lb) using pounds = kilograms / 0.45359237."
    }
  ],
  actions: {
    autoCalculate: true,
    showCalculateButton: true,
    calculateButtonLabel: "Calculate",
    resetButtonLabel: "Reset",
    shareButtonLabel: "Share"
  },
  validation: {
    rules: [
      {
        fieldId: "pounds",
        type: "min",
        value: 0,
        message: "Weight in pounds cannot be negative."
      },
      {
        fieldId: "kilogramsAdvanced",
        type: "min",
        value: 0,
        message: "Weight in kilograms cannot be negative."
      }
    ]
  },
  meta: {
    verifiedBy: "Unit conversion based on the international avoirdupois pound definition.",
    lastReviewed: "2025-01-01"
  }
};

const faqs = [
  {
    question: "How do you convert pounds to kilograms?",
    answer:
      "To convert pounds to kilograms, multiply the weight in pounds by 0.45359237. For example, 10 lb * 0.45359237 = 4.5359237 kg."
  },
  {
    question: "Is 1 kilogram equal to 2.2 pounds?",
    answer:
      "One kilogram is approximately 2.20462 pounds. The exact factor is 1 kg = 2.20462262185 lb, but 2.2 lb is often used as a quick mental approximation."
  },
  {
    question: "Why do some results differ slightly between converters?",
    answer:
      "Small differences come from rounding. The exact factor is 1 lb = 0.45359237 kg. Some converters round this to fewer decimal places, which can change the result slightly for large weights."
  }
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/"
  },
  {
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/"
  },
  {
    position: 3,
    name: "Unit Conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/"
  },
  {
    position: 4,
    name: "Pounds to Kilograms Converter",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/lbs-to-kg"
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Pounds to Kilograms Converter",
  url: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/lbs-to-kg",
  applicationCategory: "ScienceApplication",
  operatingSystem: "Any",
  description:
    "Interactive pounds to kilograms converter that instantly converts lb to kg and kg to lb using the exact international conversion factor.",
  featureList: [
    "Pounds to kilograms conversion",
    "Kilograms to pounds reverse conversion",
    "Adjustable decimal precision",
    "Shareable URL with prefilled values"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((crumb) => ({
    "@type": "ListItem",
    position: crumb.position,
    name: crumb.name,
    item: crumb.item
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Pounds to Kilograms Converter</h1>
        <p class="hero-subtitle">
          Convert pounds to kilograms and back in seconds with precise, standards based lb to kg calculations.
        </p>
        <p class="hero-meta">
          Updated for the current international avoirdupois pound definition. Optimized for mobile and desktop.
        </p>
      </div>
      <div class="hero-aside">
        <div class="trust-badges">
          <span class="badge">High precision factor: 1 lb = 0.45359237 kg</span>
          <span class="badge">Instant results</span>
          <span class="badge">No sign up required</span>
        </div>
      </div>
    </header>

    <section class="layout">
      <div class="layout-main">
        <section aria-labelledby="calculator-heading" class="calculator-section">
          <div class="calculator-header">
            <h2 id="calculator-heading">Pounds to kilograms calculator</h2>
            <p>
              Enter a weight in pounds to see the equivalent in kilograms. Use the advanced options to convert kilograms
              back to pounds and fine tune decimal precision.
            </p>
          </div>

          <CalculatorIsland slug={slug} config={calculatorConfig} />

          <div class="calculator-footnote">
            <p>
              Verified by: based on the international avoirdupois pound, where 1 pound is defined as exactly 0.45359237
              kilograms.
            </p>
          </div>
        </section>

        <section aria-labelledby="how-it-works-heading" class="content-section">
          <h2 id="how-it-works-heading">How the pounds to kilograms conversion works</h2>
          <p>
            The pound (symbol lb) is commonly used in the United States and a few other countries, while the kilogram
            (symbol kg) is the base unit of mass in the International System of Units. To compare or combine
            measurements from different systems, you often need to convert between pounds and kilograms.
          </p>
          <p>
            By international agreement, the relationship between pounds and kilograms is fixed. One avoirdupois pound is
            defined as exactly 0.45359237 kilograms. This means the conversion factor never changes.
          </p>

          <h3>Formula for pounds to kilograms</h3>
          <p>Use this formula to convert from pounds to kilograms:</p>
          <pre>kilograms = pounds * 0.45359237</pre>
          <p>To go the other way, from kilograms to pounds, use the inverse formula:</p>
          <pre>pounds = kilograms / 0.45359237</pre>
          <p>
            For quick mental math, many people approximate 1 kg as 2.2 lb. This is close but not exact. The calculator
            on this page uses the full precise factor so that even large weights remain accurate.
          </p>
        </section>

        <section aria-labelledby="example-heading" class="content-section">
          <h2 id="example-heading">Real world example: converting body weight</h2>
          <p>
            Imagine your bathroom scale shows 165 lb, but your doctor records weight in kilograms. To find your weight
            in kilograms, multiply by the conversion factor:
          </p>
          <pre>kilograms = 165 lb * 0.45359237</pre>
          <p>
            The result is approximately 74.842 kg. If you round to one decimal place, you would record your weight as
            74.8 kg.
          </p>
          <p>
            You can use the same approach for luggage limits, gym weights, shipping weights, or any situation where you
            need to switch between imperial and metric units.
          </p>
        </section>

        <section aria-labelledby="tips-heading" class="content-section">
          <h2 id="tips-heading">Tips for accurate lb to kg conversions</h2>
          <ul>
            <li>
              Use more decimal places when converting large weights, such as cargo or vehicle mass, to avoid rounding
              errors.
            </li>
            <li>
              For everyday use, rounding to one or two decimal places is usually enough, for example 72.5 kg or 72.53
              kg.
            </li>
            <li>
              Remember that 1 stone is 14 lb. If you work with stones and pounds, convert the total pounds to kilograms
              using the same factor.
            </li>
          </ul>
        </section>

        <section aria-labelledby="faq-heading" class="content-section faq-section">
          <h2 id="faq-heading">Pounds to kilograms converter: frequently asked questions</h2>
          <dl>
            {faqs.map((item) => (
              <div class="faq-item">
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      </div>

      <aside class="layout-sidebar" aria-label="Related tools and information">
        <div class="sidebar-block">
          <h2 class="sidebar-heading">About this tool</h2>
          <p>
            This pounds to kilograms converter is designed for fast, accurate everyday use. It works on mobile and
            desktop, with large inputs and instant feedback.
          </p>
        </div>
        <div class="sidebar-block sidebar-ads">
          <h2 class="sidebar-heading">Sponsored results</h2>
          <div class="ad-slot">Right rail ad slot</div>
        </div>
      </aside>
    </section>
  </main>

<style>
  .page {
    padding: 1.5rem 1rem 3rem;
    max-width: 1120px;
    margin: 0 auto;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .hero-main h1 {
    font-size: 1.9rem;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .hero-meta {
    font-size: 0.9rem;
    color: #555;
  }

  .hero-aside .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    font-size: 0.8rem;
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    background: #f3f4f6;
    color: #111827;
    border: 1px solid #e5e7eb;
  }

  .layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .layout-main {
    flex: 1 1 auto;
    min-width: 0;
  }

  .layout-sidebar {
    flex: 0 0 280px;
  }

  .calculator-section {
    border-radius: 0.75rem;
    border: 1px solid #e5e7eb;
    padding: 1.25rem;
    background: #ffffff;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.03);
    margin-bottom: 1.75rem;
  }

  .calculator-header h2 {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .calculator-header p {
    font-size: 0.95rem;
    color: #4b5563;
  }

  .calculator-footnote {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: #6b7280;
  }

  .content-section {
    margin-bottom: 1.75rem;
  }

  .content-section h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .content-section h3 {
    font-size: 1.05rem;
    margin-top: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .content-section p {
    font-size: 0.95rem;
    color: #374151;
    margin-bottom: 0.5rem;
  }

  .content-section ul {
    padding-left: 1.25rem;
    font-size: 0.95rem;
    color: #374151;
  }

  .content-section li + li {
    margin-top: 0.25rem;
  }

  pre {
    background: #f9fafb;
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
    overflow-x: auto;
    border: 1px solid #e5e7eb;
  }

  .faq-section dl {
    margin: 0;
  }

  .faq-item {
    padding: 0.75rem 0;
    border-top: 1px solid #e5e7eb;
  }

  .faq-item:first-of-type {
    border-top: none;
  }

  .faq-item dt {
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .faq-item dd {
    margin: 0;
    font-size: 0.95rem;
    color: #374151;
  }

  .sidebar-block {
    border-radius: 0.75rem;
    border: 1px solid #e5e7eb;
    padding: 1rem;
    background: #f9fafb;
    font-size: 0.9rem;
    color: #374151;
  }

  .sidebar-block + .sidebar-block {
    margin-top: 1rem;
  }

  .sidebar-heading {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .sidebar-ads .ad-slot {
    height: 250px;
    border-radius: 0.5rem;
    border: 1px dashed #d1d5db;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    color: #9ca3af;
    background: #ffffff;
  }

  @media (min-width: 900px) {
    .hero {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }

    .hero-main {
      flex: 1 1 auto;
      padding-right: 1.5rem;
    }

    .hero-aside {
      flex: 0 0 260px;
    }

    .layout {
      flex-direction: row;
      align-items: flex-start;
    }

    .layout-main {
      flex: 1 1 auto;
    }

    .layout-sidebar {
      flex: 0 0 280px;
      position: sticky;
      top: 1rem;
      align-self: flex-start;
    }

    .calculator-section {
      padding: 1.5rem;
    }
  }
</style>
</Layout>
