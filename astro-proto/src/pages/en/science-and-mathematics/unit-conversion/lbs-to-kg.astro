---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const pageTitle = "Pounds to Kilograms Converter";
const pageSlug = "lbs-to-kg";
const hub = "Science and mathematics";
const cluster = "Unit Conversion";

const canonicalUrl = "https://calcdomain.com/en/science-and-mathematics/unit-conversion/lbs-to-kg";
const description =
  "Instantly convert pounds (lbs) to kilograms (kg) and back. Accurate 1 lb = 0.45359237 kg formula, step-by-step explanation, and real-world examples.";
const keywords = "lbs to kg, pounds to kilograms converter, lb to kg, weight conversion";
const updatedYear = "2025";

const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/",
  },
  {
    "@type": "ListItem",
    position: 2,
    name: "Science and mathematics",
    item: "https://calcdomain.com/en/science-and-mathematics/",
  },
  {
    "@type": "ListItem",
    position: 3,
    name: "Unit Conversion",
    item: "https://calcdomain.com/en/science-and-mathematics/unit-conversion/",
  },
  {
    "@type": "ListItem",
    position: 4,
    name: "Pounds to Kilograms Converter",
    item: canonicalUrl,
  },
];

const webAppJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: pageTitle,
  url: canonicalUrl,
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  description,
  featureList: [
    "Instant pounds to kilograms conversion",
    "Reverse kilograms to pounds conversion",
    "Mobile-friendly numeric keypad inputs",
    "Sticky result bar on mobile",
    "Shareable URL with prefilled values",
    "Reset function to clear all fields",
  ],
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do you convert pounds to kilograms?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "To convert pounds (lb) to kilograms (kg), multiply the weight in pounds by 0.45359237. For example, 150 lb × 0.45359237 ≈ 68.04 kg.",
      },
    },
    {
      "@type": "Question",
      name: "Is 1 pound exactly 0.45 kg?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "No. By international agreement, 1 pound (avoirdupois) is defined as exactly 0.45359237 kilograms. Rounding it to 0.45 kg is fine for rough estimates but not for precise calculations.",
      },
    },
    {
      "@type": "Question",
      name: "How many pounds are in 1 kilogram?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "To convert kilograms to pounds, divide the weight in kilograms by 0.45359237 or multiply by approximately 2.20462262. So 1 kg ≈ 2.2046 lb.",
      },
    },
  ],
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};
---

<Layout
  title={pageTitle}
  description={description}
  canonical={canonicalUrl}
  meta={{
    keywords,
  }}
>
  <head>
    <script type="application/ld+json">
      {JSON.stringify(webAppJsonLd)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqJsonLd)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbJsonLd)}
    </script>
  </head>

  <main class="page">
    <section class="hero">
      <div class="hero-main">
        <h1>Pounds to Kilograms Converter</h1>
        <p class="hero-subtitle">
          Convert pounds (lb) to kilograms (kg) and back in seconds using the exact 1 lb = 0.45359237 kg formula, updated for {updatedYear}.
        </p>
        <div class="hero-trust">
          <span class="trust-pill">High-precision weight conversion</span>
          <span class="trust-pill">Based on international avoirdupois pound definition</span>
          <span class="trust-pill">Optimized for mobile &amp; desktop</span>
        </div>
        <p class="hero-verified">
          Verified by: internal QA against NIST and international standard definition of the pound (avoirdupois).
        </p>
      </div>
      <aside class="hero-aside">
        <div class="hero-aside-card">
          <h2>Why use this lbs to kg converter?</h2>
          <ul>
            <li>Instant, accurate conversion both ways (lb ↔ kg).</li>
            <li>Perfect for fitness, shipping, and science homework.</li>
            <li>Copy &amp; share results with a single click.</li>
          </ul>
        </div>
      </aside>
    </section>

    <section class="calculator-section">
      <div class="calculator-layout">
        <div class="calculator-main">
          <CalculatorIsland
            id="lbs-to-kg"
            title={pageTitle}
            mode="unit-conversion"
            primaryInputLabel="Weight in pounds"
            primaryInputName="pounds"
            primaryInputPlaceholder="e.g. 150"
            primaryInputUnit="lb"
            secondaryInputLabel="Weight in kilograms"
            secondaryInputName="kilograms"
            secondaryInputPlaceholder="e.g. 68.04"
            secondaryInputUnit="kg"
            primaryToSecondaryFactor={0.45359237}
            secondaryToPrimaryFactor={2.2046226218488}
            inputHint="Use a decimal point (.) for fractions, for example 150.5."
            advancedToggleLabel="Show kg → lb (reverse conversion)"
            calculateButtonLabel="Calculate"
            resetButtonLabel="Reset"
            shareButtonLabel="Share"
            resultLabel="Converted weight"
            resultPrimaryUnit="kg"
            resultSecondaryUnit="lb"
            stickyResultLabel="lbs → kg"
            seoSlug={pageSlug}
          />
        </div>

        <aside class="calculator-sidebar">
          <div class="sidebar-card">
            <h2>Quick reference: common lbs to kg values</h2>
            <ul class="quick-list">
              <li>100 lb ≈ 45.36 kg</li>
              <li>150 lb ≈ 68.04 kg</li>
              <li>200 lb ≈ 90.72 kg</li>
              <li>220 lb ≈ 99.79 kg</li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2>Tips</h2>
            <ul class="quick-list">
              <li>For rough mental math, use 1 lb ≈ 0.45 kg.</li>
              <li>For precise work, always keep at least 2 decimal places.</li>
              <li>Use this tool before entering weights into scientific or medical forms.</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section class="content-section" id="theory">
      <h2>How to convert pounds to kilograms</h2>
      <p>
        This converter uses the internationally agreed definition of the avoirdupois pound:
        1 pound is exactly equal to 0.45359237 kilograms. That means every pound you enter is
        multiplied by this constant to get kilograms.
      </p>
      <p>
        In formula form (written as plain text, not executable code):
      </p>
      <pre class="formula">
lbs to kg:   kg = lb × 0.45359237
kg to lbs:   lb = kg ÷ 0.45359237 ≈ kg × 2.20462262
      </pre>
      <p>
        Because 0.45359237 is an exact definition, any rounding you see in the result comes
        only from how many decimal places you choose to display, not from the formula itself.
      </p>
    </section>

    <section class="content-section" id="example">
      <h2>Real-world example: converting body weight from lbs to kg</h2>
      <p>
        Imagine you are filling out a medical form in a country that uses kilograms, but your
        bathroom scale shows your weight in pounds. Suppose the scale reads 165 lb.
      </p>
      <ol>
        <li>Enter <strong>165</strong> in the “Weight in pounds” field.</li>
        <li>The converter multiplies 165 by 0.45359237.</li>
        <li>
          The result is approximately <strong>74.84 kg</strong> (rounded to two decimal places).
        </li>
      </ol>
      <p>
        If you need to go the other way, for example a lab report lists your weight as
        70 kg and you want to know it in pounds:
      </p>
      <ol>
        <li>Open the advanced options to show the kilograms field.</li>
        <li>Enter <strong>70</strong> in the “Weight in kilograms” field.</li>
        <li>
          The converter multiplies 70 by approximately 2.20462262 and returns about
          <strong>154.32 lb</strong>.
        </li>
      </ol>
      <p>
        This is especially useful for:
      </p>
      <ul>
        <li>Fitness tracking apps that expect kilograms.</li>
        <li>Travel forms and airline baggage limits.</li>
        <li>Science and engineering problems that use SI units.</li>
      </ul>
    </section>

    <section class="content-section" id="faq">
      <h2>Pounds to kilograms converter: FAQs</h2>

      <h3>How accurate is this lbs to kg converter?</h3>
      <p>
        The converter uses the exact definition 1 lb = 0.45359237 kg, which is the same value
        used by standards bodies such as NIST. Any small differences you might see compared to
        other tools usually come from rounding to a different number of decimal places.
      </p>

      <h3>Should I use pounds or kilograms for health and fitness?</h3>
      <p>
        Many medical and scientific contexts prefer kilograms because they are part of the SI
        (metric) system. However, in the United States and a few other countries, bathroom
        scales and gym equipment often show pounds. This converter lets you switch between the
        two instantly so you can use whichever unit your form or app requires.
      </p>

      <h3>Can I convert fractional pounds, like 150.5 lb?</h3>
      <p>
        Yes. Enter decimal values such as 150.5 or 132.25 directly into the pounds field. Make
        sure you use a decimal point (.) rather than a comma, and the converter will return the
        corresponding value in kilograms with the same level of precision.
      </p>
    </section>
  </main>

  <style>
    .page {
      padding: 1.5rem 1rem 3.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 2fr);
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .hero-main h1 {
      font-size: 2rem;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }

    .hero-subtitle {
      font-size: 1rem;
      color: #444;
      margin-bottom: 0.75rem;
    }

    .hero-trust {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .trust-pill {
      font-size: 0.8rem;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      background: #f3f4f6;
      color: #111827;
      border: 1px solid #e5e7eb;
    }

    .hero-verified {
      font-size: 0.8rem;
      color: #6b7280;
    }

    .hero-aside {
      display: none;
    }

    .hero-aside-card {
      border-radius: 0.75rem;
      border: 1px solid #e5e7eb;
      padding: 1rem;
      background: #f9fafb;
    }

    .hero-aside-card h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .hero-aside-card ul {
      padding-left: 1.1rem;
      margin: 0;
    }

    .hero-aside-card li {
      font-size: 0.9rem;
      margin-bottom: 0.25rem;
    }

    .calculator-section {
      margin-bottom: 2.5rem;
    }

    .calculator-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
      align-items: flex-start;
    }

    .calculator-main {
      min-width: 0;
    }

    .calculator-sidebar {
      display: none;
    }

    .sidebar-card {
      border-radius: 0.75rem;
      border: 1px solid #e5e7eb;
      padding: 1rem;
      background: #ffffff;
    }

    .sidebar-card h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .quick-list {
      padding-left: 1.1rem;
      margin: 0;
    }

    .quick-list li {
      font-size: 0.9rem;
      margin-bottom: 0.25rem;
    }

    .content-section {
      margin-bottom: 2rem;
    }

    .content-section h2 {
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }

    .content-section h3 {
      font-size: 1.1rem;
      margin-top: 1rem;
      margin-bottom: 0.4rem;
    }

    .content-section p {
      margin-bottom: 0.6rem;
      color: #374151;
      font-size: 0.95rem;
    }

    .content-section ol,
    .content-section ul {
      padding-left: 1.2rem;
      margin-bottom: 0.75rem;
    }

    .formula {
      background: #111827;
      color: #e5e7eb;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
        "Courier New", monospace;
      font-size: 0.9rem;
      overflow-x: auto;
    }

    @media (min-width: 900px) {
      .hero {
        grid-template-columns: minmax(0, 3fr) minmax(260px, 1.4fr);
        align-items: flex-start;
      }

      .hero-main h1 {
        font-size: 2.3rem;
      }

      .hero-aside {
        display: block;
      }

      .calculator-layout {
        grid-template-columns: minmax(0, 2.2fr) minmax(260px, 1.3fr);
      }

      .calculator-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
    }
  </style>
</Layout>
