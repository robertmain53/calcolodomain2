---
import Layout from "../../../../components/Layout.astro";
import { getTaxonomy } from "../../../../data/taxonomy";

const { hub, cluster } = Astro.params;
const taxonomy = await getTaxonomy();
const hubData = taxonomy.find((entry) => entry.slug === hub);

if (!hubData) {
  throw new Error(`Hub not found: ${hub}`);
}

const clusterData = hubData.clusters.find((entry) => entry.slug === cluster);
if (!clusterData) {
  throw new Error(`Cluster not found: ${cluster} in hub ${hub}`);
}

const pageTitle = `${clusterData.name} calculators | ${hubData.name} | CalcDomain`;
const toolCount = clusterData.tools?.length ?? 0;
const pageDescription =
  clusterData.description ??
  `Discover ${clusterData.name} calculators inside the ${hubData.name} hub, complete with quick access, theory, and verified conversions.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="cluster-hero">
    <p class="eyebrow">{hubData.name} hub</p>
    <h1>{clusterData.name}</h1>
    <p class="lead">
      {clusterData.description ??
        "All calculators within this cluster share context, theory sections, and the CalculatorIsland experience."}
    </p>
    <div class="cluster-stats">
      <span>{toolCount} calculators</span>
      <a class="cta-link" href={`/en/${hubData.slug}`}>Return to {hubData.name}</a>
    </div>
  </section>

  <section class="tool-list">
    {toolCount === 0 && (
      <p class="muted">
        Coming soon: we are populating {clusterData.name} calculators. Check back soon for engineering-grade tools.
      </p>
    )}
    {clusterData.tools?.map((tool) => (
      <article>
        <header>
          <h2>{tool.title}</h2>
          <p>Instant access, mobile-first inputs, verified accuracy.</p>
        </header>
        <a class="tool-link" href={tool.url}>
          Open calculator
        </a>
      </article>
    ))}
  </section>
</Layout>

<style>
  .cluster-hero {
    padding: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .cluster-hero h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.8rem);
  }
  .cluster-hero .lead {
    margin: 0;
    color: #cbd5f5;
    max-width: 680px;
  }
  .cluster-stats {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    font-weight: 600;
    color: #e0f2fe;
  }
  .cta-link {
    color: #38bdf8;
    text-decoration: none;
  }

  .tool-list {
    display: grid;
    gap: 1rem;
  }
  .tool-list article {
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 1rem;
    padding: 1.25rem;
    background: rgba(15, 23, 42, 0.6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .tool-list header h2 {
    margin: 0;
    font-size: 1.2rem;
  }
  .tool-list header p {
    margin: 0.25rem 0 0;
    color: #cbd5f5;
  }
  .tool-link {
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #22d3ee, #4f46e5);
    color: #020617;
    font-weight: 600;
    text-decoration: none;
  }
  .muted {
    color: #94a3b8;
    font-size: 0.95rem;
  }

  @media (max-width: 720px) {
    .tool-list article {
      flex-direction: column;
      align-items: flex-start;
    }
    .cluster-stats {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
