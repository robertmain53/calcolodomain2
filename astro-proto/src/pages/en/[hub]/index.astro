---
import Layout from "../../../components/Layout.astro";
import { getTaxonomy } from "../../../data/taxonomy";

export const prerender = true;

export async function getStaticPaths() {
  const taxonomy = await getTaxonomy();
  return taxonomy.map((entry) => ({
    params: { hub: entry.slug },
  }));
}

const { hub } = Astro.params;
const taxonomy = await getTaxonomy();
const hubData = taxonomy.find((entry) => entry.slug === hub);

if (!hubData) {
  throw new Error(`Hub not found: ${hub}`);
}

const calculatorCount = hubData.clusters.reduce(
  (sum, cluster) => sum + (cluster.tools?.length ?? 0),
  0,
);
const pageTitle = `${hubData.name} calculators | CalcDomain`;
const pageDescription =
  hubData.description ??
  `Find ${hubData.name} calculators grouped by clusters tailored to engineering, science, and finance workflows.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="hub-hero">
    <p class="eyebrow">Hub</p>
    <h1>{hubData.name}</h1>
    <p class="lead">{hubData.description}</p>
    <div class="hub-stats">
      <span>{hubData.clusters.length} clusters</span>
      <span>{calculatorCount} calculators</span>
    </div>
  </section>

  <section class="cluster-grid">
    {hubData.clusters.map((cluster) => (
      <article>
        <header>
          <a class="cluster-title" href={`/en/${hubData.slug}/${cluster.slug}`}>
            {cluster.name}
          </a>
          <p class="cluster-copy">
            {cluster.description ??
              `Explore ${cluster.name.toLowerCase()} calculators and use cases.`}
          </p>
        </header>
        <div class="cluster-meta">
          <span>{cluster.tools?.length ?? 0} calculators</span>
          <a class="cluster-link" href={`/en/${hubData.slug}/${cluster.slug}`}>
            View cluster
          </a>
        </div>
        {cluster.tools && cluster.tools.length > 0 && (
          <ul>
            {cluster.tools.slice(0, 3).map((tool) => (
              <li>
                <a href={tool.url}>{tool.title}</a>
              </li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </section>
</Layout>

<style>
  .hub-hero {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2rem 0;
  }
  .hub-hero h1 {
    margin: 0;
    font-size: clamp(2.2rem, 3vw, 3rem);
  }
  .hub-hero .lead {
    max-width: 700px;
    color: #cbd5f5;
    margin: 0;
  }
  .hub-stats {
    display: flex;
    gap: 1.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: #e0f2fe;
  }

  .cluster-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
  }
  .cluster-grid article {
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 1.25rem;
    padding: 1.25rem;
    background: rgba(15, 23, 42, 0.65);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .cluster-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #f8fafc;
    text-decoration: none;
  }
  .cluster-copy {
    margin: 0;
    color: #cbd5f5;
    font-size: 0.95rem;
  }
  .cluster-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: #94a3b8;
  }
  .cluster-link {
    color: #38bdf8;
    font-weight: 600;
    text-decoration: none;
  }
  .cluster-grid ul {
    margin: 0;
    padding-left: 1rem;
    color: #e2e8f0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .cluster-grid li a {
    color: #cbd5f5;
    text-decoration: none;
  }
  .cluster-grid li a:hover {
    color: #38bdf8;
  }

  @media (max-width: 640px) {
    .hub-stats {
      flex-direction: column;
    }
  }
</style>
