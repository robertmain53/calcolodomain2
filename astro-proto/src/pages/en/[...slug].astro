---
import Layout from "../../components/Layout.astro";
import SeoHead from "../../components/SeoHead.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import StructuredData from "../../components/StructuredData.astro";
import RelatedList from "../../components/RelatedList.astro";
import CalculatorIsland from "../../components/CalculatorIsland.astro";
import { findPage, relatedPages, pages } from "../../data/pages";
import { metricForPath } from "../../data/metrics";

export const getStaticPaths = () => {
  // Generate paths for pages, hubs, and clusters so the build is fully static.
  const pagePaths = pages
    .filter((p) => p.locale === "en")
    .map((p) => ({ params: { slug: p.slug.join("/") } }));

  const hubSlugs = Array.from(
    new Set(pages.filter((p) => p.locale === "en").map((p) => p.slug[0])),
  ).map((slug) => ({ params: { slug } }));

  const clusterSlugs = Array.from(
    new Set(
      pages
        .filter((p) => p.locale === "en")
        .map((p) => p.slug.slice(0, 2).join("/")),
    ),
  ).map((pair) => ({ params: { slug: pair } }));

  return [...pagePaths, ...hubSlugs, ...clusterSlugs];
};

const slugParam = Astro.params.slug;
const segments = slugParam ? slugParam.split("/") : [];

const page = findPage("en", segments);

const hubPages =
  !page && segments.length === 1
    ? pages.filter((p) => p.locale === "en" && p.slug[0] === segments[0])
    : [];

const clusterPages =
  !page && segments.length === 2
    ? pages.filter(
        (p) =>
          p.locale === "en" &&
          p.slug[0] === segments[0] &&
          p.slug[1] === segments[1],
      )
    : [];

let mode: "page" | "hub" | "cluster" | "notfound" = "notfound";
if (page) mode = "page";
else if (hubPages.length > 0) mode = "hub";
else if (clusterPages.length > 0) mode = "cluster";

if (mode === "notfound") {
  Astro.response.status = 404;
}

const crumbs =
  mode === "page"
    ? [
        { href: "/en", label: "Home" },
        { href: `/en/${page.slug[0]}`, label: page.primary.hub },
        {
          href: `/en/${page.slug.slice(0, 2).join("/")}`,
          label: page.primary.cluster,
        },
        { href: `/en/${page.slug.join("/")}`, label: page.title },
      ]
    : mode === "hub"
      ? [
          { href: "/en", label: "Home" },
          { href: `/en/${segments[0]}`, label: hubPages[0].primary.hub },
        ]
      : mode === "cluster"
        ? [
            { href: "/en", label: "Home" },
            { href: `/en/${segments[0]}`, label: clusterPages[0].primary.hub },
            {
              href: `/en/${segments.slice(0, 2).join("/")}`,
              label: clusterPages[0].primary.cluster,
            },
          ]
        : [];

const related = page ? relatedPages(page).slice(0, 4) : [];
---

{mode === "page" ? (
  <Layout title={page.title} description={page.description}>
    <Fragment slot="head">
      <SeoHead title={page.title} description={page.description} slug={page.slug} />
      <StructuredData page={page} breadcrumbs={crumbs} />
    </Fragment>

    <Breadcrumbs items={crumbs} />

    <section class="hero">
      <div>
        <p class="kicker">{page.primary.hub} · {page.primary.cluster}</p>
        <h1>{page.title}</h1>
        <p class="lede">{page.description}</p>
        {page.secondary && (
          <p class="secondary">
            Also relevant:{" "}
            {page.secondary.map((s) => `${s.hub} · ${s.cluster}`).join(", ")}
          </p>
        )}
        <div class="tags">
          <span class="pill">{page.template}</span>
          {page.monetization?.map((m) => (
            <span class="pill muted">{m}</span>
          ))}
        </div>
      </div>
      <div class="calc-box">
        <CalculatorIsland page={page} />
      </div>
    </section>

    <section class="panel grid">
      <div>
        <h2>Inputs &amp; variables</h2>
        <ul>
          {page.content.variables.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
      <div>
        <h2>Theory</h2>
        {page.content.theory.map((item) => (
          <p>{item}</p>
        ))}
      </div>
    </section>

    <section class="panel">
      <h2>Examples</h2>
      <ul>
        {page.content.examples.map((ex) => (
          <li>{ex}</li>
        ))}
      </ul>
    </section>

    <section class="panel">
      <h2>FAQ</h2>
      <div class="faq">
        {page.content.faqs.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="panel cta">
      <div>
        <h3>Need more?</h3>
        <p class="muted">Export results, compare scenarios, and get pro guidance.</p>
      </div>
      <div class="cta-actions">
        <a class="pill" href="#">Download (CSV/PDF)</a>
        <a class="pill muted" href="#">Related guides</a>
      </div>
    </section>

    <RelatedList items={related} />
  </Layout>
) : mode === "hub" ? (
  <Layout
    title={`${hubPages[0].primary.hub} calculators`}
    description={`Explore ${hubPages[0].primary.hub} calculators organized by clusters.`}
  >
    <Fragment slot="head">
      <SeoHead
        title={`${hubPages[0].primary.hub} calculators`}
        description={`Explore ${hubPages[0].primary.hub} calculators organized by clusters.`}
        slug={[segments[0]]}
      />
    </Fragment>
    <Breadcrumbs items={crumbs} />
    <section class="panel">
      <div class="panel-head">
        <div>
          <h1>{hubPages[0].primary.hub}</h1>
          <p class="lede">
            Hub-level view with clusters, quick filters, and educational context to build topical authority.
          </p>
        </div>
        <div class="facets">
          <button class="chip" type="button" data-filter="all" onclick="filterClusters(event)">All</button>
          <button class="chip" type="button" data-filter="high-impact" onclick="filterClusters(event)">High impact</button>
          <button class="chip" type="button" data-filter="popular" onclick="filterClusters(event)">Popular</button>
        </div>
      </div>
      <div class="edu">
        <strong>Why this matters:</strong> Hubs act as semantic pillars. Add short educational blurbs and curated deep links to increase crawl depth and user understanding.
      </div>
      <div class="grid cards" id="cluster-grid">
        {Array.from(
          new Map(
            hubPages.map((p) => [p.slug[1], p.primary.cluster]),
          ).entries(),
        ).map(([clusterSlug, clusterName]) => {
          const count = hubPages.filter((p) => p.slug[1] === clusterSlug).length;
          const met = metricForPath(`/en/${segments[0]}/${clusterSlug}`);
          return (
            <a
              class="card"
              href={`/en/${segments[0]}/${clusterSlug}`}
              data-name={`${clusterName.toLowerCase()}`}
              data-popular={met.isPopular}
              data-impact={met.isHighImpact}
            >
              <div class="title">{clusterName}</div>
              <div class="meta">{count} tools · {met.views} views</div>
              <p class="muted">Faceted nav ready — add filters (personal/business, timeframe, complexity) per hub.</p>
            </a>
          );
        })}
      </div>
    </section>
  </Layout>
) : mode === "cluster" ? (
  <Layout
    title={`${clusterPages[0].primary.cluster} calculators`}
    description={`All calculators in ${clusterPages[0].primary.cluster} within ${clusterPages[0].primary.hub}.`}
  >
    <Fragment slot="head">
      <SeoHead
        title={`${clusterPages[0].primary.cluster} calculators`}
        description={`All calculators in ${clusterPages[0].primary.cluster} within ${clusterPages[0].primary.hub}.`}
        slug={segments}
      />
    </Fragment>
    <Breadcrumbs items={crumbs} />
    <section class="panel">
      <div class="panel-head">
        <div>
          <h1>{clusterPages[0].primary.cluster}</h1>
          <p class="lede">
            Cluster-level view to surface related tools, add mini-guides, and drive crawl depth.
          </p>
        </div>
        <div class="facets">
          <input
            type="search"
            aria-label="Filter tools"
            placeholder="Filter tools in this cluster..."
            oninput="filterTools(event)"
          />
        </div>
      </div>
      <div class="edu">
        <strong>Guidance:</strong> add concise educational text and related links (FAQ/HowTo) to boost topical authority.
      </div>
      <div class="grid cards" id="tool-grid">
        {clusterPages.map((p) => (
          (() => {
            const met = metricForPath(`/en/${p.slug.join("/")}`);
            return (
              <a
                class="card"
                href={`/en/${p.slug.join("/")}`}
                data-name={`${p.title.toLowerCase()} ${p.description.toLowerCase()}`}
                data-popular={met.isPopular}
                data-impact={met.isHighImpact}
              >
                <div class="title">{p.title}</div>
                <div class="meta">
                  {p.primary.hub} · {p.primary.cluster} · {met.views} views
                </div>
                <p>{p.description}</p>
              </a>
            );
          })()
        ))}
      </div>
    </section>
  </Layout>
) : (
  <Layout title="Not found">
    <h1>Not found</h1>
    <p>We could not locate this calculator.</p>
  </Layout>
)}

<style>
  .hero {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: radial-gradient(circle at 20% 10%, rgba(56, 189, 248, 0.1), transparent 40%),
      radial-gradient(circle at 80% 0%, rgba(167, 139, 250, 0.08), transparent 45%),
      rgba(255, 255, 255, 0.02);
    margin-bottom: 1rem;
  }
  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0 0 0.35rem 0;
  }
  h1 {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    color: #fff;
  }
  .lede {
    color: #cbd5e1;
    margin-top: 0.5rem;
  }
  .secondary {
    color: #a5b4fc;
    font-size: 0.95rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.14);
    color: #7dd3fc;
    font-size: 0.9rem;
    border: 1px solid rgba(56, 189, 248, 0.35);
  }
  .pill.muted {
    background: rgba(255, 255, 255, 0.04);
    color: #cbd5e1;
    border-color: var(--border);
  }
  .calc-box {
    border: 1px dashed rgba(148, 163, 184, 0.6);
    border-radius: 12px;
    padding: 1rem;
    min-height: 220px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.03);
    color: #cbd5e1;
    text-align: center;
  }
  .panel {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem 1.2rem;
    background: rgba(255, 255, 255, 0.02);
    margin-top: 1rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }
  h2 {
    margin-top: 0;
    margin-bottom: 0.6rem;
    color: #f1f5f9;
    font-size: 1.2rem;
  }
  ul {
    margin: 0;
    padding-left: 1.2rem;
    color: #cbd5e1;
  }
  li {
    margin-bottom: 0.35rem;
  }
  .cards {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .facets {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .chip {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.7rem;
    background: rgba(255, 255, 255, 0.03);
    color: #e2e8f0;
    cursor: pointer;
  }
  .facets input[type="search"] {
    padding: 0.5rem 0.7rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.03);
    color: #fff;
    min-width: 240px;
  }
  .edu {
    border: 1px dashed var(--border);
    border-radius: 10px;
    padding: 0.75rem 0.85rem;
    color: #cbd5e1;
    margin: 0.6rem 0;
    background: rgba(255, 255, 255, 0.02);
  }
  .card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.9rem;
    background: rgba(255, 255, 255, 0.02);
    color: inherit;
    text-decoration: none;
    transition: 0.15s ease;
  }
  .card:hover {
    border-color: rgba(56, 189, 248, 0.35);
  }
  .card .title {
    font-weight: 600;
    color: #e2e8f0;
  }
  .card .meta {
    color: #94a3b8;
    font-size: 0.9rem;
    margin: 0.35rem 0;
  }
  .cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .cta-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .cta .pill {
    background: rgba(56, 189, 248, 0.16);
    border-color: rgba(56, 189, 248, 0.35);
    color: #e0f2fe;
    text-decoration: none;
  }
  .cta .pill.muted {
    background: rgba(255, 255, 255, 0.04);
    color: #cbd5e1;
  }
  .faq details {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 0.75rem;
    background: rgba(255, 255, 255, 0.02);
    color: #e2e8f0;
  }
  .faq details + details {
    margin-top: 0.5rem;
  }
  summary {
    cursor: pointer;
    font-weight: 600;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary::before {
    content: "›";
    display: inline-block;
    transform: rotate(90deg);
    margin-right: 0.35rem;
    color: #94a3b8;
  }
  details[open] summary::before {
    transform: rotate(270deg);
  }
</style>

<script>
  const filterClusters = (event) => {
    const val = event.target.dataset.filter;
    document.querySelectorAll("#cluster-grid [data-name]").forEach((el) => {
      if (val === "all") {
        el.style.display = "";
        return;
      }
      if (val === "popular") {
        el.style.display = el.dataset.popular === "true" ? "" : "none";
        return;
      }
      if (val === "high-impact") {
        el.style.display = el.dataset.impact === "true" ? "" : "none";
        return;
      }
      el.style.display = "";
    });
  };

  const filterTools = (event) => {
    const query = event.target.value.toLowerCase();
    document.querySelectorAll("#tool-grid [data-name]").forEach((el) => {
      const match = el.getAttribute("data-name")?.includes(query);
      el.style.display = match || !query ? "" : "none";
    });
  };
</script>
