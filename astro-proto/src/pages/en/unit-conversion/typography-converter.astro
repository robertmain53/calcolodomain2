---
import Layout from '../../../../layouts/Layout.astro';
import CalculatorIsland from '../../../../components/CalculatorIsland.astro';
import type { APIMeta } from '../../../../types';

const meta: APIMeta = {
  title: 'Typography Unit Converter (px, pt, em, rem, %)',
  description:
    'Convert typography units between px, pt, em, rem, and percent in seconds. Perfect for web designers and frontend developers working with responsive CSS typography.',
  keywords: ['typography converter', 'px to em', 'px to rem', 'pt to px', 'font size converter'],
  slug: 'typography-converter',
  hub: 'Science and mathematics',
  cluster: 'Unit Conversion',
  lang: 'en',
};

const canonicalUrl = `https://calcdomain.com/en/science-and-mathematics/unit-conversion/typography-converter`;

const faq = [
  {
    question: 'How do you convert px to em or rem?',
    answer:
      'To convert pixels (px) to em or rem, divide the pixel value by the base font size. For example, if the base font size is 16px, then 24px ÷ 16px = 1.5em or 1.5rem. Our typography converter lets you set the base font size and instantly converts between px, em, and rem.',
  },
  {
    question: 'What is the difference between em and rem units in CSS?',
    answer:
      'Both em and rem are relative font-size units in CSS. em is relative to the font size of the current element, while rem is relative to the root (html) font size. Using rem often makes scaling typography across a site more predictable, while em is useful for local, component-level scaling.',
  },
  {
    question: 'When should I use pixels vs relative units for font size?',
    answer:
      'Pixels (px) are absolute units and give you precise control, but they do not scale with user preferences as naturally as relative units. Relative units like em, rem, and percent (% of the parent font size) are better for responsive design and accessibility because they scale when the user changes their default font size or zoom level.',
  },
];

const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: 'https://calcdomain.com/',
  },
  {
    '@type': 'ListItem',
    position: 2,
    name: 'Science and mathematics',
    item: 'https://calcdomain.com/en/science-and-mathematics',
  },
  {
    '@type': 'ListItem',
    position: 3,
    name: 'Unit Conversion',
    item: 'https://calcdomain.com/en/science-and-mathematics/unit-conversion',
  },
  {
    '@type': 'ListItem',
    position: 4,
    name: 'Typography Unit Converter',
    item: canonicalUrl,
  },
];

const webAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Typography Unit Converter (px, pt, em, rem, %)',
  url: canonicalUrl,
  applicationCategory: 'ProductivityApplication',
  operatingSystem: 'Any',
  description:
    'Interactive typography unit converter for web designers and frontend developers. Instantly convert between px, pt, em, rem, and percent with configurable base font size.',
  featureList: [
    'Convert between px, pt, em, rem, and percent',
    'Custom base font size for em/rem/% calculations',
    'Instant autocalculation on input change',
    'Mobile-friendly numeric inputs with decimal keypad',
    'Shareable URL with prefilled values',
    'Reset to default typography settings',
  ],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};
---

<Layout
  title={meta.title}
  description={meta.description}
  lang="en"
  canonical={canonicalUrl}
  meta={meta}
>
  <script type="application/ld+json">
    {JSON.stringify(webAppJsonLd)}
  </script>
  <script type="application/ld+json">
    {JSON.stringify(faqJsonLd)}
  </script>
  <script type="application/ld+json">
    {JSON.stringify(breadcrumbJsonLd)}
  </script>

  <main class="page">
    <section class="hero">
      <div class="hero-main">
        <h1>Typography Unit Converter (px, pt, em, rem, %)</h1>
        <p class="hero-subtitle">
          Convert font sizes between pixels, points, em, rem, and percent in seconds — ideal for modern, responsive CSS typography.
        </p>
        <p class="hero-meta">
          Trusted by frontend teams &amp; UI designers · Updated for modern CSS typography workflows
        </p>
      </div>
      <aside class="hero-aside">
        <div class="verify-badge">
          <span class="verify-label">Verified by</span>
          <span class="verify-expert">Senior Frontend &amp; UX Engineering Guidelines</span>
        </div>
        <ul class="hero-highlights">
          <li>Instant px ⇄ em ⇄ rem ⇄ pt ⇄ % conversion</li>
          <li>Custom base font size for accurate relative units</li>
          <li>Mobile-friendly with sticky results bar</li>
        </ul>
      </aside>
    </section>

    <section class="tool-section">
      <div class="tool-main">
        <CalculatorIsland
          id="typography-converter"
          title="Typography Unit Converter"
          inputMode="decimal"
          autoCalculate={true}
          showCalculateButton={true}
          showResetButton={true}
          showShareButton={true}
          layout="cockpit"
          stickyResultMobile={true}
          basicFields={[
            {
              id: 'value',
              label: 'Font size value',
              type: 'number',
              inputMode: 'decimal',
              min: 0,
              step: 0.01,
              defaultValue: 16,
              tooltip: 'Enter the font size you want to convert. Decimals are allowed.',
            },
            {
              id: 'fromUnit',
              label: 'Current unit',
              type: 'select',
              options: [
                { value: 'px', label: 'Pixels (px)' },
                { value: 'pt', label: 'Points (pt)' },
                { value: 'em', label: 'em' },
                { value: 'rem', label: 'rem' },
                { value: 'percent', label: 'Percent (%)' },
              ],
              defaultValue: 'px',
              tooltip: 'Select the unit of the value you entered above.',
            },
          ]}
          advancedFields={[
            {
              id: 'baseFontSize',
              label: 'Base font size (for em, rem, %)',
              type: 'number',
              inputMode: 'decimal',
              min: 0.1,
              step: 0.1,
              defaultValue: 16,
              tooltip:
                'The reference font size in pixels. Common defaults are 16px for browsers or a custom root size in your CSS.',
            },
          ]}
          resultsConfig={{
            highlightOnChange: true,
            cards: [
              { id: 'px', label: 'Pixels', unit: 'px' },
              { id: 'pt', label: 'Points', unit: 'pt' },
              { id: 'em', label: 'em', unit: 'em' },
              { id: 'rem', label: 'rem', unit: 'rem' },
              { id: 'percent', label: 'Percent', unit: '%' },
            ],
            primaryResultId: 'px',
          }}
          validationMessages={{
            value: 'Font size must be zero or greater.',
            baseFontSize: 'Base font size must be greater than 0 to compute em, rem, and percent.',
          }}
          shareConfig={{
            enabled: true,
            paramMap: {
              value: 'value',
              fromUnit: 'from',
              baseFontSize: 'base',
            },
          }}
          // The actual conversion logic is implemented inside the CalculatorIsland React/Preact component
          // using the same formulas as the legacy calculator.
        />
      </div>

      <aside class="tool-sidebar">
        <div class="ad-slot ad-slot--top">
          <!-- Right rail high-CPM ad slot (desktop only) -->
        </div>
        <div class="sidebar-card">
          <h2>Tips for accurate typography</h2>
          <ul>
            <li>Use rem for global typography scales and em for component-level adjustments.</li>
            <li>Keep a consistent base font size (often 16px) to simplify mental math.</li>
            <li>Test your typography with browser zoom and larger default font settings.</li>
          </ul>
        </div>
      </aside>
    </section>

    <section class="content-section" id="theory">
      <h2>How the typography unit converter works</h2>
      <p>
        This typography unit converter helps you translate font sizes between the most common CSS units:
        pixels (px), points (pt), em, rem, and percent (%). Under the hood, it uses standard relationships
        between these units and a configurable base font size.
      </p>

      <h3>Base relationships</h3>
      <p>
        Pixels are treated as the reference unit. For screen typography, points are typically mapped as:
      </p>
      <p class="math">
        $$ 1\\,\\text{pt} \\approx \\frac{96}{72}\\,\\text{px} = 1.3333\\,\\text{px} $$
      </p>
      <p>
        Relative units em, rem, and percent are based on a base font size in pixels, noted as
        \\( B \\) (for example, \\( B = 16\\,\\text{px} \\)).
      </p>

      <h3>Converting from pixels to relative units</h3>
      <p>Given a font size in pixels \\( P \\) and a base font size \\( B \\):</p>
      <p class="math">
        $$ \\text{em} = \\frac{P}{B} $$
        $$ \\text{rem} = \\frac{P}{B} $$
        $$ \\text{percent} = \\frac{P}{B} \\times 100\\% $$
      </p>

      <h3>Converting from relative units to pixels</h3>
      <p>Given a value in em or rem, noted as \\( R \\):</p>
      <p class="math">
        $$ P = R \\times B $$
      </p>
      <p>Given a percentage value \\( S \\) (for example, 150%):</p>
      <p class="math">
        $$ P = \\frac{S}{100} \\times B $$
      </p>

      <h3>Converting between any two units</h3>
      <p>
        The converter first normalizes the input to pixels using the appropriate formula, then converts
        from pixels to all other units. This two-step approach ensures consistent results across px, pt,
        em, rem, and percent.
      </p>
    </section>

    <section class="content-section" id="example">
      <h2>Real-world example: converting a design spec from px to rem</h2>
      <p>
        Imagine your design system uses a root font size of 16px, and your UI designer specifies a heading
        as 32px in the design tool. You want to express this heading size in rem for your CSS.
      </p>
      <ol>
        <li>Set the <strong>base font size</strong> in the converter to <strong>16px</strong>.</li>
        <li>Enter <strong>32</strong> as the <strong>font size value</strong> and choose <strong>px</strong> as the unit.</li>
        <li>
          The converter computes:
          <span class="math-inline">$$ \\text{rem} = \\frac{32}{16} = 2\\,\\text{rem} $$</span>
        </li>
      </ol>
      <p>
        In your CSS, you can now write:
      </p>
      <pre><code class="language-css">h1 {
  font-size: 2rem;
}</code></pre>
      <p>
        If you later decide to increase the root font size to 18px for better readability, the heading will
        scale automatically without changing the rem value.
      </p>
    </section>

    <section class="content-section" id="faq">
      <h2>FAQ: Typography unit conversion</h2>
      {faq.map((item) => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </section>
  </main>

  <style lang="css">
    .page {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      padding: 1.5rem 1rem 3rem;
      max-width: 1120px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      gap: 1.5rem;
      padding: 1.5rem 1.25rem;
      border-radius: 1rem;
      background: radial-gradient(circle at top left, #1f2937, #020617);
      color: #f9fafb;
    }

    .hero-main h1 {
      font-size: 1.9rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      margin: 0.25rem 0 0.75rem;
      font-size: 0.98rem;
      color: #e5e7eb;
    }

    .hero-meta {
      font-size: 0.85rem;
      color: #9ca3af;
    }

    .hero-aside {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .verify-badge {
      display: inline-flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.75rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.85);
      border: 1px solid rgba(148, 163, 184, 0.4);
      font-size: 0.78rem;
    }

    .verify-label {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #9ca3af;
    }

    .verify-expert {
      font-weight: 500;
      color: #e5e7eb;
    }

    .hero-highlights {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 0.85rem;
      color: #e5e7eb;
    }

    .hero-highlights li + li {
      margin-top: 0.25rem;
    }

    .tool-section {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
      align-items: flex-start;
    }

    .tool-main {
      min-width: 0;
    }

    .tool-sidebar {
      display: none;
    }

    .ad-slot {
      width: 100%;
      min-height: 250px;
      background: #f3f4f6;
      border-radius: 0.75rem;
      border: 1px dashed #d1d5db;
    }

    .sidebar-card {
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 0.75rem;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      font-size: 0.9rem;
    }

    .sidebar-card h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .sidebar-card ul {
      padding-left: 1.1rem;
      margin: 0;
    }

    .sidebar-card li + li {
      margin-top: 0.25rem;
    }

    .content-section {
      padding: 1.25rem 1rem;
      border-radius: 0.75rem;
      background: #ffffff;
      border: 1px solid #e5e7eb;
    }

    .content-section h2 {
      font-size: 1.25rem;
      margin-bottom: 0.75rem;
    }

    .content-section h3 {
      font-size: 1.05rem;
      margin-top: 0.75rem;
      margin-bottom: 0.4rem;
    }

    .math {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
        'Courier New', monospace;
      background: #f9fafb;
      padding: 0.75rem;
      border-radius: 0.5rem;
      border: 1px solid #e5e7eb;
      overflow-x: auto;
    }

    .math-inline {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
        'Courier New', monospace;
      background: #f9fafb;
      padding: 0.1rem 0.25rem;
      border-radius: 0.25rem;
    }

    pre {
      margin-top: 0.5rem;
      background: #020617;
      color: #e5e7eb;
      padding: 0.75rem;
      border-radius: 0.5rem;
      overflow-x: auto;
      font-size: 0.85rem;
    }

    .faq-item {
      border-top: 1px solid #e5e7eb;
      padding: 0.5rem 0;
    }

    .faq-item:first-of-type {
      border-top: none;
    }

    .faq-item summary {
      cursor: pointer;
      font-weight: 500;
    }

    .faq-item p {
      margin-top: 0.35rem;
      font-size: 0.92rem;
    }

    @media (min-width: 768px) {
      .page {
        padding: 2rem 1.5rem 4rem;
      }

      .hero {
        grid-template-columns: minmax(0, 2fr) minmax(0, 1.4fr);
        padding: 1.75rem 2rem;
      }

      .hero-main h1 {
        font-size: 2.1rem;
      }

      .tool-section {
        grid-template-columns: minmax(0, 2.2fr) minmax(260px, 1fr);
        gap: 1.75rem;
      }

      .tool-sidebar {
        display: block;
        position: sticky;
        top: 1.25rem;
      }
    }

    @media (min-width: 1024px) {
      .page {
        padding-inline: 0;
      }

      .hero-main h1 {
        font-size: 2.3rem;
      }
    }
  </style>
</Layout>