---
import { Fragment } from "astro/jsx-runtime";
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const hub = "financial";
const cluster = "taxes-and-duties";
const slug = "capital-gains-tax";

const pageTitle = "Capital gains tax calculator";
const pageDescription =
  "Instantly estimate your capital gains tax on stocks, real estate, and other investments. See taxable gain, effective tax rate, and after-tax proceeds in one place.";

const faqs = [
  {
    question: "How is capital gains tax calculated?",
    answer:
      "Capital gains tax is usually calculated as tax rate multiplied by your taxable gain. The taxable gain is the selling price minus the purchase price and allowable costs such as broker fees or improvement costs. Some tax systems apply different rates for short term and long term gains, and may also include exemptions or tax-free allowances.",
  },
  {
    question: "What is the difference between short term and long term capital gains?",
    answer:
      "Short term capital gains apply when you hold an asset for a relatively short period, for example less than one year. These gains are often taxed at your regular income tax rate. Long term capital gains apply when you hold an asset beyond a defined minimum holding period, such as more than one year, and they often benefit from reduced tax rates or special allowances.",
  },
  {
    question: "Which assets are subject to capital gains tax?",
    answer:
      "Capital gains tax can apply to many types of assets, including stocks, bonds, mutual funds, real estate, business assets, and some collectibles. Many tax systems provide exemptions for primary residences, small gains below a threshold, or specific retirement accounts. Always check the rules that apply in your country or region.",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Capital gains tax calculator",
  url: "https://calcdomain.com/en/financial/taxes-and-duties/capital-gains-tax",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Any",
  description:
    "Online capital gains tax calculator to estimate taxable gain, tax due, and after-tax proceeds for investments such as stocks and real estate.",
  featureList: [
    "Capital gain and loss calculation",
    "Short term and long term holding period support",
    "Estimated tax due and effective tax rate",
  ],
  inLanguage: "en",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://calcdomain.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Financial calculators",
      item: "https://calcdomain.com/en/financial",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Taxes and duties",
      item: "https://calcdomain.com/en/financial/taxes-and-duties",
    },
    {
      "@type": "ListItem",
      position: 4,
      name: "Capital gains tax calculator",
      item:
        "https://calcdomain.com/en/financial/taxes-and-duties/capital-gains-tax",
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="calc-page">
    <header class="calc-hero">
      <h1>Capital gains tax calculator</h1>
      <p class="hero-subtitle">
        Estimate your capital gains tax, effective tax rate, and after-tax
        proceeds in seconds for stocks, real estate, and other investments.
      </p>
      <p class="hero-trust">
        Optimized for current tax rules. For guidance only &#8212; always confirm
        with a qualified tax professional in your country.
      </p>
    </header>

    <section class="calculator-section" aria-label="Capital gains tax calculator tool">
      <CalculatorIsland slug={slug} />
    </section>

    <section class="calc-copy">
      <h2>How the capital gains tax calculator works</h2>
      <p>
        This calculator helps you estimate how much tax you may owe when you sell
        an investment for more than you paid for it. It focuses on three key
        outputs: your capital gain or loss, the estimated tax due, and your
        after-tax proceeds.
      </p>
      <p>
        You typically enter the purchase price, selling price, and any allowable
        costs, such as broker commissions or improvement costs for real estate.
        The tool then applies the tax rate that matches your holding period or
        tax bracket to estimate the tax due.
      </p>

      <h3>Basic capital gains formula</h3>
      <p>
        At its core, capital gains tax is based on your taxable gain. The
        following plain-text formulas show the typical steps.
      </p>
      <pre>
capital gain = selling price - purchase price - allowable costs
tax due = capital gain * tax rate
after tax proceeds = selling price - tax due
      </pre>
      <p>
        If the result of the first line is negative, you have a capital loss
        instead of a gain. Many tax systems allow you to offset gains with
        losses, up to certain limits.
      </p>

      <h3>Short term vs long term gains</h3>
      <p>
        Many tax systems distinguish between short term and long term capital
        gains. Short term gains apply when you hold an asset for a relatively
        short period, such as less than one year. These gains are often taxed at
        your regular income tax rate.
      </p>
      <p>
        Long term gains apply when you hold an asset beyond a minimum holding
        period, such as more than one year. Long term gains often benefit from
        reduced tax rates or special allowances. The calculator can help you
        compare the impact of different holding periods by adjusting the tax
        rate input.
      </p>

      <h3>What counts as allowable costs</h3>
      <p>
        Allowable costs reduce your taxable gain. Common examples include:
      </p>
      <ul>
        <li>Brokerage commissions when buying or selling investments</li>
        <li>Legal and notary fees related to the purchase or sale</li>
        <li>
          Documented improvement costs for real estate, such as structural
          renovations
        </li>
        <li>Transaction taxes or stamp duties that can be added to cost basis</li>
      </ul>
      <p>
        Rules differ by country, so always check which costs are recognized by
        your local tax authority.
      </p>
    </section>

    <section class="calc-example">
      <h2>Real world example</h2>
      <p>
        Imagine you bought shares in a company for 10,000 currency units and
        paid 50 in broker fees. Two years later, you sell the shares for 16,000
        and pay another 50 in broker fees. Your total purchase cost is 10,050
        and your net selling amount is 15,950.
      </p>
      <pre>
capital gain = 15,950 - 10,050 = 5,900
      </pre>
      <p>
        If your long term capital gains tax rate is 15 percent, the estimated
        tax due is:
      </p>
      <pre>
tax due = 5,900 * 0.15 = 885
after tax proceeds = 15,950 - 885 = 15,065
      </pre>
      <p>
        By adjusting the inputs in the calculator, you can quickly see how
        different purchase prices, selling prices, or tax rates change your
        after-tax proceeds.
      </p>
    </section>

    <section class="calc-faq">
      <h2>Capital gains tax FAQs</h2>
      <dl>
        {faqs.map((item) => (
          <Fragment>
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </Fragment>
        ))}
      </dl>
    </section>

    <section class="calc-disclaimer">
      <h2>Disclaimer</h2>
      <p>
        This capital gains tax calculator is for informational and educational
        purposes only. It simplifies many aspects of tax law and does not cover
        every possible exemption, allowance, or special rule. The results are
        estimates and do not constitute tax, legal, or financial advice. Always
        review your situation with a qualified professional or your local tax
        authority before making decisions.
      </p>
    </section>
  </main>
</Layout>
