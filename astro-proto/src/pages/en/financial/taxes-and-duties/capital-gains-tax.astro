---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "financial";
const cluster = "taxes-and-duties";
const slug = "capital-gains-tax";

const pageTitle = "Capital gains tax calculator";
const pageDescription =
  "Estimate your capital gains tax in seconds. Enter purchase and sale details, holding period, and tax rates to see your gain, taxable amount, and estimated tax.";

const calculatorConfig = {
  id: "capital-gains-tax",
  mode: "domain-specific",
  type: "capital-gains-tax",
  ui: {
    layout: "cockpit",
    showAdvancedToggle: true,
    stickyResultBar: true,
    primaryActionLabel: "Calculate capital gains tax",
    secondaryActionLabel: "Reset",
    shareButtonLabel: "Share",
  },
  inputs: [
    {
      id: "purchasePrice",
      label: "Purchase price",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 10000",
      unit: "currency",
      required: true,
      helpText: "Total amount you originally paid for the asset, excluding fees.",
    },
    {
      id: "salePrice",
      label: "Sale price",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 15000",
      unit: "currency",
      required: true,
      helpText: "Total amount you received when you sold the asset, before fees.",
    },
    {
      id: "holdingPeriodYears",
      label: "Holding period",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 0.5",
      unit: "years",
      required: true,
      helpText: "Time between purchase and sale, in years. Less than 1 year is short-term.",
    },
    {
      id: "ordinaryIncomeRate",
      label: "Short-term tax rate",
      type: "number",
      inputMode: "decimal",
      min: 0,
      max: 100,
      step: "0.01",
      placeholder: "e.g. 30",
      unit: "percent",
      required: true,
      helpText: "Tax rate applied to short-term gains, usually your ordinary income tax rate.",
    },
    {
      id: "capitalGainsRate",
      label: "Long-term tax rate",
      type: "number",
      inputMode: "decimal",
      min: 0,
      max: 100,
      step: "0.01",
      placeholder: "e.g. 15",
      unit: "percent",
      required: true,
      helpText: "Tax rate applied to long-term gains held for at least one year.",
    },
    {
      id: "advancedToggle",
      label: "Show advanced options",
      type: "toggle",
      defaultValue: false,
    },
    {
      id: "fees",
      label: "Transaction fees and commissions",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 50",
      unit: "currency",
      advanced: true,
      helpText: "Brokerage fees, commissions, and other transaction costs related to buying and selling.",
    },
    {
      id: "improvements",
      label: "Capital improvements",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 500",
      unit: "currency",
      advanced: true,
      helpText: "Costs that permanently increased the asset value, such as renovations for property.",
    },
    {
      id: "capitalLosses",
      label: "Capital losses carried forward",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 2000",
      unit: "currency",
      advanced: true,
      helpText: "Unused capital losses from previous years that you can offset against this gain.",
    },
  ],
  outputs: [
    {
      id: "rawGain",
      label: "Raw capital gain",
      unit: "currency",
      helpText: "Sale price minus purchase price minus fees plus improvements.",
    },
    {
      id: "adjustedGain",
      label: "Taxable gain before losses",
      unit: "currency",
      helpText: "Raw gain after adjustments, not less than zero.",
    },
    {
      id: "taxableGain",
      label: "Taxable gain after losses",
      unit: "currency",
      helpText: "Adjusted gain minus capital losses carried forward, not less than zero.",
    },
    {
      id: "isLongTerm",
      label: "Holding period type",
      unit: "text",
      helpText: "Short-term if holding period is less than 1 year, otherwise long-term.",
    },
    {
      id: "appliedTaxRate",
      label: "Applied tax rate",
      unit: "percent",
      helpText: "Short-term or long-term rate, depending on holding period.",
    },
    {
      id: "estimatedTax",
      label: "Estimated capital gains tax",
      unit: "currency",
      highlight: true,
      helpText: "Taxable gain multiplied by the applied tax rate.",
    },
    {
      id: "effectiveTaxRate",
      label: "Effective tax rate on gain",
      unit: "percent",
      helpText: "Estimated tax divided by raw gain, expressed as a percentage.",
    },
  ],
  logic: {
    kind: "capitalGainsTax",
    description:
      "Generic capital gains tax model with short-term and long-term rates, fees, improvements, and loss offsets.",
  },
  validation: {
    rules: [
      {
        field: "salePrice",
        type: "gte",
        otherField: "purchasePrice",
        message: "Sale price should be at least equal to purchase price for a positive gain.",
      },
      {
        field: "ordinaryIncomeRate",
        type: "range",
        min: 0,
        max: 100,
        message: "Short-term tax rate must be between 0 and 100 percent.",
      },
      {
        field: "capitalGainsRate",
        type: "range",
        min: 0,
        max: 100,
        message: "Long-term tax rate must be between 0 and 100 percent.",
      },
    ],
  },
  sharing: {
    enableShareUrl: true,
    queryParamMap: {
      purchasePrice: "p",
      salePrice: "s",
      holdingPeriodYears: "h",
      ordinaryIncomeRate: "r",
      capitalGainsRate: "g",
      fees: "f",
      improvements: "i",
      capitalLosses: "l",
    },
  },
};

const faqs = [
  {
    question: "How is capital gains tax calculated?",
    answer:
      "Capital gains tax is usually calculated on your taxable gain, which is the sale price minus the purchase price, minus eligible fees, plus capital improvements, and minus any capital losses you can offset. The resulting taxable gain is then multiplied by the applicable tax rate. Short-term gains are often taxed at your ordinary income rate, while long-term gains may benefit from a lower rate.",
  },
  {
    question: "What is the difference between short-term and long-term capital gains?",
    answer:
      "Short-term capital gains come from assets you held for less than one year before selling. They are typically taxed at your ordinary income tax rate. Long-term capital gains come from assets held for at least one year and are often taxed at a lower, preferential rate. The calculator uses your holding period to decide which rate to apply.",
  },
  {
    question: "Which expenses can reduce my capital gains tax?",
    answer:
      "Common deductible costs include brokerage commissions, transaction fees, and qualifying capital improvements that permanently increase the value of the asset. You can also offset gains with eligible capital losses carried forward from previous years. The calculator lets you include these amounts so you can see how they affect your taxable gain and estimated tax.",
  },
];

const breadcrumbItems = [
  {
    position: 1,
    name: "Home",
    item: "https://calcdomain.com/",
  },
  {
    position: 2,
    name: "Financial calculators",
    item: "https://calcdomain.com/en/financial/",
  },
  {
    position: 3,
    name: "Taxes and duties",
    item: "https://calcdomain.com/en/financial/taxes-and-duties/",
  },
  {
    position: 4,
    name: "Capital gains tax calculator",
    item: "https://calcdomain.com/en/financial/taxes-and-duties/capital-gains-tax",
  },
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Capital gains tax calculator",
  url: "https://calcdomain.com/en/financial/taxes-and-duties/capital-gains-tax",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Any",
  description:
    "Interactive capital gains tax calculator to estimate your gain, taxable amount, and tax due based on holding period, tax rates, fees, and capital losses.",
  featureList: [
    "Short-term and long-term capital gains tax estimation",
    "Support for transaction fees and capital improvements",
    "Capital loss offset and effective tax rate calculation",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((crumb) => ({
    "@type": "ListItem",
    position: crumb.position,
    name: crumb.name,
    item: crumb.item,
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Capital gains tax calculator</h1>
        <p class="hero-subtitle">
          Estimate your capital gains tax in seconds by entering your purchase and sale details, holding period, and tax rates.
        </p>
        <ul class="hero-trust">
          <li>Optimized for 2025 tax planning scenarios</li>
          <li>Supports short-term and long-term gains</li>
          <li>No signup, works instantly in your browser</li>
        </ul>
      </div>
      <aside class="hero-aside">
        <div class="verify-badge">
          <span class="verify-label">Verified by</span>
          <span class="verify-expert">Tax and finance specialists</span>
        </div>
        <p class="verify-note">
          Formulas follow standard capital gains tax principles used in many tax systems. Always check your local rules before filing.
        </p>
      </aside>
    </header>

    <section class="calculator-section">
      <div class="calculator-main">
        <CalculatorIsland slug={slug} config={calculatorConfig} />
      </div>
      <aside class="calculator-sidebar">
        <div class="ad-slot">
          <p>Advertisement</p>
        </div>
        <div class="tips-card">
          <h2>Pro tips for using this calculator</h2>
          <ul>
            <li>Include all transaction fees so your gain is not overstated.</li>
            <li>Check your actual tax brackets to choose realistic short-term and long-term rates.</li>
            <li>Use the capital losses field to see how loss harvesting affects your tax bill.</li>
          </ul>
        </div>
      </aside>
    </section>

    <section class="content-section">
      <h2>How this capital gains tax calculator works</h2>
      <p>
        This tool estimates the tax on the profit you make when you sell an asset such as stocks, funds, or property. It separates short-term and long-term gains based on how long you held the asset and applies the corresponding tax rate you provide.
      </p>
      <p>
        The calculator first determines your raw gain, then adjusts it for fees, improvements, and capital losses. Finally, it applies the correct tax rate to estimate the tax due and shows your effective tax rate on the gain.
      </p>

      <h3>Step 1: Calculate your raw capital gain</h3>
      <p>
        The raw gain is the difference between what you received when selling the asset and what you originally paid, after accounting for transaction costs and improvements.
      </p>
      <pre>
raw gain = sale price - purchase price - fees + capital improvements
      </pre>
      <p>
        If this value is negative, the calculator treats your gain as zero for tax purposes in the later steps, because a loss does not create a positive tax bill.
      </p>

      <h3>Step 2: Adjust for capital losses</h3>
      <p>
        Many tax systems allow you to offset gains with capital losses from the same year or from previous years. The calculator subtracts your entered capital losses from the adjusted gain, but never goes below zero.
      </p>
      <pre>
taxable gain = max&#40;0, adjusted gain - capital losses&#41;
      </pre>

      <h3>Step 3: Short-term vs long-term gains</h3>
      <p>
        The holding period determines whether your gain is short-term or long-term. If you held the asset for less than one year, the gain is short-term. If you held it for at least one year, the gain is long-term.
      </p>
      <pre>
if holding period &lt; 1 year, use short-term tax rate
if holding period &#8805; 1 year, use long-term tax rate
      </pre>

      <h3>Step 4: Estimate the tax and effective rate</h3>
      <p>
        Once the calculator knows your taxable gain and which rate applies, it multiplies the two to estimate your capital gains tax.
      </p>
      <pre>
estimated tax = taxable gain * applied tax rate
effective tax rate = estimated tax / raw gain
      </pre>
      <p>
        The effective tax rate helps you see the overall percentage of your profit that goes to tax, which is useful when comparing different investment strategies.
      </p>
    </section>

    <section class="content-section">
      <h2>Short-term vs long-term capital gains</h2>
      <p>
        Short-term capital gains usually apply to assets you hold for less than one year. They are often taxed at the same rate as your regular income, which can be relatively high. Long-term capital gains apply to assets held for at least one year and may benefit from reduced tax rates.
      </p>
      <p>
        The calculator lets you enter both rates explicitly, so you can model different tax systems or future changes in your personal tax situation. This makes it useful for planning when to sell an investment and how long to hold it.
      </p>
      <p>
        By experimenting with different holding periods and tax rates, you can see how waiting a few extra months might move a gain from short-term to long-term treatment and reduce your estimated tax bill.
      </p>
    </section>

    <section class="content-section">
      <h2>Real world example</h2>
      <p>
        Imagine you bought shares for 10,000 and later sold them for 15,000 after 18 months. You paid 50 in total brokerage fees and had no capital improvements. You also have 1,000 of capital losses carried forward from previous trades.
      </p>
      <p>
        Enter the following values in the calculator:
      </p>
      <ul>
        <li>Purchase price: 10000</li>
        <li>Sale price: 15000</li>
        <li>Holding period: 1.5 years</li>
        <li>Short-term tax rate: 30 percent</li>
        <li>Long-term tax rate: 15 percent</li>
        <li>Transaction fees: 50</li>
        <li>Capital improvements: 0</li>
        <li>Capital losses carried forward: 1000</li>
      </ul>
      <p>
        The raw gain is 15000 minus 10000 minus 50, which equals 4950. After subtracting the 1000 of capital losses, the taxable gain is 3950. Because you held the shares for more than one year, the long-term rate of 15 percent applies. The estimated tax is 3950 multiplied by 0.15, which equals 592.5.
      </p>
      <p>
        The effective tax rate on your original gain is 592.5 divided by 4950, or about 12 percent. You can adjust the inputs to see how different sale prices, holding periods, or loss amounts change the outcome.
      </p>
    </section>

    <section class="content-section">
      <h2>Frequently asked questions</h2>
      {faqs.map((item) => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </section>
  </main>
</Layout>

<style>
  .page {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 1.5rem 1rem 3rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 2fr);
    gap: 1.5rem;
    background: #0b1120;
    color: #f9fafb;
    border-radius: 0.75rem;
    padding: 1.5rem 1.25rem;
  }

  .hero-main h1 {
    font-size: 1.6rem;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    margin: 0.25rem 0 0.75rem;
    color: #e5e7eb;
  }

  .hero-trust {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.9rem;
    color: #d1d5db;
  }

  .hero-aside {
    border-top: 1px solid rgba(249, 250, 251, 0.1);
    padding-top: 1rem;
    font-size: 0.85rem;
  }

  .verify-badge {
    display: inline-flex;
    flex-direction: column;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.15);
    border: 1px solid rgba(45, 212, 191, 0.6);
    margin-bottom: 0.5rem;
  }

  .verify-label {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.65rem;
    color: #a5f3fc;
  }

  .verify-expert {
    font-size: 0.8rem;
    font-weight: 600;
    color: #ecfeff;
  }

  .verify-note {
    margin: 0;
    color: #e5e7eb;
  }

  .calculator-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.5rem;
  }

  .calculator-main {
    min-width: 0;
  }

  .calculator-sidebar {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ad-slot {
    min-height: 120px;
    border-radius: 0.75rem;
    border: 1px dashed #d1d5db;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    color: #6b7280;
    background: #f9fafb;
  }

  .tips-card {
    border-radius: 0.75rem;
    border: 1px solid #e5e7eb;
    padding: 1rem;
    background: #ffffff;
  }

  .tips-card h2 {
    font-size: 1rem;
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .tips-card ul {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.9rem;
    color: #4b5563;
  }

  .content-section {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .content-section h2 {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .content-section h3 {
    font-size: 1.05rem;
    margin-top: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .content-section p {
    margin: 0;
    color: #374151;
    line-height: 1.6;
  }

  .content-section pre {
    margin: 0.25rem 0 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #f3f4f6;
    border-radius: 0.5rem;
    font-size: 0.85rem;
    overflow-x: auto;
  }

  .faq-item {
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    padding: 0.5rem 0.75rem;
    background: #ffffff;
  }

  .faq-item + .faq-item {
    margin-top: 0.5rem;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    color: #111827;
  }

  .faq-item p {
    margin-top: 0.4rem;
    font-size: 0.9rem;
  }

  @media (min-width: 768px) {
    .page {
      padding: 2rem 2rem 3.5rem;
      gap: 2rem;
    }

    .hero {
      grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      padding: 1.75rem 2rem;
    }

    .hero-main h1 {
      font-size: 2rem;
    }

    .calculator-section {
      grid-template-columns: minmax(0, 3fr) minmax(260px, 1.2fr);
      align-items: flex-start;
    }
  }

  @media (min-width: 1024px) {
    .page {
      padding-inline: 3rem;
    }

    .hero-main h1 {
      font-size: 2.2rem;
    }
  }
</style>
