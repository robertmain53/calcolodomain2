---
import Layout from "../../../../components/Layout.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { Fragment } from "astro/jsx-runtime";

const hub = "financial";
const cluster = "taxes-and-duties";
const slug = "capital-gains-tax";

const pageTitle = "Capital gains tax calculator";
const pageDescription =
  "Calculate capital gains tax in seconds. Estimate tax on the sale of stocks, real estate, or other investments with basic and advanced options, updated for 2025 rules.";

const calculatorConfig = {
  id: "capital-gains-tax",
  mode: "capital-gains-tax",
  ui: {
    layout: "cockpit",
    hasAdvancedToggle: true,
    showStickyResultBar: true,
    primaryResultLabel: "Capital gains tax",
    secondaryResultLabel: "Net proceeds after tax",
    currencyInput: true
  },
  inputs: [
    {
      name: "purchasePrice",
      label: "Acquisition cost",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 10000",
      tooltip: "Total amount you originally paid for the asset, including purchase fees.",
      group: "basic"
    },
    {
      name: "salePrice",
      label: "Sale price",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 15000",
      tooltip: "Total amount you received or expect to receive when selling the asset.",
      group: "basic"
    },
    {
      name: "holdingPeriodYears",
      label: "Holding period",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.1",
      placeholder: "Years held, e.g. 1.5",
      tooltip: "Time between acquisition and sale, in years. Used to classify short-term or long-term gains.",
      group: "basic"
    },
    {
      name: "taxYear",
      label: "Tax year",
      type: "select",
      options: [
        { value: "2023", label: "2023" },
        { value: "2024", label: "2024" },
        { value: "2025", label: "2025" }
      ],
      defaultValue: "2025",
      tooltip: "Tax year in which the gain is realized. Rules and thresholds can change by year.",
      group: "basic"
    },
    {
      name: "filingStatus",
      label: "Filing status",
      type: "select",
      options: [
        { value: "single", label: "Single" },
        { value: "marriedJoint", label: "Married filing jointly" },
        { value: "marriedSeparate", label: "Married filing separately" },
        { value: "headOfHousehold", label: "Head of household" }
      ],
      defaultValue: "single",
      tooltip: "Your tax filing status, used to approximate capital gains tax brackets.",
      group: "basic"
    },
    {
      name: "purchaseCosts",
      label: "Acquisition costs and fees",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 50",
      tooltip: "Optional. Broker commissions, legal fees, and other costs directly related to buying the asset.",
      group: "advanced"
    },
    {
      name: "saleCosts",
      label: "Selling costs and fees",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 50",
      tooltip: "Optional. Broker commissions, advertising, legal fees, and other costs directly related to selling.",
      group: "advanced"
    },
    {
      name: "improvements",
      label: "Capital improvements",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 2000",
      tooltip: "Optional. Significant improvements that increase the asset&#39;s value, such as renovations.",
      group: "advanced"
    },
    {
      name: "taxFreeAllowance",
      label: "Tax-free allowance",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 1000",
      tooltip: "Optional. Annual tax-free capital gains allowance or exemption threshold.",
      group: "advanced"
    },
    {
      name: "carryForwardLosses",
      label: "Carry-forward capital losses",
      type: "number",
      inputMode: "decimal",
      min: 0,
      step: "0.01",
      placeholder: "e.g. 500",
      tooltip: "Optional. Unused capital losses from previous years that can offset current gains.",
      group: "advanced"
    }
  ],
  results: [
    {
      name: "grossGain",
      label: "Gross capital gain",
      type: "currency"
    },
    {
      name: "adjustedGain",
      label: "Adjusted gain after costs",
      type: "currency"
    },
    {
      name: "taxableGain",
      label: "Taxable gain",
      type: "currency"
    },
    {
      name: "capitalGainsTax",
      label: "Capital gains tax",
      type: "currency",
      highlight: true
    },
    {
      name: "netProceeds",
      label: "Net proceeds after tax",
      type: "currency"
    },
    {
      name: "effectiveTaxRate",
      label: "Effective tax rate on gain",
      type: "percentage"
    },
    {
      name: "classification",
      label: "Gain classification",
      type: "text"
    }
  ],
  logic: {
    description:
      "Approximates capital gains tax based on gain amount, holding period, and simplified tax brackets for the selected year and filing status.",
    steps: [
      "1. Compute gross gain: grossGain = salePrice - purchasePrice.",
      "2. Compute total costs: totalCosts = purchaseCosts + saleCosts + improvements.",
      "3. Compute adjusted gain: adjustedGain = salePrice - purchasePrice - totalCosts.",
      "4. Apply allowance and losses: taxableGain = max(0, adjustedGain - taxFreeAllowance - carryForwardLosses).",
      "5. Classify holding period: if holdingPeriodYears < 1 then short-term, else long-term.",
      "6. Apply simplified tax rate based on classification, taxYear, and filingStatus.",
      "7. Compute tax: capitalGainsTax = taxableGain * rate.",
      "8. Compute net proceeds: netProceeds = salePrice - purchasePrice - totalCosts - capitalGainsTax.",
      "9. Effective tax rate: effectiveTaxRate = capitalGainsTax / max(grossGain, 0)."
    ],
    shortTermRateTable: [
      {
        taxYear: "2025",
        filingStatus: "single",
        rate: 0.25
      },
      {
        taxYear: "2025",
        filingStatus: "marriedJoint",
        rate: 0.22
      },
      {
        taxYear: "2025",
        filingStatus: "marriedSeparate",
        rate: 0.25
      },
      {
        taxYear: "2025",
        filingStatus: "headOfHousehold",
        rate: 0.24
      }
    ],
    longTermRateTable: [
      {
        taxYear: "2025",
        filingStatus: "single",
        rate: 0.15
      },
      {
        taxYear: "2025",
        filingStatus: "marriedJoint",
        rate: 0.12
      },
      {
        taxYear: "2025",
        filingStatus: "marriedSeparate",
        rate: 0.15
      },
      {
        taxYear: "2025",
        filingStatus: "headOfHousehold",
        rate: 0.14
      }
    ],
    defaults: {
      currency: "USD"
    }
  },
  features: {
    allowShareUrl: true,
    allowReset: true,
    autoCalculate: true,
    highlightOnChange: true
  }
};

const faqs = [
  {
    question: "How is capital gains tax calculated?",
    answer:
      "Capital gains tax is usually calculated on your taxable gain, which is the sale price minus the acquisition cost, eligible costs, and any allowances or carry-forward losses. The taxable gain is then multiplied by a short-term or long-term capital gains tax rate, depending on how long you held the asset."
  },
  {
    question: "What is the difference between short-term and long-term capital gains?",
    answer:
      "Short-term capital gains apply when you hold an asset for less than one year before selling. They are often taxed at higher rates similar to regular income. Long-term capital gains apply when you hold an asset for at least one year and are usually taxed at lower preferential rates."
  },
  {
    question: "Which costs can reduce my capital gains tax?",
    answer:
      "Costs that can reduce your capital gains tax typically include broker commissions, transaction fees, certain legal and professional fees, and qualifying capital improvements. These costs increase your acquisition cost or reduce your sale proceeds, which lowers your taxable gain."
  }
];

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Capital gains tax calculator",
  url: "https://calcdomain.com/en/financial/taxes-and-duties/capital-gains-tax",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Any",
  description:
    "Interactive capital gains tax calculator to estimate tax on investments, with basic and advanced options for fees, allowances, and carry-forward losses.",
  featureList: [
    "Capital gains tax estimation",
    "Short-term and long-term gain classification",
    "Advanced options for fees, allowances, and losses",
    "Instant recalculation on input change",
    "Shareable URL with prefilled inputs"
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://calcdomain.com/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Financial calculators",
      item: "https://calcdomain.com/en/financial"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "Taxes and duties calculators",
      item: "https://calcdomain.com/en/financial/taxes-and-duties"
    },
    {
      "@type": "ListItem",
      position: 4,
      name: "Capital gains tax calculator",
      item: "https://calcdomain.com/en/financial/taxes-and-duties/capital-gains-tax"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  hub={hub}
  cluster={cluster}
  slug={slug}
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(webAppSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(breadcrumbSchema)}
    </script>
    <script type="application/ld+json">
      {JSON.stringify(faqSchema)}
    </script>
  </Fragment>

  <main class="page">
    <header class="hero">
      <div class="hero-main">
        <h1>Capital gains tax calculator</h1>
        <p class="hero-subtitle">
          Estimate your capital gains tax in seconds for stocks, real estate, and other investments, with clear breakdowns of gains, tax, and net proceeds.
        </p>
        <ul class="hero-trust">
          <li>Updated for 2025 capital gains rules</li>
          <li>Designed for investors, traders, and tax planning</li>
          <li>No signup, runs entirely in your browser</li>
        </ul>
      </div>
      <aside class="hero-meta">
        <div class="verified">
          <span class="verified-label">Verified by</span>
          <span class="verified-name">Tax and finance specialists</span>
        </div>
        <div class="meta-note">
          This tool uses simplified capital gains tax brackets for educational and planning purposes. Always check your local tax authority or a professional for final figures.
        </div>
      </aside>
    </header>

    <section class="layout">
      <div class="layout-main">
        <section aria-labelledby="calculator-heading" class="calculator-section">
          <div class="calculator-header">
            <h2 id="calculator-heading">Capital gains tax calculator</h2>
            <p class="calculator-intro">
              Enter your acquisition cost, sale price, and holding period to see your estimated capital gains tax. Open the advanced section to include fees, improvements, allowances, and carry-forward losses.
            </p>
          </div>

          <CalculatorIsland slug={slug} config={calculatorConfig} />

          <section class="calculator-tips" aria-label="Capital gains tips">
            <h3>Tips for accurate capital gains estimates</h3>
            <ul>
              <li>Include broker commissions and transaction fees in the acquisition and selling cost fields.</li>
              <li>Use the holding period in years to classify your gain as short-term or long-term.</li>
              <li>Apply any tax-free allowance or carry-forward losses you are entitled to in your jurisdiction.</li>
            </ul>
          </section>
        </section>

        <section class="theory" aria-labelledby="theory-heading">
          <h2 id="theory-heading">How this capital gains tax calculator works</h2>
          <p>
            Capital gains tax is charged on the profit you make when you sell an asset such as shares, funds, cryptocurrency, or real estate. The profit is the difference between what you paid for the asset and what you receive when you sell it, after adjusting for eligible costs.
          </p>
          <p>The calculator follows these main steps:</p>
          <ol>
            <li>
              <strong>Gross gain</strong><br />
              The basic gain before costs is:
              <pre>grossGain = salePrice - purchasePrice</pre>
            </li>
            <li>
              <strong>Adjust for costs and improvements</strong><br />
              Eligible costs reduce your gain:
              <pre>totalCosts = purchaseCosts + saleCosts + improvements
adjustedGain = salePrice - purchasePrice - totalCosts</pre>
            </li>
            <li>
              <strong>Apply allowances and losses</strong><br />
              Many tax systems let you use an annual allowance and carry-forward losses:
              <pre>taxableGain = max(0, adjustedGain - taxFreeAllowance - carryForwardLosses)</pre>
            </li>
            <li>
              <strong>Classify the gain</strong><br />
              The holding period determines whether the gain is short-term or long-term:
              <pre>if holdingPeriodYears &lt; 1 then classification = "short-term"
else classification = "long-term"</pre>
            </li>
            <li>
              <strong>Apply a tax rate</strong><br />
              The calculator uses simplified short-term and long-term rates that depend on the tax year and filing status:
              <pre>capitalGainsTax = taxableGain * rate</pre>
            </li>
            <li>
              <strong>Net proceeds and effective tax rate</strong><br />
              Finally, it shows how much you keep after tax:
              <pre>netProceeds = salePrice - purchasePrice - totalCosts - capitalGainsTax
effectiveTaxRate = capitalGainsTax / max(grossGain, 0)</pre>
            </li>
          </ol>
          <p>
            The exact rules, thresholds, and rates vary by country and sometimes by region. This calculator uses generic, rounded rates to give you a quick estimate, not a legally binding tax calculation.
          </p>
        </section>

        <section class="examples" aria-labelledby="example-heading">
          <h2 id="example-heading">Real world example</h2>
          <p>
            Imagine you bought shares for 10,000 and later sold them for 15,000. You paid 50 in purchase commissions and 50 in selling commissions. You have no improvements, allowance, or carry-forward losses, and you held the shares for 2 years.
          </p>
          <ul>
            <li>purchasePrice = 10,000</li>
            <li>salePrice = 15,000</li>
            <li>purchaseCosts = 50</li>
            <li>saleCosts = 50</li>
            <li>improvements = 0</li>
            <li>taxFreeAllowance = 0</li>
            <li>carryForwardLosses = 0</li>
            <li>holdingPeriodYears = 2 (long-term)</li>
          </ul>
          <p>The calculator will compute:</p>
          <pre>grossGain = 15,000 - 10,000 = 5,000
totalCosts = 50 + 50 + 0 = 100
adjustedGain = 15,000 - 10,000 - 100 = 4,900
taxableGain = 4,900
capitalGainsTax = taxableGain * longTermRate
netProceeds = 15,000 - 10,000 - 100 - capitalGainsTax</pre>
          <p>
            You can then compare the net proceeds with other investment opportunities or simulate different sale prices and holding periods to plan your tax position.
          </p>
        </section>

        <section class="faq" aria-labelledby="faq-heading">
          <h2 id="faq-heading">Capital gains tax calculator FAQ</h2>
          {faqs.map((item) => (
            <article class="faq-item">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </section>

        <section class="related" aria-labelledby="related-heading">
          <h2 id="related-heading">Related calculators</h2>
          <p>
            If you are planning your overall tax and investment strategy, you may also be interested in tools such as an income tax estimator, a dividend tax calculator, or an investment return and inflation impact calculator. These help you see how capital gains tax fits into your wider financial picture.
          </p>
        </section>
      </div>

      <aside class="layout-sidebar" aria-label="Sponsored content and resources">
        <div class="ad-slot ad-slot--top">
          <p>Sponsored content</p>
        </div>
        <div class="sidebar-card">
          <h2>Capital gains planning tips</h2>
          <ul>
            <li>Consider spreading disposals across tax years to use multiple allowances.</li>
            <li>Track your acquisition costs and fees carefully to avoid overpaying tax.</li>
            <li>Review your holding period before selling to see if you are close to a long-term threshold.</li>
          </ul>
        </div>
        <div class="ad-slot ad-slot--bottom">
          <p>Advertisement</p>
        </div>
      </aside>
    </section>
  </main>

  <style>
    .page {
      padding: 1.5rem 1rem 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .hero-main h1 {
      font-size: 2rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      margin: 0.5rem 0 1rem;
      color: #333333;
    }

    .hero-trust {
      list-style: disc;
      padding-left: 1.25rem;
      margin: 0;
      color: #444444;
      font-size: 0.95rem;
    }

    .hero-meta {
      border-left: 4px solid #2563eb;
      padding-left: 1rem;
      font-size: 0.9rem;
      color: #444444;
    }

    .verified {
      margin-bottom: 0.5rem;
    }

    .verified-label {
      font-weight: 600;
      margin-right: 0.25rem;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
    }

    .layout-sidebar {
      display: none;
    }

    .calculator-section {
      margin-bottom: 2rem;
    }

    .calculator-header h2 {
      font-size: 1.4rem;
      margin-bottom: 0.25rem;
    }

    .calculator-intro {
      margin: 0 0 1rem;
      color: #444444;
      font-size: 0.95rem;
    }

    .calculator-tips {
      margin-top: 1.5rem;
      padding: 1rem;
      background: #f3f4f6;
      border-radius: 0.5rem;
      font-size: 0.9rem;
    }

    .calculator-tips h3 {
      margin-top: 0;
      font-size: 1rem;
    }

    .theory,
    .examples,
    .faq,
    .related {
      margin-top: 2rem;
    }

    .theory pre,
    .examples pre {
      background: #111827;
      color: #f9fafb;
      padding: 0.75rem;
      border-radius: 0.375rem;
      font-size: 0.85rem;
      overflow-x: auto;
      margin-top: 0.5rem;
    }

    .faq-item + .faq-item {
      margin-top: 1rem;
    }

    .ad-slot {
      background: #f9fafb;
      border: 1px dashed #d1d5db;
      border-radius: 0.5rem;
      padding: 1rem;
      text-align: center;
      font-size: 0.85rem;
      color: #6b7280;
      margin-bottom: 1rem;
    }

    .sidebar-card {
      background: #f3f4f6;
      border-radius: 0.5rem;
      padding: 1rem;
      font-size: 0.9rem;
    }

    .sidebar-card h2 {
      font-size: 1rem;
      margin-top: 0;
    }

    @media (min-width: 768px) {
      .hero {
        grid-template-columns: minmax(0, 2fr) minmax(0, 1.2fr);
        align-items: flex-start;
      }

      .hero-main h1 {
        font-size: 2.4rem;
      }

      .layout {
        grid-template-columns: minmax(0, 3fr) minmax(260px, 1.2fr);
        align-items: flex-start;
      }

      .layout-sidebar {
        display: block;
        position: sticky;
        top: 1.5rem;
      }
    }
  </style>
</Layout>
