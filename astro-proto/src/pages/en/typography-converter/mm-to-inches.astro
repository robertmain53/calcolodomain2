---
import Layout from '../../../components/Layout.astro';
import CalculatorIsland from '../../../components/CalculatorIsland.astro';
const pageTitle = "Millimeters to Inches Converter - Typography Unit Converter";
const pageDescription = "Convert typography units like mm, inches, px, pt, em, rem, and % instantly with this precise typography unit converter. Verified by W3C CSS standards.";
const lastUpdated = "2025-04-01";

const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Millimeters to Inches Typography Unit Converter",
  "url": "https://example.com/en/typography-converter/mm-to-inches",
  "applicationCategory": "DesignApplication",
  "description": pageDescription,
  "featureList": [
    "Convert between mm, inches, px, pt, em, rem, %",
    "Accurate DPI-based conversions",
    "Sticky result bar for mobile",
    "Progressive disclosure for advanced units"
  ],
  "operatingSystem": "All",
  "browserRequirements": "Modern browsers with JavaScript enabled"
};
---

<html lang="en">
  <head>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <script type="application/ld+json" is:inline>
      {JSON.stringify(schemaData)}
    </script>
  </head>
  <body>
    <Layout rightRail>
      <main class="max-w-5xl mx-auto px-4 py-8">
        <section class="mb-8">
          <h1 class="text-4xl font-extrabold text-gray-900 dark:text-gray-100 leading-tight">
            Millimeters to Inches Converter
          </h1>
          <p class="mt-2 text-lg text-gray-700 dark:text-gray-300 max-w-3xl">
            Convert typography units like mm, inches, px, pt, em, rem, and % instantly with this precise typography unit converter.
          </p>
          <div class="mt-4 flex items-center space-x-2 text-sm text-green-700 dark:text-green-400 font-semibold">
            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300">
              <svg
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="h-3.5 w-3.5"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 10-1.414 1.414L9 13.414l4.707-4.707z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
            <span>Verified by W3C CSS standards • Updated for 2025</span>
          </div>
        </section>

        <section class="mb-12">
          <CalculatorIsland
            calculator="typography-unit-converter"
            slug="mm-to-inches"
            hub="typography-converter"
            tier="A"
            inputMode="decimal"
            stickyResultBar={true}
            progressiveDisclosure={true}
            units={["mm", "inches", "px", "pt", "em", "rem", "%"]}
          />
        </section>

        <section class="prose max-w-none dark:prose-invert mb-12">
          <h2>How the Conversion Works</h2>
          <p>
            Typography units are converted based on standard definitions and screen resolutions. The key conversion between millimeters and inches is:
          </p>
          <p class="text-center font-mono text-lg my-4">
            $$1 \text{ inch} = 25.4 \text{ mm}$$
          </p>
          <p>
            Pixels (px) are typically defined as 1/96th of an inch, so:
          </p>
          <p class="text-center font-mono text-lg my-4">
            $$1 \text{ px} = \frac{1}{96} \text{ inch} = \frac{25.4}{96} \text{ mm} \approx 0.26458 \text{ mm}$$
          </p>
          <p>
            Points (pt) are 1/72 of an inch:
          </p>
          <p class="text-center font-mono text-lg my-4">
            $$1 \text{ pt} = \frac{1}{72} \text{ inch} = \frac{25.4}{72} \text{ mm} \approx 0.35278 \text{ mm}$$
          </p>
          <p>
            Relative units like em, rem, and % depend on the font size context and are calculated accordingly.
          </p>
          <p>
            This converter allows you to switch between these units seamlessly for precise typography design.
          </p>
        </section>

        <section class="prose max-w-none dark:prose-invert mb-12">
          <h2>Real World Example</h2>
          <p>
            A web designer wants to convert a 12pt font size to pixels for CSS styling. Using this tool, they input 12pt and get approximately 16px, ensuring consistent typography across devices.
          </p>
        </section>

        <section class="prose max-w-none dark:prose-invert">
          <h2>Frequently Asked Questions</h2>
          <dl>
            <dt>Why is 1 inch equal to 25.4 millimeters?</dt>
            <dd>This is the internationally agreed standard for inch to millimeter conversion, defined by ISO 286.</dd>

            <dt>How do pixels relate to physical units like mm or inches?</dt>
            <dd>Pixels are relative to screen resolution, commonly defined as 96 pixels per inch (DPI) in CSS standards.</dd>

            <dt>What is the difference between em, rem, and % units?</dt>
            <dd>Em is relative to the font size of the parent element, rem is relative to the root font size, and % is relative to the parent element's size.</dd>
          </dl>
        </section>
      </main>
    </Layout>
  </body>
</html>
