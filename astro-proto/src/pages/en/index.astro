---
import Layout from "../../components/Layout.astro";
import SeoHead from "../../components/SeoHead.astro";
import type { PageEntry } from "../../data/pages";
import { pages } from "../../data/pages";
import SearchBox from "../../components/SearchBox.astro";

const enPages = pages.filter((p) => p.locale === "en");

type Cluster = { name: string; slug: string; items: PageEntry[] };
type Hub = { name: string; slug: string; clusters: Cluster[] };

const hubMap = new Map<string, Hub>();

for (const page of enPages) {
  const hubSlug = page.slug[0];
  if (!hubMap.has(hubSlug)) {
    hubMap.set(hubSlug, { name: page.primary.hub, slug: hubSlug, clusters: [] });
  }
  const clusterSlug = page.slug[1];
  const hub = hubMap.get(hubSlug)!;
  let cluster = hub.clusters.find((c) => c.slug === clusterSlug);
  if (!cluster) {
    cluster = { name: page.primary.cluster, slug: clusterSlug, items: [] };
    hub.clusters.push(cluster);
  }
  cluster.items.push(page);
}

const hubs = Array.from(hubMap.values());
---
<Layout
  title="CalcDomain prototype"
  description="i18n-ready Astro prototype with hubs, clusters, and semantic calculators."
>
  <Fragment slot="head">
    <SeoHead
      title="CalcDomain prototype"
      description="i18n-ready Astro prototype with hubs, clusters, and semantic calculators."
      slug={[]}
    />
  </Fragment>

  <section class="hero">
    <h1>Semantic calculator library</h1>
    <p class="lede">
      Data-driven hubs, clusters, breadcrumb-ready URLs, and structured data. This
      prototype ships 18 calculators across Finance, Engineering, and Health &amp; Fitness.
    </p>
    <SearchBox />
    <div class="chips">
      <span>i18n-ready (/en/, more locales later)</span>
      <span>Breadcrumb + WebApplication + HowTo + FAQ JSON-LD</span>
      <span>Silo URLs: /en/&#123;hub&#125;/&#123;cluster&#125;/&#123;tool&#125;</span>
    </div>
  </section>

  <section class="grid hubs">
    {hubs.map((hub) => (
      <a class="card hub" href={`/en/${hub.slug}`} data-name={`${hub.name.toLowerCase()}`} data-type="hub">
        <div class="top">
          <div class="eyebrow">Hub</div>
          <h2>{hub.name}</h2>
          <p>{hub.clusters.length} clusters · {hub.clusters.reduce((acc, c) => acc + c.items.length, 0)} tools</p>
        </div>
        <div class="clusters">
          {hub.clusters.slice(0, 3).map((cluster) => (
            <div class="cluster">
              <div class="cluster-name">{cluster.name}</div>
              <div class="cluster-meta">{cluster.items.length} tools</div>
            </div>
          ))}
        </div>
      </a>
    ))}
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <h2>Latest calculators (sample)</h2>
        <p class="muted">Deep links for fast access; search above filters these cards live.</p>
      </div>
      <div class="trust">
        <span class="pill tone">Reviewed formulas</span>
        <span class="pill tone">Low CLS / fast LCP</span>
        <span class="pill tone">Sticky results on mobile</span>
      </div>
    </div>
    <div class="grid cards" id="tools-grid">
      {enPages.slice(0, 12).map((p) => (
        <a class="card" href={`/en/${p.slug.join("/")}`} data-name={`${p.title.toLowerCase()} ${p.primary.hub.toLowerCase()} ${p.primary.cluster.toLowerCase()}`}>
          <div class="title">{p.title}</div>
          <div class="meta">{p.primary.hub} · {p.primary.cluster}</div>
          <p>{p.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.4rem;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.16), rgba(167, 139, 250, 0.12));
    margin-bottom: 1rem;
  }
  h1 {
    margin: 0 0 0.4rem 0;
    color: #fff;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }
  .lede {
    color: #cbd5e1;
    margin: 0;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.8rem;
  }
  .chips span {
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: #e2e8f0;
    font-size: 0.9rem;
  }
  .search-bar {
    display: grid;
    gap: 0.4rem;
    margin: 0.75rem 0;
  }
  .search-bar input {
    width: 100%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.8rem 0.9rem;
    color: #fff;
    font-size: 1rem;
  }
  .pill.tone {
    background: rgba(56, 189, 248, 0.16);
    border-color: rgba(56, 189, 248, 0.35);
    color: #e0f2fe;
  }
  .grid {
    display: grid;
    gap: 0.85rem;
  }
  .hubs {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .card {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.02);
    color: inherit;
    text-decoration: none;
    transition: 0.15s ease;
  }
  .card:hover {
    border-color: rgba(56, 189, 248, 0.35);
  }
  .hub h2 {
    margin: 0;
    color: #e2e8f0;
  }
  .hub p {
    color: #cbd5e1;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
    font-size: 0.8rem;
    margin-bottom: 0.2rem;
  }
  .clusters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .cluster {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.6rem 0.65rem;
  }
  .cluster-name {
    font-weight: 600;
    color: #e2e8f0;
  }
  .cluster-meta {
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .panel {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    background: rgba(255, 255, 255, 0.02);
    margin-top: 1.2rem;
  }
  .panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .trust {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .cards {
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    margin-top: 0.6rem;
  }
  .title {
    font-weight: 600;
    color: #e2e8f0;
  }
  .meta {
    color: #94a3b8;
    font-size: 0.9rem;
    margin: 0.35rem 0;
  }
  p {
    margin: 0;
    color: #cbd5e1;
  }
  .muted {
    color: #94a3b8;
    margin: 0.2rem 0 0 0;
  }
</style>

<script>
  const filterCards = (event) => {
    const query = event.target.value.toLowerCase();
    document.querySelectorAll("[data-name]").forEach((el) => {
      const match = el.getAttribute("data-name")?.includes(query);
      el.style.display = match || !query ? "" : "none";
    });
  };
</script>
