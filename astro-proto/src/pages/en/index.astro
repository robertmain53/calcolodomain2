---
import Layout from "../../../components/Layout.astro";
import { getTaxonomy, findHub } from "../../../data/taxonomy";

export async function getStaticPaths() {
  const taxonomy = await getTaxonomy();
  return taxonomy.map((hub) => ({
    params: { hub: hub.slug },
  }));
}

const { hub: hubSlug } = Astro.params;
const hub = await findHub(hubSlug);

if (!hub) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}
---

<Layout title={`${hub.name} Calculators`} description={hub.description}>
  <main class="container">
    <nav aria-label="breadcrumb">
      <ol>
        <li><a href="/en/">Home</a></li>
        <li>{hub.name}</li>
      </ol>
    </nav>
    <h1>{hub.name}</h1>
    <p class="lead">{hub.description}</p>

    <div class="cluster-list">
      {hub.clusters.map((cluster) => (
        <a href={`/en/${hub.slug}/${cluster.slug}`} class="cluster-link">
          <h3>{cluster.name}</h3>
        </a>
      ))}
    </div>
  </main>
</Layout>