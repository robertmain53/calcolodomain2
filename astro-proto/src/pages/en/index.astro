---
import Layout from "../../../../layouts/Layout.astro";
import { getTaxonomy, findCluster } from "../../../../data/taxonomy";

export async function getStaticPaths() {
  const taxonomy = await getTaxonomy();
  const paths = [];

  for (const hub of taxonomy) {
    for (const cluster of hub.clusters) {
      paths.push({
        params: { hub: hub.slug, cluster: cluster.slug },
      });
    }
  }
  return paths;
}

const { hub: hubSlug, cluster: clusterSlug } = Astro.params;
const cluster = await findCluster(hubSlug, clusterSlug);

if (!cluster) {
  return new Response(null, {
    status: 404,
    statusText: "Not Found",
  });
}
---

<Layout title={`${cluster.name} Calculators`} description={cluster.description}>
  <main class="container">
    <nav aria-label="breadcrumb">
      <ol>
        <li><a href="/en/">Home</a></li>
        <li><a href={`/en/${hubSlug}`}>{hubSlug.replace(/-/g, " ")}</a></li>
        <li>{cluster.name}</li>
      </ol>
    </nav>
    <h1>{cluster.name} Calculators</h1>

    <ul class="tool-list">
      {cluster.tools?.map((tool) => (
        <li><a href={tool.url}>{tool.title}</a></li>
      ))}
    </ul>
  </main>
</Layout>