---
import Layout from "../../components/Layout.astro";
import { getTaxonomy } from "../../data/taxonomy";

const taxonomy = await getTaxonomy();
const totalHubs = taxonomy.length;
const totalClusters = taxonomy.reduce(
  (sum, hub) => sum + hub.clusters.length,
  0,
);
const totalTools = taxonomy.reduce((sum, hub) => {
  return (
    sum +
    hub.clusters.reduce(
      (clusterSum, cluster) => clusterSum + (cluster.tools?.length ?? 0),
      0,
    )
  );
}, 0);

const heroStats = [
  { value: new Intl.NumberFormat("en-US").format(totalTools), label: "Precision calculators live" },
  { value: totalHubs, label: "Research-ready hubs" },
  { value: totalClusters, label: "Structured clusters" },
];

const flattenedClusters = taxonomy.flatMap((hub) =>
  hub.clusters.map((cluster) => ({
    hub,
    cluster,
    primaryTool: cluster.tools?.[0],
  })),
);

const highlightedClusters = flattenedClusters.slice(0, 4);

const featureCards = [
  {
    title: "Verified formulas & standards",
    body: 'Every conversion uses ISO-aligned factors kept inside "CalculatorIsland" so the UI stays tidy while the math stays authoritative.',
  },
  {
    title: "Cockpit-ready layouts",
    body: "Wide inputs, sticky answers, and instant validation keep every page usable on laptops, tablets, and phones.",
  },
  {
    title: "SEO grade content",
    body: "Structured data, hubs, clusters, and plain-text theory sections make the site discoverable by researchers and product teams.",
  },
];

const pageTitle = "CalcDomain | Precision calculators for engineering, science, and finance";
const pageDescription =
  "CalcDomain delivers professional-grade calculators organized into hubs and clusters that mirror engineering, finance, and lifestyle workflows.";
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="hero">
    <p class="eyebrow">Precision tools calibrated for modern workflows</p>
    <h1>
      Calculate conversions, finance, and engineering math with a cockpit that matches your mental model.
    </h1>
    <p class="lede">
      CalcDomain combines deep topical structure with always-on tooling so busy teams can trust the math, cite the sources, and share results instantly.
    </p>
    <div class="hero-actions">
      <a class="btn primary" href="/en/science-and-mathematics">Browse calculators</a>
      <a class="btn ghost" href="/en/science-and-mathematics/unit-conversion/mm-to-inches">
        Preview the mm → inches converter
      </a>
    </div>
    <div class="hero-stats">
      {heroStats.map((stat) => (
        <div class="stat-card">
          <span>{stat.value}</span>
          <p>{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="hub-showcase">
    <div class="section-heading">
      <p class="eyebrow">Hubs & clusters</p>
      <h2>Structured navigation for the calculators you actually use</h2>
    </div>
    <div class="hub-grid">
      {taxonomy.map((hub) => {
        const toolCount = hub.clusters.reduce(
          (clusterSum, cluster) => clusterSum + (cluster.tools?.length ?? 0),
          0,
        );
        return (
          <article class="hub-card">
            <header>
              <a href={`/en/${hub.slug}`}>{hub.name}</a>
              <p>{hub.description}</p>
            </header>
            <div class="hub-meta">
              <span>{hub.clusters.length} clusters</span>
              <span>{toolCount} calculators</span>
            </div>
            <div class="hub-clusters">
              {hub.clusters.map((cluster) => (
                <a class="cluster-chip" href={`/en/${hub.slug}/${cluster.slug}`}>
                  {cluster.name}
                </a>
              ))}
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="spotlight-grid">
    <div class="section-heading">
      <p class="eyebrow">Spotlight</p>
      <h2>Clusters worth bookmarking</h2>
    </div>
    <div class="spotlight-list">
      {highlightedClusters.map(({ hub, cluster, primaryTool }) => (
        <article>
          <p class="muted">{hub.name}</p>
          <h3>
            <a href={`/en/${hub.slug}/${cluster.slug}`}>{cluster.name}</a>
          </h3>
          <p>
            {primaryTool?.title ?? "Explore the calculators in this cluster."}
          </p>
          <a class="link-list" href={`/en/${hub.slug}/${cluster.slug}`}>
            Open {cluster.name} calculators
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="feature-section">
    <div class="section-heading">
      <p class="eyebrow">Confidence-first experience</p>
      <h2>Built with pilots who demand accuracy, clarity, and speed</h2>
    </div>
    <div class="feature-grid">
      {featureCards.map((feature) => (
        <article>
          <h3>{feature.title}</h3>
          <p>{feature.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="use-case">
    <div>
      <p class="eyebrow">Real world example</p>
      <h2>Millimeters to inches in a fabrication cockpit</h2>
      <p>
        When planning a CNC cut or machining run, millimeters are the native language, but tool drawings often publish inches. CalcDomain offers an instant mm → inches converter with a visual ruler, fraction breakdown, and sticky result that stays visible while you adjust inputs.
      </p>
      <p>
        The conversion core is provided by the CalculatorIsland component, so we never duplicate logic. The formula is simple, but the experience includes verified precision, micro copy, and instant share links to capture inputs.
      </p>
    </div>
    <div class="use-case-card">
      <h3>Formula reference</h3>
      <pre>inches = millimeters / 25.4</pre>
      <p>
        This fixed international ratio ensures every millimeter unit converts to the exact inch value. Keep three to four decimal places for tight tolerances.
      </p>
      <a class="cta-link" href="/en/science-and-mathematics/unit-conversion/mm-to-inches">
        Launch the mm → inches calculator
      </a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 0;
  }
  .eyebrow {
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #38bdf8;
    margin: 0;
  }
  .hero h1 {
    margin: 0;
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    line-height: 1.2;
  }
  .lede {
    max-width: 640px;
    font-size: 1.1rem;
    color: #cbd5f5;
  }
  .hero-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .btn {
    border-radius: 999px;
    padding: 0.6rem 1.4rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid transparent;
    transition: transform 0.2s ease;
  }
  .btn.primary {
    background: linear-gradient(135deg, #22d3ee, #4f46e5);
    color: #020617;
  }
  .btn.ghost {
    border-color: rgba(148, 163, 184, 0.6);
    color: #e2e8f0;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
  }
  .stat-card {
    padding: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.3);
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: rgba(15, 23, 42, 0.6);
  }
  .stat-card span {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .hub-showcase .section-heading h2,
  .spotlight-grid .section-heading h2,
  .feature-section .section-heading h2 {
    margin: 0.35rem 0 1.5rem;
  }
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .hub-card {
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 1.25rem;
    padding: 1.5rem;
    background: rgba(15, 23, 42, 0.6);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .hub-card header a {
    font-size: 1.25rem;
    font-weight: 600;
    color: #f8fafc;
    text-decoration: none;
  }
  .hub-card header p {
    margin: 0.3rem 0 0;
    color: #cbd5f5;
  }
  .hub-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    color: #94a3b8;
  }
  .hub-clusters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cluster-chip {
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    background: rgba(59, 130, 246, 0.15);
    text-decoration: none;
    font-size: 0.9rem;
    color: #e0f2fe;
  }

  .spotlight-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .spotlight-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .spotlight-list article {
    border-radius: 1rem;
    padding: 1.25rem;
    border: 1px solid rgba(148, 163, 184, 0.25);
    background: rgba(2, 6, 23, 0.5);
  }
  .spotlight-list h3 {
    margin: 0.35rem 0;
  }
  .spotlight-list p {
    margin: 0;
    color: #cbd5f5;
  }
  .link-list {
    color: #38bdf8;
    font-weight: 600;
    text-decoration: none;
    margin-top: 0.65rem;
    display: inline-block;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.2rem;
  }
  .feature-grid article {
    border-radius: 1rem;
    padding: 1.5rem;
    background: rgba(22, 28, 45, 0.9);
    border: 1px solid rgba(148, 163, 184, 0.2);
  }
  .feature-grid h3 {
    margin-top: 0;
  }
  .feature-grid p {
    margin-bottom: 0;
    color: #cbd5f5;
  }

  .use-case {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.65);
  }
  .use-case-card {
    border: 1px solid rgba(59, 130, 246, 0.45);
    border-radius: 1rem;
    padding: 1.5rem;
    background: rgba(2, 6, 23, 0.7);
  }
  .use-case-card pre {
    margin: 0.5rem 0;
    padding: 0.75rem;
    background: rgba(2, 6, 23, 0.85);
    border-radius: 0.75rem;
    overflow: auto;
    border: 1px solid rgba(148, 163, 184, 0.2);
    font-size: 0.95rem;
  }
  .cta-link {
    color: #38bdf8;
    font-weight: 600;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
    }
    .hub-meta {
      flex-direction: column;
    }
  }
</style>
