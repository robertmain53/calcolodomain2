---
import Layout from "../../components/Layout.astro";
import { getTaxonomy } from "../../data/taxonomy";

const taxonomy = await getTaxonomy();
---

<Layout
  title="All Calculators | Your Site Name"
  description="Browse our complete collection of free online calculators, organized by category."
>
  <main class="container">
    <h1>Our Calculators</h1>
    <p class="lead">
      Explore our full suite of tools, organized into hubs for easy navigation.
    </p>

    <div class="hub-grid">
      {
        taxonomy.map((hub) => (
          <a href={`/en/${hub.slug}`} class="hub-card">
            <h2>{hub.name}</h2>
            <p>{hub.description}</p>
          </a>
        </a>
      ))}
    </div>
  </main>
</Layout>