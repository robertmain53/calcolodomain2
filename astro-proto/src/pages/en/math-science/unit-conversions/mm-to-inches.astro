---
import fs from "node:fs";
import path from "node:path";
import Layout from "../../../../components/Layout.astro";
import SeoHead from "../../../../components/SeoHead.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const filePath = path.join(process.cwd(), "..", "sito_modificato", "mm-to-inches.html");
let raw = fs.readFileSync(filePath, "utf8");
raw = raw
  .replace(/<script[^>]*tailwindcss[^>]*><\/script>/gi, "")
  .replace(/<header[\s\S]*?<\/header>/i, "");
const stripScripts = /<script(?![^>]*application\/ld\+json)[\s\S]*?<\/script>/gi;
raw = raw.replace(stripScripts, "");
const titleMatch = raw.match(/<title>([^<]*)<\/title>/i);
const descMatch = raw.match(/<meta\s+name="description"\s+content="([^"]*)"/i);
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
const title = titleMatch?.[1]?.trim() || "Millimeters to Inches Converter";
const description =
  descMatch?.[1]?.trim() ||
  "Convert millimeters to inches (decimal and fractional) with formulas and examples.";
const body = bodyMatch?.[1] || "";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead
      title={title}
      description={description}
      slug={["math-science", "unit-conversions", "mm-to-inches"]}
    />
    <link rel="stylesheet" href="/vendor/tailwind.min.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="legacy" set:html={body}></div>

  <section class="enhanced">
    <h2>Enhanced converter (fractions, sig figs, visuals)</h2>
    <p class="lede">Reactive mm↔inch converter with fractional output (1/16), significant figures, and visual ruler.</p>
    <CalculatorIsland slug="mm-to-inches" />
  </section>
</Layout>

<style>
  .enhanced {
    margin-top: 1.5rem;
    padding: 1rem;
    border: 1px solid #1f2937;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
  }
  .enhanced .lede {
    color: #94a3b8;
  }
  .legacy header svg,
  .legacy nav svg {
    max-width: 24px;
    max-height: 24px;
  }
</style>