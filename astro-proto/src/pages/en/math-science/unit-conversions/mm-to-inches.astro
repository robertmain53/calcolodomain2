---
import Layout from "../../../../components/Layout.astro";
import SeoHead from "../../../../components/SeoHead.astro";
import RelatedList from "../../../../components/RelatedList.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import { findPage, relatedPages } from "../../../../data/pages";

const page = findPage("en", ["math-science", "unit-conversions", "mm-to-inches"]);
const related = page ? relatedPages(page).slice(0, 4) : [];
const crumbs = [
  { href: "/en", label: "Home" },
  { href: "/en/math-science", label: "Math & Science" },
  { href: "/en/math-science/unit-conversions", label: "Unit Conversions" }
];

const sameCluster =
  page ? related.filter((p) => p.primary.cluster === page.primary.cluster && p.slug[2] !== page.slug[2]) : [];
const crossCluster =
  page ? related.filter(
        (p) => p.primary.cluster !== page.primary.cluster || p.primary.hub !== page.primary.hub,
      ) : [];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Millimeters to Inches Converter",
      "applicationCategory": "EducationalApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": 0, "priceCurrency": "USD" },
      "creator": { "@type": "Organization", "name": "CalcDomain" },
      "dateCreated": "2025-01-01",
      "dateModified": "2025-01-01",
      "url": "https://calcdomain.com/en/math-science/unit-conversions/mm-to-inches"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": crumbs.map((c, idx) => ({
        "@type": "ListItem",
        "position": idx + 1,
        "name": c.label,
        "item": `https://calcdomain.com${c.href}`
      }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why is 25.4 mm the exact length of an inch?",
          "acceptedAnswer": { "@type": "Answer", "text": "In 1959, the inch was internationalized and defined as exactly 25.4 mm, aligning science, manufacturing, and trade." }
        },
        {
          "@type": "Question",
          "name": "Are decimal and 1/16 fractions shown?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes! This tool shows decimals and fractions, matching real engineering drawings and tools." }
        },
        {
          "@type": "Question",
          "name": "How do significant figures help?",
          "acceptedAnswer": { "@type": "Answer", "text": "They keep measurement precision realistic for science, machining, or tolerance checks." }
        },
        {
          "@type": "Question",
          "name": "Why have fractions and feet+inches outputs?",
          "acceptedAnswer": { "@type": "Answer", "text": "Imperial drawings and tapes use feet/inches/fractions; bridging with metric inputs aids clarity and reduces errors." }
        }
      ]
    }
  ]
};

const conversionTable = [
  [1, "0.03937", "1/32"],
  [10, "0.3937", "25/64"],
  [25.4, "1", "1"],
  [50, "1.9685", "1 31/32"],
  [100, "3.937", "3 15/16"],
  [220, "8.6614", "8 21/32"],
  [254, "10", "10"],
  [500, "19.685", "19 11/16"],
  [1000, "39.37", "39 3/8"]
];
const sources = [
  { href: "https://www.nist.gov/pml/special-publication-811/nist-guide-si-chapter-8", label: "NIST SI Inch Definition" },
  { href: "https://en.wikipedia.org/wiki/Inch", label: "Wikipedia: Inch" },
  { href: "https://www.bipm.org/en/publications/si-brochure", label: "BIPM: SI Brochure" }
];
---

<Layout title="Millimeters to Inches Converter" description="Convert millimeters to inches with decimal, fraction, and feet+inches outputs. No-CLS, mobile-ready, and covers exact standards.">
  <Fragment slot="head">
    <SeoHead
      title="Millimeters to Inches Converter"
      description="Convert millimeters to inches with decimal, fraction, and feet+inches outputs. No-CLS, mobile-ready, and covers exact standards."
      slug={["math-science", "unit-conversions", "mm-to-inches"]}
    />
    <script type="application/ld+json" set:html={JSON.stringify(schemaData, null, 2)} />
  </Fragment>

  <section class="hero" id="mm-tool">
    <div>
      <p class="kicker">
        <a href="/en">Home</a> · <a href="/en/math-science">Math & Science</a> · <a href="/en/math-science/unit-conversions">Unit Conversions</a>
      </p>
      <h1>Millimeters to Inches Converter</h1>
      <p class="lede">Convert mm &rarr; inches with decimal, fraction (1/16), and feet+inches readouts. Precision for science, machining, engineering, and design&mdash;with zero layout shift and mobile keypad!</p>
      <div class="tags">
        <span class="pill">Visual</span>
        <span class="pill muted">Fractions</span>
        <span class="pill muted">Metric/Imperial</span>
      </div>
    </div>
    <div class="calc-box">
      <CalculatorIsland slug="mm-to-inches" client:load />
      <p class="muted">Quick for unit checks; Pro for feet/inches, frac, meters, and context metrics.</p>
    </div>
  </section>

  <section class="grid two">
    <div class="panel">
      <h2>Inputs and tips</h2>
      <ul>
        <li>Value (<span class="tip" title="Input the value in mm or inches.">?</span>): <b>type mm or in</b> (keyboard optimized for mobile/decimal)</li>
        <li>Direction (<span class="tip" title="Swap mm↔in.">?</span>): mm&rarr;inches or inches&rarr;mm</li>
        <li>Significant figures (<span class="tip" title="Keeps output precision realistic.">?</span>)</li>
        <li>Fractions (1/16 in) and feet+inches (<span class="tip" title="For direct use with US/UK tapes or prints.">?</span>)</li>
      </ul>
    </div>
    <div class="panel">
      <h2>Common use cases</h2>
      <ul>
        <li>Mechanical design: parts, tolerances, schematic dimensions</li>
        <li>3D printing: STL specs, nozzle checks, fit-to-imperial block sizes</li>
        <li>Electronics: PCB footprints, display size, enclosure cutouts</li>
        <li>Carpentry/fabrication: adjusting between plans (metric↔imperial)</li>
        <li>International trade: product dimensions, compliance forms</li>
      </ul>
    </div>
  </section>

  <section class="panel">
    <h2>Conversions Table</h2>
    <table class="conv">
      <thead><tr><th>Millimeters (mm)</th><th>Inches (decimal)</th><th>Inches (fraction/ft+in)</th></tr></thead>
      <tbody>
        {conversionTable.map(([mm, dec, frac]) => (
          <tr><td>{mm}</td><td>{dec}</td><td>{frac}</td></tr>
        ))}
      </tbody>
    </table>
    <p class="muted">Feet+inches example: 39.37 in = 3 ft 3.37 in. <b>Fraction rounds to 1/16.</b></p>
  </section>

  <section class="panel">
    <h2>Theory, formula, and precision</h2>
    <ul class="bullets">
      <li><b>Global standard: </b>1 inch = <b>exactly</b> 25.4 mm (since 1959).</li>
      <li>Formula: in = mm/25.4; mm = in × 25.4. Fraction and feet+in outputs help align with imperial documentation or tapes.</li>
      <li>Significant figures: only show precision justified by input&mdash;see Pro toggle.</li>
      <li>Avoid layout shift: reserve result display area; stable on both quick and pro.</li>
      <li>Context: engineering, PCB, fabrication, and shop-floor use cases benefit from instant reliable conversion.</li>
    </ul>
  </section>

  <section class="panel">
    <h2>Examples</h2>
    <ul>
      <li>50 mm &rarr; 1.9685 in &asymp; 1 31/32 (machined part check, tape measure match)</li>
      <li>254 mm &rarr; 10 in exactly (sanity check for international inch definition)</li>
      <li>220 mm &rarr; 8.6614 in (circuit board/display footprint)</li>
      <li>39.37 in = 3 ft 3.37 in (used for checking stick length/woodcut/parts)</li>
    </ul>
  </section>
  <section class="panel">
    <h2>FAQ</h2>
    <div class="faq">
      <details open>
        <summary>Why is 25.4 mm the exact length of an inch?</summary>
        <p>In 1959, the international inch standardized at 25.4 mm; older values like 25.399 and 25.4± led to manufacturing/calibration errors.</p>
      </details>
      <details>
        <summary>Can I see fraction (1/16 in) and decimal?</summary>
        <p>Yes&mdash;decimal and 1/16 fractions are shown together, so you can bridge gap between metric and US/UK shop prints.</p>
      </details>
      <details>
        <summary>What's the benefit of significant figures?</summary>
        <p>They track real measurement precision&mdash;false precision in conversions leads to costly manufacturing and QA mistakes.</p>
      </details>
      <details>
        <summary>What about feet+inches output?</summary>
        <p>For quick reference with shop scales/tapes; ensures decimal inch values are immediately meaningful in the real world (esp. US, UK, Canada).</p>
      </details>
    </div>
  </section>
  <section class="panel">
    <h2>Sources and further reading</h2>
    <ul class="sources">
      {sources.map((s) => (
        <li><a href={s.href} rel="noopener external" target="_blank">{s.label}</a></li>
      ))}
    </ul>
  </section>
  {(sameCluster.length > 0 || crossCluster.length > 0) && (
    <section class="panel related">
      <h2>Related tools</h2>
      <div class="grid two">
        <div>
          <h3>Same cluster</h3>
          <ul>
            {sameCluster.map((p) => (
              <li><a href={`/en/${p.slug.join("/")}`}>{p.title}</a></li>
            ))}
            {sameCluster.length === 0 && <li class="muted">More unit conversion tools coming soon.</li>}
          </ul>
        </div>
        <div>
          <h3>Cross-silo</h3>
          <ul>
            {crossCluster.map((p) => (
              <li><a href={`/en/${p.slug.join("/")}`}>{p.title}</a></li>
            ))}
            {crossCluster.length === 0 && <li class="muted">More links will appear soon.</li>}
          </ul>
        </div>
      </div>
    </section>
  )}
  {related.length > 0 && <RelatedList items={related} />}
</Layout>