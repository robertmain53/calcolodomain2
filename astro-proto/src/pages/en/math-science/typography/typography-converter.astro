---
import Layout from "../../../../components/Layout.astro";
import SeoHead from "../../../../components/SeoHead.astro";
import StructuredData from "../../../../components/StructuredData.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import RelatedList from "../../../../components/RelatedList.astro";

const title = "Typography Unit Converter (px, pt, em, rem, %%)";
const description = "Convert typography units with live preview, relative vs absolute guidance, accessibility and WCAG context, and full formulae.";
const today = "2024-06-11";
const slugArr = ["math-science", "typography", "typography-converter"];
const breadCrumbs = [
  { name: "Home", href: "/en/" },
  { name: "Math & Science", href: "/en/math-science/" },
  { name: "Typography & CSS Units", href: "/en/math-science/typography/" },
  { name: "Typography Converter", href: "/en/math-science/typography/typography-converter/" },
];
const pageUrl = "/en/math-science/typography/typography-converter/";
---

<Layout title={title} description={description}>
  <SeoHead title={title} description={description} slug={slugArr} />
  <StructuredData>
    {{
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": title,
      "url": `https://calc.domain${pageUrl}`,
      "applicationCategory": "EducationalApplication",
      "creator": { "@type": "Organization", "name": "CalcDomain" },
      "dateCreated": today,
      "dateModified": today,
      "offers": { "@type": "Offer", "price": "0" },
      "description": description
    }}
    {{
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to convert px, pt, em, rem, percent",
      "step": [
        "Provide base font size",
        "Enter value for any unit (px/pt/em/rem/%)",
        "See others update automatically",
        "Use preview area to check accessibility/appearance"
      ],
      "tool": title,
      "totalTime": "PT1S"
    }}
    {{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question",
          "name": "When should I use rem vs em?",
          "acceptedAnswer": { "@type": "Answer", "text": "rem offers site/global consistency (scalable). em applies local scaling within a component or element. Use rem for general typography, em for contextual adjustments." }},
        { "@type": "Question",
          "name": "How do units impact accessibility?",
          "acceptedAnswer": { "@type": "Answer", "text": "Relative units (rem, em, %) let users resize text and honor their OS/browser preferences, dramatically improving readability for all." }},
        { "@type": "Question",
          "name": "Are px and pt really the same across devices?",
          "acceptedAnswer": { "@type": "Answer", "text": "Not quite. 1 pt = 1/72 in; px is device-dependent, but browsers map 16 px ≈ 12 pt by default for legibility. Use relative units for responsive sites." }}
      ]
    }}
  </StructuredData>

  <nav aria-label="Breadcrumb" class="breadcrumbs">
    {breadCrumbs.map((b, i) => (
      <span>{i > 0 && " · "}<a href={b.href}>{b.name}</a></span>
    ))}
  </nav>

  <main>
    <header class="section-hero">
      <h1>{title}</h1>
      <p class="lede">Convert px ⇄ pt ⇄ em ⇄ rem ⇄ % with a live preview and instant recalculation. Includes accessibility notes and formulas for UI/UX and developer use. No-CLS, mobile input ready.</p>
    </header>

    <section class="section-calc" aria-labelledby="typography-units-calculator">
      <h2 id="typography-units-calculator">Converter: all units, real-time</h2>
      <CalculatorIsland slug="typography-converter" />
      <p class="tip">Tip: Change any value and the others will adapt, including live preview for contrast/legibility.</p>
    </section>

    <section class="section-theory" aria-labelledby="typography-units-about">
      <h2 id="typography-units-about">About px, pt, em, rem, and relative units</h2>
      <ul>
        <li><b>Absolute units:</b> <code>px</code> (pixels), <code>pt</code> (points) – fixed size, don't adapt to the user or context.</li>
        <li><b>Relative units:</b> <code>em</code> and <code>rem</code> (<i>relative to element or root</i>), <code>%</code>—these scale based on parent/root font size, excellent for accessibility and responsiveness.</li>
        <li><b>Browser default:</b> 16 px base often equals 12 pt = 1 rem = 100%.</li>
      </ul>
    </section>

    <section class="section-formulas" aria-labelledby="typography-formulas">
      <h2 id="typography-formulas">Conversion formulas</h2>
      <ul>
        <li>rem = px / base font size</li>
        <li>em = px / parent font size (often = rem at root)</li>
        <li>pt = px × 0.75</li>
        <li>% = 100 × (px / base font size)</li>
      </ul>
      <p class="muted">In design systems, set font sizes in rem for predictable scaling throughout your UI.</p>
    </section>

    <section class="section-accessibility" aria-labelledby="typography-accessibility">
      <h2 id="typography-accessibility">Accessibility and responsive tips</h2>
      <ul>
        <li>rem/em allow users to zoom text to their needs (per WCAG guidance).</li>
        <li>Preview area simulates user font scaling for accessibility QA.</li>
      </ul>
    </section>

    <section class="section-examples" aria-labelledby="typography-examples">
      <h2 id="typography-examples">Examples</h2>
      <ul>
        <li><b>16 px base, 20 px heading</b> → <b>1.25 rem</b></li>
        <li><b>15 px base, 18 px label</b> → <b>1.2 rem</b> (both scale with root)</li>
        <li><b>24 px</b> → <b>18 pt</b> using pt = px × 0.75</li>
      </ul>
    </section>

    <section class="section-faq" aria-labelledby="typography-faq">
      <h2 id="typography-faq">FAQ</h2>
      <dl>
        <dt>When to use rem vs em?</dt>
        <dd>rem gives consistent, site-wide scaling; em is contextual. Use rem for major typography like paragraphs and headings, em for button text or inputs inside resizable panels.</dd>
        <dt>Why is accessibility enhanced with relative units?</dt>
        <dd>rem, em, and % let users increase text size for better readability without breaking layouts, a core WCAG recommendation.</dd>
        <dt>Are px/pt always mapped the same on all screens?</dt>
        <dd>Browsers map 16 px ≈ 12 pt by default. But this can vary; always test on target devices. Relative units are more future-proof.</dd>
      </dl>
    </section>

    <section class="section-related">
      <RelatedList slug={slugArr} />
    </section>
  </main>

  <style>
    .breadcrumbs {font-size:0.95rem;color:#64748b;margin:.7rem 0 1.2rem .3rem;}
    .breadcrumbs a {color:inherit;text-decoration:underline dotted;transition:color .17s}
    .breadcrumbs a:hover {color:#14b8a6}
    .lede {font-size:1.13rem;color:#dbeafe;font-weight:500;margin:.4em 0 1em 0;max-width:730px;}
    main {max-width: 800px; margin: 0 auto 2.5rem; padding: 0 1rem;}
    section {margin-bottom:1.7rem;}
    section h2 {font-size:1.17rem;margin-bottom:.4em;color:#f1f5f9;}
    .tip {color:#22d3ee;font-size:.98rem;margin-top:.3em;}
    dl dt {font-weight:700;margin-top:.7em;color:#f1f5f9;}
    dl dd {margin-left:0.8em;color:#e0e7ef;}
    ul {margin-bottom:.4em;}
    .section-examples ul {list-style:square;font-size:1.07em;}
    .section-examples li b {color:#38bdf8;}
    .muted {color:#94a3b8;}
  </style>
</Layout>

