---
import fs from "node:fs";
import path from "node:path";
import Layout from "../../../../components/Layout.astro";
import SeoHead from "../../../../components/SeoHead.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const filePath = path.join(process.cwd(), "..", "sito_modificato", "btu-to-kwh.html");
const raw = fs.readFileSync(filePath, "utf8");
const titleMatch = raw.match(/<title>([^<]*)<\/title>/i);
const descMatch = raw.match(/<meta\s+name="description"\s+content="([^"]*)"/i);
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
const title = titleMatch?.[1]?.trim() || "BTU to kWh Converter";
const description =
  descMatch?.[1]?.trim() ||
  "Convert BTU and kWh with clarity on energy vs power and real-world HVAC examples.";
const body = bodyMatch?.[1] || "";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead
      title={title}
      description={description}
      slug={["math-science", "energy", "btu-to-kwh"]}
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="legacy" set:html={body}></div>

  <section class="enhanced">
    <h2>Enhanced BTU ↔ kWh converter</h2>
    <p class="lede">Reactive energy converter with sig figs and reminders on energy vs power.</p>
    <CalculatorIsland slug="btu-to-kwh" />
  </section>
</Layout>

<style>
  .enhanced {
    margin-top: 1.5rem;
    padding: 1rem;
    border: 1px solid #1f2937;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
  }
  .enhanced .lede {
    color: #94a3b8;
  }
</style>
