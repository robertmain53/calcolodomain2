---
import fs from "node:fs";
import path from "node:path";
import Layout from "../../../../components/Layout.astro";
import SeoHead from "../../../../components/SeoHead.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";

const filePath = path.join(process.cwd(), "..", "sito_modificato", "degrees-to-radians.html");
const raw = fs.readFileSync(filePath, "utf8");
const titleMatch = raw.match(/<title>([^<]*)<\/title>/i);
const descMatch = raw.match(/<meta\s+name="description"\s+content="([^"]*)"/i);
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
const title = titleMatch?.[1]?.trim() || "Degrees to Radians Converter";
const description =
  descMatch?.[1]?.trim() ||
  "Convert degrees to radians and vice versa with formulas, steps, and Pi notation.";
const body = bodyMatch?.[1] || "";
---
<Layout title={title} description={description}>
  <Fragment slot="head">
    <SeoHead
      title={title}
      description={description}
      slug={["math-science", "angle", "degrees-to-radians"]}
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="legacy" set:html={body}></div>

  <section class="enhanced">
    <h2>Enhanced converter (reactive, with visuals)</h2>
    <p class="lede">Quick, reactive angle converter with unit circle visual and trig outputs. Complements the original calculator and content.</p>
    <CalculatorIsland slug="degrees-to-radians" />
  </section>
</Layout>

<style>
  .enhanced {
    margin-top: 1.5rem;
    padding: 1rem;
    border: 1px solid #1f2937;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
  }
  .enhanced .lede {
    color: #94a3b8;
  }
  /* Keep legacy and enhanced SVGs constrained */
  .legacy svg,
  .enhanced svg {
    max-width: 360px;
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }
</style>
