---
import Layout from "../../../../components/Layout.astro";
import SeoHead from "../../../../components/SeoHead.astro";
import StructuredData from "../../../../components/StructuredData.astro";
import RelatedList from "../../../../components/RelatedList.astro";
import { findPage, relatedPages } from "../../../../data/pages";

const page = findPage("en", ["engineering-construction", "thermotechnics", "btu-to-kwh"]);
const related = page ? relatedPages(page).slice(0, 4) : [];
const crumbs = [
  { href: "/en", label: "Home" },
  { href: "/en/engineering-construction", label: "Engineering & Construction" },
  { href: "/en/engineering-construction/thermotechnics", label: "Thermotechnics" },
];

const sameCluster =
  page ? related.filter((p) => p.primary.cluster === page.primary.cluster && p.slug[2] !== page.slug[2]) : [];
const crossCluster =
  page
    ? related.filter(
        (p) => p.primary.cluster !== page.primary.cluster || p.primary.hub !== page.primary.hub,
      )
    : [];

// ATTENZIONE ALLE VIRGOLE QUI SOTTO
const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "BTU to kWh Converter",
      applicationCategory: "EngineeringApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: 0, priceCurrency: "USD" }, // Virgola qui
      creator: { "@type": "Organization", name: "CalcDomain" },       // Virgola qui
      dateCreated: "2025-01-01",
      dateModified: "2025-01-01",
      url: "https://calcdomain.com/en/engineering-construction/thermotechnics/btu-to-kwh" // Niente virgola sull'ultimo elemento (opzionale ma pulito)
    }, // <--- VIRGOLA FONDAMENTALE TRA GLI OGGETTI DELL'ARRAY
    {
      "@type": "BreadcrumbList",
      itemListElement: crumbs.map((c, idx) => ({
        "@type": "ListItem",
        position: idx + 1,
        name: c.label,
        item: `https://calcdomain.com${c.href}`
      }))
    }, // <--- VIRGOLA FONDAMENTALE
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "BTU or BTU/h?",
          acceptedAnswer: { "@type": "Answer", text: "BTU is energy; BTU/h is power. Use BTU/h or kW when sizing equipment." }
        }, // Virgola
        {
          "@type": "Question",
          name: "Where does 3412 come from?",
          acceptedAnswer: { "@type": "Answer", text: "It links joules to watt-hours and BTU via the mechanical equivalent of heat." }
        }, // Virgola
        {
          "@type": "Question",
          name: "How to compare efficiencies?",
          acceptedAnswer: { "@type": "Answer", text: "Normalize to the same energy unit (kWh or BTU) and apply SEER (BTU/Wh) or COP (kW out / kW in)." }
        }
      ]
    }
  ]
};
---

<Layout
  title="BTU to kWh Converter"
  description="Convert BTU ↔ kWh with clear energy vs power context, HVAC/electrical examples, and pro outputs."
>
  <Fragment slot="head">
    <SeoHead
      title="BTU to kWh Converter"
      description="Convert BTU ↔ kWh with clear energy vs power context, HVAC/electrical examples, and pro outputs."
      slug={["engineering-construction", "thermotechnics", "btu-to-kwh"]}
    />
    
    {page && <StructuredData page={page} breadcrumbs={[...crumbs, { href: "/en/engineering-construction/thermotechnics/btu-to-kwh", label: "BTU to kWh Converter" }]} />}

    <script type="application/ld+json" set:html={JSON.stringify(schemaData, null, 2)} />
    
  </Fragment>

  <section class="hero" id="btu-tool">
    <div>
      <p class="kicker">
        <a href="/en">Home</a> · <a href="/en/engineering-construction">Engineering & Construction</a> ·
        <a href="/en/engineering-construction/thermotechnics">Thermotechnics</a>
      </p>
      <h1>BTU to kWh Converter</h1>
      <p class="lede">
        Convert BTU ↔ kWh with sig figs, Joules/Wh outputs, and an explicit reminder about energy vs power
        (BTU/h, kW) so you size HVAC and electrical loads correctly. Includes pro-grade context for technicians.
      </p>
      <div class="tags">
        <span class="pill">Scientific</span>
        <span class="pill muted">Energy</span>
        <span class="pill muted">HVAC</span>
      </div>
    </div>
    <div class="calc-box">
      <div class="mode-toggle">
        <button type="button" class="chip active" data-mode="quick">Quick</button>
        <button type="button" class="chip" data-mode="pro">Pro</button>
      </div>
      <form class="stack linear" id="btu-form">
        <label>
          <span class="lbl">Value <span class="tip" title="Energy value to convert">?</span></span>
          <input type="number" inputmode="decimal" name="value" value="12000" />
        </label>
        <label>
          <span class="lbl">Direction <span class="tip" title="Switch BTU → kWh or kWh → BTU">?</span></span>
          <select name="dir">
            <option value="btu-kwh">BTU → kWh</option>
            <option value="kwh-btu">kWh → BTU</option>
          </select>
        </label>
        <label>
          <span class="lbl">Significant figures</span>
          <select name="sig">
            <option>3</option>
            <option selected>4</option>
            <option>5</option>
            <option>6</option>
          </select>
        </label>
        <div class="result">
          <div class="big" data-field="main">0</div>
          <div class="sub" data-field="secondary">–</div>
        </div>
        <div class="pro-panel" data-pro-panel>
          <div class="pro-head">Pro outputs</div>
          <ul data-pro-list></ul>
        </div>
      </form>
      <p class="muted">Quick mode for fast conversions; Pro surfaces Joules, Wh, BTU echo, and reminders on power vs energy.</p>
    </div>
  </section>

  <section class="grid two">
    <div class="panel">
      <h2>When to use it</h2>
      <ul>
        <li>HVAC sizing: cooling/heating capacity labeled in BTU/h; electrical billing in kWh.</li>
        <li>Appliance comparison: gas vs electric heaters, heat pumps, boilers.</li>
        <li>Energy storage: battery discharge (kWh) vs thermal storage (BTU).</li>
        <li>Efficiency checks: COP/SEER ratings need consistent units; convert BTU to kWh to normalize.</li>
        <li>Audit and commissioning: compare nameplate BTU/h vs measured electrical draw in kW.</li>
      </ul>
    </div>
    <div class="panel">
      <h2>Inputs &amp; outputs</h2>
      <ul>
        <li>Energy value in BTU or kWh (sig figs supported).</li>
        <li>Direction toggle (BTU → kWh or kWh → BTU).</li>
        <li>Pro mode: Joules, Wh, and original unit echo for QA.</li>
        <li>Context tips: reminders when you should switch to BTU/h or kW (power) instead of energy.</li>
      </ul>
    </div>
  </section>

  <section class="panel">
    <h2>Theory &amp; formulas</h2>
    <ul class="bullets">
      <li>Energy link: 1 kWh ≈ 3412 BTU; inverse 1 BTU ≈ 0.00029307107 kWh.</li>
      <li>Definitions: BTU heats 1 lb of water by 1°F; kWh is 1 kW sustained for an hour.</li>
      <li>Energy vs power: BTU/kWh are energy; BTU/h and kW are power (rate). Don’t mix them when sizing equipment.</li>
      <li>SEER/COP normalization: SEER uses BTU/Wh; divide BTU/h by watts to assess seasonal efficiency.</li>
      <li>Combustion vs electric: gas furnaces specify input/output BTU; heat pumps list kW input—convert to compare apples to apples.</li>
    </ul>
  </section>

  <section class="panel">
    <h2>Examples</h2>
    <ul>
      <li>12,000 BTU/h AC ≈ 3.52 kW cooling capacity (steady hourly energy).</li>
      <li>5 kWh from a home battery ≈ 17,060 BTU of stored energy.</li>
      <li>40,000 BTU furnace cycle ≈ 11.73 kWh; check electrical breaker sizing vs gas input.</li>
      <li>Space heater 1500 W for 2 hours ≈ 3 kWh = ~10,236 BTU of delivered heat (before losses).</li>
      <li>SEER 18 unit: 18 BTU/Wh → ~5.27 COP; sanity-checking performance claims.</li>
    </ul>
  </section>

  <section class="panel">
    <h2>FAQ</h2>
    <div class="faq">
      <details open>
        <summary>BTU or BTU/h?</summary>
        <p>BTU is energy; BTU/h is power. This converter handles energy—size equipment with BTU/h or kW separately.</p>
      </details>
      <details>
        <summary>Where does 3412 come from?</summary>
        <p>It connects the joule definition to the mechanical equivalent of heat linking watt-hours and BTU.</p>
      </details>
      <details>
        <summary>Can I use sig figs?</summary>
        <p>Yes—use the sig fig selector to keep precision realistic for specs and billing.</p>
      </details>
      <details>
        <summary>How do I compare efficiencies?</summary>
        <p>Convert energy to the same unit (kWh or BTU), then apply SEER (BTU/Wh) or COP (kW out / kW in). Higher is better.</p>
      </details>
    </div>
  </section>

  {related.length > 0 && <RelatedList items={related} />}
  {(sameCluster.length > 0 || crossCluster.length > 0) && (
    <section class="panel related">
      <h2>Related tools</h2>
      <div class="grid two">
        <div>
          <h3>Same cluster</h3>
          <ul>
            {sameCluster.map((p) => (
              <li><a href={`/en/${p.slug.join("/")}`}>{p.title}</a></li>
            ))}
            {sameCluster.length === 0 && <li class="muted">More thermotechnics tools coming soon.</li>}
          </ul>
        </div>
        <div>
          <h3>Cross-silo</h3>
          <ul>
            {crossCluster.map((p) => (
              <li><a href={`/en/${p.slug.join("/")}`}>{p.title}</a></li>
            ))}
            {crossCluster.length === 0 && <li class="muted">Cross-silo links will appear here.</li>}
          </ul>
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: linear-gradient(135deg, rgba(56,189,248,0.12), rgba(167,139,250,0.08));
    margin-bottom: 1rem;
  }
  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
    font-size: 0.85rem;
    margin: 0 0 0.25rem 0;
  }
  h1 {
    margin: 0 0 0.4rem 0;
    color: #fff;
  }
  .lede {
    color: #cbd5e1;
    margin: 0 0 0.5rem 0;
  }
  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .pill {
    border: 1px solid rgba(56,189,248,0.35);
    background: rgba(56,189,248,0.16);
    color: #e0f2fe;
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    font-size: 0.9rem;
  }
  .pill.muted {
    border-color: var(--border);
    background: rgba(255,255,255,0.04);
    color: #cbd5e1;
  }
  .calc-box {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem;
    background: rgba(255,255,255,0.03);
  }
  .mode-toggle {
    display: inline-flex;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }
  .chip {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.75rem;
    background: rgba(255,255,255,0.03);
    color: #e2e8f0;
    cursor: pointer;
  }
  .chip.active {
    background: rgba(56,189,248,0.16);
    border-color: rgba(56,189,248,0.45);
    color: #e0f2fe;
  }
  .calc-box .muted {
    color: #94a3b8;
    margin-top: 0.4rem;
  }
  .stack {
    display: grid;
    gap: 0.7rem;
  }
  label {
    display: grid;
    gap: 0.25rem;
    color: #e2e8f0;
    font-weight: 600;
  }
  input, select {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 0.7rem;
    color: #fff;
    font-size: 1rem;
  }
  .result {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.8rem 0.9rem;
    background: rgba(255,255,255,0.03);
    display: grid;
    gap: 0.35rem;
  }
  .big { font-size: 1.4rem; font-weight: 700; color: #fff; }
  .sub { color: #94a3b8; }
  .pro-panel {
    border: 1px dashed var(--border);
    border-radius: 10px;
    padding: 0.6rem 0.7rem;
    background: rgba(255,255,255,0.02);
    display: none;
  }
  .pro-panel.active { display: block; }
  .pro-head { font-weight: 700; color: #e2e8f0; margin-bottom: 0.35rem; }
  [data-pro-list] { margin: 0; padding-left: 1.1rem; color: #cbd5e1; display: grid; gap: 0.25rem; }
  .tip {
    display: inline-flex;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1px solid var(--border);
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: #e2e8f0;
    background: rgba(255,255,255,0.04);
    cursor: help;
  }
  .grid.two {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .panel {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
    background: rgba(255,255,255,0.02);
    margin-top: 0.75rem;
  }
  .panel.related ul { padding-left: 1.1rem; }
  .panel.related h3 { margin: 0 0 0.35rem 0; color: #e2e8f0; }
  .panel h2 {
    margin-top: 0;
    color: #e2e8f0;
  }
  ul {
    margin: 0;
    padding-left: 1.1rem;
    color: #cbd5e1;
  }
  .bullets {
    list-style: disc;
  }
  .faq details {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.6rem 0.7rem;
    background: rgba(255,255,255,0.02);
    color: #e2e8f0;
  }
  .faq details + details {
    margin-top: 0.5rem;
  }
  summary {
    cursor: pointer;
    font-weight: 600;
  }
</style>

<script is:inline>
  const tool = document.querySelector("#btu-tool");
  const form = tool?.querySelector("#btu-form");
  const modeButtons = tool?.querySelectorAll("[data-mode]") || [];
  const valueInput = form?.querySelector('input[name="value"]');
  const dirSelect = form?.querySelector('select[name="dir"]');
  const sigSelect = form?.querySelector('select[name="sig"]');
  const main = form?.querySelector("[data-field='main']");
  const secondary = form?.querySelector("[data-field='secondary']");
  const proPanel = form?.querySelector("[data-pro-panel]");
  const proList = form?.querySelector("[data-pro-list]");
  let mode = "quick";
  modeButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      mode = btn.dataset.mode || "quick";
      modeButtons.forEach((b) => b.classList.toggle("active", b === btn));
      if (proPanel) proPanel.classList.toggle("active", mode === "pro");
      recalc();
    });
  });
  const factor = 0.00029307107;
  const recalc = () => {
    if (!form || !valueInput || !dirSelect || !sigSelect || !main || !secondary) return;
    const val = Number(valueInput.value) || 0;
    const dir = dirSelect.value;
    const sig = Number(sigSelect.value) || 4;
    let out = 0;
    if (dir === "btu-kwh") {
      out = val * factor;
      main.textContent = `${val.toLocaleString()} BTU → ${Number(out.toPrecision(sig)).toLocaleString()} kWh`;
      secondary.textContent = `BTU/h hint: divide BTU/h by 3412 to get kW (power, not energy).`;
      if (mode === "pro" && proList) {
        proList.innerHTML = "";
        const items = [
          { label: "Joules", value: (out * 3.6e6).toLocaleString(undefined, { maximumFractionDigits: 2 }) },
          { label: "Watt-hours", value: (out * 1000).toLocaleString(undefined, { maximumFractionDigits: 2 }) },
          { label: "BTU (echo)", value: val.toLocaleString() },
        ];
        items.forEach((i) => {
          const li = document.createElement("li");
          li.textContent = `${i.label}: ${i.value}`;
          proList.appendChild(li);
        });
      }
    } else {
      out = val / factor;
      main.textContent = `${val.toLocaleString()} kWh → ${Number(out.toPrecision(sig)).toLocaleString()} BTU`;
      secondary.textContent = `Power context: ${val.toLocaleString()} kWh over 1h = ${val.toFixed(3)} kW (if steady).`;
      if (mode === "pro" && proList) {
        proList.innerHTML = "";
        const items = [
          { label: "Joules", value: (val * 3.6e6).toLocaleString(undefined, { maximumFractionDigits: 2 }) },
          { label: "Watt-hours", value: (val * 1000).toLocaleString(undefined, { maximumFractionDigits: 2 }) },
          { label: "BTU (result)", value: Number(out.toPrecision(sig)).toLocaleString() },
        ];
        items.forEach((i) => {
          const li = document.createElement("li");
          li.textContent = `${i.label}: ${i.value}`;
          proList.appendChild(li);
        });
      }
    }
  };
  valueInput?.addEventListener("input", recalc);
  dirSelect?.addEventListener("change", recalc);
  sigSelect?.addEventListener("change", recalc);
  recalc();
</script>
