---
import Layout from "../../../../components/Layout.astro";
import SeoHead from "../../../../components/SeoHead.astro";
import CalculatorIsland from "../../../../components/CalculatorIsland.astro";
import StructuredData from "../../../../components/StructuredData.astro";
import RelatedList from "../../../../components/RelatedList.astro";
import { findPage, relatedPages } from "../../../../data/pages";

const page = findPage("en", ["engineering-construction", "thermotechnics", "btu-to-kwh"]);
const related = page ? relatedPages(page).slice(0, 4) : [];
const crumbs = [
  { href: "/en", label: "Home" },
  { href: "/en/engineering-construction", label: "Engineering & Construction" },
  { href: "/en/engineering-construction/thermotechnics", label: "Thermotechnics" },
];
const sameCluster =
  page ? related.filter((p) => p.primary.cluster === page.primary.cluster && p.slug[2] !== page.slug[2]) : [];
const crossCluster =
  page
    ? related.filter(
        (p) => p.primary.cluster !== page.primary.cluster || p.primary.hub !== page.primary.hub,
      )
    : [];

// --- CORREZIONE: Creazione dello Schema JSON qui nel Frontmatter ---
const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "BTU to kWh Converter",
      "applicationCategory": "EngineeringApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": 0, "priceCurrency": "USD" },
      "creator": { "@type": "Organization", "name": "CalcDomain" },
      "dateCreated": "2025-01-01",
      "dateModified": "2025-01-01",
      "url": "https://calcdomain.com/en/engineering-construction/thermotechnics/btu-to-kwh",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": crumbs.map((c, idx) => ({
        "@type": "ListItem",
        "position": idx + 1,
        "name": c.label,
        "item": `https://calcdomain.com${c.href}`,
      })),
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "BTU or BTU/h?",
          "acceptedAnswer": { "@type": "Answer", "text": "BTU is energy; BTU/h is power. Use BTU/h or kW when sizing equipment." },
        },
        {
          "@type": "Question",
          "name": "Where does 3412 come from?",
          "acceptedAnswer": { "@type": "Answer", "text": "It links joules to watt-hours and BTU via the mechanical equivalent of heat." },
        },
        {
          "@type": "Question",
          "name": "How to compare efficiencies?",
          "acceptedAnswer": { "@type": "Answer", "text": "Normalize to the same energy unit (kWh or BTU) and apply SEER (BTU/Wh) or COP (kW out / kW in)." },
        },
      ],
    },
  ],
};
// ------------------------------------------------------------------
---

<Layout
  title="BTU to kWh Converter"
  description="Convert BTU ↔ kWh with clear energy vs power context, HVAC/electrical examples, and pro outputs."
>
  <Fragment slot="head">
    <SeoHead
      title="BTU to kWh Converter"
      description="Convert BTU ↔ kWh with clear energy vs power context, HVAC/electrical examples, and pro outputs."
      slug={["engineering-construction", "thermotechnics", "btu-to-kwh"]}
    />
    
    {page && <StructuredData page={page} breadcrumbs={[...crumbs, { href: "/en/engineering-construction/thermotechnics/btu-to-kwh", label: "BTU to kWh Converter" }]} />}

    <script type="application/ld+json" set:html={JSON.stringify(schemaData, null, 2)} />
    
  </Fragment>

  <section class="hero" id="btu-tool">