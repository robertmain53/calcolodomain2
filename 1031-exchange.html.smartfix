                                <label for="currentPropertyValue" class="block text-sm font-medium text-gray-700">
                                    Current Property Value <span class="text-red-600">*</span>
                                </label>
                                <input type="number" id="currentPropertyValue" step="1000"
                                    class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                            </div>
                            <div>
