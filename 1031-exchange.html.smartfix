    <script>
        (function() {
            'use strict';

            const fmtCurrency = (value) =>
                new Intl.NumberFormat('en-US', {
                    style: 'currency',
                    currency: 'USD',
                    maximumFractionDigits: 2
                }).format(value);

            const els = {
                currentPropertyValue: document.getElementById('currentPropertyValue'),
                purchasePrice: document.getElementById('purchasePrice'),
                improvementCosts: document.getElementById('improvementCosts'),
                taxRate: document.getElementById('taxRate'),
                capitalGain: document.getElementById('capitalGain'),
                taxDeferred: document.getElementById('taxDeferred'),
                adjustedBasis: document.getElementById('adjustedBasis'),
                resetBtn: document.getElementById('resetBtn'),
                calculatorUI: document.getElementById('calculator-ui')
            };

            function calculate() {
                const currentValue = parseFloat(els.currentPropertyValue.value) || 0;
                const purchase = parseFloat(els.purchasePrice.value) || 0;
                const improvements = parseFloat(els.improvementCosts.value) || 0;
                const taxRate = (parseFloat(els.taxRate.value) || 0) / 100;

                const adjustedBasis = purchase + improvements;
                const capitalGain = currentValue - adjustedBasis;
                const taxDeferred = capitalGain > 0 ? capitalGain * taxRate : 0;

                els.capitalGain.textContent = fmtCurrency(capitalGain);
                els.taxDeferred.textContent = fmtCurrency(taxDeferred);
                els.adjustedBasis.textContent = fmtCurrency(adjustedBasis);
            }

            els.calculatorUI.addEventListener('input', calculate);

            els.resetBtn.addEventListener('click', () => {
                els.currentPropertyValue.value = '';
                els.purchasePrice.value = '';
                els.improvementCosts.value = '0';
                els.taxRate.value = '15';
                calculate();
            });

            // Mobile menu toggle
            const mobileToggle = document.getElementById('mobile-menu-toggle');
            const mobileMenu = document.getElementById('mobile-menu');
            if (mobileToggle && mobileMenu) {
                mobileToggle.addEventListener('click', () => {
                    mobileMenu.classList.toggle('hidden');
                });
            }

            calculate();
        })();
    </script>
