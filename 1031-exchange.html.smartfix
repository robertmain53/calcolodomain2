                <div class="bg-white p-6 rounded-lg shadow-md">
                    <!-- Calculator Title and Intro -->
                    <h1 class="text-3xl font-bold mb-2">1031 Exchange Calculator</h1>
                    <p class="text-gray-600 mb-6">Calculate your potential capital gains tax deferral from a 1031 exchange. Designed for real estate investors looking to reinvest in new properties while deferring capital gains taxes.</p>

                    <!-- Calculator Form -->
                    <div id="calculator-ui" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
