    <script>
        (function() {
            'use strict';

            const fmtCurrency = (value) =>
                new Intl.NumberFormat('en-US', {
                    style: 'currency',
                    currency: 'USD',
                    maximumFractionDigits: 0
                }).format(value);

            const els = {
                loanAmount: document.getElementById('loanAmount'),
                interestRate15: document.getElementById('interestRate15'),
                interestRate30: document.getElementById('interestRate30'),
                monthly15: document.getElementById('monthly15'),
                monthly30: document.getElementById('monthly30'),
                monthlyDiff: document.getElementById('monthlyDiff'),
                total15: document.getElementById('total15'),
                total30: document.getElementById('total30'),
                totalDiff: document.getElementById('totalDiff'),
                interest15: document.getElementById('interest15'),
                interest30: document.getElementById('interest30'),
                interestSavings: document.getElementById('interestSavings'),
                insight: document.getElementById('insight'),
                resetBtn: document.getElementById('resetBtn'),
                calculatorUI: document.getElementById('calculator-ui')
            };

            function calculatePayment(principal, annualRate, years) {
                const monthlyRate = annualRate / 100 / 12;
                const numPayments = years * 12;

                if (monthlyRate === 0) {
                    return principal / numPayments;
                }

                const payment = (principal * monthlyRate * Math.pow(1 + monthlyRate, numPayments)) /
                               (Math.pow(1 + monthlyRate, numPayments) - 1);
                return payment;
            }

            function calculate() {
                const principal = parseFloat(els.loanAmount.value) || 0;
                const rate15 = parseFloat(els.interestRate15.value) || 0;
                const rate30 = parseFloat(els.interestRate30.value) || 0;

                if (principal <= 0) return;

                // Calculate 15-year
                const payment15 = calculatePayment(principal, rate15, 15);
                const total15 = payment15 * 180;
                const interest15 = total15 - principal;

                // Calculate 30-year
                const payment30 = calculatePayment(principal, rate30, 30);
                const total30 = payment30 * 360;
                const interest30 = total30 - principal;

                // Differences
                const monthlyDiff = payment15 - payment30;
                const totalDiff = total30 - total15;
                const interestSavings = interest30 - interest15;

                // Update UI
                els.monthly15.textContent = fmtCurrency(payment15);
                els.monthly30.textContent = fmtCurrency(payment30);
                els.monthlyDiff.textContent = fmtCurrency(Math.abs(monthlyDiff)) + (monthlyDiff > 0 ? ' higher' : ' lower');

                els.total15.textContent = fmtCurrency(total15);
                els.total30.textContent = fmtCurrency(total30);
                els.totalDiff.textContent = fmtCurrency(Math.abs(totalDiff)) + ' more';

                els.interest15.textContent = fmtCurrency(interest15);
                els.interest30.textContent = fmtCurrency(interest30);
                els.interestSavings.textContent = fmtCurrency(interestSavings) + ' saved with 15-year';

                // Generate insight
                const percentSavings = (interestSavings / interest30 * 100).toFixed(0);
                els.insight.textContent = `With a 15-year mortgage, you'll pay ${fmtCurrency(monthlyDiff)} more per month, but save ${fmtCurrency(interestSavings)} (${percentSavings}%) in interest over the life of the loan.`;
            }

            els.calculatorUI.addEventListener('input', calculate);

            els.resetBtn.addEventListener('click', () => {
                els.loanAmount.value = '300000';
                els.interestRate15.value = '5.5';
                els.interestRate30.value = '6.5';
                calculate();
            });

            // Mobile menu toggle
            const mobileToggle = document.getElementById('mobile-menu-toggle');
            const mobileMenu = document.getElementById('mobile-menu');
            if (mobileToggle && mobileMenu) {
                mobileToggle.addEventListener('click', () => {
                    mobileMenu.classList.toggle('hidden');
                });
            }

            calculate();
        })();
    </script>
</body>
