  <!-- Calculator logic (ported from your original, cleaned up) -->
  <script>
  (function(){
    'use strict';
    const $ = (id) => document.getElementById(id);
    const live = $('results-content');

    // Panels
    const panels = {
      simplify: $('panel-simplify'),
      proportion: $('panel-proportion'),
      scale: $('panel-scale'),
      split: $('panel-split')
    };
    document.querySelectorAll('input[name="mode"]').forEach(r=>{
      r.addEventListener('change', ()=>{
        const val = r.value;
        Object.entries(panels).forEach(([k,el])=>{
          const on = (k===val);
          el.hidden = !on; el.setAttribute('aria-hidden', String(!on));
        });
        clearResults();
        announce(val);
        if(val==='proportion') syncUnknownUI();
      });
    });
    function announce(mode){
      const names = {simplify:'Simplify a ratio', proportion:'Solve a proportion', scale:'Scale a ratio', split:'Split a total'};
      live.innerHTML = '<p>Mode: <strong>'+names[mode]+'</strong>. Enter values to calculate.</p>';
    }

    // Parsing/formatting
    function parseNum(v){
      if(typeof v!=='string') return NaN;
      const s = v.trim().replace(',', '.');
      if(s==='') return NaN;
      const n = Number(s);
      return Number.isFinite(n)?n:NaN;
    }
    function fmt(n){
      if(!Number.isFinite(n)) return '—';
      const abs = Math.abs(n);
      if(abs!==0 && (abs < 1e-4 || abs >= 1e7)) return n.toExponential(6);
      return (+n.toFixed(10)).toString();
    }

    // Helpers
    function setErr(input, id, msg){ const el=$(id); if(el) el.textContent = msg||''; input?.setAttribute('aria-invalid', msg? 'true':'false'); }
    function clearResults(){ live.innerHTML = '<p>Enter values to see results. The results panel is reserved for output to prevent layout shift.</p>'; }
    function render(pairs, title){
      const items = pairs.map(([label, value]) =>
        '<div class="result-item"><span class="result-label">'+esc(label)+'</span><span class="result-value">'+esc(value)+'</span></div>'
      ).join('');
      live.innerHTML = '<h3 class="font-semibold mb-2">'+esc(title)+' — Output</h3>'+items;
    }
    function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;'); }

    // gcd + decimals handling
    function gcdInt(a,b){ a=Math.abs(a); b=Math.abs(b); while(b){ const t=b; b=a%b; a=t; } return a||1; }
    function normalizeToIntegers(a,b){
      function dp(x){ const s=String(x), i=s.indexOf('.'); return i===-1?0:s.length-i-1; }
      const p = Math.pow(10, Math.max(dp(a), dp(b)));
      return [Math.round(a*p), Math.round(b*p)];
    }

    /*** Simplify ***/
    const simpA=$('simp-a'), simpB=$('simp-b');
    $('btn-simplify').addEventListener('click', doSimplify);
    $('btn-simplify-reset').addEventListener('click', ()=>{ simpA.value=''; simpB.value=''; setErr(simpA,'simp-a-err',''); setErr(simpB,'simp-b-err',''); clearResults(); });
    [simpA,simpB].forEach(el=>el.addEventListener('blur', validateSimplify));

    function validateSimplify(){
      const a=parseNum(simpA.value), b=parseNum(simpB.value);
      setErr(simpA,'simp-a-err', Number.isNaN(a)?'Enter a valid number for a.':'');
      setErr(simpB,'simp-b-err', Number.isNaN(b)?'Enter a valid number for b.':'');
      if(!Number.isNaN(a)&&!Number.isNaN(b)&&a===0&&b===0){
        setErr(simpA,'simp-a-err','a and b cannot both be zero.');
        setErr(simpB,'simp-b-err','a and b cannot both be zero.');
      }
    }
    function doSimplify(){
      validateSimplify();
      const a0=parseNum(simpA.value), b0=parseNum(simpB.value);
      if([a0,b0].some(Number.isNaN) || (a0===0 && b0===0)) return;

      // Zero cases
      if(a0!==0 && b0===0){
        const simplified = (a0<0?'-1:0':'1:0');
        render([
          ['Input ratio', fmt(a0)+':'+fmt(b0)],
          ['Simplified', simplified],
          ['As fraction a/b', '∞ (division by zero)'],
          ['Decimal a/b', 'undefined']
        ], 'Simplify');
        return;
      }
      if(a0===0 && b0!==0){
        const simplified = (b0<0?'0:-1':'0:1');
        render([
          ['Input ratio', fmt(a0)+':'+fmt(b0)],
          ['Simplified', simplified],
          ['As fraction a/b', '0'],
          ['Decimal a/b', '0']
        ], 'Simplify');
        return;
      }

      const [ai,bi]=normalizeToIntegers(a0,b0);
      const g=gcdInt(ai,bi);
      const sa=ai/g, sb=bi/g;
      const frac = b0!==0 ? (a0/b0) : NaN;

      render([
        ['Input ratio', fmt(a0)+':'+fmt(b0)],
        ['Scale removed decimals', ai+':'+bi],
        ['GCD', String(g)],
        ['Simplified', sa+':'+sb],
        ['As fraction a/b', b0!==0 ? fmt(a0)+'/'+fmt(b0) : '—'],
        ['Decimal a/b', fmt(frac)]
      ], 'Simplify');
    }

    /*** Proportion ***/
    const pA=$('p-a'), pB=$('p-b'), pC=$('p-c'), pD=$('p-d');
    $('btn-proportion').addEventListener('click', doProportion);
    $('btn-proportion-reset').addEventListener('click', ()=>{
      [pA,pB,pC,pD].forEach(el=>{ el.value=''; el.removeAttribute('aria-invalid'); });
      ['p-a-err','p-b-err','p-c-err','p-d-err'].forEach(id=>$(id).textContent='');
      clearResults(); syncUnknownUI();
    });
    [pA,pB,pC,pD].forEach(el=>el.addEventListener('blur', validateProportion));
    document.querySelectorAll('input[name="unknown"]').forEach(r=>r.addEventListener('change', syncUnknownUI));
    function syncUnknownUI(){
      const unknown=document.querySelector('input[name="unknown"]:checked')?.value||'a';
      const map={a:pA,b:pB,c:pC,d:pD};
      Object.entries(map).forEach(([k,input])=>{
        const isU=(k===unknown);
        input.disabled=isU; input.setAttribute('aria-disabled', String(isU));
        input.placeholder=isU?'Unknown':'';
        setErr(input, `p-${k}-err`, '');
      });
    }
    function validateProportion(){
      const unknown=document.querySelector('input[name="unknown"]:checked')?.value||'a';
      const vals={a:pA,b:pB,c:pC,d:pD};
      Object.entries(vals).forEach(([k,input])=>{
        if(k===unknown){ setErr(input, `p-${k}-err`, ''); return; }
        const v=parseNum(input.value);
        setErr(input, `p-${k}-err`, Number.isNaN(v)?`Enter a valid number for ${k}.`:'');
      });
    }
    function approxEqual(x,y){ const ax=Math.abs(x), ay=Math.abs(y); const tol=1e-10*Math.max(1,ax,ay); return Math.abs(x-y)<=tol; }
    function doProportion(){
      validateProportion();
      const unknown=document.querySelector('input[name="unknown"]:checked')?.value||'a';
      const v={ a:parseNum(pA.value), b:parseNum(pB.value), c:parseNum(pC.value), d:parseNum(pD.value) };
      const known=['a','b','c','d'].filter(k=>k!==unknown);
      if(known.some(k=>Number.isNaN(v[k]))) return;

      let sol, formula;
      try{
        if(unknown==='a'){ if(v.d===0) throw new Error('d cannot be zero when solving for a.'); sol=(v.b*v.c)/v.d; formula='a = (b × c) / d'; }
        else if(unknown==='b'){ if(v.c===0) throw new Error('c cannot be zero when solving for b.'); sol=(v.a*v.d)/v.c; formula='b = (a × d) / c'; }
        else if(unknown==='c'){ if(v.b===0) throw new Error('b cannot be zero when solving for c.'); sol=(v.a*v.d)/v.b; formula='c = (a × d) / b'; }
        else { if(v.a===0) throw new Error('a cannot be zero when solving for d.'); sol=(v.b*v.c)/v.a; formula='d = (b × c) / a'; }
      }catch(e){
        $(`p-${unknown}-err`).textContent = e.message + ' Adjust inputs and try again.';
        return;
      }

      const aV=(unknown==='a')?sol:v.a, bV=(unknown==='b')?sol:v.b, cV=(unknown==='c')?sol:v.c, dV=(unknown==='d')?sol:v.d;
      const L=aV*dV, R=bV*cV;
      const ok=approxEqual(L,R);

      render([
        ['Given', `a:${fmt(v.a)}  b:${fmt(v.b)}  c:${fmt(v.c)}  d:${fmt(v.d)}`],
        ['Unknown solved', `${unknown} = ${fmt(sol)} (${formula})`],
        ['Cross-check', `ad = ${fmt(L)} ; bc = ${fmt(R)}`],
        ['Status', ok ? 'Proportion holds (within tolerance).' : 'Proportion slightly off (rounding).']
      ], 'Proportion');
    }

    /*** Scale ***/
    const scA=$('sc-a'), scB=$('sc-b'), scTarget=$('sc-target');
    $('btn-scale').addEventListener('click', doScale);
    $('btn-scale-reset').addEventListener('click', ()=>{ scA.value=''; scB.value=''; scTarget.value=''; ['sc-a-err','sc-b-err','sc-target-err'].forEach(id=>$(id).textContent=''); [scA,scB,scTarget].forEach(i=>i.removeAttribute('aria-invalid')); clearResults(); });
    [scA,scB,scTarget].forEach(el=>el.addEventListener('blur', validateScale));
    function validateScale(){
      const a=parseNum(scA.value), b=parseNum(scB.value), t=parseNum(scTarget.value);
      setErr(scA,'sc-a-err', Number.isNaN(a)?'Enter a valid number for a.':'');
      setErr(scB,'sc-b-err', Number.isNaN(b)?'Enter a valid number for b.':'');
      setErr(scTarget,'sc-target-err', Number.isNaN(t)?'Enter a valid target value.':'');
    }
    function doScale(){
      validateScale();
      const a=parseNum(scA.value), b=parseNum(scB.value), t=parseNum(scTarget.value);
      if([a,b,t].some(Number.isNaN)) return;
      const pin=document.querySelector('input[name="sc-pin"]:checked')?.value||'a';
      const rounding=document.querySelector('input[name="sc-round"]:checked')?.value||'none';
      const pinValue = pin==='a'?a:b;
      if(pinValue===0 && t!==0){ $(pin==='a'?'sc-a-err':'sc-b-err').textContent = `Cannot scale: the selected term (${pin}) is zero while target is non-zero.`; return; }
      if(pinValue===0 && t===0){ render([['Notice','Infinite solutions: any scale with a=b=0 yields target 0. Adjust inputs.']], 'Scale'); return; }
      const k=t/pinValue, a2=a*k, b2=b*k, a2r=rounding==='nearest'?Math.round(a2):a2, b2r=rounding==='nearest'?Math.round(b2):b2;
      const out=[ ['Input ratio', fmt(a)+':'+fmt(b)], ['Pinned', `${pin} → ${fmt(t)} (k = ${fmt(k)})`], ['Scaled (exact)', `${fmt(a2)} : ${fmt(b2)}`] ];
      if(rounding==='nearest') out.push(['Scaled (rounded)', `${fmt(a2r)} : ${fmt(b2r)}`]);
      render(out, 'Scale');
    }

    /*** Split ***/
    const spA=$('sp-a'), spB=$('sp-b'), spT=$('sp-total');
    $('btn-split').addEventListener('click', doSplit);
    $('btn-split-reset').addEventListener('click', ()=>{ spA.value=''; spB.value=''; spT.value=''; ['sp-a-err','sp-b-err','sp-total-err'].forEach(id=>$(id).textContent=''); [spA,spB,spT].forEach(i=>i.removeAttribute('aria-invalid')); clearResults(); });
    [spA,spB,spT].forEach(el=>el.addEventListener('blur', validateSplit));
    function validateSplit(){
      const a=parseNum(spA.value), b=parseNum(spB.value), T=parseNum(spT.value);
      setErr(spA,'sp-a-err', (Number.isNaN(a)||a<0)?'Enter a valid non-negative number for a.':'');
      setErr(spB,'sp-b-err', (Number.isNaN(b)||b<0)?'Enter a valid non-negative number for b.':'');
      setErr(spT,'sp-total-err', Number.isNaN(T)?'Enter a valid total T.':'');
    }
    function doSplit(){
      validateSplit();
      const a=parseNum(spA.value), b=parseNum(spB.value), T=parseNum(spT.value);
      if([a,b,T].some(v=>Number.isNaN(v))) return;
      const s=a+b;
      if(s===0){ $('sp-a-err').textContent='a + b must be greater than 0 to split a total.'; $('sp-b-err').textContent='a + b must be greater than 0 to split a total.'; return; }
      const x=(a/s)*T, y=(b/s)*T;
      render([ ['Ratio', fmt(a)+':'+fmt(b)], ['Total T', fmt(T)], ['Part for a', `${fmt(x)} (T × a/(a+b))`], ['Part for b', `${fmt(y)} (T × b/(a+b))`] ], 'Split Total');
    }

    // Init
    announce('simplify'); syncUnknownUI();
    // Keyboard support for segmented radiogroups
    document.querySelectorAll('.segmented[role="radiogroup"]').forEach(group=>{
      group.addEventListener('keydown', (e)=>{
        const radios = Array.from(group.querySelectorAll('input[type="radio"]'));
        const i = radios.findIndex(r=>r.checked); if(i<0) return;
        if(e.key==='ArrowRight' || e.key==='ArrowDown'){ e.preventDefault(); const n=(i+1)%radios.length; radios[n].checked=true; radios[n].dispatchEvent(new Event('change',{bubbles:true})); radios[n].focus(); }
        else if(e.key==='ArrowLeft'||e.key==='ArrowUp'){ e.preventDefault(); const p=(i-1+radios.length)%radios.length; radios[p].checked=true; radios[p].dispatchEvent(new Event('change',{bubbles:true})); radios[p].focus(); }
      });
    });
  })();
  </script>
</body>
</html>
